@section Scripts {
<script>
var _viewCost     = @(ViewBag.ViewCost     != null ? (ViewBag.ViewCost     ? "true" : "false") : "true");
var _viewSupplier = @(ViewBag.ViewSupplier != null ? (ViewBag.ViewSupplier ? "true" : "false") : "true");
var previewOpen = false;

(function(){
    var pg = document.getElementById('PrimaryGroup');
    var sg = document.getElementById('SecondaryGroup');
    var tg = document.getElementById('ThirdGroup');
    var genBtn = document.getElementById('generateBtn');
    if (!pg || !sg || !tg) return;

    var none = '0';

    function cascade() {
        if (pg.value === none) {
            sg.value = none; sg.disabled = true;
            tg.value = none; tg.disabled = true;
        } else {
            sg.disabled = false;
            if (sg.value === none) { tg.value = none; tg.disabled = true; }
            else { tg.disabled = false; }
        }
    }

    function checkDuplicates() {
        var pv = pg.value, sv = sg.value, tv = tg.value;
        var ok = true;

        sg.classList.remove('is-invalid');
        tg.classList.remove('is-invalid');
        document.getElementById('secondaryGroupError').textContent = '';
        document.getElementById('thirdGroupError').textContent = '';

        if (sv !== none && pv !== none && sv === pv) {
            sg.classList.add('is-invalid');
            document.getElementById('secondaryGroupError').textContent = 'Must be different from Group By';
            ok = false;
        }
        if (tv !== none) {
            if (pv !== none && tv === pv) {
                tg.classList.add('is-invalid');
                document.getElementById('thirdGroupError').textContent = 'Must be different from Group By';
                ok = false;
            } else if (sv !== none && tv === sv) {
                tg.classList.add('is-invalid');
                document.getElementById('thirdGroupError').textContent = 'Must be different from Then By';
                ok = false;
            }
        }

        if (genBtn) {
            genBtn.disabled = !ok;
            if (!ok) genBtn.title = 'Fix duplicate group selections first';
            else genBtn.title = '';
        }
    }

    // "Sort Sizes by Sequence" is only meaningful when one of the group levels is Size (9).
    var sizeVal = '9';
    function toggleSizeSequenceOption() {
        var wrap = document.getElementById('sortBySizeSequenceWrap');
        if (!wrap) return;
        var hasSize = (pg.value === sizeVal || sg.value === sizeVal || tg.value === sizeVal);
        wrap.style.display = hasSize ? '' : 'none';
        if (!hasSize) {
            var chk = document.getElementById('sortBySizeSequenceCheck');
            if (chk) chk.checked = false;
        }
    }
    window.toggleSizeSequenceOption = toggleSizeSequenceOption;

    pg.addEventListener('change', function() { cascade(); checkDuplicates(); toggleSizeSequenceOption(); });
    sg.addEventListener('change', function() { cascade(); checkDuplicates(); toggleSizeSequenceOption(); });
    tg.addEventListener('change', function() { checkDuplicates(); toggleSizeSequenceOption(); });

    var rm = document.getElementById('ReportMode');
    function toggleMonthlyControls() {
        var isM = rm && rm.value === '2';
        if (document.getElementById('showProfitCheck')) document.getElementById('showProfitCheck').disabled = isM;
        if (document.getElementById('showStockCheck')) document.getElementById('showStockCheck').disabled = isM;
        if (document.getElementById('showOnOrderCheck')) document.getElementById('showOnOrderCheck').disabled = isM;
        if (document.getElementById('showReservationCheck')) document.getElementById('showReservationCheck').disabled = isM;
        if (document.getElementById('showAvailableCheck')) document.getElementById('showAvailableCheck').disabled = isM;
        if (isM) { tg.value = none; tg.disabled = true; }
    }

    if (rm) rm.addEventListener('change', function() { toggleMonthlyControls(); cascade(); checkDuplicates(); });
    cascade();
    checkDuplicates();
    toggleMonthlyControls();
    toggleSizeSequenceOption();
})();

function populateItemsSelectionHidden() {
    if (typeof getItemsSelectionFilter === 'function') {
        document.getElementById('itemsSelectionJsonHidden').value = JSON.stringify(getItemsSelectionFilter());
    }
    if (typeof getItemsSelectionStoreCodes === 'function') {
        document.getElementById('selectedStoreCodesHidden').value = getItemsSelectionStoreCodes();
    }
    if (typeof getItemsSelectionItemIds === 'function') {
        document.getElementById('selectedItemIdsHidden').value = getItemsSelectionItemIds();
    }
}

function clearPreset(){document.querySelectorAll('input[name="DatePreset"]').forEach(r=>r.checked=false);}
function submitToResults(){populateItemsSelectionHidden();var form=document.getElementById('reportForm');var action=form.getAttribute('action')||'';if(action.indexOf('#')>-1)action=action.substring(0,action.indexOf('#'));form.setAttribute('action',action+'#results');form.submit();}
function goToPage(p){document.getElementById('pageNumberHidden').value=p;submitToResults();}
function sortBy(col){var curCol=document.getElementById('sortColumnHidden').value;var curDir=document.getElementById('sortDirectionHidden').value;document.getElementById('sortColumnHidden').value=col;document.getElementById('sortDirectionHidden').value=(col===curCol&&curDir==='ASC')?'DESC':'ASC';document.getElementById('pageNumberHidden').value=1;submitToResults();}

function getItemsSelectionJsonValue(){populateItemsSelectionHidden();return document.getElementById('itemsSelectionJsonHidden').value||'';}
function collectPsParams(){
    return {
        dateFrom: document.getElementById('DateFrom').value,
        dateTo: document.getElementById('DateTo').value,
        reportMode: document.getElementById('ReportMode').value,
        primaryGroup: document.getElementById('PrimaryGroup').value,
        secondaryGroup: document.getElementById('SecondaryGroup').value,
        thirdGroup: document.getElementById('ThirdGroup').value,
