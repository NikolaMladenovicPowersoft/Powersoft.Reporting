function onRecurrenceChange() {
    var v = document.getElementById('schedRecurrence').value;
    document.getElementById('schedWeeklyDaysContainer').style.display = v === 'Weekly' ? '' : 'none';
    document.getElementById('schedMonthDayContainer').style.display = v === 'Monthly' ? '' : 'none';
}

function onSchedDateRangeTypeChange() {
    var sel = document.getElementById('schedDateRangeType');
    var isCustom = sel.value === 'Custom';
    document.getElementById('schedCustomDateFromWrap').style.display = isCustom ? '' : 'none';
    document.getElementById('schedCustomDateToWrap').style.display = isCustom ? '' : 'none';
}

function onSchedAiToggle() {
    document.getElementById('schedAiDetails').style.display = document.getElementById('schedIncludeAi').checked ? '' : 'none';
}

function autoSelectScheduleDateRange() {
    var preset = document.querySelector('input[name="DatePreset"]:checked');
    if (!preset) return;
    var map = {'ytd':'YearToDate','lastYear':'LastYear','thisMonth':'ThisMonth','lastMonth':'LastMonth','last7':'LastNDays_7','last30':'LastNDays_30'};
    var mapped = map[preset.value];
    if (!mapped) return;
    var sel = document.getElementById('schedDateRangeType');
    for (var i = 0; i < sel.options.length; i++) {
        var opt = sel.options[i];
        if (mapped.startsWith('LastNDays_')) {
            var days = mapped.split('_')[1];
            if (opt.value === 'LastNDays' && opt.getAttribute('data-value') === days) { sel.selectedIndex = i; return; }
        } else if (opt.value === mapped) { sel.selectedIndex = i; return; }
    }
}

function buildRecurrenceJson() {
    var rec = document.getElementById('schedRecurrence').value;
    var obj = { recurrenceType: rec, startDate: document.getElementById('schedStartDate').value, time: document.getElementById('schedTime').value };
    if (rec === 'Weekly') {
        var days = []; document.querySelectorAll('.sched-dow:checked').forEach(function(cb) { days.push(parseInt(cb.value)); });
        obj.daysOfWeek = days;
    }
    if (rec === 'Monthly') obj.dayOfMonth = parseInt(document.getElementById('schedMonthDay').value);
    return JSON.stringify(obj);
}

function validateEmailList(val) {
    var emails = val.split(/[,;]/).map(function(s) { return s.trim(); }).filter(Boolean);
    if (emails.length === 0) return { valid: false, errors: ['At least one email is required'] };
    var re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
    var bad = emails.filter(function(e) { return !re.test(e); });
    return bad.length > 0 ? { valid: false, errors: bad.map(function(e) { return 'Invalid: ' + e; }) } : { valid: true, errors: [] };
}

function saveSchedule() {
    var name = document.getElementById('schedName').value.trim();
    var recipients = document.getElementById('schedRecipients').value.trim();
    var alertDiv = document.getElementById('scheduleAlert');
    if (!name || !recipients) {
        alertDiv.innerHTML = '<div class="alert alert-warning mb-0">Please fill in schedule name and recipients.</div>';
        alertDiv.style.display = '';
        return;
    }
    var ev = validateEmailList(recipients);
    if (!ev.valid) {
        alertDiv.innerHTML = '<div class="alert alert-warning mb-0">Invalid email(s): ' + ev.errors.join('; ') + '</div>';
        alertDiv.style.display = '';
        return;
    }

    var params = collectChartParams();
    var formData = new FormData();
    formData.append('scheduleName', name);
    formData.append('recipients', recipients);
    formData.append('exportFormat', document.getElementById('schedFormat').value);
    formData.append('scheduleTime', document.getElementById('schedTime').value);
    formData.append('recurrenceType', document.getElementById('schedRecurrence').value);
    formData.append('emailSubject', document.getElementById('schedSubject').value);
    formData.append('skipIfEmpty', document.getElementById('schedSkipIfEmpty').checked);
    formData.append('includeAiAnalysis', document.getElementById('schedIncludeAi').checked);
    formData.append('aiLocale', document.getElementById('schedAiLocale').value);
    formData.append('parametersJson', JSON.stringify(params));
    formData.append('recurrenceJson', buildRecurrenceJson());

    var sel = document.getElementById('schedDateRangeType');
    var drType = sel.value;
    var drValue = sel.options[sel.selectedIndex].getAttribute('data-value') || '';
    params.dateRangeType = drType;
    params.dateRangeValue = drValue;
    if (drType === 'Custom') {
        params.customDateFrom = document.getElementById('schedDateFrom').value;
        params.customDateTo = document.getElementById('schedDateTo').value;
    }
    formData.set('parametersJson', JSON.stringify(params));

    if (document.getElementById('schedRecurrence').value === 'Monthly')
        formData.append('recurrenceDay', document.getElementById('schedMonthDay').value);

    var sid = document.getElementById('schedId').value;
    if (sid) formData.append('scheduleId', sid);

    var saveBtn = document.querySelector('#scheduleModal .btn-primary[onclick="saveSchedule()"]');
    if (saveBtn) saveBtn.disabled = true;

    fetch('@Url.Action("SaveChartSchedule", "Reports")', { method: 'POST', body: formData })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (saveBtn) saveBtn.disabled = false;
            if (data.success) {
                loadExistingSchedules();
                if (data.updated) {
                    showScheduleToast('Schedule updated', 'success');
                } else {
                    setTimeout(function() { resetScheduleForm(); }, 600);
                    showScheduleToast('Schedule saved successfully', 'success');
                }
            } else {
                alertDiv.innerHTML = '<div class="alert alert-danger mb-0">' + data.message + '</div>';
                alertDiv.style.display = '';
            }
        })
        .catch(function() { if (saveBtn) saveBtn.disabled = false; showScheduleToast('Network error', 'danger'); });
}

function showScheduleToast(message, type) {
    var existing = document.getElementById('schedToast');
    if (existing) existing.remove();
    var div = document.createElement('div');
    div.id = 'schedToast';
    div.className = 'alert alert-' + type + ' alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow';
    div.style.zIndex = '11000';
    div.innerHTML = '<i class="bi bi-' + (type === 'success' ? 'check-circle' : 'exclamation-triangle') + ' me-1"></i>' + message + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    document.body.appendChild(div);
    setTimeout(function() { if (div.parentNode) div.remove(); }, 4000);
}

function deleteScheduleRow(scheduleId, scheduleName) {
    if (!confirm('Delete schedule "' + scheduleName + '"?\nThis cannot be undone.')) return;
    var fd = new FormData();
    fd.append('scheduleId', scheduleId);
    fetch('@Url.Action("DeleteSchedule", "Reports")', { method: 'POST', body: fd })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.success) { showScheduleToast('Schedule deleted', 'success'); loadExistingSchedules(); resetScheduleForm(); }
            else { showScheduleToast(d.message || 'Failed to delete schedule', 'danger'); }
        })
        .catch(function() { showScheduleToast('Network error', 'danger'); });
}

function loadExistingSchedules() {
    fetch('@Url.Action("GetChartSchedules", "Reports")')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var c = document.getElementById('existingSchedules');
            if (!data || data.length === 0) { c.innerHTML = '<em>No schedules configured yet.</em>'; return; }
            var html = '<table class="table table-sm mb-0 align-middle"><thead><tr><th>Name</th><th>Recurrence</th><th>Format</th><th>Time</th><th>Next Run</th><th class="text-end">Actions</th></tr></thead><tbody>';
            data.forEach(function(s) {
                var safeName = (s.scheduleName || '').replace(/'/g, "\\'").replace(/"/g, '&quot;');
                html += '<tr data-schedule-id="' + s.scheduleId + '" style="cursor:pointer;" title="Click to load this schedule">'
                    + '<td>' + escapeHtml(s.scheduleName || '') + '</td>'
                    + '<td>' + s.recurrenceType + '</td>'
                    + '<td>' + s.exportFormat + '</td>'
                    + '<td>' + s.scheduleTime + '</td>'
                    + '<td>' + (s.nextRun || '-') + '</td>'
                    + '<td class="text-end">'
                    +   '<button type="button" class="btn btn-sm btn-outline-primary me-1" title="Load into form" onclick="event.stopPropagation(); loadScheduleIntoForm(' + s.scheduleId + ')"><i class="bi bi-pencil"></i></button>'
                    +   '<button type="button" class="btn btn-sm btn-outline-danger" title="Delete schedule" onclick="event.stopPropagation(); deleteScheduleRow(' + s.scheduleId + ', \'' + safeName + '\')"><i class="bi bi-trash"></i></button>'
                    + '</td></tr>';
            });
            html += '</tbody></table>';
            c.innerHTML = html;
            c.querySelectorAll('tr[data-schedule-id]').forEach(function(tr) {
                tr.addEventListener('click', function() {
                    loadScheduleIntoForm(parseInt(tr.getAttribute('data-schedule-id'), 10));
                });
            });
        })
        .catch(function() { document.getElementById('existingSchedules').innerHTML = '<em>Could not load schedules.</em>'; });
}

function resetScheduleForm() {
    document.getElementById('schedId').value = '';
    document.getElementById('schedName').value = '';
    document.getElementById('schedRecipients').value = '';
    document.getElementById('schedSubject').value = '';
    document.getElementById('schedFormat').value = 'Excel';
    document.getElementById('schedRecurrence').value = 'Daily';
    document.getElementById('schedTime').value = '08:00';
    var sd = document.getElementById('schedStartDate');
    if (sd) sd.value = new Date().toISOString().slice(0, 10);
    document.querySelectorAll('.sched-dow').forEach(function(cb) { cb.checked = false; });
    var skip = document.getElementById('schedSkipIfEmpty'); if (skip) skip.checked = false;
    var ai = document.getElementById('schedIncludeAi'); if (ai) ai.checked = false;
    onRecurrenceChange();
    onSchedAiToggle();
    var a = document.getElementById('scheduleAlert');
    if (a) { a.style.display = 'none'; a.innerHTML = ''; }
}

function loadScheduleIntoForm(scheduleId) {
    fetch('@Url.Action("GetScheduleById", "Reports")?scheduleId=' + scheduleId)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data || !data.success || !data.schedule) {
                showScheduleToast((data && data.message) || 'Could not load schedule', 'danger');
                return;
            }
            var s = data.schedule;
            document.getElementById('schedId').value = scheduleId;
            document.getElementById('schedName').value = s.scheduleName || '';
            document.getElementById('schedRecipients').value = s.recipients || '';
            document.getElementById('schedSubject').value = s.emailSubject || '';
            document.getElementById('schedFormat').value = s.exportFormat || 'Excel';
            document.getElementById('schedRecurrence').value = s.recurrenceType || 'Daily';
            document.getElementById('schedTime').value = (s.scheduleTime || '08:00');
            onRecurrenceChange();
            if (s.recurrenceType === 'Weekly' && s.recurrenceJson) {
                try {
                    var rj = JSON.parse(s.recurrenceJson);
                    (rj.daysOfWeek || []).forEach(function(d) {
                        var cb = document.querySelector('.sched-dow[value="' + d + '"]');
                        if (cb) cb.checked = true;
                    });
                } catch (e) {}
            }
            if (s.recurrenceType === 'Monthly' && s.recurrenceDay)
                document.getElementById('schedMonthDay').value = s.recurrenceDay;
            var skip = document.getElementById('schedSkipIfEmpty');
            if (skip) skip.checked = !!s.skipIfEmpty;
            var ai = document.getElementById('schedIncludeAi');
            if (ai) ai.checked = !!s.includeAiAnalysis;
            onSchedAiToggle();
            if (s.aiLocale) document.getElementById('schedAiLocale').value = s.aiLocale;

            var alertDiv = document.getElementById('scheduleAlert');
            alertDiv.style.display = '';
            alertDiv.innerHTML = '<div class="alert alert-info mb-0 py-2"><i class="bi bi-pencil-square me-1"></i>Editing <strong>' + escapeHtml(s.scheduleName || '') + '</strong>. Saving will update this schedule in place &mdash; click <em>Reset</em> to start a new one instead.</div>';
        })
        .catch(function() { showScheduleToast('Network error loading schedule', 'danger'); });
}

(function() {
    var schedModal = document.getElementById('scheduleModal');
    if (schedModal) {
        schedModal.addEventListener('show.bs.modal', function() {
