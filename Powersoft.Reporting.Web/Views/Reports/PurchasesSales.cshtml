@model Powersoft.Reporting.Web.ViewModels.PurchasesSalesViewModel
@using Powersoft.Reporting.Core.Enums
@using Powersoft.Reporting.Core.Models
@{
    ViewData["Title"] = "Purchases vs Sales";
    var filterCols = new[] { "ItemCode", "ItemName", "Level1Value", "Level2Value", "Level3Value",
        "QuantityPurchased", "NetPurchasedValue", "GrossPurchasedValue",
        "QuantitySold", "NetSoldValue", "GrossSoldValue", "Profit", "TotalStockQty" };
    bool hasAnyFilter = Model.FilterValues != null && Model.FilterValues.Any(kv => !string.IsNullOrEmpty(kv.Value));
    bool isMonthly = Model.ReportMode == PsReportMode.Monthly;
    bool hasResults = isMonthly ? Model.MonthlyResults.Any() : Model.Results.Any();
    bool hasL1 = Model.HasPrimaryGroup;
    bool hasL2 = Model.HasSecondaryGroup;
    bool hasL3 = isMonthly ? false : Model.HasThirdGroup;
    bool showItem = isMonthly
        ? (Model.PrimaryGroup == PsGroupBy.None && Model.SecondaryGroup == PsGroupBy.None)
        : (!Model.ToPurchasesSalesFilter().IsSummary || (!hasL1 && !hasL2 && !hasL3));
    bool useGross = Model.IncludeVat;
}

<style>
    a.dd-link-purch { color: #2563eb; text-decoration: none; cursor: pointer; border-bottom: 1px dashed #2563eb; }
    a.dd-link-purch:hover { color: #1d4ed8; border-bottom-style: solid; }
    a.dd-link-sales { color: #059669; text-decoration: none; cursor: pointer; border-bottom: 1px dashed #059669; }
    a.dd-link-sales:hover { color: #047857; border-bottom-style: solid; }
    th.col-purch { background: #eff6ff !important; color: #1e40af; }
    th.col-sales { background: #ecfdf5 !important; color: #065f46; }
</style>

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-start">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">Reports</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">Stock Control</a></li>
                    <li class="breadcrumb-item active">Purchases vs Sales</li>
                </ol>
            </nav>
            <h2 class="mb-0">
                <i class="bi bi-arrow-left-right me-2 text-primary"></i>Purchases vs Sales
            </h2>
            <p class="text-muted mb-0">Compare purchasing and selling quantities and values per item</p>
        </div>
        <div class="mt-3">
            @await Html.PartialAsync("_TutorialButton", ("Purchases vs Sales", ""))
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="bi bi-funnel me-2"></i>Report Parameters</div>
    <div class="card-body">
        <form asp-action="PurchasesSales" method="post" id="reportForm">
            <input type="hidden" asp-for="SelectedStoreCodesString" id="selectedStoreCodesHidden" />
            <input type="hidden" asp-for="SelectedItemIdsString" id="selectedItemIdsHidden" />
            <input type="hidden" asp-for="ItemsSelectionJson" id="itemsSelectionJsonHidden" />
            <input type="hidden" asp-for="PageNumber" id="pageNumberHidden" />
            <input type="hidden" asp-for="SortColumn" id="sortColumnHidden" />
            <input type="hidden" asp-for="SortDirection" id="sortDirectionHidden" />
            <input type="hidden" asp-for="HiddenColumns" id="hiddenColumnsInput" />
            @foreach (var col in filterCols)
            {
                <input type="hidden" name="FilterValues[@col]" id="fv_@col" value="@(Model.FilterValues.GetValueOrDefault(col, ""))" />
                <input type="hidden" name="FilterOperators[@col]" id="fo_@col" value="@(Model.FilterOperators.GetValueOrDefault(col, ""))" />
            }

            <div class="row mb-3">
                <div class="col-12">
                    <label class="form-label fw-semibold mb-2">Quick Date Selection</label>
                    <div class="date-presets btn-group flex-wrap" role="group">
                        <input type="radio" class="btn-check" name="DatePreset" id="presetToday" value="today" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetToday">Today</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetYesterday" value="yesterday" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetYesterday">Yesterday</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLast7" value="last7" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLast7">Last 7 Days</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLast30" value="last30" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLast30">Last 30 Days</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetThisMonth" value="thisMonth" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetThisMonth">This Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastMonth" value="lastMonth" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLastMonth">Last Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetYTD" value="ytd" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetYTD">Year to Date</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastYear" value="lastYear" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLastYear">Last Year</label>
                    </div>
                </div>
            </div>

            <hr class="my-3">

            <div class="row g-3 mb-3 align-items-end">
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date From</label>
                    <input type="date" asp-for="DateFrom" class="form-control" onchange="clearPreset()" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date To</label>
                    <input type="date" asp-for="DateTo" class="form-control" onchange="clearPreset()" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Report Mode</label>
                    <select asp-for="ReportMode" id="ReportMode" class="form-select" asp-items="Html.GetEnumSelectList<PsReportMode>()"></select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Group By</label>
                    <select asp-for="PrimaryGroup" id="PrimaryGroup" class="form-select group-select" asp-items="Html.GetEnumSelectList<PsGroupBy>()"></select>
                    <div class="invalid-feedback" id="primaryGroupError"></div>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Then By</label>
                    <select asp-for="SecondaryGroup" id="SecondaryGroup" class="form-select group-select" asp-items="Html.GetEnumSelectList<PsGroupBy>()"></select>
                    <div class="invalid-feedback" id="secondaryGroupError"></div>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Third Group</label>
                    <select asp-for="ThirdGroup" id="ThirdGroup" class="form-select group-select" asp-items="Html.GetEnumSelectList<PsGroupBy>()"></select>
                    <div class="invalid-feedback" id="thirdGroupError"></div>
                </div>
            </div>


            <div class="row g-3 mb-4 align-items-end">
                <div class="col-auto">
                    <div class="form-check">
                        <input type="checkbox" asp-for="IncludeVat" class="form-check-input" id="includeVatCheck" />
                        <label asp-for="IncludeVat" class="form-check-label">Include VAT</label>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="form-check">
                        <input type="checkbox" asp-for="ShowProfit" class="form-check-input" id="showProfitCheck" />
                        <label asp-for="ShowProfit" class="form-check-label">Show Profit</label>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="form-check">
                        <input type="checkbox" asp-for="ShowStock" class="form-check-input" id="showStockCheck" />
                        <label asp-for="ShowStock" class="form-check-label">Show Stock</label>
                    </div>
                </div>
                <div class="col-auto ms-md-auto">
                    <label class="form-label fw-semibold small text-muted mb-1">Rows per page</label>
                    <select asp-for="PageSize" class="form-select form-select-sm w-auto">
                        <option value="50">50</option>
                        <option value="100">100</option>
                        <option value="250">250</option>
                        <option value="500">500</option>
                    </select>
                </div>
            </div>

            <div class="report-form-actions d-flex flex-wrap gap-2 pt-2 border-top">
                <button type="submit" class="btn btn-primary btn-lg btn-generate" id="generateBtn">
                    <span class="btn-text"><i class="bi bi-play-fill me-2"></i>Generate Report</span>
                    <span class="spinner-border spinner-border-sm d-none" role="status"></span>
                </button>
                @if (Model.CanSchedule)
                {
                    <button type="button" class="btn btn-warning btn-lg" data-bs-toggle="modal" data-bs-target="#scheduleModal" title="Schedule recurring report delivery">
                        <i class="bi bi-clock-history me-2"></i>Schedule
                    </button>
                }
                <div class="btn-group ms-auto">
                    <button type="button" class="btn btn-outline-info" onclick="saveCurrentLayout()" title="Save current parameters as your default layout">
                        <i class="bi bi-save me-1"></i>Save Layout
                    </button>
                    @if (Model.HasSavedLayout)
                    {
                        <button type="button" class="btn btn-outline-secondary" onclick="resetSavedLayout()" title="Discard your saved layout and restore factory defaults">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Layout
                        </button>
                    }
                    <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#columnSettingsModal" title="Choose which columns to show/hide">
                        <i class="bi bi-layout-three-columns me-1"></i>Columns
                    </button>
                </div>
                <a asp-action="PurchasesSales" class="btn btn-outline-secondary btn-reset" title="Clear all filters">
                    <i class="bi bi-funnel me-1"></i>Clear Filters
                </a>
            </div>
            @if (Model.HasSavedLayout)
            {
                <div class="mt-2"><small class="text-info"><i class="bi bi-check-circle me-1"></i>Saved layout loaded</small></div>
            }
        </form>
    </div>
</div>

@{
    var storesJson = System.Text.Json.JsonSerializer.Serialize(Model.AvailableStores.Select(s => new { code = s.StoreCode, name = s.StoreName }));
}
@await Html.PartialAsync("_ItemsSelection", new ItemsSelectionConfig
{
    ShowCategories = true,
    ShowDepartments = true,
    ShowBrands = true,
    ShowSeasons = true,
    ShowSuppliers = true,
    ShowCustomers = true,
    ShowStores = true,
    ShowItems = true,
    StoresJson = storesJson,
    SavedFilterJson = Model.ItemsSelectionJson ?? ""
})

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <div class="d-flex align-items-start">
            <i class="bi bi-exclamation-triangle-fill me-2 mt-1"></i>
            <div><strong>Unable to generate report</strong><p class="mb-0 mt-1">@Model.ErrorMessage</p></div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (hasResults)
{
    <div class="row mb-4 g-3">
        @if (isMonthly)
        {
            <div class="col-6 col-md-4">
                <div class="stat-card text-center">
                    <div class="stat-value">@Model.MonthlyTotalPurchased.ToString("N2")</div>
                    <div class="stat-label">Total Purchased</div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="stat-card text-center">
                    <div class="stat-value">@Model.MonthlyTotalSold.ToString("N2")</div>
                    <div class="stat-label">Total Sold</div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="stat-card text-center">
                    <div class="stat-value">@Model.TotalCount.ToString("N0")</div>
                    <div class="stat-label">Total Rows</div>
                </div>
            </div>
        }
        else
        {
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <div class="stat-value">@Model.TotalPurchasedQty.ToString("N0")</div>
                <div class="stat-label">Total Qty Purchased</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <div class="stat-value">@Model.TotalSoldQty.ToString("N0")</div>
                <div class="stat-label">Total Qty Sold</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <div class="stat-value">@Model.TotalPurchasedValue.ToString("N2")</div>
                <div class="stat-label">@(useGross ? "Gross" : "Net") Purchased</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                @{var profitColor = Model.TotalProfit >= 0 ? "text-success" : "text-danger";}
                <div class="stat-value @profitColor">@Model.TotalProfit.ToString("N2")</div>
                <div class="stat-label">Total Profit</div>
            </div>
        </div>
        }
    </div>

    <div class="card" id="results">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>
                <i class="bi bi-table me-2"></i>Results: @Model.TotalCount.ToString("N0") total rows
                @if (hasL1) { <span class="badge bg-secondary ms-2">Grouped by @Model.PrimaryGroup</span> }
                @if (hasL2) { <span class="badge bg-secondary ms-1">then @Model.SecondaryGroup</span> }
                @if (hasL3) { <span class="badge bg-secondary ms-1">then @Model.ThirdGroup</span> }
            </span>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                @if (hasAnyFilter)
                {
                    <button class="btn btn-sm btn-outline-warning" onclick="clearAllFilters()" title="Clear column filters">
                        <i class="bi bi-funnel me-1"></i>Clear column filters
                    </button>
                }
                <button class="btn btn-sm btn-outline-primary" onclick="togglePreview()" id="previewToggleBtn" title="Toggle document preview">
                    <i class="bi bi-eye me-1"></i>Preview
                </button>
                <div class="btn-group btn-group-sm">
                    <a class="btn btn-outline-success" asp-action="ExportPsCsv"
                       asp-route-dateFrom="@Model.DateFrom.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo.ToString("yyyy-MM-dd")"
                       asp-route-reportMode="@Model.ReportMode" asp-route-primaryGroup="@Model.PrimaryGroup"
                       asp-route-secondaryGroup="@Model.SecondaryGroup" asp-route-thirdGroup="@Model.ThirdGroup"
                       asp-route-includeVat="@Model.IncludeVat" asp-route-showProfit="@Model.ShowProfit" asp-route-showStock="@Model.ShowStock"
                       asp-route-storeCodes="@Model.SelectedStoreCodesString" asp-route-itemIds="@Model.SelectedItemIdsString"
                       asp-route-sortColumn="@Model.SortColumn" asp-route-sortDirection="@Model.SortDirection">
                        <i class="bi bi-filetype-csv me-1"></i>CSV
                    </a>
                    <a class="btn btn-outline-success" asp-action="ExportPsExcel"
                       asp-route-dateFrom="@Model.DateFrom.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo.ToString("yyyy-MM-dd")"
                       asp-route-reportMode="@Model.ReportMode" asp-route-primaryGroup="@Model.PrimaryGroup"
                       asp-route-secondaryGroup="@Model.SecondaryGroup" asp-route-thirdGroup="@Model.ThirdGroup"
                       asp-route-includeVat="@Model.IncludeVat" asp-route-showProfit="@Model.ShowProfit" asp-route-showStock="@Model.ShowStock"
                       asp-route-storeCodes="@Model.SelectedStoreCodesString" asp-route-itemIds="@Model.SelectedItemIdsString"
                       asp-route-sortColumn="@Model.SortColumn" asp-route-sortDirection="@Model.SortDirection">
                        <i class="bi bi-filetype-xlsx me-1"></i>Excel
                    </a>
                    <a class="btn btn-outline-danger" asp-action="ExportPsPdf"
                       asp-route-dateFrom="@Model.DateFrom.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo.ToString("yyyy-MM-dd")"
                       asp-route-reportMode="@Model.ReportMode" asp-route-primaryGroup="@Model.PrimaryGroup"
                       asp-route-secondaryGroup="@Model.SecondaryGroup" asp-route-thirdGroup="@Model.ThirdGroup"
                       asp-route-includeVat="@Model.IncludeVat" asp-route-showProfit="@Model.ShowProfit" asp-route-showStock="@Model.ShowStock"
                       asp-route-storeCodes="@Model.SelectedStoreCodesString" asp-route-itemIds="@Model.SelectedItemIdsString"
                       asp-route-sortColumn="@Model.SortColumn" asp-route-sortDirection="@Model.SortDirection">
                        <i class="bi bi-filetype-pdf me-1"></i>PDF
                    </a>
                </div>
                <button class="btn btn-sm btn-outline-primary" onclick="openSendEmailModal()" title="Send report via email">
                    <i class="bi bi-envelope me-1"></i>Send to Email
                </button>
                <button class="btn btn-sm btn-outline-info" onclick="analyzePsReport()" title="AI-powered report analysis" id="btnAnalyzePs">
                    <i class="bi bi-stars me-1"></i>AI Analyze
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
            @if (isMonthly)
            {
                var months = new[]{"Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"};
                int fixedCols = (hasL1?1:0)+(hasL2?1:0)+(showItem?2:0)+1;
                int monthlyCols = fixedCols + 13 + 13;
                <table class="table table-hover mb-0 table-sm" id="resultsTable" style="font-size:0.82rem;">
                    <thead>
                        <tr>
                            @if (hasL1) { <th rowspan="2">@Model.PrimaryGroup</th> }
                            @if (hasL2) { <th rowspan="2">@Model.SecondaryGroup</th> }
                            @if (showItem) { <th rowspan="2">Code</th><th rowspan="2">Name</th> }
                            <th rowspan="2" class="text-center">Year</th>
                            <th colspan="13" class="text-center col-purch">Purchased</th>
                            <th colspan="13" class="text-center col-sales">Sold</th>
                        </tr>
                        <tr>
                            @for (int mi=0; mi<12; mi++){<th class="text-end col-purch" style="font-size:0.75rem;">@months[mi]</th>}
                            <th class="text-end col-purch fw-semibold">Total</th>
                            @for (int mi=0; mi<12; mi++){<th class="text-end col-sales" style="font-size:0.75rem;">@months[mi]</th>}
                            <th class="text-end col-sales fw-semibold">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                    @{
                        var monthlyGroups = hasL1 ? Model.MonthlyResults.GroupBy(r => r.Level1Value ?? r.Level1 ?? "N/A") : null;
                    }
                    @if (hasL1 && monthlyGroups != null)
                    {
                        foreach (var l1g in monthlyGroups)
                        {
                            <tr class="group-header-row"><td colspan="@monthlyCols"><i class="bi bi-diagram-3 me-2"></i><strong>@Model.PrimaryGroup:</strong> @l1g.Key</td></tr>
                            var l1rows = l1g.ToList();
                            if (hasL2)
                            {
                                var l2gs = l1rows.GroupBy(r => r.Level2Value ?? "N/A");
                                foreach (var l2g in l2gs)
                                {
                                    <tr class="group-header-row" style="background:#e8f0fe;"><td colspan="@monthlyCols" class="ps-4"><i class="bi bi-chevron-right me-1"></i><strong>@Model.SecondaryGroup:</strong> @l2g.Key</td></tr>
                                    foreach (var row in l2g)
                                    {
                                        <tr>
                                            @if(hasL1){<td>@row.Level1Value</td>}@if(hasL2){<td>@row.Level2Value</td>}
                                            @if(showItem){<td class="fw-semibold">@row.ItemCode</td><td>@row.ItemName</td>}
                                            <td class="text-center">@row.TransYear</td>
                                            @for(int mi=0;mi<12;mi++){<td class="text-end">@row.Purchased[mi].ToString("N2")</td>}
                                            <td class="text-end fw-semibold">@row.TotalPurchased.ToString("N2")</td>
                                            @for(int mi=0;mi<12;mi++){<td class="text-end">@row.Sold[mi].ToString("N2")</td>}
                                            <td class="text-end fw-semibold">@row.TotalSold.ToString("N2")</td>
                                        </tr>
                                    }
                                    var l2p = SumMonthlyPurch(l2g); var l2s = SumMonthlySold(l2g);
                                    <tr class="subtotal-row" style="background:#e8f0fe;">
                                        @for(int c=0;c<fixedCols;c++){<td></td>}
                                        @for(int mi=0;mi<12;mi++){<td class="text-end fw-semibold">@l2p[mi].ToString("N2")</td>}
                                        <td class="text-end fw-bold">@l2p.Sum().ToString("N2")</td>
                                        @for(int mi=0;mi<12;mi++){<td class="text-end fw-semibold">@l2s[mi].ToString("N2")</td>}
                                        <td class="text-end fw-bold">@l2s.Sum().ToString("N2")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                foreach (var row in l1rows)
                                {
                                    <tr>
                                        @if(hasL1){<td>@row.Level1Value</td>}@if(hasL2){<td>@row.Level2Value</td>}
                                        @if(showItem){<td class="fw-semibold">@row.ItemCode</td><td>@row.ItemName</td>}
                                        <td class="text-center">@row.TransYear</td>
                                        @for(int mi=0;mi<12;mi++){<td class="text-end">@row.Purchased[mi].ToString("N2")</td>}
                                        <td class="text-end fw-semibold">@row.TotalPurchased.ToString("N2")</td>
                                        @for(int mi=0;mi<12;mi++){<td class="text-end">@row.Sold[mi].ToString("N2")</td>}
                                        <td class="text-end fw-semibold">@row.TotalSold.ToString("N2")</td>
                                    </tr>
                                }
                            }
                            var l1p = SumMonthlyPurch(l1g); var l1s = SumMonthlySold(l1g);
                            <tr class="subtotal-row" style="background:#dbeafe;">
                                @for(int c=0;c<fixedCols;c++){<td></td>}
                                @for(int mi=0;mi<12;mi++){<td class="text-end fw-semibold">@l1p[mi].ToString("N2")</td>}
                                <td class="text-end fw-bold">@l1p.Sum().ToString("N2")</td>
                                @for(int mi=0;mi<12;mi++){<td class="text-end fw-semibold">@l1s[mi].ToString("N2")</td>}
                                <td class="text-end fw-bold">@l1s.Sum().ToString("N2")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        foreach (var row in Model.MonthlyResults)
                        {
                            <tr>
                                @if(hasL1){<td>@row.Level1Value</td>}@if(hasL2){<td>@row.Level2Value</td>}
                                @if(showItem){<td class="fw-semibold">@row.ItemCode</td><td>@row.ItemName</td>}
                                <td class="text-center">@row.TransYear</td>
                                @for(int mi=0;mi<12;mi++){<td class="text-end">@row.Purchased[mi].ToString("N2")</td>}
                                <td class="text-end fw-semibold">@row.TotalPurchased.ToString("N2")</td>
                                @for(int mi=0;mi<12;mi++){<td class="text-end">@row.Sold[mi].ToString("N2")</td>}
                                <td class="text-end fw-semibold">@row.TotalSold.ToString("N2")</td>
                            </tr>
                        }
                    }
                    </tbody>
                    <tfoot>
                        @{ var gp = SumMonthlyPurch(Model.MonthlyResults); var gs = SumMonthlySold(Model.MonthlyResults); }
                        <tr class="grand-total-row">
                            @for(int c=0;c<fixedCols;c++){if(c==0 && showItem){<td><i class="bi bi-calculator me-1"></i>GRAND TOTAL</td>}else{<td></td>}}
                            @for(int mi=0;mi<12;mi++){<td class="text-end fw-bold">@gp[mi].ToString("N2")</td>}
                            <td class="text-end fw-bold">@gp.Sum().ToString("N2")</td>
                            @for(int mi=0;mi<12;mi++){<td class="text-end fw-bold">@gs[mi].ToString("N2")</td>}
                            <td class="text-end fw-bold">@gs.Sum().ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            }
            else
            {
                <table class="table table-hover mb-0" id="resultsTable">
                    @{
                        var sc = Model.SortColumn ?? "ItemCode";
                        var sd = Model.SortDirection ?? "ASC";
                        string SortClass(string col) => sc.Equals(col, StringComparison.OrdinalIgnoreCase) ? (sd == "ASC" ? "sortable sort-asc" : "sortable sort-desc") : "sortable";
                        string SortIcon(string col) => sc.Equals(col, StringComparison.OrdinalIgnoreCase) ? (sd == "ASC" ? "bi-caret-up-fill" : "bi-caret-down-fill") : "bi-caret-up-fill";
                    }
                    <thead>
                        <tr>
                            @if (hasL1) { <th data-col="Level1Value" class="@SortClass("Level1Value")" onclick="sortBy('Level1Value')">@Model.PrimaryGroup<i class="bi @SortIcon("Level1Value") sort-icon"></i></th> }
                            @if (hasL2) { <th data-col="Level2Value" class="@SortClass("Level2Value")" onclick="sortBy('Level2Value')">@Model.SecondaryGroup<i class="bi @SortIcon("Level2Value") sort-icon"></i></th> }
                            @if (hasL3) { <th data-col="Level3Value" class="@SortClass("Level3Value")" onclick="sortBy('Level3Value')">@Model.ThirdGroup<i class="bi @SortIcon("Level3Value") sort-icon"></i></th> }
                            @if (showItem)
                            {
                                <th data-col="ItemCode" class="@SortClass("ItemCode")" onclick="sortBy('ItemCode')">Code<i class="bi @SortIcon("ItemCode") sort-icon"></i></th>
                                <th data-col="ItemName" class="@SortClass("ItemName")" onclick="sortBy('ItemName')">Name<i class="bi @SortIcon("ItemName") sort-icon"></i></th>
                            }
                            <th data-col="QuantityPurchased" class="text-end col-purch @SortClass("QuantityPurchased")" onclick="sortBy('QuantityPurchased')">Qty Purch<i class="bi @SortIcon("QuantityPurchased") sort-icon"></i></th>
                            <th data-col="@(useGross?"GrossPurchasedValue":"NetPurchasedValue")" class="text-end col-purch @SortClass(useGross?"GrossPurchasedValue":"NetPurchasedValue")" onclick="sortBy('@(useGross?"GrossPurchasedValue":"NetPurchasedValue")')">@(useGross?"Gross":"Net") Purch<i class="bi @SortIcon(useGross?"GrossPurchasedValue":"NetPurchasedValue") sort-icon"></i></th>
                            <th data-col="QuantitySold" class="text-end col-sales @SortClass("QuantitySold")" onclick="sortBy('QuantitySold')">Qty Sold<i class="bi @SortIcon("QuantitySold") sort-icon"></i></th>
                            <th data-col="@(useGross?"GrossSoldValue":"NetSoldValue")" class="text-end col-sales @SortClass(useGross?"GrossSoldValue":"NetSoldValue")" onclick="sortBy('@(useGross?"GrossSoldValue":"NetSoldValue")')">@(useGross?"Gross":"Net") Sold<i class="bi @SortIcon(useGross?"GrossSoldValue":"NetSoldValue") sort-icon"></i></th>
                            @if (Model.ShowProfit) { <th data-col="Profit" class="text-end @SortClass("Profit")" onclick="sortBy('Profit')">Profit<i class="bi @SortIcon("Profit") sort-icon"></i></th> }
                            <th class="text-end">Qty %</th>
                            <th class="text-end">Val %</th>
                            @if (Model.ShowStock) { <th data-col="TotalStockQty" class="text-end @SortClass("TotalStockQty")" onclick="sortBy('TotalStockQty')">Stock<i class="bi @SortIcon("TotalStockQty") sort-icon"></i></th> }
                        </tr>
                    </thead>
                    @{
                        int totalColumns = (hasL1?1:0)+(hasL2?1:0)+(hasL3?1:0)+(showItem?2:0)+4+(Model.ShowProfit?1:0)+2+(Model.ShowStock?1:0);
                    }
                    <tbody>
                        @if (hasL1)
                        {
                            var l1Groups = Model.Results.GroupBy(r => r.Level1Value ?? r.Level1 ?? "N/A").ToList();
                            foreach (var l1Group in l1Groups)
                            {
                                var l1Rows = l1Group.ToList();
                                <tr class="group-header-row">
                                    <td colspan="@totalColumns"><i class="bi bi-diagram-3 me-2"></i><strong>@Model.PrimaryGroup:</strong> @l1Group.Key</td>
                                </tr>

                                @if (hasL2)
                                {
                                    var l2Groups = l1Rows.GroupBy(r => r.Level2Value ?? "N/A").ToList();
                                    foreach (var l2Group in l2Groups)
                                    {
                                        var l2Rows = l2Group.ToList();
                                        <tr class="group-header-row" style="background:#e8f0fe;">
                                            <td colspan="@totalColumns" class="ps-4"><i class="bi bi-chevron-right me-1"></i><strong>@Model.SecondaryGroup:</strong> @l2Group.Key</td>
                                        </tr>

                                        @if (hasL3)
                                        {
                                            var l3Groups = l2Rows.GroupBy(r => r.Level3Value ?? "N/A").ToList();
                                            foreach (var l3Group in l3Groups)
                                            {
                                                var l3Rows = l3Group.ToList();
                                                <tr class="group-header-row" style="background:#f0f4f8;">
                                                    <td colspan="@totalColumns" class="ps-5"><i class="bi bi-dash me-1"></i><strong>@Model.ThirdGroup:</strong> @l3Group.Key</td>
                                                </tr>
                                                @foreach (var row in l3Rows)
                                                {
                                                    <tr>
                                                        @if (hasL1) { <td class="fw-semibold text-info">@(row.Level1Value ?? "N/A")</td> }
                                                        @if (hasL2) { <td class="text-info">@(row.Level2Value ?? "N/A")</td> }
                                                        @if (hasL3) { <td class="text-info">@(row.Level3Value ?? "N/A")</td> }
                                                        @if (showItem) { <td class="fw-semibold"><a href="#" class="text-decoration-none" onclick="drillDown('@row.ItemCode','all');return false;">@row.ItemCode</a></td><td>@row.ItemName</td> }
                                                        <td class="text-end"><a href="#" class="dd-link-purch" onclick="drillDown('@row.ItemCode','purchases');return false;">@row.QuantityPurchased.ToString("N0")</a></td>
                                                        <td class="text-end"><a href="#" class="dd-link-purch" onclick="drillDown('@row.ItemCode','purchases');return false;">@((useGross ? row.GrossPurchasedValue : row.NetPurchasedValue).ToString("N2"))</a></td>
                                                        <td class="text-end"><a href="#" class="dd-link-sales" onclick="drillDown('@row.ItemCode','sales');return false;">@row.QuantitySold.ToString("N0")</a></td>
                                                        <td class="text-end"><a href="#" class="dd-link-sales" onclick="drillDown('@row.ItemCode','sales');return false;">@((useGross ? row.GrossSoldValue : row.NetSoldValue).ToString("N2"))</a></td>
                                                        @if (Model.ShowProfit) { var pC = row.Profit >= 0 ? "text-success" : "text-danger"; <td class="text-end @pC fw-semibold">@row.Profit.ToString("N2")</td> }
                                                        <td class="text-end">@row.QtyPercent.ToString("N1")%</td>
                                                        <td class="text-end">@row.ValPercent.ToString("N1")%</td>
                                                        @if (Model.ShowStock) { <td class="text-end">@row.TotalStockQty.ToString("N0")</td> }
                                                    </tr>
                                                }
                                                var l3QP = l3Rows.Sum(r => r.QuantityPurchased);
                                                var l3VP = l3Rows.Sum(r => useGross ? r.GrossPurchasedValue : r.NetPurchasedValue);
                                                var l3QS = l3Rows.Sum(r => r.QuantitySold);
                                                var l3VS = l3Rows.Sum(r => useGross ? r.GrossSoldValue : r.NetSoldValue);
                                                var l3Profit = l3Rows.Sum(r => r.Profit);
                                                <tr class="group-subtotal-row" style="background:#f0f4f8;">
                                                    @for (int i = 0; i < (hasL1?1:0)+(hasL2?1:0)+(hasL3?1:0); i++) { <td></td> }
                                                    @if (showItem) { <td class="fw-semibold text-muted small">@l3Group.Key subtotal</td><td></td> }
                                                    <td class="text-end fw-semibold">@l3QP.ToString("N0")</td>
                                                    <td class="text-end fw-semibold">@l3VP.ToString("N2")</td>
                                                    <td class="text-end fw-semibold">@l3QS.ToString("N0")</td>
                                                    <td class="text-end fw-semibold">@l3VS.ToString("N2")</td>
                                                    @if (Model.ShowProfit) { <td class="text-end fw-semibold">@l3Profit.ToString("N2")</td> }
                                                    <td class="text-end">-</td><td class="text-end">-</td>
                                                    @if (Model.ShowStock) { <td></td> }
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            @foreach (var row in l2Rows)
                                            {
                                                <tr>
                                                    @if (hasL1) { <td class="fw-semibold text-info">@(row.Level1Value ?? "N/A")</td> }
                                                    @if (hasL2) { <td class="text-info">@(row.Level2Value ?? "N/A")</td> }
                                                    @if (showItem) { <td class="fw-semibold"><a href="#" class="text-decoration-none" onclick="drillDown('@row.ItemCode','all');return false;">@row.ItemCode</a></td><td>@row.ItemName</td> }
                                                    <td class="text-end"><a href="#" class="dd-link-purch" onclick="drillDown('@row.ItemCode','purchases');return false;">@row.QuantityPurchased.ToString("N0")</a></td>
                                                    <td class="text-end"><a href="#" class="dd-link-purch" onclick="drillDown('@row.ItemCode','purchases');return false;">@((useGross ? row.GrossPurchasedValue : row.NetPurchasedValue).ToString("N2"))</a></td>
                                                    <td class="text-end"><a href="#" class="dd-link-sales" onclick="drillDown('@row.ItemCode','sales');return false;">@row.QuantitySold.ToString("N0")</a></td>
                                                    <td class="text-end"><a href="#" class="dd-link-sales" onclick="drillDown('@row.ItemCode','sales');return false;">@((useGross ? row.GrossSoldValue : row.NetSoldValue).ToString("N2"))</a></td>
                                                    @if (Model.ShowProfit) { var pC = row.Profit >= 0 ? "text-success" : "text-danger"; <td class="text-end @pC fw-semibold">@row.Profit.ToString("N2")</td> }
                                                    <td class="text-end">@row.QtyPercent.ToString("N1")%</td>
                                                    <td class="text-end">@row.ValPercent.ToString("N1")%</td>
                                                    @if (Model.ShowStock) { <td class="text-end">@row.TotalStockQty.ToString("N0")</td> }
                                                </tr>
                                            }
                                        }
                                        var l2QP = l2Rows.Sum(r => r.QuantityPurchased);
                                        var l2VP = l2Rows.Sum(r => useGross ? r.GrossPurchasedValue : r.NetPurchasedValue);
                                        var l2QS = l2Rows.Sum(r => r.QuantitySold);
                                        var l2VS = l2Rows.Sum(r => useGross ? r.GrossSoldValue : r.NetSoldValue);
                                        var l2Profit = l2Rows.Sum(r => r.Profit);
                                        <tr class="group-subtotal-row" style="background:#e8f0fe;">
                                            @for (int i = 0; i < (hasL1?1:0)+(hasL2?1:0)+(hasL3?1:0); i++) { <td></td> }
                                            @if (showItem) { <td class="fw-semibold text-muted">@l2Group.Key subtotal</td><td></td> }
                                            <td class="text-end fw-semibold">@l2QP.ToString("N0")</td>
                                            <td class="text-end fw-semibold">@l2VP.ToString("N2")</td>
                                            <td class="text-end fw-semibold">@l2QS.ToString("N0")</td>
                                            <td class="text-end fw-semibold">@l2VS.ToString("N2")</td>
                                            @if (Model.ShowProfit) { <td class="text-end fw-semibold">@l2Profit.ToString("N2")</td> }
                                            <td class="text-end">-</td><td class="text-end">-</td>
                                            @if (Model.ShowStock) { <td></td> }
                                        </tr>
                                    }
                                }
                                else
                                {
                                    @foreach (var row in l1Rows)
                                    {
                                        <tr>
                                            @if (hasL1) { <td class="fw-semibold text-info">@(row.Level1Value ?? "N/A")</td> }
                                            @if (showItem) { <td class="fw-semibold"><a href="#" class="text-decoration-none" onclick="drillDown('@row.ItemCode','all');return false;">@row.ItemCode</a></td><td>@row.ItemName</td> }
                                            <td class="text-end"><a href="#" class="dd-link-purch" onclick="drillDown('@row.ItemCode','purchases');return false;">@row.QuantityPurchased.ToString("N0")</a></td>
                                            <td class="text-end"><a href="#" class="dd-link-purch" onclick="drillDown('@row.ItemCode','purchases');return false;">@((useGross ? row.GrossPurchasedValue : row.NetPurchasedValue).ToString("N2"))</a></td>
                                            <td class="text-end"><a href="#" class="dd-link-sales" onclick="drillDown('@row.ItemCode','sales');return false;">@row.QuantitySold.ToString("N0")</a></td>
                                            <td class="text-end"><a href="#" class="dd-link-sales" onclick="drillDown('@row.ItemCode','sales');return false;">@((useGross ? row.GrossSoldValue : row.NetSoldValue).ToString("N2"))</a></td>
                                            @if (Model.ShowProfit) { var pC = row.Profit >= 0 ? "text-success" : "text-danger"; <td class="text-end @pC fw-semibold">@row.Profit.ToString("N2")</td> }
                                            <td class="text-end">@row.QtyPercent.ToString("N1")%</td>
                                            <td class="text-end">@row.ValPercent.ToString("N1")%</td>
                                            @if (Model.ShowStock) { <td class="text-end">@row.TotalStockQty.ToString("N0")</td> }
                                        </tr>
                                    }
                                }

                                var l1QP = l1Rows.Sum(r => r.QuantityPurchased);
                                var l1VP = l1Rows.Sum(r => useGross ? r.GrossPurchasedValue : r.NetPurchasedValue);
                                var l1QS = l1Rows.Sum(r => r.QuantitySold);
                                var l1VS = l1Rows.Sum(r => useGross ? r.GrossSoldValue : r.NetSoldValue);
                                var l1Profit = l1Rows.Sum(r => r.Profit);
                                <tr class="group-subtotal-row">
                                    @for (int i = 0; i < (hasL1?1:0)+(hasL2?1:0)+(hasL3?1:0); i++) { <td></td> }
                                    @if (showItem) { <td class="fw-semibold text-uppercase text-muted">@l1Group.Key total</td><td></td> }
                                    <td class="text-end fw-semibold">@l1QP.ToString("N0")</td>
                                    <td class="text-end fw-semibold">@l1VP.ToString("N2")</td>
                                    <td class="text-end fw-semibold">@l1QS.ToString("N0")</td>
                                    <td class="text-end fw-semibold">@l1VS.ToString("N2")</td>
                                    @if (Model.ShowProfit) { <td class="text-end fw-semibold">@l1Profit.ToString("N2")</td> }
                                    <td class="text-end fw-semibold">-</td>
                                    <td class="text-end fw-semibold">-</td>
                                    @if (Model.ShowStock) { <td></td> }
                                </tr>
                            }
                        }
                        else
                        {
                            foreach (var row in Model.Results)
                            {
                                <tr>
                                    @if (showItem) { <td class="fw-semibold"><a href="#" class="text-decoration-none" onclick="drillDown('@row.ItemCode','all');return false;">@row.ItemCode</a></td><td>@row.ItemName</td> }
                                    <td class="text-end"><a href="#" class="dd-link-purch" onclick="drillDown('@row.ItemCode','purchases');return false;">@row.QuantityPurchased.ToString("N0")</a></td>
                                    <td class="text-end"><a href="#" class="dd-link-purch" onclick="drillDown('@row.ItemCode','purchases');return false;">@((useGross ? row.GrossPurchasedValue : row.NetPurchasedValue).ToString("N2"))</a></td>
                                    <td class="text-end"><a href="#" class="dd-link-sales" onclick="drillDown('@row.ItemCode','sales');return false;">@row.QuantitySold.ToString("N0")</a></td>
                                    <td class="text-end"><a href="#" class="dd-link-sales" onclick="drillDown('@row.ItemCode','sales');return false;">@((useGross ? row.GrossSoldValue : row.NetSoldValue).ToString("N2"))</a></td>
                                    @if (Model.ShowProfit) { var pC = row.Profit >= 0 ? "text-success" : "text-danger"; <td class="text-end @pC fw-semibold">@row.Profit.ToString("N2")</td> }
                                    <td class="text-end">@row.QtyPercent.ToString("N1")%</td>
                                    <td class="text-end">@row.ValPercent.ToString("N1")%</td>
                                    @if (Model.ShowStock) { <td class="text-end">@row.TotalStockQty.ToString("N0")</td> }
                                </tr>
                            }
                        }
                    </tbody>
                    <tfoot>
                        <tr class="grand-total-row">
                            @{ int emptyCols = (hasL1?1:0)+(hasL2?1:0)+(hasL3?1:0); }
                            @for(int i=0;i<emptyCols;i++){<td></td>}
                            @if (showItem) { <td><i class="bi bi-calculator me-1"></i>GRAND TOTAL</td><td></td> }
                            <td class="text-end">@Model.TotalPurchasedQty.ToString("N0")</td>
                            <td class="text-end">@Model.TotalPurchasedValue.ToString("N2")</td>
                            <td class="text-end">@Model.TotalSoldQty.ToString("N0")</td>
                            <td class="text-end">@Model.TotalSoldValue.ToString("N2")</td>
                            @if (Model.ShowProfit) { <td class="text-end fw-semibold">@Model.TotalProfit.ToString("N2")</td> }
                            <td class="text-end">-</td>
                            <td class="text-end">-</td>
                            @if (Model.ShowStock) { <td class="text-end">-</td> }
                        </tr>
                    </tfoot>
                </table>
            }
            </div>
        </div>

        @if (!isMonthly && Model.TotalPages > 1)
        {
            <div class="card-footer">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="text-muted">
                        Showing @((Model.PageNumber - 1) * Model.PageSize + 1) to @(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount)) of @Model.TotalCount rows
                    </div>
                    <nav>
                        <ul class="pagination mb-0">
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")"><a class="page-link" href="#" onclick="goToPage(1);return false;"><i class="bi bi-chevron-double-left"></i></a></li>
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")"><a class="page-link" href="#" onclick="goToPage(@(Model.PageNumber-1));return false;"><i class="bi bi-chevron-left"></i></a></li>
                            @for (int p = Math.Max(1, Model.PageNumber - 2); p <= Math.Min(Model.TotalPages, Model.PageNumber + 2); p++)
                            {
                                <li class="page-item @(p == Model.PageNumber ? "active" : "")"><a class="page-link" href="#" onclick="goToPage(@p);return false;">@p</a></li>
                            }
                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")"><a class="page-link" href="#" onclick="goToPage(@(Model.PageNumber+1));return false;"><i class="bi bi-chevron-right"></i></a></li>
                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")"><a class="page-link" href="#" onclick="goToPage(@Model.TotalPages);return false;"><i class="bi bi-chevron-double-right"></i></a></li>
                        </ul>
                    </nav>
                </div>
            </div>
        }
    </div>

    <div id="previewPanel" style="display:none;" class="mt-3">
        <div class="card border-primary">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-2">
                <span><i class="bi bi-file-earmark-text me-2"></i>Document Preview</span>
                <button class="btn btn-sm btn-outline-light" onclick="togglePreview()"><i class="bi bi-x-lg me-1"></i>Back to Grid</button>
            </div>
            <div class="card-body p-0">
                <iframe id="previewFrame" style="width:100%;border:none;min-height:700px;background:#525659;"></iframe>
            </div>
        </div>
    </div>
}
else if (ViewContext.HttpContext.Request.Method == "POST")
{
    <div class="card" id="results">
        <div class="card-body text-center py-5">
            <i class="bi bi-inbox empty-state-icon text-muted"></i>
            <h4 class="mt-3">No Data Found</h4>
            <p class="text-muted">No transactions found for the selected criteria.</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-bar-chart empty-state-icon text-primary"></i>
            <h4 class="mt-3">Generate Your Report</h4>
            <p class="text-muted">Select your parameters above and click "Generate Report" to view the Purchases vs Sales analysis.</p>
        </div>
    </div>
}

<!-- Schedule Modal -->
<div class="modal fade" id="scheduleModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-clock-history me-2"></i>Schedule Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-light border mb-3 py-2">
                    <small class="text-muted"><i class="bi bi-info-circle me-1"></i>The report will run automatically and recipients will receive an email with a link to download the exported file.</small>
                </div>

                <h6 class="text-muted mb-2"><i class="bi bi-funnel me-1"></i>Parameters (current selection)</h6>
                <div class="bg-light rounded p-2 mb-3 small">
                    <span class="me-3"><strong>Mode:</strong> @Model.ReportMode</span>
                    @if (Model.HasPrimaryGroup) { <span class="me-3"><strong>Group:</strong> @Model.PrimaryGroup</span> }
                    @if (Model.SelectedStoreCodes.Any()) { <span><strong>Stores:</strong> @Model.SelectedStoreCodes.Count selected</span> }
                </div>

                <h6 class="text-muted mb-2"><i class="bi bi-calendar-range me-1"></i>Report date range</h6>
                <p class="small text-muted mb-2">Computed when the schedule runs.</p>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Period type</label>
                        <select class="form-select" id="schedDateRangeType" onchange="onSchedDateRangeTypeChange()">
                            <option value="LastNDays" data-value="7">Last 7 days</option>
                            <option value="LastNDays" data-value="30">Last 30 days</option>
                            <option value="ThisMonth">This month (to today)</option>
                            <option value="LastMonth">Last month</option>
                            <option value="YearToDate">Year to date</option>
                            <option value="LastYear">Last year</option>
                            <option value="Custom">Custom (fixed dates)</option>
                        </select>
                    </div>
                    <div class="col-md-3" id="schedCustomDateFromWrap" style="display:none;">
                        <label class="form-label fw-semibold">From</label>
                        <input type="date" class="form-control" id="schedDateFrom" value="@Model.DateFrom.ToString("yyyy-MM-dd")">
                    </div>
                    <div class="col-md-3" id="schedCustomDateToWrap" style="display:none;">
                        <label class="form-label fw-semibold">To</label>
                        <input type="date" class="form-control" id="schedDateTo" value="@Model.DateTo.ToString("yyyy-MM-dd")">
                    </div>
                </div>

                <h6 class="text-muted mb-2"><i class="bi bi-gear me-1"></i>Schedule settings</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Schedule Name</label>
                        <input type="text" class="form-control" id="schedName" placeholder="e.g. Weekly Purchases vs Sales" required>
                        <input type="hidden" id="schedId" value="">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Export Format</label>
                        <select class="form-select" id="schedFormat">
                            <option value="Excel">Excel (.xlsx)</option>
                            <option value="PDF">PDF</option>
                            <option value="CSV">CSV</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Recurrence</label>
                        <select class="form-select" id="schedRecurrence" onchange="onRecurrenceChange()">
                            <option value="Once">Run Once</option>
                            <option value="Daily" selected>Daily</option>
                            <option value="Weekly">Weekly</option>
                            <option value="Monthly">Monthly</option>
                        </select>
                    </div>
                    <div class="col-md-4" id="schedWeeklyDaysContainer" style="display:none;">
                        <label class="form-label fw-semibold">Days of week</label>
                        <div class="d-flex flex-wrap gap-2">
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="1"> Mon</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="2"> Tue</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="3"> Wed</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="4"> Thu</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="5"> Fri</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="6"> Sat</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="0"> Sun</label>
                        </div>
                    </div>
                    <div class="col-md-4" id="schedMonthDayContainer" style="display:none;">
                        <label class="form-label fw-semibold">Day of month</label>
                        <select class="form-select" id="schedMonthDay">
                            @for (var i = 1; i <= 28; i++) { <option value="@i">@i</option> }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Time</label>
                        <input type="time" class="form-control" id="schedTime" value="08:00">
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Start date</label>
                        <input type="date" class="form-control" id="schedStartDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" min="@DateTime.Today.ToString("yyyy-MM-dd")" style="max-width:12rem;">
                    </div>
                    <div class="col-12 mt-2">
                        <h6 class="text-muted mb-2"><i class="bi bi-envelope me-1"></i>Recipients</h6>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Email addresses</label>
                        <input type="text" class="form-control" id="schedRecipients" placeholder="user@@company.com, manager@@company.com">
                        <small class="text-muted">Separate multiple addresses with commas</small>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Email Subject <span class="text-muted fw-normal">(optional)</span></label>
                        <input type="text" class="form-control" id="schedSubject" placeholder="Purchases vs Sales Report - {date}">
                    </div>

                    <div class="col-12 mt-3">
                        <h6 class="text-muted mb-2"><i class="bi bi-stars me-1"></i>AI Analysis</h6>
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="schedSkipIfEmpty">
                            <label class="form-check-label fw-semibold" for="schedSkipIfEmpty">Don't send if empty</label>
                        </div>
                        <small class="text-muted d-block mb-3">When enabled, the email will not be sent if the report returns 0 records.</small>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="schedIncludeAi" onchange="onSchedAiToggle()">
                            <label class="form-check-label fw-semibold" for="schedIncludeAi">Include AI Analysis in email</label>
                        </div>
                        <small class="text-muted d-block mt-1">When enabled, an AI-generated business intelligence summary will be included in the scheduled email body.</small>
                        <div id="schedAiDetails" class="mt-2 ps-4" style="display:none;">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto">
                                    <label class="form-label small mb-0 fw-semibold" for="schedAiLocale">Language</label>
                                </div>
                                <div class="col-auto">
                                    <select class="form-select form-select-sm" id="schedAiLocale" style="width:auto;min-width:140px;">
                                        <option value="el">Ελληνικά</option>
                                        <option value="en">English</option>
                                        <option value="sr">Srpski</option>
                                        <option value="de">Deutsch</option>
                                        <option value="fr">Français</option>
                                        <option value="bg">Български</option>
                                        <option value="ru">Русский</option>
                                        <option value="uk">Українська</option>
                                        <option value="et">Eesti</option>
                                        <option value="nl">Nederlands</option>
                                    </select>
                                </div>
                            </div>
                            <div class="alert alert-light border py-2 mt-2 mb-0 small">
                                <i class="bi bi-info-circle me-1 text-primary"></i>
                                <strong>Estimated cost:</strong> ~$0.002–0.01 per analysis (depends on report size).
                                Token usage is logged for each execution.
                            </div>
                        </div>
                    </div>
                </div>
                <div id="scheduleAlert" class="mt-3" style="display:none;"></div>

                <hr class="my-3">
                <h6 class="text-muted"><i class="bi bi-list-check me-1"></i>Existing Schedules</h6>
                <div id="existingSchedules" class="small text-muted">Loading...</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary me-auto" onclick="resetScheduleForm()" title="Clear the form to create a new schedule"><i class="bi bi-arrow-counterclockwise me-1"></i>Reset</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveSchedule()"><i class="bi bi-check-lg me-1"></i>Save Schedule</button>
            </div>
        </div>
    </div>
</div>

<!-- Column Settings Modal -->
<div class="modal fade" id="columnSettingsModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-layout-three-columns me-2"></i>Column Visibility</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-2">Search and toggle which columns are visible.</p>
                <div class="input-group mb-3">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" id="colSearchInput" placeholder="Search columns..." oninput="filterColumnList()">
                </div>
                <div class="border rounded" style="max-height:300px;overflow-y:auto;">
                    <div class="list-group list-group-flush" id="colToggleList">
                        @{
                            var colDefs = new (string key, string label)[] {
                                ("QuantityPurchased", "Qty Purchased"), ("NetPurchasedValue", useGross?"Gross Purchased":"Net Purchased"),
                                ("QuantitySold", "Qty Sold"), ("NetSoldValue", useGross?"Gross Sold":"Net Sold"),
                                ("Profit", "Profit"), ("TotalStockQty", "Stock Qty")
                            };
                        }
                        @foreach (var (key, label) in colDefs)
                        {
                            <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="@label.ToLower()">
                                <input class="form-check-input col-toggle me-2" type="checkbox" value="@key" id="colToggle_@key" checked onchange="applyColumnVisibility()">
                                <span>@label</span>
                            </label>
                        }
                    </div>
                </div>
                <div class="mt-2 d-flex justify-content-between small text-muted">
                    <span><span id="colVisibleCount">@colDefs.Length</span> of @colDefs.Length columns visible</span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleAllColumns(true)">Select All</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleAllColumns(false)">Deselect All</button>
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Done</button>
            </div>
        </div>
    </div>
</div>

<!-- AI Analysis Modal -->
