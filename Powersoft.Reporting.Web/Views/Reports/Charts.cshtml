@using Powersoft.Reporting.Core.Models
@using System.Text.Json
@{
    ViewData["Title"] = "Charts & Dashboards";
    var stores = ViewBag.Stores as List<Store> ?? new List<Store>();
    var dbName = ViewBag.ConnectedDatabase as string ?? "Unknown";
    var storesJson = JsonSerializer.Serialize(stores.Select(s => new { s.StoreCode, s.StoreName }));
    bool canSchedule = ViewBag.CanSchedule as bool? ?? false;
    bool hasSavedLayout = ViewBag.HasSavedLayout as bool? ?? false;
    var savedLayout = ViewBag.SavedLayout as Dictionary<string, string>;
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-start">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">Reports</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">Stock Control</a></li>
                    <li class="breadcrumb-item active">Charts & Dashboards</li>
                </ol>
            </nav>
            <h2 class="mb-0">
                <i class="bi bi-pie-chart me-2 text-primary"></i>Charts & Dashboards
            </h2>
            <p class="text-muted mb-0">Visual data exploration — @dbName</p>
        </div>
        <div class="mt-3">
            @await Html.PartialAsync("_TutorialButton", ("Charts", ""))
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-funnel me-2"></i>Chart Parameters
    </div>
    <div class="card-body">
        <form id="chartForm">
            <div class="row mb-3">
                <div class="col-12">
                    <label class="form-label fw-semibold mb-2">Quick Date Selection</label>
                    <div class="date-presets btn-group flex-wrap" role="group">
                        <input type="radio" class="btn-check" name="DatePreset" id="presetToday" value="today" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetToday">Today</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetYesterday" value="yesterday" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetYesterday">Yesterday</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLast7" value="last7" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLast7">Last 7 Days</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLast30" value="last30" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLast30">Last 30 Days</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetThisMonth" value="thisMonth" autocomplete="off" checked>
                        <label class="btn btn-outline-secondary btn-sm" for="presetThisMonth">This Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastMonth" value="lastMonth" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLastMonth">Last Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetYTD" value="ytd" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetYTD">Year to Date</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastYear" value="lastYear" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLastYear">Last Year</label>
                    </div>
                </div>
            </div>

            <hr class="my-3">

            <div class="row g-3 mb-3 align-items-end">
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date From</label>
                    <input type="date" class="form-control" id="dateFrom" onchange="clearPreset()"
                           value="@DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date To</label>
                    <input type="date" class="form-control" id="dateTo" onchange="clearPreset()"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Chart On</label>
                    <select class="form-select" id="chartMode" onchange="onChartModeChange()">
                        <option value="Sales">Sales</option>
                        <option value="SalesVsReturns">Sales vs Returns</option>
                        <option value="Purchases">Purchases</option>
                        <option value="PurchasesVsReturns">Purchases vs Returns</option>
                        <option value="SalesVsPurchases">Sales vs Purchases</option>
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Group By</label>
                    <select class="form-select" id="dimension">
                        <option value="Category">Category</option>
                        <option value="Store">Store / Shop</option>
                        <option value="Brand">Brand</option>
                        <option value="Customer">Customer</option>
                        <option value="Item">Item</option>
                        <option value="Supplier" data-perm-opt="supplier">Supplier</option>
                        <option value="Department">Department</option>
                        <option value="Season">Season</option>
                        <option value="Agent">Agent</option>
                        <option value="User">User</option>
                        <option value="CSAgent">Customer/Supplier Agent</option>
                        <optgroup label="MODA">
                            <option value="Model">Model</option>
                            <option value="Colour">Colour</option>
                            <option value="Size">Size</option>
                            <option value="SizeGroup">Size Group</option>
                            <option value="Fabric">Fabric</option>
                        </optgroup>
                        <optgroup label="Attributes">
                            <option value="Attr1">Attribute 1</option>
                            <option value="Attr2">Attribute 2</option>
                            <option value="Attr3">Attribute 3</option>
                            <option value="Attr4">Attribute 4</option>
                            <option value="Attr5">Attribute 5</option>
                            <option value="Attr6">Attribute 6</option>
                        </optgroup>
                        <optgroup label="Customer Categories">
                            <option value="CustCat1">Customer Category 1</option>
                            <option value="CustCat2">Customer Category 2</option>
                            <option value="CustCat3">Customer Category 3</option>
                        </optgroup>
                        <optgroup label="Time Analysis">
                            <option value="HourOfDay">Rush Hours (Hour of Day)</option>
                        </optgroup>
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Metric</label>
                    <select class="form-select" id="metric">
                        <option value="Value">Value (€)</option>
                        <option value="Quantity">Quantity</option>
                        <option value="Count">No. of Transactions</option>
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Top N</label>
                    <select class="form-select" id="topN">
                        <option value="5">Top 5</option>
                        <option value="10" selected>Top 10</option>
                        <option value="15">Top 15</option>
                        <option value="20">Top 20</option>
                    </select>
                </div>
            </div>

            <div class="row g-3 mb-3 align-items-end">
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Chart Type</label>
                    <select class="form-select" id="chartType">
                        <option value="pie">Pie Chart</option>
                        <option value="doughnut">Doughnut</option>
                        <option value="bar">Bar Chart</option>
                        <option value="horizontalBar">Horizontal Bar</option>
                    </select>
                </div>
            </div>

            <div class="row g-3 mb-4 align-items-end">
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="showOthers" checked>
                        <label class="form-check-label" for="showOthers">Show Others</label>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="compareLastYear">
                        <label class="form-check-label" for="compareLastYear">Compare with Last Year</label>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="includeVat">
                        <label class="form-check-label" for="includeVat">Include VAT</label>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="showDataLabels">
                        <label class="form-check-label" for="showDataLabels">Show Data Labels</label>
                    </div>
                </div>
                <div class="col-auto" id="labelPositionGroup" style="display:none;">
                    <select class="form-select form-select-sm" id="labelPosition" style="width:auto;">
                        <option value="auto">Auto</option>
                        <option value="inside">Inside</option>
                        <option value="outside">Outside</option>
                    </select>
                </div>
            </div>

            <div class="report-form-actions d-flex flex-wrap gap-2 pt-2 border-top">
                <button type="button" class="btn btn-primary btn-lg" onclick="loadChart()" id="generateBtn">
                    <i class="bi bi-play-fill me-2"></i>Generate Chart
                </button>
                @if (canSchedule)
                {
                    <button type="button" class="btn btn-warning btn-lg" data-bs-toggle="modal" data-bs-target="#scheduleModal" title="Schedule recurring report delivery">
                        <i class="bi bi-clock-history me-2"></i>Schedule
                    </button>
                }
                <div class="btn-group ms-auto">
                    <div class="btn-group">
                        <button type="button" class="btn btn-outline-info dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false"
                                title="Saved report layouts" id="layoutsDropdownBtn">
                            <i class="bi bi-bookmark me-1"></i><span id="layoutsCurrentName">Layouts</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" id="layoutsDropdownMenu" style="min-width: 320px;">
                            <li><h6 class="dropdown-header">Loading...</h6></li>
                        </ul>
                    </div>
                    <button type="button" class="btn btn-outline-info" onclick="saveCurrentLayout()" title="Overwrite your default layout with current parameters">
                        <i class="bi bi-save me-1"></i>Save
                    </button>
                    <button type="button" class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#saveChartLayoutAsModal"
                            title="Save current parameters as a new named layout (optionally shared with all users)">
                        <i class="bi bi-bookmark-plus me-1"></i>Save as...
                    </button>
                    @if (hasSavedLayout)
                    {
                        <button type="button" class="btn btn-outline-secondary" onclick="resetSavedLayout()" title="Discard your saved default layout and restore factory defaults">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Default
                        </button>
                    }
                </div>
            </div>
            @if (hasSavedLayout)
            {
                <div class="mt-2"><small class="text-info"><i class="bi bi-check-circle me-1"></i>Saved layout loaded</small></div>
            }
        </form>
    </div>
</div>

@await Html.PartialAsync("_ItemsSelection", new ItemsSelectionConfig
{
    ShowCategories = true,
    ShowDepartments = true,
    ShowBrands = true,
    ShowSeasons = true,
    ShowSuppliers = true,
    ShowCustomers = false,
    ShowStores = true,
    StoresJson = storesJson,
    ReportType = "Charts"
})

<div id="chartLoading" class="text-center py-5 d-none">
    <div class="spinner-border text-primary"></div>
    <p class="text-muted mt-2">Loading chart data...</p>
</div>
<div id="chartError" class="alert alert-danger d-none"></div>

<div id="chartArea" class="d-none">
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-bar-chart me-2"></i>Chart Results</span>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <div class="btn-group btn-group-sm" id="exportGroup">
                    <button type="button" class="btn btn-outline-success" onclick="exportChart('excel')" title="Export to Excel">
                        <i class="bi bi-file-earmark-spreadsheet me-1"></i>Excel
                    </button>
                    <button type="button" class="btn btn-outline-secondary" onclick="exportChart('csv')" title="Export to CSV">
                        <i class="bi bi-filetype-csv me-1"></i>CSV
                    </button>
                    <button type="button" class="btn btn-outline-danger" onclick="exportChart('pdf')" title="Export to PDF">
                        <i class="bi bi-filetype-pdf me-1"></i>PDF
                    </button>
                </div>
                <button class="btn btn-sm btn-outline-primary" onclick="openSendEmailModal()" title="Send report via email">
                    <i class="bi bi-envelope me-1"></i>Send to Email
                </button>
                <button class="btn btn-sm btn-outline-info" id="btnAnalyze" onclick="openAiAnalysis()">
                    <i class="bi bi-stars me-1"></i>AI Analyze
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-lg-8">
                    <div style="position:relative;height:500px;">
                        <canvas id="mainChart"></canvas>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header small fw-semibold py-2">
                            <i class="bi bi-table me-1"></i>Data Summary
                        </div>
                        <div class="card-body p-0" style="max-height:460px;overflow-y:auto;">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light sticky-top">
                                    <tr class="small">
                                        <th>#</th>
                                        <th>Label</th>
                                        <th class="text-end">Value</th>
                                        <th class="text-end">%</th>
                                    </tr>
                                </thead>
                                <tbody id="dataSummary" class="small"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="emptyState" class="text-center py-5 text-muted">
    <i class="bi bi-pie-chart" style="font-size:3rem;opacity:0.3;"></i>
    <p class="mt-3">Select your parameters and click <strong>Generate Chart</strong> to begin.</p>
</div>

@* Schedule Modal — shared partial *@
@await Html.PartialAsync("_Schedule", new Powersoft.Reporting.Web.ViewModels.SchedulePartialModel {
    SaveAction      = "SaveChartSchedule",
    ListAction      = "GetChartSchedules",
    ReportBadge     = "Charts",
    NamePlaceholder = "e.g. Weekly Charts Report",
    SubjectPlaceholder = "Charts Report - {date}"
})

@await Html.PartialAsync("_AiAnalyze", new Powersoft.Reporting.Web.ViewModels.AiAnalyzePartialModel {
    AnalyzeActionUrl = Url.Action("AnalyzeChartReport", "Reports"),
    ReportType = "Charts"
})

@* Send Email Modal — shared partial *@
@await Html.PartialAsync("_SendEmail", new Powersoft.Reporting.Web.ViewModels.SendEmailPartialModel {
    SendAction = "SendChartEmail",
    ReportType = "Charts",
    SubjectDefault = "Charts & Dashboards"
})

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
<script>
var _viewCost     = @(ViewBag.ViewCost     != null ? (ViewBag.ViewCost     ? "true" : "false") : "true");
var _viewSupplier = @(ViewBag.ViewSupplier != null ? (ViewBag.ViewSupplier ? "true" : "false") : "true");
Chart.register(ChartDataLabels);
Chart.defaults.set('plugins.datalabels', { display: false });

document.getElementById('showDataLabels').addEventListener('change', function() {
    document.getElementById('labelPositionGroup').style.display = this.checked ? '' : 'none';
});

var _chart = null;
var COLORS = [
    '#2563eb','#059669','#d97706','#dc2626','#7c3aed',
    '#0891b2','#be185d','#65a30d','#ea580c','#4f46e5',
    '#0d9488','#c026d3','#ca8a04','#e11d48','#2dd4bf',
    '#f97316','#8b5cf6','#14b8a6','#f43f5e','#6366f1',
    '#94a3b8'
];

document.querySelectorAll('input[name="DatePreset"]').forEach(function(el) {
    el.addEventListener('change', function() {
        var now = new Date();
        var y = now.getFullYear(), m = now.getMonth(), d = now.getDate();
        var from, to;
        switch (this.value) {
            case 'today': from = to = new Date(y, m, d); break;
            case 'yesterday': from = to = new Date(y, m, d - 1); break;
            case 'last7': from = new Date(y, m, d - 7); to = new Date(y, m, d); break;
            case 'last30': from = new Date(y, m, d - 30); to = new Date(y, m, d); break;
            case 'thisMonth': from = new Date(y, m, 1); to = new Date(y, m, d); break;
            case 'lastMonth': from = new Date(y, m - 1, 1); to = new Date(y, m, 0); break;
            case 'ytd': from = new Date(y, 0, 1); to = new Date(y, m, d); break;
            case 'lastYear': from = new Date(y - 1, 0, 1); to = new Date(y - 1, 11, 31); break;
        }
        if (from) document.getElementById('dateFrom').value = from.toISOString().split('T')[0];
        if (to) document.getElementById('dateTo').value = to.toISOString().split('T')[0];
    });
});
function clearPreset() { document.querySelectorAll('input[name="DatePreset"]').forEach(function(r) { r.checked = false; }); }

function getItemsSelectionJson() {
    if (typeof getItemsSelectionFilter === 'function') {
        var f = getItemsSelectionFilter();
        return Object.keys(f).length > 0 ? JSON.stringify(f) : '';
    }
    return '';
}

function getSelectedStoreCodes() {
    return typeof getItemsSelectionStoreCodes === 'function'
        ? getItemsSelectionStoreCodes() : '';
}

function onChartModeChange() {
    var mode = document.getElementById('chartMode').value;
    var isVs = mode.indexOf('Vs') >= 0;
    var cly = document.getElementById('compareLastYear');
    if (isVs) { cly.checked = false; cly.disabled = true; }
    else { cly.disabled = false; }
    var ct = document.getElementById('chartType');
    if (isVs && (ct.value === 'pie' || ct.value === 'doughnut')) { ct.value = 'bar'; }
}

function exportChart(format) {
    var dateFrom = document.getElementById('dateFrom').value;
    var dateTo = document.getElementById('dateTo').value;
    if (!dateFrom || !dateTo) { alert('Please select dates first.'); return; }

    var params = new URLSearchParams({
        dateFrom: dateFrom,
        dateTo: dateTo,
        mode: document.getElementById('chartMode').value,
        dimension: document.getElementById('dimension').value,
        metric: document.getElementById('metric').value,
        topN: document.getElementById('topN').value,
        showOthers: document.getElementById('showOthers').checked,
        compareLastYear: document.getElementById('compareLastYear').checked,
        includeVat: document.getElementById('includeVat').checked,
        storeCodes: getSelectedStoreCodes(),
        chartType: document.getElementById('chartType').value
    });
    var isJson = getItemsSelectionJson();
    if (isJson) params.append('itemsSelection', isJson);

    var action = format === 'excel' ? 'ExportChartExcel' : format === 'pdf' ? 'ExportChartPdf' : 'ExportChartCsv';
    window.location.href = '/Reports/' + action + '?' + params.toString();
}

function loadChart() {
    var dateFrom = document.getElementById('dateFrom').value;
    var dateTo = document.getElementById('dateTo').value;
    if (!dateFrom || !dateTo) { alert('Please select dates.'); return; }

    document.getElementById('chartLoading').classList.remove('d-none');
    document.getElementById('chartError').classList.add('d-none');
    document.getElementById('chartArea').classList.add('d-none');
    document.getElementById('emptyState').classList.add('d-none');

    var fd = new FormData();
    fd.append('dateFrom', dateFrom);
    fd.append('dateTo', dateTo);
    fd.append('mode', document.getElementById('chartMode').value);
    fd.append('dimension', document.getElementById('dimension').value);
    fd.append('metric', document.getElementById('metric').value);
    fd.append('topN', document.getElementById('topN').value);
    fd.append('showOthers', document.getElementById('showOthers').checked);
    fd.append('compareLastYear', document.getElementById('compareLastYear').checked);
    fd.append('includeVat', document.getElementById('includeVat').checked);
    fd.append('storeCodes', getSelectedStoreCodes());
    fd.append('chartType', document.getElementById('chartType').value);
    var isJson = getItemsSelectionJson();
    if (isJson) fd.append('itemsSelection', isJson);

    fetch('/Reports/GetChartData', { method: 'POST', body: fd })
        .then(function(r) { return r.json(); })
        .then(function(result) {
            document.getElementById('chartLoading').classList.add('d-none');
            if (!result.success) {
                document.getElementById('chartError').textContent = result.message;
                document.getElementById('chartError').classList.remove('d-none');
                return;
            }
            renderChart(result.data, result.chartType);
        })
        .catch(function(err) {
            document.getElementById('chartLoading').classList.add('d-none');
            document.getElementById('chartError').textContent = 'Network error: ' + err.message;
            document.getElementById('chartError').classList.remove('d-none');
        });
}

window.collectAiFormData = function() {
    var fd = new FormData();
    fd.append('dateFrom', document.getElementById('dateFrom').value);
    fd.append('dateTo', document.getElementById('dateTo').value);
    fd.append('mode', document.getElementById('chartMode').value);
    fd.append('dimension', document.getElementById('dimension').value);
    fd.append('metric', document.getElementById('metric').value);
    fd.append('topN', document.getElementById('topN').value);
    fd.append('showOthers', document.getElementById('showOthers').checked);
    fd.append('compareLastYear', document.getElementById('compareLastYear').checked);
    fd.append('includeVat', document.getElementById('includeVat').checked);
    fd.append('storeCodes', getSelectedStoreCodes());
    var isJson = getItemsSelectionJson();
    if (isJson) fd.append('itemsSelection', isJson);
    return fd;
};

// ==================== Send to Email (shared _SendEmail partial) ====================
// Host hook for Views/Shared/_SendEmail.cshtml. The partial supplies the modal,
// openSendEmailModal(), sendReportEmail(), loadEmailTemplates(), onEmailTemplateChange(),
// validateEmailListSend() and _emailTemplatesCache. It appends recipients/cc/bcc/
// emailSubject/exportFormat/templateId itself, then every key returned below.
// Mirrors the field names posted by the export endpoints (exportChart()).
window.collectEmailParameters = function() {
    if (!_chart) { alert('Generate a chart first.'); return null; }
    var p = {
        dateFrom: document.getElementById('dateFrom').value,
        dateTo: document.getElementById('dateTo').value,
        mode: document.getElementById('chartMode').value,
        dimension: document.getElementById('dimension').value,
        metric: document.getElementById('metric').value,
        topN: document.getElementById('topN').value,
        showOthers: document.getElementById('showOthers').checked,
        compareLastYear: document.getElementById('compareLastYear').checked,
        includeVat: document.getElementById('includeVat').checked,
        storeCodes: getSelectedStoreCodes(),
        chartType: document.getElementById('chartType').value
    };
    var isJson = getItemsSelectionJson();
    if (isJson) p.itemsSelection = isJson;
    return p;
};

function getVsLabels(mode) {
    switch (mode) {
        case 'SalesVsReturns': return ['Sales', 'Returns', 'Difference'];
        case 'PurchasesVsReturns': return ['Purchases', 'Returns', 'Difference'];
        case 'SalesVsPurchases': return ['Sales', 'Purchases', 'Difference'];
        default: return ['', '', ''];
    }
}

function onChartItemClick(d) {
    var dim = document.getElementById('dimension').value;
    var df = document.getElementById('dateFrom').value;
    var dt = document.getElementById('dateTo').value;
    if (dim === 'Item') {
        var itemCode = d.label.split(' - ')[0].trim();
        var url = '/Reports/PurchasesSales?dateFrom=' + df + '&dateTo=' + dt + '&groupBy=Item&itemSearch=' + encodeURIComponent(itemCode);
        window.open(url, '_blank');
    } else {
        var detailBox = document.getElementById('chartClickDetail');
        if (!detailBox) {
            detailBox = document.createElement('div');
            detailBox.id = 'chartClickDetail';
            detailBox.className = 'alert alert-info alert-dismissible fade show mt-2';
            detailBox.setAttribute('role', 'alert');
            document.getElementById('chartArea').appendChild(detailBox);
        }
        var metricVal = document.getElementById('metric').value;
        var fmt = (metricVal === 'Quantity' || metricVal === 'Count')
            ? d.value.toLocaleString()
            : '€' + d.value.toLocaleString(undefined, {minimumFractionDigits:2});
        detailBox.innerHTML = '<strong>' + d.label + '</strong> — ' + fmt
            + (d.compareValue ? ' (Last Year: €' + d.compareValue.toLocaleString(undefined, {minimumFractionDigits:2}) + ')' : '')
            + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
        detailBox.classList.add('show');
    }
}

function renderChart(data, chartType) {
    if (!data || data.length === 0) {
        document.getElementById('chartError').textContent = 'No data found for the selected criteria.';
        document.getElementById('chartError').classList.remove('d-none');
        return;
    }

    var mode = document.getElementById('chartMode').value;
    var isVsMode = data.some(function(d) { return d.value2 !== null && d.value2 !== undefined; });

    document.getElementById('chartArea').classList.remove('d-none');
    document.getElementById('exportGroup').style.display = '';
    var labels = data.map(function(d) { return d.label; });
    var values = data.map(function(d) { return d.value; });
    var total = values.reduce(function(a, b) { return a + b; }, 0);
    var hasCompare = !isVsMode && data.some(function(d) { return d.compareValue !== null && d.compareValue !== undefined; });
    var compareValues = hasCompare ? data.map(function(d) { return d.compareValue || 0; }) : null;
    var colors = labels.map(function(_, i) { return COLORS[i % COLORS.length]; });

    var isPie = !isVsMode && (chartType === 'pie' || chartType === 'doughnut');
    var isHoriz = chartType === 'horizontalBar';
    var cjsType = isHoriz ? 'bar' : (isPie ? chartType : 'bar');

    if (_chart) _chart.destroy();

    var metricVal = document.getElementById('metric').value;
    var metricLabel = metricVal === 'Quantity' ? 'Quantity' : metricVal === 'Count' ? 'Transactions' : 'Value';
    var datasets;

    if (isVsMode) {
        var vsLabels = getVsLabels(mode);
        var values2 = data.map(function(d) { return d.value2 || 0; });
        var diffValues = data.map(function(d) { return d.diffValue || 0; });
        datasets = [
            { label: vsLabels[0], data: values, backgroundColor: '#2563ebCC', borderColor: '#2563eb', borderWidth: 1 },
            { label: vsLabels[1], data: values2, backgroundColor: '#dc2626CC', borderColor: '#dc2626', borderWidth: 1 },
            { label: vsLabels[2], data: diffValues, backgroundColor: '#059669CC', borderColor: '#059669', borderWidth: 1 }
        ];
    } else {
        datasets = [{
            label: metricLabel,
            data: values,
            backgroundColor: isPie ? colors : colors.map(function(c) { return c + 'CC'; }),
            borderColor: isPie ? '#fff' : colors,
            borderWidth: isPie ? 2 : 1
        }];
        if (hasCompare) {
            var diffValues = data.map(function(d) { return d.diffValue || 0; });
            datasets.push({
                label: 'Last Year',
                data: compareValues,
                backgroundColor: isPie ? colors.map(function(c) { return c + '66'; }) : '#dc2626AA',
                borderColor: isPie ? colors.map(function(c) { return c + '88'; }) : '#dc2626',
                borderWidth: 1
            });
            if (!isPie) {
                datasets.push({
                    label: 'YoY Difference',
                    data: diffValues,
                    backgroundColor: '#059669AA',
                    borderColor: '#059669',
                    borderWidth: 1
                });
            }
        }
    }

    var ctx = document.getElementById('mainChart').getContext('2d');
    _chart = new Chart(ctx, {
        type: cjsType,
        data: { labels: labels, datasets: datasets },
        options: {
            indexAxis: isHoriz ? 'y' : 'x',
            responsive: true,
            maintainAspectRatio: false,
            onClick: function(evt, elements) {
                if (elements.length === 0) return;
                var idx = elements[0].index;
                var clickedData = data[idx];
                if (!clickedData) return;
                onChartItemClick(clickedData);
            },
            plugins: {
                legend: { position: isPie ? 'right' : 'top', labels: { font: { size: 11 } } },
                tooltip: {
                    callbacks: {
                        label: function(ctx) {
                            var v = ctx.parsed !== undefined ? (isPie ? ctx.parsed : (isHoriz ? ctx.parsed.x : ctx.parsed.y)) : 0;
                            var pct = total > 0 ? ((Math.abs(v) / total) * 100).toFixed(1) : '0';
                            var isQty = metricVal === 'Quantity';
                            var isCnt = metricVal === 'Count';
                            if (isQty || isCnt) return ctx.dataset.label + ': ' + v.toLocaleString() + ' (' + pct + '%)';
                            return ctx.dataset.label + ': €' + v.toLocaleString(undefined, {minimumFractionDigits:2}) + ' (' + pct + '%)';
                        }
                    }
                },
                datalabels: (function() {
                    var showDl = document.getElementById('showDataLabels').checked;
                    if (!showDl) return { display: false };
                    var pos = document.getElementById('labelPosition').value;
                    var anchor = pos === 'inside' ? 'center' : pos === 'outside' ? 'end' : (isPie ? 'center' : 'end');
                    var align = pos === 'inside' ? 'center' : pos === 'outside' ? 'end' : (isPie ? 'center' : 'top');
                    return {
                        display: true,
                        color: isPie ? '#fff' : '#333',
                        font: { size: 10, weight: 'bold' },
                        anchor: anchor,
                        align: align,
                        formatter: function(value) {
                            if (metricVal === 'Quantity' || metricVal === 'Count') return value.toLocaleString();
                            return '€' + value.toLocaleString(undefined, {minimumFractionDigits:0, maximumFractionDigits:0});
                        }
                    };
                })()
            },
            scales: isPie ? {} : {
                y: { beginAtZero: true, ticks: { font: { size: 11 } } },
                x: { ticks: { font: { size: 10 }, maxRotation: 45 } }
            }
        }
    });

    var isQty = metricVal === 'Quantity';
    var isCnt = metricVal === 'Count';
    var fmt = function(v) { return (isQty || isCnt) ? v.toLocaleString() : '€' + v.toLocaleString(undefined, {minimumFractionDigits:2}); };
    var tbody = document.getElementById('dataSummary');
    tbody.innerHTML = '';
    data.forEach(function(d, i) {
        var pct = total > 0 ? ((d.value / total) * 100).toFixed(1) : '0.0';
        var dot = '<span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:' + COLORS[i % COLORS.length] + ';margin-right:6px;"></span>';
        var row;
        if (isVsMode) {
            row = '<tr><td>' + (i+1) + '</td><td>' + dot + d.label + '</td><td class="text-end">' + fmt(d.value)
                + '<br><small class="text-muted">' + fmt(d.value2 || 0) + '</small></td><td class="text-end">'
                + fmt(d.diffValue || 0) + '</td></tr>';
        } else if (hasCompare && d.compareValue !== null && d.compareValue !== undefined) {
            var yoyPct = d.compareValue > 0 ? (((d.value - d.compareValue) / d.compareValue) * 100).toFixed(1) : 'N/A';
            var cls = yoyPct !== 'N/A' && parseFloat(yoyPct) >= 0 ? 'text-success' : 'text-danger';
            var absDiff = d.diffValue !== null && d.diffValue !== undefined ? d.diffValue : (d.value - d.compareValue);
            row = '<tr><td>' + (i+1) + '</td><td>' + dot + d.label + '</td><td class="text-end">' + fmt(d.value)
                + '<br><small class="text-muted">LY: ' + fmt(d.compareValue) + '</small></td><td class="text-end">' + fmt(absDiff)
                + '<br><small class="' + cls + '">' + (yoyPct !== 'N/A' ? yoyPct + '%' : yoyPct) + '</small></td></tr>';
        } else {
            row = '<tr><td>' + (i+1) + '</td><td>' + dot + d.label + '</td><td class="text-end">' + fmt(d.value) + '</td><td class="text-end">' + pct + '%</td></tr>';
        }
        tbody.innerHTML += row;
    });
    tbody.innerHTML += '<tr class="fw-bold table-light"><td></td><td>Total</td><td class="text-end">' + fmt(total) + '</td><td class="text-end">100%</td></tr>';
}

// ==================== Schedule ====================

function collectChartParams() {
    return {
        mode: document.getElementById('chartMode').value,
        dimension: document.getElementById('dimension').value,
        metric: document.getElementById('metric').value,
        topN: document.getElementById('topN').value,
        chartType: document.getElementById('chartType').value,
        showOthers: document.getElementById('showOthers').checked ? '1' : '0',
        compareLastYear: document.getElementById('compareLastYear').checked ? '1' : '0',
        includeVat: document.getElementById('includeVat').checked ? '1' : '0',
        storeCodes: getSelectedStoreCodes(),
        itemsSelection: getItemsSelectionJson()
    };
}

// ===== Shared schedule partial API =====

// collectChartParams() defined above. Partial merges reportDateRange.
function collectScheduleParameters() {
    return collectChartParams();
}

function onScheduleParametersLoaded(p) {
    if (!p) return;
    function sv(id, val) { var el = document.getElementById(id); if (el && val != null) el.value = val; }
    function sc(id, val) { var el = document.getElementById(id); if (el && val != null) el.checked = !!val; }
    sv('chartMode',  p.mode);
    sv('dimension',  p.dimension);
    sv('metric',     p.metric);
    sv('topN',       p.topN);
    sv('chartType',  p.chartType);
    if (p.showOthers !== undefined) sc('showOthers', p.showOthers === '1' || p.showOthers === true);
    if (p.compareLastYear !== undefined) sc('compareLastYear', p.compareLastYear === '1' || p.compareLastYear === true);
    if (p.includeVat !== undefined) sc('includeVat', p.includeVat === '1' || p.includeVat === true);
    if (typeof onChartModeChange === 'function') onChartModeChange();
    if (p.itemsSelection && typeof reloadItemsSelectionFromJson === 'function') {
        try { reloadItemsSelectionFromJson(typeof p.itemsSelection === 'string' ? JSON.parse(p.itemsSelection) : p.itemsSelection); } catch(e) {}
    }
}

// autoSelectScheduleDateRange maps Charts radio-button presets to shared modal date range.
function autoSelectScheduleDateRange() {
    var preset = document.querySelector('input[name="DatePreset"]:checked');
    if (!preset) return;
    var map = {'ytd':'YearToDate','lastYear':'LastYear','thisMonth':'ThisMonth','lastMonth':'LastMonth','last7':'LastNDays_7','last30':'LastNDays_30'};
    var mapped = map[preset.value];
    if (!mapped) return;
    var sel = document.getElementById('schedDateRangeType');
    if (!sel) return;
    for (var i = 0; i < sel.options.length; i++) {
        var opt = sel.options[i];
        if (mapped.startsWith('LastNDays_')) {
            var days = mapped.split('_')[1];
            if (opt.value === 'LastNDays' && opt.getAttribute('data-value') === days) { sel.selectedIndex = i; break; }
        } else if (opt.value === mapped) { sel.selectedIndex = i; break; }
    }
    if (typeof onSchedDateRangeTypeChange === 'function') onSchedDateRangeTypeChange();
}

// ===== End shared schedule partial API =====
// Lazy load the layouts list the first time the dropdown opens + reset Save As modal
document.addEventListener('DOMContentLoaded', function() {
    var btn = document.getElementById('layoutsDropdownBtn');
    if (btn) {
        var loadedOnce = false;
        btn.addEventListener('show.bs.dropdown', function() {
            if (!loadedOnce) { loadedOnce = true; loadChartLayoutsList(); }
        });
    }
    var modalEl = document.getElementById('saveChartLayoutAsModal');
    if (modalEl) {
        modalEl.addEventListener('show.bs.modal', function() {
            document.getElementById('saveChartLayoutAsName').value = '';
            document.getElementById('saveChartLayoutAsPublic').checked = false;
            var alertEl = document.getElementById('saveChartLayoutAsAlert');
            if (alertEl) { alertEl.classList.add('d-none'); alertEl.textContent = ''; }
        });
    }
});

function showLayoutToast(msg, type) {
    var existing = document.getElementById('layoutToast');
    if (existing) existing.remove();
    var div = document.createElement('div');
    div.id = 'layoutToast';
    div.className = 'alert alert-' + type + ' alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow';
    div.style.zIndex = '11000';
    div.innerHTML = '<i class="bi bi-' + (type === 'success' ? 'check-circle' : 'exclamation-triangle') + ' me-1"></i>' + msg + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    document.body.appendChild(div);
    setTimeout(function() { if (div.parentNode) div.remove(); }, 4000);
}

// Apply saved layout on page load
@if (savedLayout != null && savedLayout.Count > 0)
{
    <text>
(function() {
    var saved = @Html.Raw(JsonSerializer.Serialize(savedLayout));
    if (saved.mode) document.getElementById('chartMode').value = saved.mode;
    if (saved.dimension) document.getElementById('dimension').value = saved.dimension;
    if (saved.metric) document.getElementById('metric').value = saved.metric;
    if (saved.topN) document.getElementById('topN').value = saved.topN;
    if (saved.chartType) document.getElementById('chartType').value = saved.chartType;
    if (saved.showOthers !== undefined) document.getElementById('showOthers').checked = saved.showOthers === '1';
    if (saved.compareLastYear !== undefined) document.getElementById('compareLastYear').checked = saved.compareLastYear === '1';
    if (saved.includeVat !== undefined) document.getElementById('includeVat').checked = saved.includeVat === '1';
    onChartModeChange();
})();
    </text>
}
</script>
}
