@section Scripts {
<script>
    const defaultDisplayCols = ['ItemCode','ItemName','Quantity','Value','Discount','NetValue','VatAmount','GrossAmount'];

    function getSelectedDisplayCols() {
        return document.getElementById('displayColumnsHidden').value
            .split(',').filter(c => c.length > 0);
    }

    function setSelectedDisplayCols(cols) {
        document.getElementById('displayColumnsHidden').value = cols.join(',');
    }

    function toggleDisplayCol(btn) {
        const col = btn.dataset.col;
        let cols = getSelectedDisplayCols();
        const idx = cols.findIndex(c => c.toLowerCase() === col.toLowerCase());
        if (idx >= 0) {
            cols.splice(idx, 1);
            btn.classList.remove('btn-primary');
            btn.classList.add('btn-outline-secondary');
            const icon = btn.querySelector('i');
            if (icon) icon.remove();
        } else {
            cols.push(col);
            btn.classList.remove('btn-outline-secondary');
            btn.classList.add('btn-primary');
            const icon = document.createElement('i');
            icon.className = 'bi bi-x-lg ms-1 small';
            btn.appendChild(icon);
        }
        setSelectedDisplayCols(cols);
    }

    function clearAllDisplayCols() {
        setSelectedDisplayCols([]);
        document.querySelectorAll('.display-col-btn').forEach(btn => {
            btn.classList.remove('btn-primary');
            btn.classList.add('btn-outline-secondary');
            const icon = btn.querySelector('i');
            if (icon) icon.remove();
        });
    }

    function resetDefaultDisplayCols() {
        clearAllDisplayCols();
        setSelectedDisplayCols([...defaultDisplayCols]);
        document.querySelectorAll('.display-col-btn').forEach(btn => {
            if (defaultDisplayCols.includes(btn.dataset.col)) {
                btn.classList.remove('btn-outline-secondary');
                btn.classList.add('btn-primary');
                const icon = document.createElement('i');
                icon.className = 'bi bi-x-lg ms-1 small';
                btn.appendChild(icon);
            }
        });
    }

    function clearPreset() {
        document.querySelectorAll('input[name="DatePreset"]').forEach(r => r.checked = false);
    }

    // Toggle between date-only and datetime-local inputs preserving the current value.
    // Browsers accept value in ISO (yyyy-MM-dd or yyyy-MM-ddTHH:mm) for those input types.
    function onUseDateTimeToggle(useTime) {
        var from = document.getElementById('DateFrom');
        var to = document.getElementById('DateTo');
        if (!from || !to) return;
        if (useTime) {
            var fv = (from.value || '').length >= 10 ? from.value.substring(0, 10) + 'T00:00' : from.value;
            var tv = (to.value || '').length >= 10 ? to.value.substring(0, 10) + 'T23:59' : to.value;
            from.type = 'datetime-local'; from.value = fv;
            to.type = 'datetime-local'; to.value = tv;
        } else {
            var fv2 = (from.value || '').substring(0, 10);
            var tv2 = (to.value || '').substring(0, 10);
            from.type = 'date'; from.value = fv2;
            to.type = 'date'; to.value = tv2;
        }
    }

    document.querySelectorAll('.date-presets input[type="radio"]').forEach(radio => {
        radio.addEventListener('change', function () {
            const today = new Date();
            let from, to;
            switch (this.value) {
                case 'today': from = to = today; break;
                case 'yesterday': from = to = new Date(today.getFullYear(), today.getMonth(), today.getDate() - 1); break;
                case 'last7': from = new Date(today.getFullYear(), today.getMonth(), today.getDate() - 6); to = today; break;
                case 'last30': from = new Date(today.getFullYear(), today.getMonth(), today.getDate() - 29); to = today; break;
                case 'thisMonth': from = new Date(today.getFullYear(), today.getMonth(), 1); to = today; break;
                case 'lastMonth': from = new Date(today.getFullYear(), today.getMonth() - 1, 1); to = new Date(today.getFullYear(), today.getMonth(), 0); break;
                case 'ytd': from = new Date(today.getFullYear(), 0, 1); to = today; break;
                case 'lastYear': from = new Date(today.getFullYear() - 1, 0, 1); to = new Date(today.getFullYear() - 1, 11, 31); break;
            }
            if (from && to) {
                document.getElementById('DateFrom').value = from.toISOString().split('T')[0];
                document.getElementById('DateTo').value = to.toISOString().split('T')[0];
            }
        });
    });

    // Cascading group selects
    const pg = document.getElementById('PrimaryGroup');
    const sg = document.getElementById('SecondaryGroup');
    const tg = document.getElementById('ThirdGroup');

    function cascade() {
        if (pg.value === '0') { sg.value = '0'; sg.disabled = true; tg.value = '0'; tg.disabled = true; }
        else { sg.disabled = false; }
        if (sg.value === '0') { tg.value = '0'; tg.disabled = true; }
        else { tg.disabled = false; }
    }

    pg.addEventListener('change', cascade);
    sg.addEventListener('change', cascade);
    cascade();

    function goToPage(p) {
        try { sessionStorage.setItem('catalogue_scroll', String(window.scrollY || 0)); } catch (e) {}
        document.getElementById('pageNumberHidden').value = p;
        document.getElementById('reportForm').submit();
    }

    // Sticky-sort: remember scroll position before submitting so the user
    // doesn't get bumped to the top when clicking a column header.
    document.querySelectorAll('th.sortable').forEach(th => {
        th.addEventListener('click', function () {
            const col = this.dataset.col;
            const curCol = document.getElementById('sortColumnHidden').value;
            const curDir = document.getElementById('sortDirectionHidden').value;
            document.getElementById('sortColumnHidden').value = col;
            document.getElementById('sortDirectionHidden').value = (col === curCol && curDir === 'ASC') ? 'DESC' : 'ASC';
            document.getElementById('pageNumberHidden').value = '1';
            try {
                const tableTop = document.getElementById('results');
                const y = tableTop ? (tableTop.getBoundingClientRect().top + window.scrollY) : (window.scrollY || 0);
                sessionStorage.setItem('catalogue_scroll', String(y));
                sessionStorage.setItem('catalogue_scroll_source', 'sort');
            } catch (e) {}
            document.getElementById('reportForm').submit();
        });
    });

    document.getElementById('reportForm').addEventListener('submit', function () {
        const btn = document.getElementById('generateBtn');
        btn.querySelector('.btn-text').classList.add('d-none');
        btn.querySelector('.spinner-border').classList.remove('d-none');
        btn.disabled = true;
