function onScheduleParametersLoaded(p) {
    if (!p) return;
    function sv(id, val) { var el = document.getElementById(id); if (el && val != null) el.value = val; }
    function sc(id, val) { var el = document.getElementById(id); if (el && val != null) el.checked = !!val; }
    sv('Breakdown',        p.breakdown);
    sv('GroupBy',          p.groupBy);
    sv('SecondaryGroupBy', p.secondaryGroupBy);
