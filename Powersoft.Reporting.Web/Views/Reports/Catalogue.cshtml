    function autoSelectScheduleDateRange() {
        var preset = document.querySelector('input[name="DatePreset"]:checked');
        if (!preset) return;
        var map = {
            'ytd': 'YearToDate', 'lastYear': 'LastYear', 'thisMonth': 'ThisMonth',
            'lastMonth': 'LastMonth', 'last7': 'LastNDays_7', 'last30': 'LastNDays_30'
        };
        var mapped = map[preset.value];
        if (!mapped) return;
        var sel = document.getElementById('schedDateRangeType');
        for (var i = 0; i < sel.options.length; i++) {
            var opt = sel.options[i];
            if (mapped.startsWith('LastNDays_')) {
                var days = mapped.split('_')[1];
                if (opt.value === 'LastNDays' && opt.getAttribute('data-value') === days) { sel.selectedIndex = i; return; }
            } else if (opt.value === mapped) { sel.selectedIndex = i; return; }
        }
    }

    function onSchedDateRangeTypeChange() {
        var sel = document.getElementById('schedDateRangeType');
        var isCustom = (sel.options[sel.selectedIndex].value === 'Custom');
        document.getElementById('schedCustomDateFromWrap').style.display = isCustom ? '' : 'none';
        document.getElementById('schedCustomDateToWrap').style.display = isCustom ? '' : 'none';
    }

    function onRecurrenceChange() {
        var type = document.getElementById('schedRecurrence').value;
        document.getElementById('schedDayContainer').style.display = 'none';
        document.getElementById('schedWeeklyDaysContainer').style.display = 'none';
        document.getElementById('schedMonthDayContainer').style.display = 'none';
        if (type === 'Weekly') document.getElementById('schedWeeklyDaysContainer').style.display = '';
        else if (type === 'Monthly') document.getElementById('schedMonthDayContainer').style.display = '';
    }

    function validateEmailList(input) {
        if (!input || !input.trim()) return { valid: false, emails: [], errors: ['Please enter at least one email address.'] };
        var emails = input.split(/[,;]/).map(function(e) { return e.trim(); }).filter(function(e) { return e.length > 0; });
        var re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
        var invalid = emails.filter(function(e) { return !re.test(e); });
        if (invalid.length > 0) return { valid: false, emails: emails, errors: invalid.map(function(e) { return 'Invalid: ' + e; }) };
        return { valid: true, emails: emails, errors: [] };
    }

    function collectCatalogueParams() {
        return {
            dateFrom: document.getElementById('DateFrom').value,
            dateTo: document.getElementById('DateTo').value,
            reportMode: document.getElementById('ReportMode').value,
            reportOn: document.getElementById('ReportOn').value,
            primaryGroup: document.getElementById('PrimaryGroup').value,
            secondaryGroup: document.getElementById('SecondaryGroup').value,
            thirdGroup: document.getElementById('ThirdGroup').value,
            displayColumns: document.getElementById('displayColumnsHidden').value || '',
            showProfit: document.getElementById('ShowProfit') ? document.getElementById('ShowProfit').checked : false,
            showStock: document.getElementById('ShowStock') ? document.getElementById('ShowStock').checked : false,
            storeCodes: document.getElementById('selectedStoreCodesHidden').value || '',
            itemsSelection: document.getElementById('itemsSelectionJsonHidden').value || '',
            sortColumn: document.getElementById('sortColumnHidden').value || 'ItemCode',
            sortDirection: document.getElementById('sortDirectionHidden').value || 'ASC'
        };
    }

    function saveSchedule() {
        var name = document.getElementById('schedName').value.trim();
        var recipients = document.getElementById('schedRecipients').value.trim();
        var alertDiv = document.getElementById('scheduleAlert');

        if (!name || !recipients) {
            alertDiv.innerHTML = '<div class="alert alert-warning mb-0">Please fill in schedule name and recipients.</div>';
            alertDiv.style.display = ''; return;
        }
        var ev = validateEmailList(recipients);
        if (!ev.valid) {
            alertDiv.innerHTML = '<div class="alert alert-warning mb-0">Invalid email address(es): ' + ev.errors.join('; ') + '</div>';
            alertDiv.style.display = ''; return;
        }

        var recurrence = document.getElementById('schedRecurrence').value;
        if (recurrence === 'Once') {
            var startDate = document.getElementById('schedStartDate').value;
            var today = new Date().toISOString().slice(0, 10);
            if (!startDate || startDate < today) {
                alertDiv.innerHTML = '<div class="alert alert-warning mb-0">For "Run once", start date must be today or in the future.</div>';
                alertDiv.style.display = ''; return;
            }
        }

        var day = (recurrence === 'Monthly') ? parseInt(document.getElementById('schedMonthDay').value, 10) : null;

        var fd = new FormData();
        fd.append('scheduleName', name);
        fd.append('recurrenceType', recurrence);
        if (day !== null && !isNaN(day)) fd.append('recurrenceDay', day);
        fd.append('scheduleTime', document.getElementById('schedTime').value);
        fd.append('exportFormat', document.getElementById('schedFormat').value);
        fd.append('recipients', recipients);
        fd.append('emailSubject', document.getElementById('schedSubject').value);
        fd.append('includeAiAnalysis', document.getElementById('schedIncludeAi').checked);
        fd.append('aiLocale', document.getElementById('schedAiLocale').value);
        fd.append('skipIfEmpty', document.getElementById('schedSkipIfEmpty').checked);

        var dsel = document.getElementById('schedDateRangeType');
        var dopt = dsel.options[dsel.selectedIndex];
        var reportDateRange = { type: dopt.value };
        if (reportDateRange.type === 'LastNDays') reportDateRange.value = parseInt(dopt.getAttribute('data-value') || '7', 10);
        else if (reportDateRange.type === 'Custom') {
            reportDateRange.dateFrom = document.getElementById('schedDateFrom').value;
            reportDateRange.dateTo = document.getElementById('schedDateTo').value;
        }

        var params = collectCatalogueParams();
        params.reportDateRange = reportDateRange;
        fd.append('parametersJson', JSON.stringify(params));

        var startDateSc = document.getElementById('schedStartDate').value || new Date().toISOString().slice(0, 10);
        var recurrenceJson = {
            type: recurrence,
            time: document.getElementById('schedTime').value,
            range: { startDate: startDateSc, noEndDate: true }
        };
        if (recurrence === 'Weekly') {
            var days = [];
            document.querySelectorAll('.sched-dow:checked').forEach(function(cb) { days.push(parseInt(cb.value, 10)); });
            recurrenceJson.pattern = { interval: 1, daysOfWeek: days.length ? days : [1] };
        } else if (recurrence === 'Monthly') {
            recurrenceJson.pattern = { dayOfMonth: day !== null ? day : 1 };
        }
        fd.append('recurrenceJson', JSON.stringify(recurrenceJson));

        fetch('@Url.Action("SaveCatalogueSchedule", "Reports")', { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    alertDiv.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle me-1"></i>' + data.message + '</div>';
                    alertDiv.style.display = '';
                    document.getElementById('schedName').value = '';
                    loadExistingSchedules();
                } else {
                    alertDiv.innerHTML = '<div class="alert alert-danger mb-0">' + data.message + '</div>';
                    alertDiv.style.display = '';
                }
            })
            .catch(function() {
                alertDiv.innerHTML = '<div class="alert alert-danger mb-0">Network error. Please try again.</div>';
                alertDiv.style.display = '';
            });
    }

    function loadExistingSchedules() {
        fetch('@Url.Action("GetCatalogueSchedules", "Reports")')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var c = document.getElementById('existingSchedules');
                if (!data || data.length === 0) { c.innerHTML = '<em>No schedules configured yet.</em>'; return; }
                var html = '<table class="table table-sm mb-0"><thead><tr><th>Name</th><th>Recurrence</th><th>Format</th><th>Time</th><th>Next Run</th></tr></thead><tbody>';
                data.forEach(function(s) {
                    html += '<tr><td>' + s.scheduleName + '</td><td>' + s.recurrenceType + '</td><td>' + s.exportFormat + '</td><td>' + s.scheduleTime + '</td><td>' + (s.nextRun || '-') + '</td></tr>';
                });
                html += '</tbody></table>';
                c.innerHTML = html;
            })
            .catch(function() { document.getElementById('existingSchedules').innerHTML = '<em>Could not load schedules.</em>'; });
    }

