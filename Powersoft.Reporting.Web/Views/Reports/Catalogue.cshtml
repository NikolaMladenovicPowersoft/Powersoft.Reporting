            + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Unit Price</th>'
            + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Discount</th>'
            + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Net</th>'
            + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">VAT</th>'
            + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Gross</th>'
            + '</tr></thead><tbody>'
            + d.lines.map(function (l) {
                return '<tr>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;font-weight:600">' + l.itemCode + '</td>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9">' + l.itemName + '</td>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">' + l.qty.toLocaleString(undefined, { maximumFractionDigits: 2 }) + '</td>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">' + fmt2(l.price) + '</td>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">' + fmt2(l.discount) + '</td>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">' + fmt2(l.net) + '</td>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">' + fmt2(l.vat) + '</td>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">' + fmt2(l.gross) + '</td>'
                    + '</tr>';
            }).join('')
            + '</tbody><tfoot><tr style="font-weight:700;border-top:3px double #1e293b;background:#f1f5f9">'
            + '<td colspan="5" style="padding:8px 10px;text-align:right">Totals</td>'
            + '<td style="padding:8px 10px;text-align:right">' + fmt2(d.totalNet) + '</td>'
            + '<td style="padding:8px 10px;text-align:right">' + fmt2(d.totalVat) + '</td>'
            + '<td style="padding:8px 10px;text-align:right">' + fmt2(d.totalGross) + '</td>'
            + '</tr></tfoot></table>'
            + '<div style="text-align:center;margin-top:24px;padding-top:12px;border-top:1px solid #e2e8f0;font-size:10px;color:#94a3b8">Powersoft Reporting</div>';
    }

    function toggleDocView() {
        if (!_currentDocData) return;
        if (_docViewMode === 'compact') {
            document.getElementById('docCompactView').classList.add('d-none');
            var fv = document.getElementById('docFullView');
            fv.innerHTML = buildFullViewHtml(_currentDocData);
            fv.classList.remove('d-none');
            document.getElementById('btnDocToggleView').innerHTML = '<i class="bi bi-eye-slash me-1"></i>Compact';
            _docViewMode = 'full';
        } else {
            document.getElementById('docFullView').classList.add('d-none');
            document.getElementById('docCompactView').classList.remove('d-none');
            document.getElementById('btnDocToggleView').innerHTML = '<i class="bi bi-eye me-1"></i>Preview';
            _docViewMode = 'compact';
        }
    }

    function printDocFromModal() {
        if (!_currentDocData) return;
        var printWin = window.open('', '_blank', 'width=900,height=700');
        printWin.document.write('<html><head><title>' + _currentDocData.docTypeDescription + ' — ' + _currentDocData.documentNumber + '</title>'
            + '<style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:Segoe UI,system-ui,sans-serif;padding:24px;color:#1e293b}</style>'
            + '</head><body>' + buildFullViewHtml(_currentDocData) + '</body></html>');
        printWin.document.close();
        printWin.focus();
        printWin.print();
    }

    function openDocument(docType, docNumber) {
        _currentDocType = docType;
        _currentDocNumber = docNumber;
        _currentDocData = null;
        _docViewMode = 'compact';
        document.getElementById('docFullView').classList.add('d-none');
        document.getElementById('docFullView').innerHTML = '';
        document.getElementById('btnDocToggleView').innerHTML = '<i class="bi bi-eye me-1"></i>Preview';
        var modal = new bootstrap.Modal(document.getElementById('docDetailModal'));
        var hdr = document.getElementById('docDetailHeader');
        var isPurch = (docType === 'P' || docType === 'E');
        hdr.className = 'modal-header ' + (isPurch ? 'bg-primary bg-opacity-10' : 'bg-success bg-opacity-10');

        document.getElementById('docDetailLoading').classList.remove('d-none');
        document.getElementById('docDetailError').classList.add('d-none');
        document.getElementById('docCompactView').classList.add('d-none');

        var typeNames = { P: 'Purchase Invoice', E: 'Purchase Return', I: 'Sales Invoice', C: 'Credit Note' };
        document.getElementById('docDetailTitle').innerHTML =
            '<i class="bi bi-file-earmark-text me-2"></i>' + (typeNames[docType] || 'Document') + ' — ' + docNumber;

        modal.show();

        fetch('/Reports/GetDocumentDetail?docType=' + encodeURIComponent(docType) + '&docNumber=' + encodeURIComponent(docNumber))
            .then(function (r) { return r.json(); })
            .then(function (data) {
                document.getElementById('docDetailLoading').classList.add('d-none');
                if (!data.success) {
                    document.getElementById('docDetailError').classList.remove('d-none');
                    document.getElementById('docDetailError').textContent = data.message;
                    return;
                }
                var d = data.doc;
                document.getElementById('docDate').textContent = d.date;
                document.getElementById('docStore').textContent = d.storeCode || '—';
                document.getElementById('docEntity').textContent = d.entityCode ? (d.entityCode + ' — ' + d.entityName) : (d.entityName || '—');

                var fmt2 = function (v) { return (v || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }); };
                var tbody = document.getElementById('docDetailLines');
                tbody.innerHTML = d.lines.map(function (l) {
                    return '<tr>'
                        + '<td class="fw-semibold">' + l.itemCode + '</td>'
                        + '<td>' + l.itemName + '</td>'
                        + '<td class="text-end">' + l.qty.toLocaleString(undefined, { maximumFractionDigits: 2 }) + '</td>'
                        + '<td class="text-end">' + fmt2(l.price) + '</td>'
                        + '<td class="text-end">' + fmt2(l.discount) + '</td>'
                        + '<td class="text-end">' + fmt2(l.net) + '</td>'
                        + '<td class="text-end">' + fmt2(l.vat) + '</td>'
                        + '<td class="text-end">' + fmt2(l.gross) + '</td>'
                        + '</tr>';
                }).join('');

                document.getElementById('docTotalNet').textContent = fmt2(d.totalNet);
                document.getElementById('docTotalVat').textContent = fmt2(d.totalVat);
                document.getElementById('docTotalGross').textContent = fmt2(d.totalGross);
                document.getElementById('docLineCount').textContent = d.lineCount + ' line item(s)';

                _currentDocData = d;
                document.getElementById('docCompactView').classList.remove('d-none');
            })
            .catch(function (err) {
                document.getElementById('docDetailLoading').classList.add('d-none');
                document.getElementById('docDetailError').classList.remove('d-none');
                document.getElementById('docDetailError').textContent = 'Network error: ' + err.message;
            });
    }

    // Report Title — sync input to results header
    (function () {
        var inp = document.getElementById('ReportTitle');
        var hdr = document.getElementById('resultsTitle');
        if (inp && hdr) {
            inp.addEventListener('input', function () {
                hdr.textContent = inp.value || 'Results';
            });
        }
    })();

    // Show/Hide Selections panel
    (function () {
        var btn = document.getElementById('toggleSelectionsBtn');
        var panel = document.getElementById('selectionsPanel');
        if (!btn || !panel) return;

        function buildSelections() {
            var parts = [];
            var f = document.getElementById('DateFrom');
            var t = document.getElementById('DateTo');
            if (f && t) parts.push({ label: 'Period', value: f.value + ' \u2013 ' + t.value });

            var rm = document.querySelector('[name="ReportMode"]');
            if (rm) parts.push({ label: 'Mode', value: rm.options[rm.selectedIndex].text });
            var ro = document.querySelector('[name="ReportOn"]');
            if (ro) parts.push({ label: 'Report On', value: ro.options[ro.selectedIndex].text });

            ['PrimaryGroup', 'SecondaryGroup', 'ThirdGroup'].forEach(function (id) {
                var el = document.getElementById(id);
                if (el && el.value !== '0') parts.push({ label: id.replace(/Group$/, ' Group'), value: el.options[el.selectedIndex].text });
            });

            var ct = document.querySelector('[name="CostType"]');
            if (ct) parts.push({ label: 'Cost', value: ct.options[ct.selectedIndex].text });

            var cont = document.getElementById('selectionsContent');
            cont.innerHTML = parts.map(function (p) {
                return '<span class="badge bg-primary bg-opacity-10 text-primary border px-2 py-1">'
                    + '<strong>' + p.label + ':</strong> ' + p.value + '</span>';
            }).join('');
        }

        btn.addEventListener('click', function () {
            if (panel.style.display === 'none') {
                buildSelections();
                panel.style.display = '';
                btn.classList.add('active');
            } else {
                panel.style.display = 'none';
                btn.classList.remove('active');
            }
        });
    })();
</script>
}
