@using Powersoft.Reporting.Core.Models
@using System.Text.Json
@{
    ViewData["Title"] = "Charts & Dashboards";
    var stores = ViewBag.Stores as List<Store> ?? new List<Store>();
    var dbName = ViewBag.ConnectedDatabase as string ?? "Unknown";
    var storesJson = JsonSerializer.Serialize(stores.Select(s => new { s.StoreCode, s.StoreName }));
    bool canSchedule = ViewBag.CanSchedule as bool? ?? false;
    bool hasSavedLayout = ViewBag.HasSavedLayout as bool? ?? false;
    var savedLayout = ViewBag.SavedLayout as Dictionary<string, string>;
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-start">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">Reports</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">Stock Control</a></li>
                    <li class="breadcrumb-item active">Charts & Dashboards</li>
                </ol>
            </nav>
            <h2 class="mb-0">
                <i class="bi bi-pie-chart me-2 text-primary"></i>Charts & Dashboards
            </h2>
            <p class="text-muted mb-0">Visual data exploration — @dbName</p>
        </div>
        <div class="mt-3">
            @await Html.PartialAsync("_TutorialButton", ("Charts", ""))
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-funnel me-2"></i>Chart Parameters
    </div>
    <div class="card-body">
        <form id="chartForm">
            <div class="row mb-3">
                <div class="col-12">
                    <label class="form-label fw-semibold mb-2">Quick Date Selection</label>
                    <div class="date-presets btn-group flex-wrap" role="group">
                        <input type="radio" class="btn-check" name="DatePreset" id="presetToday" value="today" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetToday">Today</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetYesterday" value="yesterday" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetYesterday">Yesterday</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLast7" value="last7" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLast7">Last 7 Days</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLast30" value="last30" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLast30">Last 30 Days</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetThisMonth" value="thisMonth" autocomplete="off" checked>
                        <label class="btn btn-outline-secondary btn-sm" for="presetThisMonth">This Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastMonth" value="lastMonth" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLastMonth">Last Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetYTD" value="ytd" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetYTD">Year to Date</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastYear" value="lastYear" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLastYear">Last Year</label>
                    </div>
                </div>
            </div>

            <hr class="my-3">

            <div class="row g-3 mb-3 align-items-end">
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date From</label>
                    <input type="date" class="form-control" id="dateFrom" onchange="clearPreset()"
                           value="@DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date To</label>
                    <input type="date" class="form-control" id="dateTo" onchange="clearPreset()"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Chart On</label>
                    <select class="form-select" id="chartMode" onchange="onChartModeChange()">
                        <option value="Sales">Sales</option>
                        <option value="SalesVsReturns">Sales vs Returns</option>
                        <option value="Purchases">Purchases</option>
                        <option value="PurchasesVsReturns">Purchases vs Returns</option>
                        <option value="SalesVsPurchases">Sales vs Purchases</option>
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Group By</label>
                    <select class="form-select" id="dimension">
                        <option value="Category">Category</option>
                        <option value="Store">Store / Shop</option>
                        <option value="Brand">Brand</option>
                        <option value="Customer">Customer</option>
                        <option value="Item">Item</option>
                        <option value="Supplier">Supplier</option>
                        <option value="Department">Department</option>
                        <option value="Season">Season</option>
                        <option value="Agent">Agent</option>
                        <option value="User">User</option>
                        <option value="CSAgent">Customer/Supplier Agent</option>
                        <optgroup label="MODA">
                            <option value="Model">Model</option>
                            <option value="Colour">Colour</option>
                            <option value="Size">Size</option>
                            <option value="SizeGroup">Size Group</option>
                            <option value="Fabric">Fabric</option>
                        </optgroup>
                        <optgroup label="Attributes">
                            <option value="Attr1">Attribute 1</option>
                            <option value="Attr2">Attribute 2</option>
                            <option value="Attr3">Attribute 3</option>
                            <option value="Attr4">Attribute 4</option>
                            <option value="Attr5">Attribute 5</option>
                            <option value="Attr6">Attribute 6</option>
                        </optgroup>
                        <optgroup label="Customer Categories">
                            <option value="CustCat1">Customer Category 1</option>
                            <option value="CustCat2">Customer Category 2</option>
                            <option value="CustCat3">Customer Category 3</option>
                        </optgroup>
                        <optgroup label="Time Analysis">
                            <option value="HourOfDay">Rush Hours (Hour of Day)</option>
                        </optgroup>
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Metric</label>
                    <select class="form-select" id="metric">
                        <option value="Value">Value (€)</option>
                        <option value="Quantity">Quantity</option>
                        <option value="Count">No. of Transactions</option>
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Top N</label>
                    <select class="form-select" id="topN">
                        <option value="5">Top 5</option>
                        <option value="10" selected>Top 10</option>
                        <option value="15">Top 15</option>
                        <option value="20">Top 20</option>
                    </select>
                </div>
            </div>

            <div class="row g-3 mb-3 align-items-end">
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Chart Type</label>
                    <select class="form-select" id="chartType">
                        <option value="pie">Pie Chart</option>
                        <option value="doughnut">Doughnut</option>
                        <option value="bar">Bar Chart</option>
                        <option value="horizontalBar">Horizontal Bar</option>
                    </select>
                </div>
            </div>

            <div class="row g-3 mb-4 align-items-end">
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="showOthers" checked>
                        <label class="form-check-label" for="showOthers">Show Others</label>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="compareLastYear">
                        <label class="form-check-label" for="compareLastYear">Compare with Last Year</label>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="includeVat">
                        <label class="form-check-label" for="includeVat">Include VAT</label>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="showDataLabels">
                        <label class="form-check-label" for="showDataLabels">Show Data Labels</label>
                    </div>
                </div>
                <div class="col-auto" id="labelPositionGroup" style="display:none;">
                    <select class="form-select form-select-sm" id="labelPosition" style="width:auto;">
                        <option value="auto">Auto</option>
                        <option value="inside">Inside</option>
                        <option value="outside">Outside</option>
                    </select>
                </div>
            </div>

            <div class="report-form-actions d-flex flex-wrap gap-2 pt-2 border-top">
                <button type="button" class="btn btn-primary btn-lg" onclick="loadChart()" id="generateBtn">
                    <i class="bi bi-play-fill me-2"></i>Generate Chart
                </button>
                @if (canSchedule)
                {
                    <button type="button" class="btn btn-warning btn-lg" data-bs-toggle="modal" data-bs-target="#scheduleModal" title="Schedule recurring report delivery">
                        <i class="bi bi-clock-history me-2"></i>Schedule
                    </button>
                }
                <div class="btn-group ms-auto">
                    <div class="btn-group">
                        <button type="button" class="btn btn-outline-info dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false"
                                title="Saved report layouts" id="layoutsDropdownBtn">
                            <i class="bi bi-bookmark me-1"></i><span id="layoutsCurrentName">Layouts</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" id="layoutsDropdownMenu" style="min-width: 320px;">
                            <li><h6 class="dropdown-header">Loading...</h6></li>
                        </ul>
                    </div>
                    <button type="button" class="btn btn-outline-info" onclick="saveCurrentLayout()" title="Overwrite your default layout with current parameters">
                        <i class="bi bi-save me-1"></i>Save
                    </button>
                    <button type="button" class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#saveChartLayoutAsModal"
                            title="Save current parameters as a new named layout (optionally shared with all users)">
                        <i class="bi bi-bookmark-plus me-1"></i>Save as...
                    </button>
                    @if (hasSavedLayout)
                    {
                        <button type="button" class="btn btn-outline-secondary" onclick="resetSavedLayout()" title="Discard your saved default layout and restore factory defaults">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Default
                        </button>
                    }
                </div>
            </div>
            @if (hasSavedLayout)
            {
                <div class="mt-2"><small class="text-info"><i class="bi bi-check-circle me-1"></i>Saved layout loaded</small></div>
            }
        </form>
    </div>
</div>

@await Html.PartialAsync("_ItemsSelection", new ItemsSelectionConfig
{
    ShowCategories = true,
    ShowDepartments = true,
    ShowBrands = true,
    ShowSeasons = true,
    ShowSuppliers = true,
    ShowCustomers = false,
    ShowStores = true,
    StoresJson = storesJson,
    ReportType = "Charts"
})

<div id="chartLoading" class="text-center py-5 d-none">
    <div class="spinner-border text-primary"></div>
    <p class="text-muted mt-2">Loading chart data...</p>
</div>
<div id="chartError" class="alert alert-danger d-none"></div>

<div id="chartArea" class="d-none">
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-bar-chart me-2"></i>Chart Results</span>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <div class="btn-group btn-group-sm" id="exportGroup">
                    <button type="button" class="btn btn-outline-success" onclick="exportChart('excel')" title="Export to Excel">
                        <i class="bi bi-file-earmark-spreadsheet me-1"></i>Excel
                    </button>
                    <button type="button" class="btn btn-outline-secondary" onclick="exportChart('csv')" title="Export to CSV">
                        <i class="bi bi-filetype-csv me-1"></i>CSV
                    </button>
                    <button type="button" class="btn btn-outline-danger" onclick="exportChart('pdf')" title="Export to PDF">
                        <i class="bi bi-filetype-pdf me-1"></i>PDF
                    </button>
                </div>
                <button class="btn btn-sm btn-outline-primary" onclick="openSendEmailModal()" title="Send report via email">
                    <i class="bi bi-envelope me-1"></i>Send to Email
                </button>
                <button class="btn btn-sm btn-outline-info" id="aiAnalyzeBtn" onclick="analyzeChart()">
                    <i class="bi bi-stars me-1"></i>AI Analyze
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-lg-8">
                    <div style="position:relative;height:500px;">
                        <canvas id="mainChart"></canvas>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header small fw-semibold py-2">
                            <i class="bi bi-table me-1"></i>Data Summary
                        </div>
                        <div class="card-body p-0" style="max-height:460px;overflow-y:auto;">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light sticky-top">
                                    <tr class="small">
                                        <th>#</th>
                                        <th>Label</th>
                                        <th class="text-end">Value</th>
                                        <th class="text-end">%</th>
                                    </tr>
                                </thead>
                                <tbody id="dataSummary" class="small"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="emptyState" class="text-center py-5 text-muted">
    <i class="bi bi-pie-chart" style="font-size:3rem;opacity:0.3;"></i>
    <p class="mt-3">Select your parameters and click <strong>Generate Chart</strong> to begin.</p>
</div>

<!-- AI Analysis Modal -->
<div class="modal fade" id="aiAnalysisModal" tabindex="-1" aria-labelledby="aiAnalysisModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header" style="background:linear-gradient(135deg,#6366f1 0%,#8b5cf6 100%);color:white;">
                <h5 class="modal-title" id="aiAnalysisModalLabel">
                    <i class="bi bi-stars me-2"></i>AI Business Intelligence
                </h5>
                <div class="ms-auto me-3 d-flex align-items-center gap-2">
                    <select id="aiPromptTemplateSelect" class="form-select form-select-sm" style="width:auto;min-width:140px;background:rgba(255,255,255,0.15);color:white;border-color:rgba(255,255,255,0.3);" title="AI Prompt Template" onchange="this.setAttribute('data-user-picked','1')">
                        <option value="0" style="color:#333;">Default Prompt</option>
                    </select>
                    <button type="button" class="btn btn-sm btn-outline-light" onclick="togglePromptEditor()" title="Manage AI prompt templates" style="border-color:rgba(255,255,255,0.3);">
                        <i class="bi bi-gear"></i>
                    </button>
                    <label class="me-1 mb-0 small opacity-75" for="aiLangSelect"><i class="bi bi-translate"></i></label>
                    <select id="aiLangSelect" class="form-select form-select-sm" style="width:auto;min-width:120px;background:rgba(255,255,255,0.15);color:white;border-color:rgba(255,255,255,0.3);" onchange="saveAiLang(this.value)">
                        <option value="el" style="color:#333;">Ελληνικά</option>
                        <option value="en" style="color:#333;">English</option>
                        <option value="sr" style="color:#333;">Srpski</option>
                        <option value="de" style="color:#333;">Deutsch</option>
                        <option value="fr" style="color:#333;">Français</option>
                        <option value="bg" style="color:#333;">Български</option>
                        <option value="ru" style="color:#333;">Русский</option>
                        <option value="uk" style="color:#333;">Українська</option>
                        <option value="et" style="color:#333;">Eesti</option>
                        <option value="nl" style="color:#333;">Nederlands</option>
                    </select>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div id="aiLoading" class="text-center py-5">
                    <div class="spinner-grow text-primary mb-2" style="width:3rem;height:3rem;"></div>
                    <h6 class="mt-3 text-muted">AI is analyzing your chart data...</h6>
                    <p class="text-muted small">Identifying patterns, trends, and actionable insights</p>
                    <div class="progress mx-auto" style="width:200px;height:4px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" style="width:100%"></div>
                    </div>
                </div>
                <div id="aiError" class="d-none p-4">
                    <div class="alert alert-danger" id="aiErrorMsg"></div>
                </div>
                <div id="aiPromptEditor" class="d-none border-bottom" style="background:#f8fafc;">
                    <div class="p-4">
                        <h6 class="mb-3"><i class="bi bi-pencil-square me-1"></i>AI Prompt Templates</h6>
                        <div class="row g-3">
                            <div class="col-md-5">
                                <label class="form-label small fw-semibold">Template Name</label>
                                <input type="text" class="form-control form-control-sm" id="aiPromptName" placeholder="e.g. Focus on top categories">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-semibold">Applies to</label>
                                <select class="form-select form-select-sm" id="aiPromptReportType">
                                    <option value="">All Reports</option>
                                    <option value="AverageBasket">Average Basket</option>
                                    <option value="PurchasesSales">Purchases vs Sales</option>
                                    <option value="Charts">Charts</option>
                                </select>
                            </div>
                            <div class="col-md-3 d-flex align-items-end">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="aiPromptIsDefault">
                                    <label class="form-check-label small" for="aiPromptIsDefault">Set as default</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-semibold">System Prompt</label>
                                <textarea class="form-control form-control-sm" id="aiPromptText" rows="6" placeholder="You are a senior data analyst..."></textarea>
                                <small class="text-muted">This prompt will be sent to the AI as the system instruction.</small>
                            </div>
                            <div class="col-12 d-flex gap-2">
                                <button class="btn btn-sm btn-primary" onclick="saveAiPromptTemplate()"><i class="bi bi-save me-1"></i>Save Template</button>
                                <button class="btn btn-sm btn-outline-secondary" onclick="clearPromptEditor()">Clear</button>
                                <div id="aiPromptAlert" class="ms-2 small align-self-center"></div>
                            </div>
                        </div>
                        <hr class="my-3">
                        <div id="aiPromptTemplatesList" class="small text-muted">Loading templates...</div>
                    </div>
                </div>
                <div id="aiResults" class="d-none">
                    <div id="aiHealthBanner" class="px-4 py-3 d-flex align-items-center justify-content-between" style="background:#f8fafc;border-bottom:1px solid #e2e8f0;">
                        <div class="d-flex align-items-center gap-3">
                            <div id="aiHealthBadge" class="d-flex flex-column align-items-center justify-content-center rounded-circle" style="width:64px;height:64px;font-weight:700;font-size:1.2rem;"></div>
                            <div>
                                <div class="fw-bold" id="aiHealthLabel" style="font-size:1.1rem;"></div>
                                <div class="text-muted small" id="aiTrendDesc"></div>
                            </div>
                        </div>
                        <div id="aiTrendBadge" class="badge fs-6 px-3 py-2"></div>
                    </div>
                    <div class="p-4">
                        <div class="alert border-start border-4 border-primary bg-primary bg-opacity-10 mb-4" id="aiExecSummary" style="font-size:0.95rem;"></div>
                        <div class="row g-2 mb-4" id="aiKpis"></div>
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-header bg-transparent border-0 pb-0">
                                        <h6 class="mb-0"><i class="bi bi-lightbulb-fill text-warning me-2"></i>Key Findings</h6>
                                    </div>
                                    <div class="card-body pt-2" id="aiKeyFindings"></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-header bg-transparent border-0 pb-0">
                                        <h6 class="mb-0"><i class="bi bi-check2-circle text-success me-2"></i>Recommendations</h6>
                                    </div>
                                    <div class="card-body pt-2" id="aiRecs"></div>
                                </div>
                            </div>
                        </div>
                        <div class="row g-4 mt-1">
                            <div class="col-md-6" id="aiTopSection">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-header bg-transparent border-0 pb-0">
                                        <h6 class="mb-0"><i class="bi bi-trophy-fill text-warning me-2"></i>Top Performers</h6>
                                    </div>
                                    <div class="card-body pt-2" id="aiTopPerformers"></div>
                                </div>
                            </div>
                            <div class="col-md-6" id="aiBottomSection">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-header bg-transparent border-0 pb-0">
                                        <h6 class="mb-0"><i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>Needs Attention</h6>
                                    </div>
                                    <div class="card-body pt-2" id="aiBottomPerformers"></div>
                                </div>
                            </div>
                        </div>
                        <div id="aiAlertsSection" class="mt-4"></div>
                    </div>
                    <div class="px-4 py-2 d-flex justify-content-between align-items-center" style="background:#f8fafc;border-top:1px solid #e2e8f0;">
                        <span class="text-muted small"><i class="bi bi-cpu me-1"></i><span id="aiModel"></span></span>
                        <span class="text-muted small"><i class="bi bi-currency-dollar me-1"></i><span id="aiTokens"></span></span>
                        <span class="text-muted small"><i class="bi bi-clock me-1"></i><span id="aiTime"></span></span>
                    </div>
                    <div class="border-top" style="background:#f8fafc;">
                        <div class="px-4 py-2">
                            <h6 class="mb-2 text-muted"><i class="bi bi-chat-dots me-1"></i>Follow-up Questions</h6>
                        </div>
                        <div id="aiChatMessages" class="px-4" style="max-height:300px;overflow-y:auto;"></div>
                        <div class="px-4 py-3">
                            <div class="input-group">
                                <input type="text" class="form-control" id="aiChatInput" placeholder="Ask a follow-up question about this chart..."
                                       onkeydown="if(event.key==='Enter'){event.preventDefault();sendAiChat();}">
                                <button class="btn btn-primary" type="button" onclick="sendAiChat()" id="btnSendChat">
                                    <i class="bi bi-send"></i>
                                </button>
                            </div>
                            <div id="aiChatTokenInfo" class="text-muted small mt-1" style="display:none;"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn text-white" style="background:linear-gradient(135deg,#6366f1,#8b5cf6);" onclick="analyzeChart()" id="btnReanalyze" style="display:none;">
                    <i class="bi bi-arrow-clockwise me-1"></i>Re-analyze
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Schedule Modal -->
<div class="modal fade" id="scheduleModal" tabindex="-1" aria-labelledby="scheduleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="scheduleModalLabel">
                    <i class="bi bi-clock-history me-2"></i>Schedule Chart Report
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-light border mb-3 py-2">
                    <small class="text-muted">
                        <i class="bi bi-info-circle me-1"></i>
                        The chart report will run automatically and recipients will receive an email with the exported file.
                    </small>
                </div>

                <h6 class="text-muted mb-2"><i class="bi bi-funnel me-1"></i>Parameters (current selection)</h6>
                <div class="bg-light rounded p-2 mb-3 small" id="schedParamsSummary"></div>

                <h6 class="text-muted mb-2"><i class="bi bi-calendar-range me-1"></i>Report date range</h6>
                <p class="small text-muted mb-2">Computed when the schedule runs (e.g. last 7 days from run date).</p>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Period type</label>
                        <select class="form-select" id="schedDateRangeType" onchange="onSchedDateRangeTypeChange()">
                            <option value="LastNDays" data-value="7">Last 7 days</option>
                            <option value="LastNDays" data-value="30">Last 30 days</option>
                            <option value="ThisMonth">This month (to today)</option>
                            <option value="LastMonth">Last month</option>
                            <option value="YearToDate">Year to date</option>
                            <option value="LastYear">Last year</option>
                            <option value="Custom">Custom (fixed dates)</option>
                        </select>
                    </div>
                    <div class="col-md-3" id="schedCustomDateFromWrap" style="display:none;">
                        <label class="form-label fw-semibold">From</label>
                        <input type="date" class="form-control" id="schedDateFrom" value="@DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd")">
                    </div>
                    <div class="col-md-3" id="schedCustomDateToWrap" style="display:none;">
                        <label class="form-label fw-semibold">To</label>
                        <input type="date" class="form-control" id="schedDateTo" value="@DateTime.Today.ToString("yyyy-MM-dd")">
                    </div>
                </div>

                <h6 class="text-muted mb-2"><i class="bi bi-gear me-1"></i>Schedule settings</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Schedule Name</label>
                        <input type="text" class="form-control" id="schedName" placeholder="e.g. Weekly Sales Charts" required>
                        <input type="hidden" id="schedId" value="">
                        <small class="text-muted">A label to identify this schedule in the list</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Export Format</label>
                        <select class="form-select" id="schedFormat">
                            <option value="Excel">Excel (.xlsx)</option>
                            <option value="PDF">PDF</option>
                            <option value="CSV">CSV</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Recurrence</label>
                        <select class="form-select" id="schedRecurrence" onchange="onRecurrenceChange()">
                            <option value="Once">Run Once</option>
                            <option value="Daily" selected>Daily</option>
                            <option value="Weekly">Weekly</option>
                            <option value="Monthly">Monthly</option>
                        </select>
                    </div>
                    <div class="col-md-4" id="schedWeeklyDaysContainer" style="display:none;">
                        <label class="form-label fw-semibold">Days of week</label>
                        <div class="d-flex flex-wrap gap-2">
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="1"> Mon</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="2"> Tue</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="3"> Wed</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="4"> Thu</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="5"> Fri</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="6"> Sat</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="0"> Sun</label>
                        </div>
                    </div>
                    <div class="col-md-4" id="schedMonthDayContainer" style="display:none;">
                        <label class="form-label fw-semibold">Day of month</label>
                        <select class="form-select" id="schedMonthDay">
                            @for (var i = 1; i <= 28; i++) { <option value="@i">@i</option> }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Time</label>
                        <input type="time" class="form-control" id="schedTime" value="08:00">
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Start date (recurrence)</label>
                        <input type="date" class="form-control" id="schedStartDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" min="@DateTime.Today.ToString("yyyy-MM-dd")" style="max-width:12rem;">
                    </div>
                    <div class="col-12 mt-2">
                        <h6 class="text-muted mb-2"><i class="bi bi-envelope me-1"></i>Recipients</h6>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Email addresses</label>
                        <input type="text" class="form-control" id="schedRecipients" placeholder="user@@company.com, manager@@company.com">
                        <small class="text-muted">Separate multiple addresses with commas</small>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Email Subject <span class="text-muted fw-normal">(optional)</span></label>
                        <input type="text" class="form-control" id="schedSubject" placeholder="Charts & Dashboards Report - {date}">
                    </div>
                    <div class="col-12 mt-3">
                        <h6 class="text-muted mb-2"><i class="bi bi-stars me-1"></i>AI Analysis</h6>
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="schedSkipIfEmpty">
                            <label class="form-check-label fw-semibold" for="schedSkipIfEmpty">Don't send if empty</label>
                        </div>
                        <small class="text-muted d-block mb-3">When enabled, the email will not be sent if the report returns 0 data points.</small>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="schedIncludeAi" onchange="onSchedAiToggle()">
                            <label class="form-check-label fw-semibold" for="schedIncludeAi">Include AI Analysis in email</label>
                        </div>
                        <small class="text-muted d-block mt-1">When enabled, an AI-generated business intelligence summary will be included in the scheduled email body.</small>
                        <div id="schedAiDetails" class="mt-2 ps-4" style="display:none;">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto">
                                    <label class="form-label small mb-0 fw-semibold" for="schedAiLocale">Language</label>
                                </div>
                                <div class="col-auto">
                                    <select class="form-select form-select-sm" id="schedAiLocale" style="width:auto;min-width:140px;">
                                        <option value="el">Ελληνικά</option>
                                        <option value="en">English</option>
                                        <option value="sr">Srpski</option>
                                        <option value="de">Deutsch</option>
                                        <option value="fr">Français</option>
                                        <option value="bg">Български</option>
                                        <option value="ru">Русский</option>
                                        <option value="uk">Українська</option>
                                        <option value="et">Eesti</option>
                                        <option value="nl">Nederlands</option>
                                    </select>
                                </div>
                            </div>
                            <div class="alert alert-light border py-2 mt-2 mb-0 small">
                                <i class="bi bi-info-circle me-1 text-primary"></i>
                                <strong>Estimated cost:</strong> ~$0.002–0.01 per analysis (depends on data size).
                            </div>
                        </div>
                    </div>
                </div>
                <div id="scheduleAlert" class="mt-3" style="display:none;"></div>

                <hr class="my-3">
                <h6 class="text-muted"><i class="bi bi-list-check me-1"></i>Existing Schedules</h6>
                <div id="existingSchedules" class="small text-muted">Loading...</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary me-auto" onclick="resetScheduleForm()" title="Clear the form to create a new schedule">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveSchedule()">
                    <i class="bi bi-check-lg me-1"></i>Save Schedule
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Send to Email Modal -->
<div class="modal fade" id="sendEmailModal" tabindex="-1" aria-labelledby="sendEmailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="sendEmailModalLabel">
                    <i class="bi bi-envelope me-2"></i>Send Chart Report via Email
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">To <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="sendEmailRecipients" placeholder="user@@company.com, manager@@company.com">
                        <small class="text-muted">Comma or semicolon separated</small>
                        <div class="invalid-feedback" id="sendEmailRecipientsError"></div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Template</label>
                        <select class="form-select" id="sendEmailTemplate" onchange="onEmailTemplateChange()">
                            <option value="">-- No template (default) --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">CC <span class="text-muted fw-normal">(optional)</span></label>
                        <input type="text" class="form-control" id="sendEmailCC" placeholder="Semicolon list of email addresses">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">BCC <span class="text-muted fw-normal">(optional)</span></label>
                        <input type="text" class="form-control" id="sendEmailBCC" placeholder="Semicolon list of email addresses">
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-semibold">Subject</label>
                        <input type="text" class="form-control" id="sendEmailSubject" value="Charts & Dashboards — @DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd") to @DateTime.Today.ToString("yyyy-MM-dd")">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Format</label>
                        <select class="form-select" id="sendEmailFormat">
                            <option value="Excel" selected>Excel (.xlsx)</option>
                            <option value="PDF">PDF</option>
                            <option value="CSV">CSV</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Email Message</label>
                        <div class="border rounded" style="max-height:250px; overflow-y:auto; padding:12px; font-family:Arial,sans-serif; font-size:13px; background:#fafafa;" id="sendEmailBodyPreview">
                            <em class="text-muted">Select a template to preview the email body, or the default body will be used.</em>
                        </div>
                    </div>
                </div>
                <div id="sendEmailAlert" class="mt-3" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <a asp-controller="Settings" asp-action="EmailTemplates" class="btn btn-outline-secondary me-auto" title="Manage email templates">
                    <i class="bi bi-gear me-1"></i>Manage Templates
                </a>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="sendEmailBtn" onclick="sendReportEmail()">
                    <span class="spinner-border spinner-border-sm d-none me-1" id="sendEmailSpinner"></span>
                    <i class="bi bi-send me-1" id="sendEmailIcon"></i>Send
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Save Chart Layout As Modal (named / public layouts) -->
<div class="modal fade" id="saveChartLayoutAsModal" tabindex="-1" aria-labelledby="saveChartLayoutAsLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="saveChartLayoutAsLabel"><i class="bi bi-bookmark-plus me-2"></i>Save Layout As</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="saveChartLayoutAsName" class="form-label">Layout name <span class="text-danger">*</span></label>
                    <input type="text" id="saveChartLayoutAsName" class="form-control" maxlength="100" placeholder="e.g. Monthly Sales Charts" autocomplete="off" />
                    <div class="form-text">Used to identify the layout. You can have multiple named layouts.</div>
