@functions {
    decimal[] SumMonthlyPurch(IEnumerable<PurchasesSalesMonthlyRow> rows)
    {
        var t = new decimal[12];
        foreach (var r in rows) for (int i = 0; i < 12; i++) t[i] += r.Purchased[i];
        return t;
    }
    decimal[] SumMonthlySold(IEnumerable<PurchasesSalesMonthlyRow> rows)
    {
        var t = new decimal[12];
        foreach (var r in rows) for (int i = 0; i < 12; i++) t[i] += r.Sold[i];
        return t;
    }
}
