document.addEventListener('DOMContentLoaded',function(){initColumnVisibilityFromServer();updateColVisibleCount();var colSearch=document.getElementById('colSearchInput');if(colSearch){colSearch.addEventListener('input',filterColumnList);colSearch.addEventListener('keyup',filterColumnList);}var savedPreset='@(Model.DatePreset??"")';if(savedPreset){var pr=document.querySelector('input[name="DatePreset"][value="'+savedPreset+'"]');if(pr)pr.checked=true;}document.querySelectorAll('input[name="DatePreset"]').forEach(function(r){r.addEventListener('change',function(){applyPresetDates(this.value);});});var form=document.getElementById('reportForm');form.addEventListener('submit',function(){populateItemsSelectionHidden();showLoading();});document.getElementById('generateBtn').addEventListener('click',function(){resetPage();});var schedModal=document.getElementById('scheduleModal');if(schedModal){schedModal.addEventListener('show.bs.modal',function(){resetScheduleForm();loadExistingSchedules();autoSelectScheduleDateRange();onSchedDateRangeTypeChange();});}
var urlSchedId=new URLSearchParams(window.location.search).get('scheduleId');if(urlSchedId){history.replaceState(null,'',window.location.pathname);fetch('@Url.Action("GetScheduleById","Reports")?scheduleId='+urlSchedId).then(function(r){return r.json();}).then(function(data){if(!data||!data.success||!data.schedule)return;var s=data.schedule;var p={};try{p=typeof s.parametersJson==='string'?JSON.parse(s.parametersJson):(s.parametersJson||{});}catch(e){}var rdr=p.reportDateRange||{};var resolved=_resolvePsDates(rdr);var dfEl=document.getElementById('DateFrom');var dtEl=document.getElementById('DateTo');if(dfEl)dfEl.value=resolved.from;if(dtEl)dtEl.value=resolved.to;function _sv(id,v){var el=document.getElementById(id);if(el&&v!=null)el.value=v;}function _sc(id,v){var el=document.getElementById(id);if(el&&v!=null)el.checked=!!v;}_sv('ReportMode',p.reportMode);_sv('PrimaryGroup',p.primaryGroup);_sv('SecondaryGroup',p.secondaryGroup);_sv('ThirdGroup',p.thirdGroup);_sc('includeVatCheck',p.includeVat);_sc('showProfitCheck',p.showProfit);_sc('showStockCheck',p.showStock);_sc('showOnOrderCheck',p.showOnOrder);_sc('showReservationCheck',p.showReservation);_sc('showAvailableCheck',p.showAvailable);_sc('includeAdditionalChargesCheck',p.includeAdditionalCharges);_sc('sortBySizeSequenceCheck',p.sortBySizeSequence);if(window.toggleSizeSequenceOption)window.toggleSizeSequenceOption();setTimeout(function(){var btn=document.getElementById('generateBtn');if(btn)btn.click();},300);}).catch(function(){});}
function _resolvePsDates(rdr){var today=new Date();today.setHours(0,0,0,0);function addD(d,n){var r=new Date(d);r.setDate(r.getDate()+n);return r;}function fmt(d){return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}var f,t;switch(rdr.type){case'Today':f=t=today;break;case'Yesterday':f=t=addD(today,-1);break;case'LastNDays':f=addD(today,-(Math.max(rdr.value||7,1)-1));t=today;break;case'ThisMonth':f=new Date(today.getFullYear(),today.getMonth(),1);t=today;break;case'LastMonth':f=new Date(today.getFullYear(),today.getMonth()-1,1);t=new Date(today.getFullYear(),today.getMonth(),0);break;case'YearToDate':f=new Date(today.getFullYear(),0,1);t=today;break;case'LastYear':f=new Date(today.getFullYear()-1,0,1);t=new Date(today.getFullYear()-1,11,31);break;case'Custom':return{from:rdr.dateFrom||fmt(addD(today,-29)),to:rdr.dateTo||fmt(today)};default:f=addD(today,-29);t=today;}return{from:fmt(f),to:fmt(t)};}
});

var _expandedRows = {};

function drillDown(itemCode, type) {
    var key = itemCode + '_' + type;
    var existing = document.querySelectorAll('.dd-row[data-key="' + key + '"]');
    if (existing.length > 0) {
        existing.forEach(function(r) { r.remove(); });
        delete _expandedRows[key];
        return;
    }

    Object.keys(_expandedRows).forEach(function(k) {
        document.querySelectorAll('.dd-row[data-key="' + k + '"]').forEach(function(r) { r.remove(); });
        delete _expandedRows[k];
    });

    var clickedLink = event.target.closest('a');
    var parentRow = clickedLink ? clickedLink.closest('tr') : null;
    if (!parentRow) return;

    var colSpan = parentRow.cells.length;
    var loadingRow = document.createElement('tr');
    loadingRow.className = 'dd-row';
    loadingRow.dataset.key = key;
    loadingRow.innerHTML = '<td colspan="' + colSpan + '" class="bg-light py-2 text-center"><span class="spinner-border spinner-border-sm me-2"></span>Loading transaction details...</td>';
    parentRow.after(loadingRow);
    _expandedRows[key] = true;

    var url = '/Reports/GetTransactionDetails?itemCode=' + encodeURIComponent(itemCode)
        + '&type=' + type
        + '&dateFrom=' + encodeURIComponent(document.getElementById('DateFrom').value)
        + '&dateTo=' + encodeURIComponent(document.getElementById('DateTo').value)
        + '&storeCodes=' + (typeof getItemsSelectionStoreCodes === 'function' ? encodeURIComponent(getItemsSelectionStoreCodes()) : '');

    fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            loadingRow.remove();
            if (!_expandedRows[key]) return;

            if (!data.success) {
                var errRow = document.createElement('tr');
                errRow.className = 'dd-row';
                errRow.dataset.key = key;
                errRow.innerHTML = '<td colspan="' + colSpan + '" class="bg-danger bg-opacity-10 text-danger py-2 px-3"><i class="bi bi-exclamation-triangle me-1"></i>' + data.message + '</td>';
                parentRow.after(errRow);
                return;
            }

            if (data.count === 0) {
                var emptyRow = document.createElement('tr');
                emptyRow.className = 'dd-row';
                emptyRow.dataset.key = key;
                emptyRow.innerHTML = '<td colspan="' + colSpan + '" class="bg-light text-muted py-2 px-3">No transactions found for this item in the selected period.</td>';
                parentRow.after(emptyRow);
                return;
            }

            var kindColors = { 'P': 'bg-info', 'E': 'bg-warning', 'I': 'bg-success', 'C': 'bg-danger' };
            var typeLabels = { purchases: 'Purchase', sales: 'Sales', all: 'All' };
            var headerTheme = type === 'purchases'
                ? { bg: 'background:#e8f0fe;border-color:#2563eb;', border: 'border-color:#2563eb;', tblBg: '#f0f4ff' }
                : type === 'sales'
                ? { bg: 'background:#d1fae5;border-color:#059669;', border: 'border-color:#059669;', tblBg: '#f0fdf4' }
                : { bg: 'background:#e8f0fe;border-color:#6366f1;', border: 'border-color:#6366f1;', tblBg: '#f5f3ff' };

            var headerRow = document.createElement('tr');
            headerRow.className = 'dd-row';
            headerRow.dataset.key = key;
            headerRow.innerHTML = '<td colspan="' + colSpan + '" class="p-0">'
                + '<div style="' + headerTheme.bg + 'padding:8px 12px;border-top:2px solid;border-bottom:2px solid;' + headerTheme.border + '">'
                + '<strong><i class="bi bi-list-columns-reverse me-1"></i>' + (typeLabels[type] || '') + ' Transactions for ' + itemCode + '</strong>'
                + '<span class="ms-3 text-muted">' + data.count + ' transactions | Qty: ' + data.totalQty.toLocaleString(undefined,{maximumFractionDigits:2})
                + ' | Net: ' + data.totalNet.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})
                + '</span>'
                + '<button class="btn btn-sm btn-outline-secondary float-end py-0" onclick="drillDown(\'' + itemCode + '\',\'' + type + '\')"><i class="bi bi-x-lg"></i></button>'
                + '</div>'
                + '<table class="table table-sm table-bordered mb-0" style="background:' + headerTheme.tblBg + ';">'
                + '<thead><tr class="table-light small">'
                + '<th>Date</th><th>Type</th><th>Doc #</th><th>Entity</th><th>Store</th>'
                + '<th class="text-end">Qty</th><th class="text-end">Price</th><th class="text-end">Discount</th>'
                + '<th class="text-end">Net</th><th class="text-end">VAT</th><th class="text-end">Gross</th>'
                + '</tr></thead><tbody>'
                + data.rows.map(function(r) {
                    var bc = kindColors[r.kind] || 'bg-secondary';
                    return '<tr class="small">'
                        + '<td>' + r.date + '</td>'
                        + '<td><span class="badge ' + bc + ' badge-sm">' + r.kindDescription + '</span></td>'
                        + '<td class="fw-semibold"><a href="#" class="text-primary text-decoration-underline" onclick="openDocument(\'' + r.kind + '\',\'' + r.doc.replace(/'/g, "\\'") + '\');return false;" title="View document details">' + r.doc + '</a></td>'
                        + '<td>' + (r.entityCode ? r.entityCode + ' — ' : '') + r.entityName + '</td>'
                        + '<td>' + r.store + '</td>'
                        + '<td class="text-end">' + r.qty.toLocaleString(undefined,{maximumFractionDigits:2}) + '</td>'
                        + '<td class="text-end">' + r.price.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                        + '<td class="text-end">' + r.discount.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                        + '<td class="text-end">' + r.net.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                        + '<td class="text-end">' + r.vat.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                        + '<td class="text-end">' + r.gross.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                        + '</tr>';
                }).join('')
                + '</tbody></table></td>';
            parentRow.after(headerRow);
        })
        .catch(function(err) {
            loadingRow.remove();
            var errRow = document.createElement('tr');
            errRow.className = 'dd-row';
            errRow.dataset.key = key;
            errRow.innerHTML = '<td colspan="' + colSpan + '" class="bg-danger bg-opacity-10 text-danger py-2 px-3"><i class="bi bi-exclamation-triangle me-1"></i>Network error: ' + err.message + '</td>';
            parentRow.after(errRow);
        });
}

function collectAiFormData() {
    populateItemsSelectionHidden();
    var form = document.getElementById('reportForm');
    var formData = new FormData(form);
    formData.append('storeCodes', typeof getItemsSelectionStoreCodes === 'function' ? getItemsSelectionStoreCodes() : '');
    formData.append('itemIds', typeof getItemsSelectionItemIds === 'function' ? getItemsSelectionItemIds() : '');
    formData.append('sortColumn', document.getElementById('sortColumnHidden').value);
    formData.append('sortDirection', document.getElementById('sortDirectionHidden').value);
    return formData;
}

var _currentDocType = '', _currentDocNumber = '';

function buildFullViewHtml(d) {
    var isPurch = (d.docType === 'P' || d.docType === 'E');
    var accent = isPurch ? '#2563eb' : '#059669';
    var accentBg = isPurch ? '#eff6ff' : '#ecfdf5';
    var entityLabel = isPurch ? 'Supplier' : 'Customer';
    var fmt2 = function(v) { return v.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}); };

    return '<div style="text-align:center;margin-bottom:24px;padding-bottom:16px;border-bottom:3px solid '+accent+'">'
        + '<div style="font-size:20px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:'+accent+'">'+d.docTypeDescription+'</div>'
        + '<div style="font-size:14px;font-weight:600;color:#475569;margin-top:2px">Document #: '+d.documentNumber+'</div>'
        + '</div>'
        + '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;font-size:12px;margin-bottom:20px;padding:12px 16px;background:'+accentBg+';border-radius:6px">'
        + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">Date</div><div style="font-weight:500;margin-top:1px">'+d.date+'</div></div>'
        + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">Store</div><div style="font-weight:500;margin-top:1px">'+(d.storeCode||'—')+'</div></div>'
        + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">'+entityLabel+'</div><div style="font-weight:500;margin-top:1px">'+(d.entityCode ? d.entityCode+' — ' : '')+d.entityName+'</div></div>'
        + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">Line Items</div><div style="font-weight:500;margin-top:1px">'+d.lineCount+'</div></div>'
        + '</div>'
        + '<table style="width:100%;border-collapse:collapse;font-size:11px">'
        + '<thead><tr style="background:#e2e8f0">'
        + '<th style="padding:6px 10px;text-align:left;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Item Code</th>'
        + '<th style="padding:6px 10px;text-align:left;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Description</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Qty</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Unit Price</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Discount</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Net</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">VAT</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Gross</th>'
        + '</tr></thead><tbody>'
        + d.lines.map(function(l){
            return '<tr>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;font-weight:600">'+l.itemCode+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9">'+l.itemName+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">'+l.qty.toLocaleString(undefined,{maximumFractionDigits:2})+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">'+fmt2(l.price)+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">'+fmt2(l.discount)+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">'+fmt2(l.net)+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">'+fmt2(l.vat)+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">'+fmt2(l.gross)+'</td>'
                + '</tr>';
        }).join('')
        + '</tbody><tfoot><tr style="font-weight:700;border-top:3px double #1e293b;background:#f1f5f9">'
