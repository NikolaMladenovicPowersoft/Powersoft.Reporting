        showStock: document.getElementById('showStockCheck').checked,
        showOnOrder: document.getElementById('showOnOrderCheck').checked,
        showReservation: document.getElementById('showReservationCheck').checked,
        showAvailable: document.getElementById('showAvailableCheck').checked,
        includeAdditionalCharges: document.getElementById('includeAdditionalChargesCheck').checked,
        sortBySizeSequence: document.getElementById('sortBySizeSequenceCheck').checked,
        storeCodes: (typeof getItemsSelectionStoreCodes==='function'?getItemsSelectionStoreCodes():'')||document.getElementById('selectedStoreCodesHidden').value||'',
        itemIds: (typeof getItemsSelectionItemIds==='function'?getItemsSelectionItemIds():'')||document.getElementById('selectedItemIdsHidden').value||'',
        sortColumn: document.getElementById('sortColumnHidden').value,
