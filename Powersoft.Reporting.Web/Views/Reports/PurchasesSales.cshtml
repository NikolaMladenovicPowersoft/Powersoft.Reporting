                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">'+fmt2(l.discount)+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">'+fmt2(l.net)+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">'+fmt2(l.vat)+'</td>'
