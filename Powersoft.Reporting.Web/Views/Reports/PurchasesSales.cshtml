<!-- Send to Email Modal -->
<div class="modal fade" id="sendEmailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-envelope me-2"></i>Send Report via Email</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">To <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="sendEmailRecipients" placeholder="user@@company.com, manager@@company.com">
                        <small class="text-muted">Comma or semicolon separated</small>
                        <div class="invalid-feedback" id="sendEmailRecipientsError"></div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Template</label>
                        <select class="form-select" id="sendEmailTemplate" onchange="onEmailTemplateChange()">
                            <option value="">-- No template (default) --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">CC <span class="text-muted fw-normal">(optional)</span></label>
                        <input type="text" class="form-control" id="sendEmailCC" placeholder="cc@@example.com">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">BCC <span class="text-muted fw-normal">(optional)</span></label>
                        <input type="text" class="form-control" id="sendEmailBCC" placeholder="bcc@@example.com">
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-semibold">Subject</label>
                        <input type="text" class="form-control" id="sendEmailSubject" value="Purchases vs Sales Report — @Model.DateFrom.ToString("yyyy-MM-dd") to @Model.DateTo.ToString("yyyy-MM-dd")">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Format</label>
                        <select class="form-select" id="sendEmailFormat">
                            <option value="Excel" selected>Excel (.xlsx)</option>
                            <option value="PDF">PDF</option>
                            <option value="CSV">CSV</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Email Message</label>
                        <div class="border rounded" style="max-height:250px;overflow-y:auto;padding:12px;font-family:Arial,sans-serif;font-size:13px;background:#fafafa;" id="sendEmailBodyPreview">
                            <em class="text-muted">Select a template to preview the email body, or the default body will be used.</em>
                        </div>
                    </div>
                </div>
                <div id="sendEmailAlert" class="mt-3" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <a asp-controller="Settings" asp-action="EmailTemplates" class="btn btn-outline-secondary me-auto" title="Manage email templates">
                    <i class="bi bi-gear me-1"></i>Manage Templates
                </a>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="sendEmailBtn" onclick="sendReportEmail()">
                    <span class="spinner-border spinner-border-sm d-none me-1" id="sendEmailSpinner"></span>
                    <i class="bi bi-send me-1" id="sendEmailIcon"></i>Send
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var previewOpen = false;

let storeDropdownOpen = false;
function toggleStoreDropdown(event) { event.stopPropagation(); var d=document.getElementById('storeDropdown'); storeDropdownOpen=!storeDropdownOpen; d.classList.toggle('show',storeDropdownOpen); }
document.addEventListener('click',function(e){var c=document.querySelector('.store-select-container');if(c&&!c.contains(e.target)){document.getElementById('storeDropdown').classList.remove('show');storeDropdownOpen=false;}});
function updateStoreSelection(){var cbs=document.querySelectorAll('#storeList input[type="checkbox"]:checked');var codes=Array.from(cbs).map(c=>c.value);document.getElementById('selectedStoreCodesHidden').value=codes.join(',');document.getElementById('storeSelectionText').textContent=codes.length===0?'All Stores':codes.length+' stores selected';}
function selectAllStores(){document.querySelectorAll('#storeList input[type="checkbox"]').forEach(c=>c.checked=true);updateStoreSelection();}
function clearStoreSelection(){document.querySelectorAll('#storeList input[type="checkbox"]').forEach(c=>c.checked=false);updateStoreSelection();}
function filterStores(){var s=document.getElementById('storeSearchInput').value.toLowerCase();document.querySelectorAll('.store-item').forEach(function(item){var visible=item.dataset.name.includes(s)||item.dataset.code.toLowerCase().includes(s);item.style.display=visible?'flex':'none';});}

let itemModalSelectedIds = new Set();
function openItemsModal(){itemModalSelectedIds=new Set((document.getElementById('selectedItemIdsHidden').value||'').split(',').map(s=>parseInt(s,10)).filter(n=>!isNaN(n)));document.getElementById('itemSearchInput').value='';document.getElementById('itemResultsList').innerHTML='<div class="list-group-item text-muted text-center py-4"><span class="spinner-border spinner-border-sm me-2"></span>Loading...</div>';var m=new bootstrap.Modal(document.getElementById('itemsModal'));m.show();setTimeout(searchItems,300);}
function searchItems(){var search=document.getElementById('itemSearchInput').value.trim();var list=document.getElementById('itemResultsList');var status=document.getElementById('itemSearchStatus');status.textContent='Searching...';fetch('@Url.Action("SearchItems","Reports")?search='+encodeURIComponent(search)).then(r=>r.json()).then(function(data){if(!data||data.length===0){status.textContent='No items found.';list.innerHTML='<div class="list-group-item text-muted text-center py-4">No items</div>';return;}status.textContent=data.length+' items found.';list.innerHTML=data.map(function(i){var chk=itemModalSelectedIds.has(i.id)?'checked':'';return '<label class="list-group-item list-group-item-action d-flex align-items-center"><input type="checkbox" class="form-check-input me-2" value="'+i.id+'" '+chk+' onchange="toggleItemInModal('+i.id+')"><span><strong>'+i.code+'</strong> - '+i.name+'</span></label>';}).join('');}).catch(function(){status.textContent='Search failed.';});}
function toggleItemInModal(id){if(itemModalSelectedIds.has(id))itemModalSelectedIds.delete(id);else itemModalSelectedIds.add(id);document.getElementById('itemSelectedCount').textContent=itemModalSelectedIds.size;}
function clearItemsInModal(){itemModalSelectedIds.clear();document.querySelectorAll('#itemResultsList input[type="checkbox"]').forEach(c=>c.checked=false);document.getElementById('itemSelectedCount').textContent=0;}
function applyItemSelection(){document.getElementById('selectedItemIdsHidden').value=Array.from(itemModalSelectedIds).join(',');updateItemSelectionText();}
function clearItemSelection(){document.getElementById('selectedItemIdsHidden').value='';updateItemSelectionText();}
function updateItemSelectionText(){var v=document.getElementById('selectedItemIdsHidden').value;var c=v?v.split(',').filter(s=>s.trim()).length:0;document.getElementById('itemSelectionText').textContent=c===0?'All Items':c+' items selected';}

function clearPreset(){document.querySelectorAll('input[name="DatePreset"]').forEach(r=>r.checked=false);}
function goToPage(p){document.getElementById('pageNumberHidden').value=p;document.getElementById('reportForm').submit();}
function sortBy(col){var curCol=document.getElementById('sortColumnHidden').value;var curDir=document.getElementById('sortDirectionHidden').value;document.getElementById('sortColumnHidden').value=col;document.getElementById('sortDirectionHidden').value=(col===curCol&&curDir==='ASC')?'DESC':'ASC';document.getElementById('pageNumberHidden').value=1;document.getElementById('reportForm').submit();}

function togglePreview(){var panel=document.getElementById('previewPanel');var grid=document.getElementById('results');var btn=document.getElementById('previewToggleBtn');previewOpen=!previewOpen;if(previewOpen){grid.style.display='none';panel.style.display='block';btn.innerHTML='<i class="bi bi-table me-1"></i>Grid';btn.classList.remove('btn-outline-primary');btn.classList.add('btn-outline-warning');var f=document.getElementById('previewFrame');if(!f.src||f.src==='about:blank'){f.src='@Url.Action("PrintPsPreview")?dateFrom=@Model.DateFrom.ToString("yyyy-MM-dd")&dateTo=@Model.DateTo.ToString("yyyy-MM-dd")&reportMode=@Model.ReportMode&primaryGroup=@Model.PrimaryGroup&secondaryGroup=@Model.SecondaryGroup&thirdGroup=@Model.ThirdGroup&includeVat=@Model.IncludeVat&showProfit=@Model.ShowProfit&showStock=@Model.ShowStock&storeCodes=@(Model.SelectedStoreCodesString??"")&sortColumn=@Model.SortColumn&sortDirection=@Model.SortDirection';}f.onload=function(){try{f.style.height=Math.max(f.contentDocument.body.scrollHeight+80,700)+'px';}catch(e){f.style.height='900px';}};}else{panel.style.display='none';grid.style.display='';btn.innerHTML='<i class="bi bi-eye me-1"></i>Preview';btn.classList.remove('btn-outline-warning');btn.classList.add('btn-outline-primary');}}

function clearAllFilters(){@foreach(var c in filterCols){<text>document.getElementById('fv_@c').value='';document.getElementById('fo_@c').value='';</text>}document.getElementById('pageNumberHidden').value=1;document.getElementById('reportForm').submit();}

function validateEmailList(input){if(!input||!input.trim())return{valid:false,errors:['Enter at least one email.']};var emails=input.split(/[,;]/).map(e=>e.trim()).filter(e=>e.length>0);var re=/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;var invalid=emails.filter(e=>!re.test(e));if(invalid.length>0)return{valid:false,errors:invalid.map(e=>'Invalid: '+e)};return{valid:true,emails:emails,errors:[]};}

var _emailTemplatesCache = [];
function openSendEmailModal(){document.getElementById('sendEmailRecipients').value='';document.getElementById('sendEmailAlert').style.display='none';document.getElementById('sendEmailRecipients').classList.remove('is-invalid');loadEmailTemplates();var m=new bootstrap.Modal(document.getElementById('sendEmailModal'));m.show();}

function loadEmailTemplates(){fetch('@Url.Action("GetEmailTemplates","Reports")?reportType=PurchasesSales').then(r=>r.json()).then(function(data){_emailTemplatesCache=data||[];var sel=document.getElementById('sendEmailTemplate');sel.innerHTML='<option value="">-- No template (default) --</option>';data.forEach(function(t){var opt=document.createElement('option');opt.value=t.templateId;opt.textContent=t.templateName+(t.isDefault?' (default)':'');opt.dataset.subject=t.emailSubject||'';sel.appendChild(opt);if(t.isDefault)opt.selected=true;});onEmailTemplateChange();}).catch(function(){});}

function onEmailTemplateChange(){var sel=document.getElementById('sendEmailTemplate');var id=parseInt(sel.value,10);var preview=document.getElementById('sendEmailBodyPreview');if(isNaN(id)||!id){preview.innerHTML='<em class="text-muted">Default email body will be used.</em>';return;}var tmpl=_emailTemplatesCache.find(function(t){return t.templateId===id;});if(!tmpl)return;if(tmpl.emailSubject)document.getElementById('sendEmailSubject').value=replaceMergeFieldsPreview(tmpl.emailSubject);if(tmpl.emailBodyHtml)preview.innerHTML=replaceMergeFieldsPreview(tmpl.emailBodyHtml);}

function replaceMergeFieldsPreview(text){return text.replace(/\u00ABReportName\u00BB/g,'Purchases vs Sales').replace(/\u00ABDatabaseName\u00BB/g,'@(Model.ConnectedDatabase??"Unknown")').replace(/\u00ABPeriod\u00BB/g,'@Model.DateFrom.ToString("yyyy-MM-dd") to @Model.DateTo.ToString("yyyy-MM-dd")').replace(/\u00ABRowCount\u00BB/g,'@(Model.Results?.Count??0)').replace(/\u00ABExportFormat\u00BB/g,document.getElementById('sendEmailFormat').value).replace(/\u00ABGeneratedDate\u00BB/g,new Date().toLocaleString()).replace(/\u00ABUserName\u00BB/g,'@(User.Identity?.Name??"Unknown")').replace(/\u00ABCompanyName\u00BB/g,'@(Model.ConnectedDatabase??"")').replace(/\u00AB/g,'').replace(/\u00BB/g,'');}

function sendReportEmail(){var ri=document.getElementById('sendEmailRecipients');var ad=document.getElementById('sendEmailAlert');var v=validateEmailList(ri.value);if(!v.valid){ri.classList.add('is-invalid');document.getElementById('sendEmailRecipientsError').textContent=v.errors.join('; ');return;}ri.classList.remove('is-invalid');var btn=document.getElementById('sendEmailBtn');var sp=document.getElementById('sendEmailSpinner');var ic=document.getElementById('sendEmailIcon');btn.disabled=true;sp.classList.remove('d-none');ic.classList.add('d-none');var fd=new FormData();fd.append('recipients',ri.value.trim());fd.append('cc',(document.getElementById('sendEmailCC').value||'').trim());fd.append('bcc',(document.getElementById('sendEmailBCC').value||'').trim());fd.append('emailSubject',document.getElementById('sendEmailSubject').value);fd.append('exportFormat',document.getElementById('sendEmailFormat').value);fd.append('templateId',document.getElementById('sendEmailTemplate').value||'');fd.append('dateFrom','@Model.DateFrom.ToString("yyyy-MM-dd")');fd.append('dateTo','@Model.DateTo.ToString("yyyy-MM-dd")');fd.append('reportMode','@Model.ReportMode');fd.append('primaryGroup','@Model.PrimaryGroup');fd.append('secondaryGroup','@Model.SecondaryGroup');fd.append('thirdGroup','@Model.ThirdGroup');fd.append('includeVat','@Model.IncludeVat');fd.append('showProfit','@Model.ShowProfit');fd.append('showStock','@Model.ShowStock');fd.append('storeCodes','@(Model.SelectedStoreCodesString??"")');fd.append('sortColumn','@Model.SortColumn');fd.append('sortDirection','@Model.SortDirection');fetch('@Url.Action("SendPsReportEmail","Reports")',{method:'POST',body:fd}).then(r=>r.json()).then(function(d){btn.disabled=false;sp.classList.add('d-none');ic.classList.remove('d-none');ad.innerHTML='<div class="alert alert-'+(d.success?'success':'danger')+' mb-0">'+(d.success?'<i class="bi bi-check-circle me-1"></i>':'<i class="bi bi-exclamation-triangle me-1"></i>')+d.message+'</div>';ad.style.display='';}).catch(function(){btn.disabled=false;sp.classList.add('d-none');ic.classList.remove('d-none');ad.innerHTML='<div class="alert alert-danger mb-0">Network error.</div>';ad.style.display='';});}

function filterColumnList(){var el=document.getElementById('colSearchInput');if(!el)return;var s=el.value.toLowerCase().trim();document.querySelectorAll('#colToggleList label').forEach(function(lbl){if(!s){lbl.classList.remove('d-none');return;}var name=(lbl.getAttribute('data-col-name')||'').toLowerCase();var text=lbl.querySelector('span')?lbl.querySelector('span').textContent.toLowerCase():'';var match=name.indexOf(s)!==-1||text.indexOf(s)!==-1;if(match)lbl.classList.remove('d-none');else lbl.classList.add('d-none');});}
function toggleAllColumns(chk){document.querySelectorAll('.col-toggle').forEach(function(cb){cb.checked=chk;});applyColumnVisibility();updateColVisibleCount();}
function updateColVisibleCount(){var total=document.querySelectorAll('.col-toggle').length;var vis=document.querySelectorAll('.col-toggle:checked').length;var el=document.getElementById('colVisibleCount');if(el)el.textContent=vis;}

function applyColumnVisibility(){var hidden=[];document.querySelectorAll('.col-toggle').forEach(function(cb){if(!cb.checked)hidden.push(cb.value);});var hi=document.getElementById('hiddenColumnsInput');if(hi)hi.value=hidden.join(',');var styleEl=document.getElementById('colVisibilityStyle');if(!styleEl){styleEl=document.createElement('style');styleEl.id='colVisibilityStyle';document.head.appendChild(styleEl);}var table=document.getElementById('resultsTable');if(!table)return;var rules=[];document.querySelectorAll('.col-toggle').forEach(function(cb){if(!cb.checked){var headers=table.querySelectorAll('thead tr:first-child th');for(var i=0;i<headers.length;i++){if(headers[i].getAttribute('data-col')===cb.value){rules.push('#resultsTable th:nth-child('+(i+1)+'),#resultsTable td:nth-child('+(i+1)+'){display:none;}');break;}}}});styleEl.textContent=rules.join('\n');updateColVisibleCount();}

function onSchedDateRangeTypeChange(){var sel=document.getElementById('schedDateRangeType');var opt=sel.options[sel.selectedIndex];var isCustom=(opt.value==='Custom');document.getElementById('schedCustomDateFromWrap').style.display=isCustom?'':'none';document.getElementById('schedCustomDateToWrap').style.display=isCustom?'':'none';}
function onRecurrenceChange(){var t=document.getElementById('schedRecurrence').value;document.getElementById('schedWeeklyDaysContainer').style.display=t==='Weekly'?'':'none';document.getElementById('schedMonthDayContainer').style.display=t==='Monthly'?'':'none';}
function saveSchedule(){var name=document.getElementById('schedName').value.trim();var recipients=document.getElementById('schedRecipients').value.trim();var alertDiv=document.getElementById('scheduleAlert');if(!name||!recipients){alertDiv.innerHTML='<div class="alert alert-warning mb-0">Please fill in schedule name and recipients.</div>';alertDiv.style.display='';return;}var ev=validateEmailList(recipients);if(!ev.valid){alertDiv.innerHTML='<div class="alert alert-warning mb-0">Invalid email(s): '+ev.errors.join('; ')+'</div>';alertDiv.style.display='';return;}var recurrence=document.getElementById('schedRecurrence').value;if(recurrence==='Once'){var sd=document.getElementById('schedStartDate').value;var today=new Date().toISOString().slice(0,10);if(!sd||sd<today){alertDiv.innerHTML='<div class="alert alert-warning mb-0">Start date must be today or later.</div>';alertDiv.style.display='';return;}}var day=(recurrence==='Monthly')?parseInt(document.getElementById('schedMonthDay').value,10):null;var fd=new FormData();fd.append('scheduleName',name);fd.append('recurrenceType',recurrence);if(day!==null&&!isNaN(day))fd.append('recurrenceDay',day);fd.append('scheduleTime',document.getElementById('schedTime').value);fd.append('exportFormat',document.getElementById('schedFormat').value);fd.append('recipients',recipients);fd.append('emailSubject',document.getElementById('schedSubject').value);var dateRangeSel=document.getElementById('schedDateRangeType');var dateRangeOpt=dateRangeSel.options[dateRangeSel.selectedIndex];var reportDateRange={type:dateRangeOpt.value};if(reportDateRange.type==='LastNDays'){reportDateRange.value=parseInt(dateRangeOpt.getAttribute('data-value')||'7',10);}else if(reportDateRange.type==='Custom'){reportDateRange.dateFrom=document.getElementById('schedDateFrom').value;reportDateRange.dateTo=document.getElementById('schedDateTo').value;}var params={reportDateRange:reportDateRange,dateFrom:document.getElementById('DateFrom').value,dateTo:document.getElementById('DateTo').value,reportMode:document.getElementById('ReportMode').value,primaryGroup:document.getElementById('PrimaryGroup').value,secondaryGroup:document.getElementById('SecondaryGroup').value,thirdGroup:document.getElementById('ThirdGroup').value,includeVat:document.getElementById('includeVatCheck').checked,showProfit:document.getElementById('showProfitCheck').checked,showStock:document.getElementById('showStockCheck').checked,storeCodes:document.getElementById('selectedStoreCodesHidden').value||'',itemIds:document.getElementById('selectedItemIdsHidden').value||'',sortColumn:document.getElementById('sortColumnHidden').value||'ItemCode',sortDirection:document.getElementById('sortDirectionHidden').value||'ASC',reportType:'PurchasesSales'};fd.append('parametersJson',JSON.stringify(params));var startDate=document.getElementById('schedStartDate').value||new Date().toISOString().slice(0,10);var recurrenceJson={type:recurrence,time:document.getElementById('schedTime').value,range:{startDate:startDate,noEndDate:true}};if(recurrence==='Weekly'){var days=[];document.querySelectorAll('.sched-dow:checked').forEach(function(cb){days.push(parseInt(cb.value,10));});recurrenceJson.pattern={interval:1,daysOfWeek:days.length?days:[1]};}else if(recurrence==='Monthly'){recurrenceJson.pattern={dayOfMonth:day!==null?day:1};}fd.append('recurrenceJson',JSON.stringify(recurrenceJson));fetch('@Url.Action("SavePsSchedule","Reports")',{method:'POST',body:fd}).then(r=>r.json()).then(function(d){if(d.success){alertDiv.innerHTML='<div class="alert alert-success mb-0"><i class="bi bi-check-circle me-1"></i>'+d.message+'</div>';alertDiv.style.display='';document.getElementById('schedName').value='';loadExistingSchedules();}else{alertDiv.innerHTML='<div class="alert alert-danger mb-0">'+d.message+'</div>';alertDiv.style.display='';}}).catch(function(){alertDiv.innerHTML='<div class="alert alert-danger mb-0">Network error.</div>';alertDiv.style.display='';});}
function loadExistingSchedules(){fetch('@Url.Action("GetPsSchedules","Reports")').then(r=>r.json()).then(function(data){var c=document.getElementById('existingSchedules');if(!data||data.length===0){c.innerHTML='<em>No schedules configured yet.</em>';return;}var h='<table class="table table-sm mb-0"><thead><tr><th>Name</th><th>Report</th><th>Recurrence</th><th>Format</th><th>Time</th><th>Next Run</th></tr></thead><tbody>';data.forEach(function(s){h+='<tr><td>'+s.scheduleName+'</td><td><span class="badge bg-primary">Purchases/Sales</span></td><td>'+s.recurrenceType+'</td><td>'+s.exportFormat+'</td><td>'+s.scheduleTime+'</td><td>'+(s.nextRun||'-')+'</td></tr>';});h+='</tbody></table>';c.innerHTML=h;}).catch(function(){document.getElementById('existingSchedules').innerHTML='<em>Could not load schedules.</em>';});}

function collectCurrentLayout(){var p={};var vat=document.getElementById('includeVatCheck');if(vat)p['IncludeVat']=vat.checked?'1':'0';var sp=document.getElementById('showProfitCheck');if(sp)p['ShowProfit']=sp.checked?'1':'0';var ss=document.getElementById('showStockCheck');if(ss)p['ShowStock']=ss.checked?'1':'0';var rm=document.getElementById('ReportMode');if(rm)p['ReportMode']=rm.options[rm.selectedIndex].text;var pg=document.getElementById('PrimaryGroup');if(pg)p['PrimaryGroup']=pg.options[pg.selectedIndex].text;var sg=document.getElementById('SecondaryGroup');if(sg)p['SecondaryGroup']=sg.options[sg.selectedIndex].text;var tg=document.getElementById('ThirdGroup');if(tg)p['ThirdGroup']=tg.options[tg.selectedIndex].text;var ps=document.getElementById('PageSize');if(ps)p['PageSize']=ps.value;var hidden=[];document.querySelectorAll('.col-toggle').forEach(function(cb){if(!cb.checked)hidden.push(cb.value);});p['HiddenColumns']=hidden.join(',');return p;}

function saveCurrentLayout(){var p=collectCurrentLayout();fetch('@Url.Action("SavePsLayout","Reports")',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(p)}).then(r=>r.json()).then(function(d){showLayoutToast(d.success?'Layout saved successfully':(d.message||'Failed'),d.success?'success':'danger');}).catch(function(){showLayoutToast('Network error','danger');});}

function resetSavedLayout(){if(!confirm('Reset your saved layout to factory defaults?'))return;fetch('@Url.Action("ResetPsLayout","Reports")',{method:'POST'}).then(r=>r.json()).then(function(d){if(d.success){showLayoutToast('Layout reset — reloading...','success');setTimeout(function(){window.location.href='@Url.Action("PurchasesSales")';},800);}else{showLayoutToast(d.message||'Failed','danger');}}).catch(function(){showLayoutToast('Network error','danger');});}

function showLayoutToast(msg,type){var ex=document.getElementById('layoutToast');if(ex)ex.remove();var d=document.createElement('div');d.id='layoutToast';d.className='alert alert-'+type+' alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow';d.style.zIndex='9999';d.innerHTML='<i class="bi bi-'+(type==='success'?'check-circle':'exclamation-triangle')+' me-1"></i>'+msg+'<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';document.body.appendChild(d);setTimeout(function(){if(d.parentNode)d.remove();},4000);}

function initColumnVisibilityFromServer(){var hc='@(Model.HiddenColumns??"")';if(!hc)return;var hidden=hc.split(',').filter(s=>s.trim());if(hidden.length===0)return;hidden.forEach(function(col){var cb=document.querySelector('.col-toggle[value="'+col.trim()+'"]');if(cb)cb.checked=false;});applyColumnVisibility();}

function applyPresetDates(preset){var today=new Date();var from,to;switch(preset){case'today':from=to=today;break;case'yesterday':from=to=new Date(today.getTime()-86400000);break;case'last7':from=new Date(today.getTime()-6*86400000);to=today;break;case'last30':from=new Date(today.getTime()-29*86400000);to=today;break;case'thisMonth':from=new Date(today.getFullYear(),today.getMonth(),1);to=today;break;case'lastMonth':var lm=new Date(today.getFullYear(),today.getMonth()-1,1);from=lm;to=new Date(lm.getFullYear(),lm.getMonth()+1,0);break;case'ytd':from=new Date(today.getFullYear(),0,1);to=today;break;case'lastYear':from=new Date(today.getFullYear()-1,0,1);to=new Date(today.getFullYear()-1,11,31);break;default:return;}function fmt(d){return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}document.getElementById('DateFrom').value=fmt(from);document.getElementById('DateTo').value=fmt(to);}
function resetPage(){document.getElementById('pageNumberHidden').value=1;}
function showLoading(){var btn=document.getElementById('generateBtn');btn.querySelector('.btn-text').classList.add('d-none');btn.querySelector('.spinner-border').classList.remove('d-none');btn.disabled=true;}
document.addEventListener('DOMContentLoaded',function(){updateStoreSelection();updateItemSelectionText();initColumnVisibilityFromServer();updateColVisibleCount();var colSearch=document.getElementById('colSearchInput');if(colSearch){colSearch.addEventListener('input',filterColumnList);colSearch.addEventListener('keyup',filterColumnList);}document.querySelectorAll('input[name="DatePreset"]').forEach(function(r){r.addEventListener('change',function(){applyPresetDates(this.value);});});var form=document.getElementById('reportForm');form.addEventListener('submit',function(){showLoading();});document.getElementById('generateBtn').addEventListener('click',function(){resetPage();});var schedModal=document.getElementById('scheduleModal');if(schedModal){schedModal.addEventListener('show.bs.modal',function(){loadExistingSchedules();onSchedDateRangeTypeChange();});}
    fetch('/Reports/GetAiStatus').then(r=>r.json()).then(d=>{if(!d.configured){var btn=document.getElementById('btnAnalyzePs');if(btn){btn.title='AI not configured — set API key in Settings';btn.classList.add('disabled');}}}).catch(()=>{});
});

var _expandedRows = {};

function drillDown(itemCode, type) {
    var key = itemCode + '_' + type;
    var existing = document.querySelectorAll('.dd-row[data-key="' + key + '"]');
    if (existing.length > 0) {
        existing.forEach(function(r) { r.remove(); });
        delete _expandedRows[key];
        return;
    }

    Object.keys(_expandedRows).forEach(function(k) {
        document.querySelectorAll('.dd-row[data-key="' + k + '"]').forEach(function(r) { r.remove(); });
        delete _expandedRows[k];
    });

    var clickedLink = event.target.closest('a');
    var parentRow = clickedLink ? clickedLink.closest('tr') : null;
    if (!parentRow) return;

    var colSpan = parentRow.cells.length;
    var loadingRow = document.createElement('tr');
    loadingRow.className = 'dd-row';
    loadingRow.dataset.key = key;
    loadingRow.innerHTML = '<td colspan="' + colSpan + '" class="bg-light py-2 text-center"><span class="spinner-border spinner-border-sm me-2"></span>Loading transaction details...</td>';
    parentRow.after(loadingRow);
    _expandedRows[key] = true;

    var url = '/Reports/GetTransactionDetails?itemCode=' + encodeURIComponent(itemCode)
        + '&type=' + type
        + '&dateFrom=@Model.DateFrom.ToString("yyyy-MM-dd")'
        + '&dateTo=@Model.DateTo.ToString("yyyy-MM-dd")'
        + '&storeCodes=@(Model.SelectedStoreCodesString ?? "")';

    fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            loadingRow.remove();
            if (!_expandedRows[key]) return;

            if (!data.success) {
                var errRow = document.createElement('tr');
                errRow.className = 'dd-row';
                errRow.dataset.key = key;
                errRow.innerHTML = '<td colspan="' + colSpan + '" class="bg-danger bg-opacity-10 text-danger py-2 px-3"><i class="bi bi-exclamation-triangle me-1"></i>' + data.message + '</td>';
                parentRow.after(errRow);
                return;
            }

            if (data.count === 0) {
                var emptyRow = document.createElement('tr');
                emptyRow.className = 'dd-row';
                emptyRow.dataset.key = key;
                emptyRow.innerHTML = '<td colspan="' + colSpan + '" class="bg-light text-muted py-2 px-3">No transactions found for this item in the selected period.</td>';
                parentRow.after(emptyRow);
                return;
            }

            var kindColors = { 'P': 'bg-info', 'E': 'bg-warning', 'I': 'bg-success', 'C': 'bg-danger' };
            var typeLabels = { purchases: 'Purchase', sales: 'Sales', all: 'All' };
            var headerTheme = type === 'purchases'
                ? { bg: 'background:#e8f0fe;border-color:#2563eb;', border: 'border-color:#2563eb;', tblBg: '#f0f4ff' }
                : type === 'sales'
                ? { bg: 'background:#d1fae5;border-color:#059669;', border: 'border-color:#059669;', tblBg: '#f0fdf4' }
                : { bg: 'background:#e8f0fe;border-color:#6366f1;', border: 'border-color:#6366f1;', tblBg: '#f5f3ff' };

            var headerRow = document.createElement('tr');
            headerRow.className = 'dd-row';
            headerRow.dataset.key = key;
            headerRow.innerHTML = '<td colspan="' + colSpan + '" class="p-0">'
                + '<div style="' + headerTheme.bg + 'padding:8px 12px;border-top:2px solid;border-bottom:2px solid;' + headerTheme.border + '">'
                + '<strong><i class="bi bi-list-columns-reverse me-1"></i>' + (typeLabels[type] || '') + ' Transactions for ' + itemCode + '</strong>'
                + '<span class="ms-3 text-muted">' + data.count + ' transactions | Qty: ' + data.totalQty.toLocaleString(undefined,{maximumFractionDigits:2})
                + ' | Net: ' + data.totalNet.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})
                + '</span>'
                + '<button class="btn btn-sm btn-outline-secondary float-end py-0" onclick="drillDown(\'' + itemCode + '\',\'' + type + '\')"><i class="bi bi-x-lg"></i></button>'
                + '</div>'
                + '<table class="table table-sm table-bordered mb-0" style="background:' + headerTheme.tblBg + ';">'
                + '<thead><tr class="table-light small">'
                + '<th>Date</th><th>Type</th><th>Doc #</th><th>Entity</th><th>Store</th>'
                + '<th class="text-end">Qty</th><th class="text-end">Price</th><th class="text-end">Discount</th>'
                + '<th class="text-end">Net</th><th class="text-end">VAT</th><th class="text-end">Gross</th>'
                + '</tr></thead><tbody>'
                + data.rows.map(function(r) {
                    var bc = kindColors[r.kind] || 'bg-secondary';
                    return '<tr class="small">'
                        + '<td>' + r.date + '</td>'
                        + '<td><span class="badge ' + bc + ' badge-sm">' + r.kindDescription + '</span></td>'
                        + '<td class="fw-semibold"><a href="#" class="text-primary text-decoration-underline" onclick="openDocument(\'' + r.kind + '\',\'' + r.doc.replace(/'/g, "\\'") + '\');return false;" title="View document details">' + r.doc + '</a></td>'
                        + '<td>' + (r.entityCode ? r.entityCode + ' — ' : '') + r.entityName + '</td>'
                        + '<td>' + r.store + '</td>'
                        + '<td class="text-end">' + r.qty.toLocaleString(undefined,{maximumFractionDigits:2}) + '</td>'
                        + '<td class="text-end">' + r.price.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                        + '<td class="text-end">' + r.discount.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                        + '<td class="text-end">' + r.net.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                        + '<td class="text-end">' + r.vat.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                        + '<td class="text-end">' + r.gross.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                        + '</tr>';
                }).join('')
                + '</tbody></table></td>';
            parentRow.after(headerRow);
        })
        .catch(function(err) {
            loadingRow.remove();
            var errRow = document.createElement('tr');
            errRow.className = 'dd-row';
            errRow.dataset.key = key;
            errRow.innerHTML = '<td colspan="' + colSpan + '" class="bg-danger bg-opacity-10 text-danger py-2 px-3"><i class="bi bi-exclamation-triangle me-1"></i>Network error: ' + err.message + '</td>';
            parentRow.after(errRow);
        });
}

function analyzePsReport() {
    var modal = new bootstrap.Modal(document.getElementById('aiAnalysisModal'));
    document.getElementById('aiLoading').classList.remove('d-none');
    document.getElementById('aiError').classList.add('d-none');
    document.getElementById('aiResults').classList.add('d-none');
    document.getElementById('btnReanalyze').style.display = 'none';
    modal.show();

    var form = document.getElementById('reportForm');
    var formData = new FormData(form);
    formData.append('storeCodes', '@Model.SelectedStoreCodesString');
    formData.append('itemIds', '@(Model.SelectedItemIdsString ?? "")');
    formData.append('sortColumn', '@Model.SortColumn');
    formData.append('sortDirection', '@Model.SortDirection');

    fetch('/Reports/AnalyzePsReport', { method: 'POST', body: formData })
        .then(r => r.json())
        .then(data => {
            document.getElementById('aiLoading').classList.add('d-none');
            if (!data.success) {
                document.getElementById('aiError').classList.remove('d-none');
                document.getElementById('aiErrorMsg').textContent = data.message;
                document.getElementById('btnReanalyze').style.display = 'inline-block';
                return;
            }
            var a = data.analysis;
            document.getElementById('aiSummary').textContent = a.summary || '';

            var kfList = document.getElementById('aiKeyFindings');
            kfList.innerHTML = '';
            var kfSection = document.getElementById('aiKeyFindingsSection');
            if (a.keyFindings && a.keyFindings.length > 0) {
                kfSection.classList.remove('d-none');
                a.keyFindings.forEach(function(f) { var li = document.createElement('li'); li.textContent = f; kfList.appendChild(li); });
            } else { kfSection.classList.add('d-none'); }

            var alertsList = document.getElementById('aiAlerts');
            alertsList.innerHTML = '';
            var alertsSection = document.getElementById('aiAlertsSection');
            if (a.alerts && a.alerts.length > 0) {
                alertsSection.classList.remove('d-none');
                a.alerts.forEach(function(f) { var li = document.createElement('li'); li.textContent = f; alertsList.appendChild(li); });
            } else { alertsSection.classList.add('d-none'); }

            var recsList = document.getElementById('aiRecs');
            recsList.innerHTML = '';
            var recsSection = document.getElementById('aiRecsSection');
            if (a.recommendations && a.recommendations.length > 0) {
                recsSection.classList.remove('d-none');
                a.recommendations.forEach(function(f) { var li = document.createElement('li'); li.textContent = f; recsList.appendChild(li); });
            } else { recsSection.classList.add('d-none'); }

            document.getElementById('aiModel').textContent = a.modelUsed || 'N/A';
            document.getElementById('aiTokens').textContent = (a.inputTokens || 0) + ' in / ' + (a.outputTokens || 0) + ' out';
            document.getElementById('aiTime').textContent = ((a.durationMs || 0) / 1000).toFixed(1) + 's';

            document.getElementById('aiResults').classList.remove('d-none');
            document.getElementById('btnReanalyze').style.display = 'inline-block';
        })
        .catch(err => {
            document.getElementById('aiLoading').classList.add('d-none');
            document.getElementById('aiError').classList.remove('d-none');
            document.getElementById('aiErrorMsg').textContent = 'Network error: ' + err.message;
            document.getElementById('btnReanalyze').style.display = 'inline-block';
        });
}

var _currentDocType = '', _currentDocNumber = '';

function buildFullViewHtml(d) {
    var isPurch = (d.docType === 'P' || d.docType === 'E');
    var accent = isPurch ? '#2563eb' : '#059669';
    var accentBg = isPurch ? '#eff6ff' : '#ecfdf5';
    var entityLabel = isPurch ? 'Supplier' : 'Customer';
    var fmt2 = function(v) { return v.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}); };

    return '<div style="text-align:center;margin-bottom:24px;padding-bottom:16px;border-bottom:3px solid '+accent+'">'
        + '<div style="font-size:20px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:'+accent+'">'+d.docTypeDescription+'</div>'
        + '<div style="font-size:14px;font-weight:600;color:#475569;margin-top:2px">Document #: '+d.documentNumber+'</div>'
        + '</div>'
        + '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;font-size:12px;margin-bottom:20px;padding:12px 16px;background:'+accentBg+';border-radius:6px">'
        + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">Date</div><div style="font-weight:500;margin-top:1px">'+d.date+'</div></div>'
        + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">Store</div><div style="font-weight:500;margin-top:1px">'+(d.storeCode||'—')+'</div></div>'
        + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">'+entityLabel+'</div><div style="font-weight:500;margin-top:1px">'+(d.entityCode ? d.entityCode+' — ' : '')+d.entityName+'</div></div>'
        + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">Line Items</div><div style="font-weight:500;margin-top:1px">'+d.lineCount+'</div></div>'
        + '</div>'
        + '<table style="width:100%;border-collapse:collapse;font-size:11px">'
        + '<thead><tr style="background:#e2e8f0">'
        + '<th style="padding:6px 10px;text-align:left;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Item Code</th>'
        + '<th style="padding:6px 10px;text-align:left;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Description</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Qty</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Unit Price</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Discount</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Net</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">VAT</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Gross</th>'
        + '</tr></thead><tbody>'
        + d.lines.map(function(l){
            return '<tr>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;font-weight:600">'+l.itemCode+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9">'+l.itemName+'</td>'
