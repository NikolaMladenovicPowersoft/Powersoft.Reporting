{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Process",
      "Serilog.Enrichers.Thread"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/reporting-.json",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PSCentral": "Data Source=YOUR_SERVER;Initial Catalog=pscentral;User ID=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;Encrypt=False;Pooling=true"
  },
  "Email": {
    "SmtpHost": "smtp-relay.brevo.com",
    "SmtpPort": 587,
    "FromEmail": "reports@powersoft.com.cy",
    "FromName": "Powersoft Reports",
    "SmtpUser": "YOUR_SMTP_USER",
    "SmtpPassword": "YOUR_SMTP_PASSWORD"
  },
  "Scheduler": {
    "IntervalSeconds": 60
  },
  "Storage": {
    "ServiceUrl": "",
    "Region": "fra1",
    "BucketName": "reports-ai-cold",
    "AccessKey": "",
    "SecretKey": "",
    "KeyPrefix": "scheduled-reports/"
  },
  "AiAnalyzer": {
    "Provider": "OpenAI",
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "MaxOutputTokens": 2048,
    "Temperature": 0.3
  }
}
