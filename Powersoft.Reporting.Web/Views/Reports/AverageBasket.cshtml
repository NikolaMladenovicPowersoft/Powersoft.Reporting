    formData.append('emailSubject', document.getElementById('sendEmailSubject').value);
    formData.append('exportFormat', document.getElementById('sendEmailFormat').value);
    formData.append('templateId', document.getElementById('sendEmailTemplate').value || '');
    formData.append('dateFrom', '@Model.DateFrom.ToString("yyyy-MM-dd")');
    formData.append('dateTo', '@Model.DateTo.ToString("yyyy-MM-dd")');
    formData.append('breakdown', '@Model.Breakdown');
    formData.append('groupBy', '@Model.GroupBy');
    formData.append('secondaryGroupBy', '@Model.SecondaryGroupBy');
    formData.append('includeVat', '@Model.IncludeVat');
    formData.append('compareLastYear', '@Model.CompareLastYear');
    formData.append('storeCodes', typeof getItemsSelectionStoreCodes === 'function' ? getItemsSelectionStoreCodes() : (document.getElementById('selectedStoreCodesHidden').value || ''));
    formData.append('itemIds', typeof getItemsSelectionItemIds === 'function' ? getItemsSelectionItemIds() : (document.getElementById('selectedItemIdsHidden').value || ''));
