@model Powersoft.Reporting.Web.ViewModels.CatalogueViewModel
@using Powersoft.Reporting.Core.Enums
@using Powersoft.Reporting.Core.Models
@{
    ViewData["Title"] = "Power Reports Catalogue";
    var filterCols = new[] { "ItemCode", "ItemDescription", "Level1Description", "Level2Description", "Level3Description",
        "Quantity", "NetValue", "GrossAmount", "ProfitValue", "TransactionCost", "TotalStockQty",
        "EntityName", "StoreCode", "BrandName", "ItemCategoryDescr" };
    bool hasResults = Model.Results.Any();
    bool hasL1 = Model.HasPrimaryGroup;
    bool hasL2 = Model.HasSecondaryGroup;
    bool hasL3 = Model.HasThirdGroup;
    bool showItem = !Model.IsSummary || (!hasL1 && !hasL2 && !hasL3);
    bool useGross = Model.HasDisplayColumn("GrossAmount");

    var displayCols = Model.GetDisplayColumns();
    bool dc(string c) => displayCols.Contains(c, StringComparer.OrdinalIgnoreCase);
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-start">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">Reports</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">Stock Control</a></li>
                    <li class="breadcrumb-item active">Power Reports Catalogue</li>
                </ol>
            </nav>
            <h2 class="mb-0">
                <i class="bi bi-journal-text me-2 text-primary"></i>Power Reports Catalogue
            </h2>
            <p class="text-muted mb-0">Comprehensive transaction catalogue with flexible grouping and filtering</p>
        </div>
        <div class="mt-3">
            @await Html.PartialAsync("_TutorialButton", ("Power Reports Catalogue", ""))
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="bi bi-funnel me-2"></i>Report Parameters</div>
    <div class="card-body">
        <form asp-action="Catalogue" method="post" id="reportForm">
            <input type="hidden" asp-for="SelectedStoreCodesString" id="selectedStoreCodesHidden" />
            <input type="hidden" asp-for="ItemsSelectionJson" id="itemsSelectionJsonHidden" />
            <input type="hidden" asp-for="PageNumber" id="pageNumberHidden" />
            <input type="hidden" asp-for="SortColumn" id="sortColumnHidden" />
            <input type="hidden" asp-for="SortDirection" id="sortDirectionHidden" />
            <input type="hidden" asp-for="DisplayColumnsString" id="displayColumnsHidden" />
            <input type="hidden" asp-for="ColumnOrder" id="columnOrderHidden" />
            @foreach (var col in filterCols)
            {
                <input type="hidden" name="FilterValues[@col]" id="fv_@col" value="@(Model.FilterValues.GetValueOrDefault(col, ""))" />
                <input type="hidden" name="FilterOperators[@col]" id="fo_@col" value="@(Model.FilterOperators.GetValueOrDefault(col, ""))" />
            }

            @* ===== ROW 1: Date Selection ===== *@
            <div class="row mb-3">
                <div class="col-12">
                    <label class="form-label fw-semibold mb-2">Quick Date Selection</label>
                    <div class="date-presets btn-group flex-wrap" role="group">
                        <input type="radio" class="btn-check" name="DatePreset" id="presetToday" value="today" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetToday">Today</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetYesterday" value="yesterday" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetYesterday">Yesterday</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLast7" value="last7" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLast7">Last 7 Days</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLast30" value="last30" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLast30">Last 30 Days</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetThisMonth" value="thisMonth" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetThisMonth">This Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastMonth" value="lastMonth" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLastMonth">Last Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetYTD" value="ytd" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetYTD">Year to Date</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastYear" value="lastYear" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLastYear">Last Year</label>
                    </div>
                </div>
            </div>

            <hr class="my-3">

            <div class="row g-3 mb-3 align-items-end">
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date Basis</label>
                    <select asp-for="DateBasis" class="form-select" asp-items="Html.GetEnumSelectList<CatalogueDateBasis>()"
                            title="Filter by Transaction Date (h.DateTrans) or Session Date (h.SessionDateTime)"></select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date From</label>
                    <input type="@(Model.UseDateTime ? "datetime-local" : "date")" asp-for="DateFrom" class="form-control" id="DateFrom"
                           value="@(Model.UseDateTime ? Model.DateFrom.ToString("yyyy-MM-ddTHH:mm") : Model.DateFrom.ToString("yyyy-MM-dd"))"
                           onchange="clearPreset()" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date To</label>
                    <input type="@(Model.UseDateTime ? "datetime-local" : "date")" asp-for="DateTo" class="form-control" id="DateTo"
                           value="@(Model.UseDateTime ? Model.DateTo.ToString("yyyy-MM-ddTHH:mm") : Model.DateTo.ToString("yyyy-MM-dd"))"
                           onchange="clearPreset()" />
                </div>
                <div class="col-6 col-md-1">
                    <label class="form-label fw-semibold small" title="Include time component in filter">Use Time</label>
                    <div class="form-check form-switch pt-1">
                        <input type="checkbox" asp-for="UseDateTime" class="form-check-input" id="UseDateTime"
                               onchange="onUseDateTimeToggle(this.checked)" />
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Report Mode</label>
                    <select asp-for="ReportMode" class="form-select" asp-items="Html.GetEnumSelectList<CatalogueReportMode>()"></select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Report On</label>
                    <select asp-for="ReportOn" class="form-select" asp-items="Html.GetEnumSelectList<CatalogueReportOn>()"></select>
                </div>
            </div>

            @* ===== ROW 3: Grouping + Report Title ===== *@
            <div class="row g-3 mb-3 align-items-end">
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Primary Group</label>
                    <select asp-for="PrimaryGroup" id="PrimaryGroup" class="form-select group-select" asp-items="Html.GetEnumSelectList<CatalogueGroupBy>()"></select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Secondary Group</label>
                    <select asp-for="SecondaryGroup" id="SecondaryGroup" class="form-select group-select" asp-items="Html.GetEnumSelectList<CatalogueGroupBy>()"></select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Third Group</label>
                    <select asp-for="ThirdGroup" id="ThirdGroup" class="form-select group-select" asp-items="Html.GetEnumSelectList<CatalogueGroupBy>()"></select>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label fw-semibold">Report Title</label>
                    <input type="text" asp-for="ReportTitle" class="form-control" id="ReportTitle"
                           placeholder="Power Report" />
                </div>
            </div>

            @* ===== ROW 4: Profit / Stock / Cost (dropdowns + Includes VAT) + Options (Show Gross/Profit/Stock) + Rows per page ===== *@
            <div class="row g-3 mb-4 align-items-start">
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold small mb-1">Profit Based On</label>
                    <select asp-for="ProfitBasedOn" class="form-select form-select-sm" asp-items="Html.GetEnumSelectList<CatalogueCostBasis>()"></select>
                    <div class="form-check mt-1">
                        <input type="checkbox" asp-for="ProfitIncludesVat" class="form-check-input" />
                        <label asp-for="ProfitIncludesVat" class="form-check-label small">Includes VAT</label>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold small mb-1">Stock Value Based On</label>
                    <select asp-for="StockValueBasedOn" class="form-select form-select-sm" asp-items="Html.GetEnumSelectList<CatalogueCostBasis>()"></select>
                    <div class="form-check mt-1">
                        <input type="checkbox" asp-for="StockValueIncludesVat" class="form-check-input" />
                        <label asp-for="StockValueIncludesVat" class="form-check-label small">Includes VAT</label>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold small mb-1">Cost Type</label>
                    <select asp-for="CostType" class="form-select form-select-sm" asp-items="Html.GetEnumSelectList<CatalogueCostBasis>()"></select>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label fw-semibold small mb-1">Display Options</label>
                    <div class="d-flex flex-wrap gap-3 pt-1">
                        <div class="form-check" title="Quick-toggle for Profit / Markup / Margin columns. Synced with Display Columns selector.">
                            <input type="checkbox" asp-for="ShowProfit" class="form-check-input" id="showProfitToggle" />
                            <label asp-for="ShowProfit" class="form-check-label small">Show Profit</label>
                        </div>
                        <div class="form-check" title="Quick-toggle for Stock Qty / Stock Value columns. Synced with Display Columns selector.">
                            <input type="checkbox" asp-for="ShowStock" class="form-check-input" id="showStockToggle" />
                            <label asp-for="ShowStock" class="form-check-label small">Show Stock</label>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold small mb-1">Rows per page</label>
                    <select asp-for="PageSize" class="form-select form-select-sm">
                        <option value="50">50</option>
                        <option value="100">100</option>
                        <option value="250">250</option>
                        <option value="500">500</option>
                    </select>
                </div>
            </div>

            <div class="report-form-actions d-flex flex-wrap gap-2 pt-2 border-top">
                <button type="submit" class="btn btn-primary btn-lg btn-generate" id="generateBtn">
                    <span class="btn-text"><i class="bi bi-play-fill me-2"></i>Generate Report</span>
                    <span class="spinner-border spinner-border-sm d-none" role="status"></span>
                </button>
                @if (Model.CanSchedule)
                {
                    <button type="button" class="btn btn-warning btn-lg" data-bs-toggle="modal" data-bs-target="#scheduleModal" title="Schedule recurring report delivery">
                        <i class="bi bi-clock-history me-2"></i>Schedule
                    </button>
                }
                <div class="btn-group ms-auto">
                    <div class="btn-group">
                        <button type="button" class="btn btn-outline-info dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false"
                                title="Saved report layouts" id="layoutsDropdownBtn">
                            <i class="bi bi-bookmark me-1"></i><span id="layoutsCurrentName">Layouts</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" id="layoutsDropdownMenu" style="min-width: 320px;">
                            <li><h6 class="dropdown-header">Loading...</h6></li>
                        </ul>
                    </div>
                    <button type="button" class="btn btn-outline-info" onclick="saveCurrentLayout()" title="Overwrite your default layout with current parameters">
                        <i class="bi bi-save me-1"></i>Save
                    </button>
                    <button type="button" class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#saveLayoutAsModal"
                            title="Save current parameters as a new named layout (optionally shared with all users)">
                        <i class="bi bi-bookmark-plus me-1"></i>Save as...
                    </button>
                    @if (Model.HasSavedLayout)
                    {
                        <button type="button" class="btn btn-outline-secondary" onclick="resetSavedLayout()" title="Discard your saved default layout and restore factory defaults">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Default
                        </button>
                    }
                    <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#columnSettingsModal" title="Choose which columns to show/hide">
                        <i class="bi bi-layout-three-columns me-1"></i>Columns
                    </button>
                </div>
                <a asp-action="Catalogue" class="btn btn-outline-secondary btn-reset" title="Clear all filters">
                    <i class="bi bi-funnel me-1"></i>Clear Filters
                </a>
            </div>
            @if (Model.HasSavedLayout)
            {
                <div class="mt-2"><small class="text-info"><i class="bi bi-check-circle me-1"></i>Saved layout loaded</small></div>
            }
        </form>
    </div>
</div>

@{
    var storesJson = System.Text.Json.JsonSerializer.Serialize(Model.AvailableStores.Select(s => new { code = s.StoreCode, name = s.StoreName }));
}
@await Html.PartialAsync("_ItemsSelection", new ItemsSelectionConfig
{
    ShowCategories = true,
    ShowDepartments = true,
    ShowBrands = true,
    ShowSeasons = true,
    ShowSuppliers = true,
    ShowCustomers = true,
    ShowAgents = true,
    ShowPostalCodes = true,
    ShowStores = true,
    ShowItems = false,
    ShowPaymentTypes = true,
    ShowZReports = true,
    ShowTowns = true,
    ShowUsers = true,
    StoresJson = storesJson,
    SavedFilterJson = Model.ItemsSelectionJson ?? ""
})

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.ErrorMessage</div>
}

@if (hasResults && Model.Totals != null)
{
    <div class="row mb-4 g-3">
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <div class="stat-value">@Model.Totals.TotalQuantity.ToString("N2")</div>
                <div class="stat-label">Total Quantity</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <div class="stat-value">@((useGross ? Model.Totals.TotalGrossAmount : Model.Totals.TotalNetValue).ToString("N2"))</div>
                <div class="stat-label">@(useGross ? "Total Gross" : "Total Net Value")</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                @{ var catProfitColor = Model.Totals.TotalProfitValue >= 0 ? "text-success" : "text-danger"; }
                <div class="stat-value @catProfitColor">@Model.Totals.TotalProfitValue.ToString("N2")</div>
                <div class="stat-label">Total Profit</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                @{ var catMarginColor = Model.Totals.TotalMargin >= 0 ? "text-success" : "text-danger"; }
                <div class="stat-value @catMarginColor">@Model.Totals.TotalMargin.ToString("N2")%</div>
                <div class="stat-label">Avg Margin</div>
            </div>
        </div>
    </div>
}

@if (hasResults)
{
    <div class="card mb-4" id="results">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>
                <i class="bi bi-table me-2"></i>
                <span id="resultsTitle">@(string.IsNullOrWhiteSpace(Model.ReportTitle) ? "Results" : Model.ReportTitle)</span>
                <span class="badge bg-primary ms-2">@Model.TotalCount.ToString("N0") rows</span>
                @if (Model.Totals != null)
                {
                    <span class="badge bg-secondary ms-1">@Model.DateFrom.ToString("dd/MM/yyyy") - @Model.DateTo.ToString("dd/MM/yyyy")</span>
                }
                <button type="button" class="btn btn-sm btn-outline-secondary ms-2" id="toggleSelectionsBtn"
                        title="Show/Hide active filter selections">
                    <i class="bi bi-list-check me-1"></i>Selections
                </button>
            </span>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <div class="btn-group btn-group-sm">
                    <button type="button" class="btn btn-outline-success" onclick="exportCatalogue('csv')">
                        <i class="bi bi-filetype-csv me-1"></i>CSV
                    </button>
                    <button type="button" class="btn btn-outline-success" onclick="exportCatalogue('excel')">
                        <i class="bi bi-filetype-xlsx me-1"></i>Excel
                    </button>
                </div>
                <button class="btn btn-sm btn-outline-primary" onclick="togglePreview()" id="previewToggleBtn" title="Toggle document-style preview">
                    <i class="bi bi-eye me-1"></i>Preview
                </button>
                <button class="btn btn-sm btn-outline-primary" onclick="openSendEmailModal()" title="Send report via email">
                    <i class="bi bi-envelope me-1"></i>Send to Email
                </button>
                <button class="btn btn-sm btn-outline-info" onclick="analyzeReport()" title="AI-powered report analysis" id="btnAnalyze">
                    <i class="bi bi-stars me-1"></i>AI Analyze
                </button>
            </div>
        </div>

        <div id="selectionsPanel" class="border-bottom px-3 py-2 bg-light small" style="display:none;">
            <strong class="text-muted">Active Selections:</strong>
            <div id="selectionsContent" class="mt-1 d-flex flex-wrap gap-2"></div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover table-striped mb-0" id="resultsTable">
                    <thead class="table-light sticky-top">
                        <tr>
                            @* data-fixed-left="1" marks columns that stay anchored to the left and are NOT part of
                               drag&drop reordering (controlled by Primary/Secondary/Third Group + Item visibility). *@
                            @if (hasL1) { <th class="sortable" data-col="Level1Description" data-fixed-left="1">Group 1</th> }
                            @if (hasL2) { <th class="sortable" data-col="Level2Description" data-fixed-left="1">Group 2</th> }
                            @if (hasL3) { <th class="sortable" data-col="Level3Description" data-fixed-left="1">Group 3</th> }
                            @if (showItem && dc("ItemCode")) { <th class="sortable" data-col="ItemCode" data-fixed-left="1">Code</th> }
                            @if (showItem && dc("MainBarcode")) { <th class="sortable" data-col="MainBarcode" data-fixed-left="1">Barcode</th> }
                            @if (showItem && dc("ItemName")) { <th class="sortable" data-col="ItemDescription" data-fixed-left="1">Description</th> }
                            @if (showItem && dc("ItemInvoiceDescription")) { <th class="sortable" data-col="ItemInvoiceDescription" data-fixed-left="1">Invoice Descr</th> }
                            @if (dc("Quantity")) { <th class="sortable text-end col-trans" data-col="Quantity">Qty</th> }
                            @if (dc("Value")) { <th class="sortable text-end col-trans" data-col="ValueBeforeDiscount">Value</th> }
                            @if (dc("Discount")) { <th class="sortable text-end col-trans" data-col="Discount">Discount</th> }
                            @if (dc("NetValue")) { <th class="sortable text-end col-trans" data-col="NetValue">Net Value</th> }
                            @if (dc("VatAmount")) { <th class="sortable text-end col-trans" data-col="VatAmount">VAT</th> }
                            @if (dc("GrossAmount")) { <th class="sortable text-end col-trans" data-col="GrossAmount">Gross Amt</th> }
                            @if (dc("Profit")) { <th class="sortable text-end col-profit" data-col="ProfitValue">Profit</th> }
                            @if (dc("Markup")) { <th class="text-end col-profit" data-col="Markup">Markup %</th> }
                            @if (dc("Margin")) { <th class="text-end col-profit" data-col="Margin">Margin %</th> }
                            @if (dc("Cost")) { <th class="sortable text-end col-cost" data-col="Cost">Cost</th> }
                            @if (dc("TotalCost")) { <th class="sortable text-end col-cost" data-col="TotalCost">Total Cost</th> }
                            @if (dc("TotalStockQty")) { <th class="sortable text-end col-stock" data-col="TotalStockQty">Stock Qty</th> }
                            @if (dc("TotalStockValue")) { <th class="text-end col-stock" data-col="TotalStockValue">Stock Value</th> }
                            @if (dc("EntityCode")) { <th data-col="EntityCode">Entity Code</th> }
                            @if (dc("EntityName")) { <th data-col="EntityName">Entity Name</th> }
                            @if (dc("EntityShortName")) { <th data-col="EntityShortName">Short Name</th> }
                            @if (dc("EntityID")) { <th data-col="EntityID">Entity ID</th> }
                            @if (dc("Sundry")) { <th data-col="Sundry">Sundry</th> }
                            @if (dc("InvoiceNumber")) { <th data-col="InvoiceNumber">Invoice No</th> }
                            @if (dc("InvoiceType")) { <th data-col="InvoiceType">Inv. Type</th> }
                            @if (dc("StoreCode")) { <th data-col="StoreCode">Store Code</th> }
                            @if (dc("StoreName")) { <th data-col="StoreName">Store</th> }
                            @if (dc("StationCode")) { <th data-col="StationCode">Station</th> }
                            @if (dc("DateTrans")) { <th class="sortable" data-col="DateTrans">Date</th> }
                            @if (dc("UserCode")) { <th data-col="UserCode">User</th> }
                            @if (dc("AgentName")) { <th data-col="AgentName">Agent</th> }
                            @if (dc("ZReportNumber")) { <th data-col="ZReportNumber">Z Report</th> }
                            @if (dc("PaymentType")) { <th data-col="PaymentType">Payment Type</th> }
                            @if (dc("ItemCategory")) { <th data-col="ItemCategory">Category</th> }
                            @if (dc("ItemDepartment")) { <th data-col="ItemDepartment">Department</th> }
                            @if (dc("Brand")) { <th data-col="Brand">Brand</th> }
                            @if (dc("Season")) { <th data-col="Season">Season</th> }
                            @if (dc("Model")) { <th data-col="Model">Model</th> }
                            @if (dc("Colour")) { <th data-col="Colour">Colour</th> }
                            @if (dc("Size")) { <th data-col="Size">Size</th> }
                            @if (dc("Franchise")) { <th data-col="Franchise">Franchise</th> }
                            @if (dc("CustomerCategory1")) { <th data-col="CustomerCategory1Descr">Cust Cat 1</th> }
                            @if (dc("CustomerCategory2")) { <th data-col="CustomerCategory2Descr">Cust Cat 2</th> }
                            @if (dc("CustomerCategory3")) { <th data-col="CustomerCategory3Descr">Cust Cat 3</th> }
                            @if (dc("ItemSupplier")) { <th data-col="ItemSupplier">Supplier</th> }
                            @if (dc("Price1Excl")) { <th class="text-end" data-col="Price1Excl">Price 1 Ex</th> }
                            @if (dc("Price1Incl")) { <th class="text-end" data-col="Price1Incl">Price 1 In</th> }
                            @if (dc("Price2Excl")) { <th class="text-end" data-col="Price2Excl">Price 2 Ex</th> }
                            @if (dc("Price2Incl")) { <th class="text-end" data-col="Price2Incl">Price 2 In</th> }
                            @if (dc("Price3Excl")) { <th class="text-end" data-col="Price3Excl">Price 3 Ex</th> }
                            @if (dc("Price3Incl")) { <th class="text-end" data-col="Price3Incl">Price 3 In</th> }
                            @if (dc("Price4Excl")) { <th class="text-end" data-col="Price4Excl">Price 4 Ex</th> }
                            @if (dc("Price4Incl")) { <th class="text-end" data-col="Price4Incl">Price 4 In</th> }
                            @if (dc("Price5Excl")) { <th class="text-end" data-col="Price5Excl">Price 5 Ex</th> }
                            @if (dc("Price5Incl")) { <th class="text-end" data-col="Price5Incl">Price 5 In</th> }
                            @if (dc("Price6Excl")) { <th class="text-end" data-col="Price6Excl">Price 6 Ex</th> }
                            @if (dc("Price6Incl")) { <th class="text-end" data-col="Price6Incl">Price 6 In</th> }
                            @if (dc("Price7Excl")) { <th class="text-end" data-col="Price7Excl">Price 7 Ex</th> }
                            @if (dc("Price7Incl")) { <th class="text-end" data-col="Price7Incl">Price 7 In</th> }
                            @if (dc("Price8Excl")) { <th class="text-end" data-col="Price8Excl">Price 8 Ex</th> }
                            @if (dc("Price8Incl")) { <th class="text-end" data-col="Price8Incl">Price 8 In</th> }
                            @if (dc("Price9Excl")) { <th class="text-end" data-col="Price9Excl">Price 9 Ex</th> }
                            @if (dc("Price9Incl")) { <th class="text-end" data-col="Price9Incl">Price 9 In</th> }
                            @if (dc("Price10Excl")) { <th class="text-end" data-col="Price10Excl">Price 10 Ex</th> }
                            @if (dc("Price10Incl")) { <th class="text-end" data-col="Price10Incl">Price 10 In</th> }
                            @if (dc("InvPriceExcl")) { <th class="text-end" data-col="InvPriceExcl">Inv. Price Ex</th> }
                            @if (dc("InvPriceIncl")) { <th class="text-end" data-col="InvPriceIncl">Inv. Price In</th> }
                            @if (dc("ItemAttr1")) { <th data-col="ItemAttr1">Attr 1</th> }
                            @if (dc("ItemAttr2")) { <th data-col="ItemAttr2">Attr 2</th> }
                            @if (dc("ItemAttr3")) { <th data-col="ItemAttr3">Attr 3</th> }
                            @if (dc("ItemAttr4")) { <th data-col="ItemAttr4">Attr 4</th> }
                            @if (dc("ItemAttr5")) { <th data-col="ItemAttr5">Attr 5</th> }
                            @if (dc("ItemAttr6")) { <th data-col="ItemAttr6">Attr 6</th> }
                        </tr>
                    </thead>
                    @{
                        int totalColumns = (hasL1?1:0)+(hasL2?1:0)+(hasL3?1:0)
                            + (showItem && dc("ItemCode") ? 1 : 0) + (showItem && dc("MainBarcode") ? 1 : 0)
                            + (showItem && dc("ItemName") ? 1 : 0) + (showItem && dc("ItemInvoiceDescription") ? 1 : 0)
                            + (dc("Quantity")?1:0)+(dc("Value")?1:0)+(dc("Discount")?1:0)+(dc("NetValue")?1:0)
                            + (dc("VatAmount")?1:0)+(dc("GrossAmount")?1:0)+(dc("Profit")?1:0)
                            + (dc("Markup")?1:0)+(dc("Margin")?1:0)+(dc("Cost")?1:0)+(dc("TotalCost")?1:0)
                            + (dc("TotalStockQty")?1:0)+(dc("TotalStockValue")?1:0);
                        var dimColsForCount = new[] {"EntityCode","EntityName","EntityShortName","EntityID","Sundry",
                            "CustomerCategory1","CustomerCategory2","CustomerCategory3",
                            "InvoiceNumber","InvoiceType",
                            "StoreCode","StoreName","StationCode","DateTrans","UserCode","AgentName",
                            "ZReportNumber","PaymentType","ItemCategory","ItemDepartment","Brand",
                            "Season","Model","Colour","Size","Franchise","ItemSupplier",
                            "Price1Excl","Price1Incl","Price2Excl","Price2Incl","Price3Excl","Price3Incl",
                            "Price4Excl","Price4Incl","Price5Excl","Price5Incl","Price6Excl","Price6Incl",
                            "Price7Excl","Price7Incl","Price8Excl","Price8Incl","Price9Excl","Price9Incl",
                            "Price10Excl","Price10Incl","InvPriceExcl","InvPriceIncl",
                            "ItemAttr1","ItemAttr2","ItemAttr3","ItemAttr4","ItemAttr5","ItemAttr6"};
                        foreach (var c in dimColsForCount) { if (dc(c)) totalColumns++; }

                        Func<CatalogueRow, object> renderDataRow = @<tr class="data-row">
                            @if (hasL1) { <td>@(@item.Level1Value)</td> }
                            @if (hasL2) { <td>@(@item.Level2Value)</td> }
                            @if (hasL3) { <td>@(@item.Level3Value)</td> }
                            @if (showItem && dc("ItemCode")) { <td class="text-nowrap fw-semibold"><a href="#" class="dd-link-item" data-item-code="@item.ItemCode" data-item-name="@item.ItemDescription" title="View transaction history / stock position">@item.ItemCode</a></td> }
                            @if (showItem && dc("MainBarcode")) { <td class="text-nowrap small">@item.MainBarcode</td> }
                            @if (showItem && dc("ItemName")) { <td><a href="#" class="dd-link-item" data-item-code="@item.ItemCode" data-item-name="@item.ItemDescription" title="View transaction history / stock position">@item.ItemDescription</a></td> }
                            @if (showItem && dc("ItemInvoiceDescription")) { <td class="small">@item.ItemInvoiceDescription</td> }
                            @if (dc("Quantity")) { <td class="text-end">@item.Quantity.ToString("N2")</td> }
                            @if (dc("Value")) { <td class="text-end">@item.ValueBeforeDiscount.ToString("N2")</td> }
                            @if (dc("Discount")) { <td class="text-end">@item.Discount.ToString("N2")</td> }
                            @if (dc("NetValue")) { <td class="text-end">@item.NetValue.ToString("N2")</td> }
                            @if (dc("VatAmount")) { <td class="text-end">@item.VatAmount.ToString("N2")</td> }
                            @if (dc("GrossAmount")) { <td class="text-end">@item.GrossAmount.ToString("N2")</td> }
                            @if (dc("Profit")) { <td class="text-end @(item.ProfitValue < 0 ? "text-danger" : "text-success")">@item.ProfitValue.ToString("N2")</td> }
                            @if (dc("Markup")) { <td class="text-end">@item.Markup.ToString("N1")%</td> }
                            @if (dc("Margin")) { <td class="text-end">@item.Margin.ToString("N1")%</td> }
                            @if (dc("Cost")) { <td class="text-end">@item.Cost.ToString("N2")</td> }
                            @if (dc("TotalCost")) { <td class="text-end">@item.TotalCost.ToString("N2")</td> }
                            @if (dc("TotalStockQty")) { <td class="text-end">@item.TotalStockQty.ToString("N0")</td> }
                            @if (dc("TotalStockValue")) { <td class="text-end">@item.TotalStockValue.ToString("N2")</td> }
                            @{var entityType = (item.InvoiceType == "P" || item.InvoiceType == "E") ? "supplier" : "customer";}
                            @if (dc("EntityCode")) { <td class="small"><a href="#" class="dd-link-entity" data-entity-code="@item.EntityCode" data-entity-type="@entityType" title="View entity details">@item.EntityCode</a></td> }
                            @if (dc("EntityName")) { <td class="small"><a href="#" class="dd-link-entity" data-entity-code="@item.EntityCode" data-entity-type="@entityType" title="View entity details">@item.EntityName</a></td> }
                            @if (dc("EntityShortName")) { <td class="small">@item.EntityShortName</td> }
                            @if (dc("EntityID")) { <td class="small">@item.EntityID</td> }
                            @if (dc("Sundry")) { <td class="small">@item.Sundry</td> }
                            @if (dc("InvoiceNumber")) { <td class="small">@item.InvoiceNumber</td> }
                            @if (dc("InvoiceType")) { <td class="small">@item.InvoiceType</td> }
                            @if (dc("StoreCode")) { <td class="small">@item.StoreCode</td> }
                            @if (dc("StoreName")) { <td class="small">@item.StoreName</td> }
                            @if (dc("StationCode")) { <td class="small">@item.StationCode</td> }
                            @if (dc("DateTrans")) { <td class="small text-nowrap">@(item.DateTrans?.ToString("dd/MM/yyyy") ?? "")</td> }
                            @if (dc("UserCode")) { <td class="small">@item.UserCode</td> }
                            @if (dc("AgentName")) { <td class="small">@item.AgentName</td> }
                            @if (dc("ZReportNumber")) { <td class="small">@item.ZReportNumber</td> }
                            @if (dc("PaymentType")) { <td class="small">@item.PaymentType</td> }
                            @if (dc("ItemCategory")) { <td class="small">@item.ItemCategoryDescr</td> }
                            @if (dc("ItemDepartment")) { <td class="small">@item.ItemDepartmentDescr</td> }
                            @if (dc("Brand")) { <td class="small">@item.BrandName</td> }
                            @if (dc("Season")) { <td class="small">@item.SeasonName</td> }
                            @if (dc("Model")) { <td class="small">@item.ModelCode</td> }
                            @if (dc("Colour")) { <td class="small">@item.Colour</td> }
                            @if (dc("Size")) { <td class="small">@item.Size</td> }
                            @if (dc("Franchise")) { <td class="small">@item.FranchiseName</td> }
                            @if (dc("CustomerCategory1")) { <td class="small">@item.CustomerCategory1Descr</td> }
                            @if (dc("CustomerCategory2")) { <td class="small">@item.CustomerCategory2Descr</td> }
                            @if (dc("CustomerCategory3")) { <td class="small">@item.CustomerCategory3Descr</td> }
                            @if (dc("ItemSupplier")) { <td class="small">@item.ItemSupplierName</td> }
                            @if (dc("Price1Excl")) { <td class="text-end">@item.Price1Excl.ToString("N2")</td> }
                            @if (dc("Price1Incl")) { <td class="text-end">@item.Price1Incl.ToString("N2")</td> }
                            @if (dc("Price2Excl")) { <td class="text-end">@item.Price2Excl.ToString("N2")</td> }
                            @if (dc("Price2Incl")) { <td class="text-end">@item.Price2Incl.ToString("N2")</td> }
                            @if (dc("Price3Excl")) { <td class="text-end">@item.Price3Excl.ToString("N2")</td> }
                            @if (dc("Price3Incl")) { <td class="text-end">@item.Price3Incl.ToString("N2")</td> }
                            @if (dc("Price4Excl")) { <td class="text-end">@item.Price4Excl.ToString("N2")</td> }
                            @if (dc("Price4Incl")) { <td class="text-end">@item.Price4Incl.ToString("N2")</td> }
                            @if (dc("Price5Excl")) { <td class="text-end">@item.Price5Excl.ToString("N2")</td> }
                            @if (dc("Price5Incl")) { <td class="text-end">@item.Price5Incl.ToString("N2")</td> }
                            @if (dc("Price6Excl")) { <td class="text-end">@item.Price6Excl.ToString("N2")</td> }
                            @if (dc("Price6Incl")) { <td class="text-end">@item.Price6Incl.ToString("N2")</td> }
                            @if (dc("Price7Excl")) { <td class="text-end">@item.Price7Excl.ToString("N2")</td> }
                            @if (dc("Price7Incl")) { <td class="text-end">@item.Price7Incl.ToString("N2")</td> }
                            @if (dc("Price8Excl")) { <td class="text-end">@item.Price8Excl.ToString("N2")</td> }
                            @if (dc("Price8Incl")) { <td class="text-end">@item.Price8Incl.ToString("N2")</td> }
                            @if (dc("Price9Excl")) { <td class="text-end">@item.Price9Excl.ToString("N2")</td> }
                            @if (dc("Price9Incl")) { <td class="text-end">@item.Price9Incl.ToString("N2")</td> }
                            @if (dc("Price10Excl")) { <td class="text-end">@item.Price10Excl.ToString("N2")</td> }
                            @if (dc("Price10Incl")) { <td class="text-end">@item.Price10Incl.ToString("N2")</td> }
                            @if (dc("InvPriceExcl")) { <td class="text-end">@item.InvPriceExcl.ToString("N2")</td> }
                            @if (dc("InvPriceIncl")) { <td class="text-end">@item.InvPriceIncl.ToString("N2")</td> }
                            @if (dc("ItemAttr1")) { <td class="small">@item.ItemAttr1Descr</td> }
                            @if (dc("ItemAttr2")) { <td class="small">@item.ItemAttr2Descr</td> }
                            @if (dc("ItemAttr3")) { <td class="small">@item.ItemAttr3Descr</td> }
                            @if (dc("ItemAttr4")) { <td class="small">@item.ItemAttr4Descr</td> }
                            @if (dc("ItemAttr5")) { <td class="small">@item.ItemAttr5Descr</td> }
                            @if (dc("ItemAttr6")) { <td class="small">@item.ItemAttr6Descr</td> }
                        </tr>;

                        // Renders a subtotal row (numeric sums + Markup/Margin recomputed from sums).
                        // item = Tuple(rows, label, bgColor, indent). Indent = empty group cells before the label.
                        Func<Tuple<List<CatalogueRow>, string, string, int>, object> renderSubtotal =
                            @<tr class="group-subtotal-row" style="background:@item.Item3;">
                                @{
                                    var subRows = ((List<CatalogueRow>)item.Item1);
                                    var subLabel = (string)item.Item2;
                                    var subIndent = (int)item.Item4;
                                    var subQty = subRows.Sum(r => r.Quantity);
                                    var subVal = subRows.Sum(r => r.ValueBeforeDiscount);
                                    var subDisc = subRows.Sum(r => r.Discount);
                                    var subNet = subRows.Sum(r => r.NetValue);
                                    var subVat = subRows.Sum(r => r.VatAmount);
                                    var subGross = subRows.Sum(r => r.GrossAmount);
                                    var subProfit = subRows.Sum(r => r.ProfitValue);
                                    var subTransCost = subRows.Sum(r => r.TransactionCost);
                                    var subTotalCost = subRows.Sum(r => r.TotalCost);
                                    var subStockQty = subRows.Sum(r => r.TotalStockQty);
                                    var subMargin = subNet != 0 ? Math.Round(subProfit / subNet * 100m, 2) : 0;
                                    var subMarkup = subTransCost != 0 ? Math.Round(subProfit / subTransCost * 100m, 2) : 0;

                                    int groupCols = (hasL1?1:0)+(hasL2?1:0)+(hasL3?1:0);
                                    int itemCols = (showItem && dc("ItemCode") ? 1 : 0) + (showItem && dc("MainBarcode") ? 1 : 0)
                                        + (showItem && dc("ItemName") ? 1 : 0) + (showItem && dc("ItemInvoiceDescription") ? 1 : 0);
                                    int labelSpan = (groupCols - subIndent) + itemCols;
                                    if (labelSpan < 1) labelSpan = 1;
                                }
                                @for (int i = 0; i < subIndent; i++) { <td></td> }
                                <td colspan="@labelSpan" class="fw-semibold text-uppercase text-muted">@subLabel</td>
                                @if (dc("Quantity")) { <td class="text-end fw-semibold">@subQty.ToString("N2")</td> }
                                @if (dc("Value")) { <td class="text-end fw-semibold">@subVal.ToString("N2")</td> }
                                @if (dc("Discount")) { <td class="text-end fw-semibold">@subDisc.ToString("N2")</td> }
                                @if (dc("NetValue")) { <td class="text-end fw-semibold">@subNet.ToString("N2")</td> }
                                @if (dc("VatAmount")) { <td class="text-end fw-semibold">@subVat.ToString("N2")</td> }
                                @if (dc("GrossAmount")) { <td class="text-end fw-semibold">@subGross.ToString("N2")</td> }
                                @if (dc("Profit")) { <td class="text-end fw-semibold @(subProfit < 0 ? "text-danger" : "text-success")">@subProfit.ToString("N2")</td> }
                                @if (dc("Markup")) { <td class="text-end fw-semibold">@subMarkup.ToString("N1")%</td> }
                                @if (dc("Margin")) { <td class="text-end fw-semibold">@subMargin.ToString("N1")%</td> }
                                @if (dc("Cost")) { <td></td> }
                                @if (dc("TotalCost")) { <td class="text-end fw-semibold">@subTotalCost.ToString("N2")</td> }
                                @if (dc("TotalStockQty")) { <td class="text-end fw-semibold">@subStockQty.ToString("N0")</td> }
                                @if (dc("TotalStockValue")) { <td></td> }
                                @foreach (var c in dimColsForCount) { if (dc(c)) { <td></td> } }
                            </tr>;
                    }
                    <tbody>
                        @if (hasL1)
                        {
                            var l1Groups = Model.Results.GroupBy(r => r.Level1Value ?? r.Level1 ?? "N/A").ToList();
                            foreach (var l1Group in l1Groups)
                            {
                                var l1Rows = l1Group.ToList();
                                <tr class="group-header-row" style="background:#dbeafe;">
                                    <td colspan="@totalColumns"><i class="bi bi-diagram-3 me-2"></i><strong>@Model.PrimaryGroup:</strong> @l1Group.Key</td>
                                </tr>

                                @if (hasL2)
                                {
                                    var l2Groups = l1Rows.GroupBy(r => r.Level2Value ?? "N/A").ToList();
                                    foreach (var l2Group in l2Groups)
                                    {
                                        var l2Rows = l2Group.ToList();
                                        <tr class="group-header-row" style="background:#e8f0fe;">
                                            <td colspan="@totalColumns" class="ps-4"><i class="bi bi-chevron-right me-1"></i><strong>@Model.SecondaryGroup:</strong> @l2Group.Key</td>
                                        </tr>

                                        @if (hasL3)
                                        {
                                            var l3Groups = l2Rows.GroupBy(r => r.Level3Value ?? "N/A").ToList();
                                            foreach (var l3Group in l3Groups)
                                            {
                                                var l3Rows = l3Group.ToList();
                                                <tr class="group-header-row" style="background:#f0f4f8;">
                                                    <td colspan="@totalColumns" class="ps-5"><i class="bi bi-dash me-1"></i><strong>@Model.ThirdGroup:</strong> @l3Group.Key</td>
                                                </tr>
                                                @foreach (var r in l3Rows) { @renderDataRow(r) }
                                                @renderSubtotal(Tuple.Create(l3Rows, l3Group.Key + " subtotal", "#f0f4f8", 3))
                                            }
                                        }
                                        else
                                        {
                                            @foreach (var r in l2Rows) { @renderDataRow(r) }
                                        }

                                        @renderSubtotal(Tuple.Create(l2Rows, l2Group.Key + " subtotal", "#e8f0fe", 2))
                                    }
                                }
                                else
                                {
                                    @foreach (var r in l1Rows) { @renderDataRow(r) }
                                }

                                @renderSubtotal(Tuple.Create(l1Rows, l1Group.Key + " total", "#dbeafe", 1))
                            }
                        }
                        else
                        {
                            @foreach (var r in Model.Results) { @renderDataRow(r) }
                        }
                    </tbody>
                    @if (Model.Totals != null)
                    {
                        int countGroupCols = (hasL1 ? 1 : 0) + (hasL2 ? 1 : 0) + (hasL3 ? 1 : 0);
                        int countItemCols = (showItem && dc("ItemCode") ? 1 : 0) + (showItem && dc("MainBarcode") ? 1 : 0)
                            + (showItem && dc("ItemName") ? 1 : 0) + (showItem && dc("ItemInvoiceDescription") ? 1 : 0);
                        int spanCols = countGroupCols + countItemCols;

                        <tfoot>
                            <tr class="grand-total-row">
                                @if (spanCols > 0) { <td colspan="@spanCols"><i class="bi bi-calculator me-1"></i>GRAND TOTAL</td> }
                                @if (dc("Quantity")) { <td class="text-end">@Model.Totals.TotalQuantity.ToString("N2")</td> }
                                @if (dc("Value")) { <td class="text-end">@Model.Totals.TotalValueBeforeDiscount.ToString("N2")</td> }
                                @if (dc("Discount")) { <td class="text-end">@Model.Totals.TotalDiscount.ToString("N2")</td> }
                                @if (dc("NetValue")) { <td class="text-end">@Model.Totals.TotalNetValue.ToString("N2")</td> }
                                @if (dc("VatAmount")) { <td class="text-end">@Model.Totals.TotalVatAmount.ToString("N2")</td> }
                                @if (dc("GrossAmount")) { <td class="text-end">@Model.Totals.TotalGrossAmount.ToString("N2")</td> }
                                @if (dc("Profit")) { <td class="text-end">@Model.Totals.TotalProfitValue.ToString("N2")</td> }
                                @if (dc("Markup")) { <td class="text-end">@Model.Totals.TotalMarkup.ToString("N1")%</td> }
                                @if (dc("Margin")) { <td class="text-end">@Model.Totals.TotalMargin.ToString("N1")%</td> }
                                @if (dc("Cost")) { <td></td> }
                                @if (dc("TotalCost")) { <td class="text-end">@Model.Totals.TotalTotalCost.ToString("N2")</td> }
                                @if (dc("TotalStockQty")) { <td class="text-end">@Model.Totals.TotalStockQty.ToString("N0")</td> }
                                @if (dc("TotalStockValue")) { <td></td> }
                                @{
                                    var dimCols = new[] {"EntityCode","EntityName","EntityShortName","EntityID","Sundry",
                                        "CustomerCategory1","CustomerCategory2","CustomerCategory3",
                                        "InvoiceNumber","InvoiceType",
                                        "StoreCode","StoreName","StationCode","DateTrans","UserCode","AgentName",
                                        "ZReportNumber","PaymentType","ItemCategory","ItemDepartment","Brand",
                                        "Season","Model","Colour","Size","Franchise","ItemSupplier",
                                        "Price1Excl","Price1Incl","Price2Excl","Price2Incl","Price3Excl","Price3Incl",
                                        "Price4Excl","Price4Incl","Price5Excl","Price5Incl","Price6Excl","Price6Incl",
                                        "Price7Excl","Price7Incl","Price8Excl","Price8Incl","Price9Excl","Price9Incl",
                                        "Price10Excl","Price10Incl","InvPriceExcl","InvPriceIncl",
                                        "ItemAttr1","ItemAttr2","ItemAttr3","ItemAttr4","ItemAttr5","ItemAttr6"};
                                }
                                @foreach (var c in dimCols) { if (dc(c)) { <td></td> } }
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>

    @* Preview panel — hidden by default, toggled via Preview button in results toolbar.
       Mirrors PurchasesSales preview pattern (panel with iframe, dark backdrop). *@
    <div id="previewPanel" style="display:none;" class="mt-3 mb-4">
        <div class="card border-primary">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-2">
                <span><i class="bi bi-file-earmark-text me-2"></i>Document Preview</span>
                <button class="btn btn-sm btn-outline-light" onclick="togglePreview()"><i class="bi bi-x-lg me-1"></i>Back to Grid</button>
            </div>
            <div class="card-body p-0">
                <iframe id="previewFrame" src="about:blank" style="width:100%;border:none;min-height:700px;background:#525659;"></iframe>
            </div>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="d-flex justify-content-between align-items-center mb-4">
            <span class="text-muted small">Page @Model.PageNumber of @Model.TotalPages (@Model.TotalCount.ToString("N0") total rows)</span>
            <ul class="pagination mb-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="#" onclick="goToPage(@(Model.PageNumber - 1)); return false;">Previous</a>
                </li>
                @for (int p = Math.Max(1, Model.PageNumber - 3); p <= Math.Min(Model.TotalPages, Model.PageNumber + 3); p++)
                {
                    <li class="page-item @(p == Model.PageNumber ? "active" : "")">
                        <a class="page-link" href="#" onclick="goToPage(@p); return false;">@p</a>
                    </li>
                }
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="#" onclick="goToPage(@(Model.PageNumber + 1)); return false;">Next</a>
                </li>
            </ul>
        </nav>
    }
}
else if (ViewContext.HttpContext.Request.Method == "POST")
{
    <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>No data found for the selected parameters.</div>
}

<style>
    /* Table theme: match PurchasesSales / AverageBasket — minimal, two semantic colors */
    #resultsTable thead th { background: #f8fafc; color: #334155; font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.3px; border-bottom: 2px solid #e2e8f0; }
    #resultsTable thead th.col-trans  { background: #eff6ff !important; color: #1e40af; }  /* Qty/Value/Net/VAT/Gross */
    #resultsTable thead th.col-profit { background: #ecfdf5 !important; color: #065f46; }  /* Profit/Markup/Margin */
    #resultsTable thead th.col-cost   { background: #fff7ed !important; color: #9a3412; }  /* Cost/Total Cost */
    #resultsTable thead th.col-stock  { background: #f5f3ff !important; color: #5b21b6; }  /* Stock Qty/Value */

    #resultsTable thead th.sortable { cursor: pointer; user-select: none; }
    #resultsTable thead th.sortable:hover { filter: brightness(0.96); }

    #results { scroll-margin-top: 16px; }

    /* Drill-down link style (same as PurchasesSales) */
    #resultsTable a.dd-link-item { color: #2563eb; text-decoration: none; cursor: pointer; border-bottom: 1px dashed #2563eb; }
    #resultsTable a.dd-link-item:hover { color: #1d4ed8; border-bottom-style: solid; }
    #resultsTable a.dd-link-entity { color: #7c3aed; text-decoration: none; cursor: pointer; border-bottom: 1px dashed #7c3aed; }
    #resultsTable a.dd-link-entity:hover { color: #5b21b6; border-bottom-style: solid; }

    /* Column reorder (Column Options modal) */
    #colToggleList .col-reorderable { cursor: default; }
    #colToggleList .col-drag-handle { cursor: grab; padding: 2px 4px; border-radius: 3px; }
    #colToggleList .col-drag-handle:hover { background: #e2e8f0; color: #334155 !important; }
    #colToggleList .col-reorderable.dragging { opacity: 0.45; background: #e0f2fe !important; }
    #colToggleList .col-reorderable.drop-before { border-top: 2px solid #2563eb !important; }
    #colToggleList .col-reorderable.drop-after  { border-bottom: 2px solid #2563eb !important; }
    #colToggleList .btn-group .btn { padding: 0.1rem 0.35rem; font-size: 0.75rem; line-height: 1; }

    /* Highlight toggled row that requires a refresh (column not yet in the rendered grid) */
    #colToggleList label.col-needs-refresh { background: #fff3cd !important; border-left: 3px solid #f59e0b; }

    /* Pulse animation for "Apply & Refresh" when there are uncommitted column changes that affect data */
    @@keyframes applyColsPulse {
        0%   { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.7); }
        70%  { box-shadow: 0 0 0 10px rgba(245, 158, 11, 0); }
        100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0); }
    }
    #applyColumnsBtn.needs-refresh {
        background: #f59e0b !important; border-color: #d97706 !important;
        animation: applyColsPulse 1.6s infinite;
    }
</style>

<!-- Schedule Modal -->
<div class="modal fade" id="scheduleModal" tabindex="-1" aria-labelledby="scheduleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="scheduleModalLabel"><i class="bi bi-clock-history me-2"></i>Schedule Catalogue Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-light border mb-3 py-2">
                    <small class="text-muted">
                        <i class="bi bi-info-circle me-1"></i>
                        The report will run automatically and recipients will receive an email with a link to download the exported file.
                    </small>
                </div>

                <h6 class="text-muted mb-2"><i class="bi bi-funnel me-1"></i>Parameters (current selection)</h6>
                <div class="bg-light rounded p-2 mb-3 small">
                    <span class="me-3"><strong>Mode:</strong> @Model.ReportMode</span>
                    <span class="me-3"><strong>Report On:</strong> @Model.ReportOn</span>
                    @if (Model.HasPrimaryGroup)
                    {
                        <span class="me-3"><strong>Group:</strong> @Model.PrimaryGroup @(Model.HasSecondaryGroup ? $"→ {Model.SecondaryGroup}" : "") @(Model.HasThirdGroup ? $"→ {Model.ThirdGroup}" : "")</span>
                    }
                    @if (Model.SelectedStoreCodes.Any())
                    {
                        <span><strong>Stores:</strong> @Model.SelectedStoreCodes.Count selected</span>
                    }
                </div>

                <h6 class="text-muted mb-2"><i class="bi bi-calendar-range me-1"></i>Report date range</h6>
                <p class="small text-muted mb-2">Computed when the schedule runs (e.g. last 7 days from run date).</p>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Period type</label>
                        <select class="form-select" id="schedDateRangeType" onchange="onSchedDateRangeTypeChange()">
                            <option value="LastNDays" data-value="7">Last 7 days</option>
                            <option value="LastNDays" data-value="30">Last 30 days</option>
                            <option value="ThisMonth">This month (to today)</option>
                            <option value="LastMonth">Last month</option>
                            <option value="YearToDate">Year to date</option>
                            <option value="LastYear">Last year</option>
                            <option value="Custom">Custom (fixed dates)</option>
                        </select>
                    </div>
                    <div class="col-md-3" id="schedCustomDateFromWrap" style="display:none;">
                        <label class="form-label fw-semibold">From</label>
                        <input type="date" class="form-control" id="schedDateFrom" value="@Model.DateFrom.ToString("yyyy-MM-dd")">
                    </div>
                    <div class="col-md-3" id="schedCustomDateToWrap" style="display:none;">
                        <label class="form-label fw-semibold">To</label>
                        <input type="date" class="form-control" id="schedDateTo" value="@Model.DateTo.ToString("yyyy-MM-dd")">
                    </div>
                </div>

                <h6 class="text-muted mb-2"><i class="bi bi-gear me-1"></i>Schedule settings</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Schedule Name</label>
                        <input type="text" class="form-control" id="schedName" placeholder="e.g. Weekly Catalogue Summary" required>
                        <input type="hidden" id="schedId" value="">
                        <small class="text-muted">A label to identify this schedule in the list</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Export Format</label>
                        <select class="form-select" id="schedFormat">
                            <option value="Excel">Excel (.xlsx)</option>
                            <option value="CSV">CSV</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Recurrence</label>
                        <select class="form-select" id="schedRecurrence" onchange="onRecurrenceChange()">
                            <option value="Once">Run Once</option>
                            <option value="Daily" selected>Daily</option>
                            <option value="Weekly">Weekly</option>
                            <option value="Monthly">Monthly</option>
                        </select>
                    </div>
                    <div class="col-md-4" id="schedDayContainer" style="display:none;">
                        <label class="form-label fw-semibold" id="schedDayLabel">Day</label>
                        <select class="form-select" id="schedDay">
                            <option value="1">Monday</option>
                            <option value="2">Tuesday</option>
                            <option value="3">Wednesday</option>
                            <option value="4">Thursday</option>
                            <option value="5">Friday</option>
                            <option value="6">Saturday</option>
                            <option value="0">Sunday</option>
                        </select>
                    </div>
                    <div class="col-md-4" id="schedWeeklyDaysContainer" style="display:none;">
                        <label class="form-label fw-semibold">Days of week</label>
                        <div class="d-flex flex-wrap gap-2">
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="1"> Mon</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="2"> Tue</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="3"> Wed</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="4"> Thu</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="5"> Fri</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="6"> Sat</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="0"> Sun</label>
                        </div>
                    </div>
                    <div class="col-md-4" id="schedMonthDayContainer" style="display:none;">
                        <label class="form-label fw-semibold">Day of month</label>
                        <select class="form-select" id="schedMonthDay">
                            @for (var i = 1; i <= 28; i++) { <option value="@i">@i</option> }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Time</label>
                        <input type="time" class="form-control" id="schedTime" value="08:00">
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Start date (recurrence)</label>
                        <input type="date" class="form-control" id="schedStartDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" min="@DateTime.Today.ToString("yyyy-MM-dd")" style="max-width:12rem;">
                    </div>

                    <div class="col-12 mt-2">
                        <h6 class="text-muted mb-2"><i class="bi bi-envelope me-1"></i>Recipients</h6>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Email addresses</label>
                        <input type="text" class="form-control" id="schedRecipients" placeholder="user@@company.com, manager@@company.com">
                        <small class="text-muted">Separate multiple addresses with commas</small>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Email Subject <span class="text-muted fw-normal">(optional)</span></label>
                        <input type="text" class="form-control" id="schedSubject" placeholder="Catalogue Report - {date}">
                    </div>

                    <div class="col-12 mt-3">
                        <h6 class="text-muted mb-2"><i class="bi bi-stars me-1"></i>AI Analysis</h6>
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="schedSkipIfEmpty">
                            <label class="form-check-label fw-semibold" for="schedSkipIfEmpty">Don't send if empty</label>
                        </div>
                        <small class="text-muted d-block mb-3">When enabled, the email will not be sent if the report returns 0 records.</small>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="schedIncludeAi" onchange="onSchedAiToggle()">
                            <label class="form-check-label fw-semibold" for="schedIncludeAi">Include AI Analysis in email</label>
                        </div>
                        <small class="text-muted d-block mt-1">When enabled, an AI-generated business intelligence summary will be included in the scheduled email body.</small>
                        <div id="schedAiDetails" class="mt-2 ps-4" style="display:none;">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto">
                                    <label class="form-label small mb-0 fw-semibold" for="schedAiLocale">Language</label>
                                </div>
                                <div class="col-auto">
                                    <select class="form-select form-select-sm" id="schedAiLocale" style="width:auto;min-width:140px;">
                                        <option value="el">Ελληνικά</option>
                                        <option value="en">English</option>
                                        <option value="sr">Srpski</option>
                                        <option value="de">Deutsch</option>
                                        <option value="fr">Français</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div id="scheduleAlert" class="mt-3" style="display:none;"></div>

                <hr class="my-3">
                <h6 class="text-muted"><i class="bi bi-list-check me-1"></i>Existing Schedules</h6>
                <div id="existingSchedules" class="small text-muted">Loading...</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary me-auto" onclick="resetScheduleForm()" title="Clear the form to create a new schedule">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveSchedule()">
                    <i class="bi bi-check-lg me-1"></i>Save Schedule
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Column Settings Modal (searchable) -->
<div class="modal fade" id="columnSettingsModal" tabindex="-1" aria-labelledby="columnSettingsLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="columnSettingsLabel"><i class="bi bi-layout-three-columns me-2"></i>Column Visibility</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-2">
                    Choose which columns appear in the table. Changes to column selection require re-running the report
                    (press <strong>Apply &amp; Refresh</strong>).
                </p>
                @* Prominent dirty banner — shown the moment the user checks a column that is NOT currently rendered.
                   Placed ABOVE the list (within user's eye-line), not below. *@
                <div id="colAddBanner" class="alert alert-warning py-2 px-3 mb-3 d-none" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <span id="colAddBannerText">New columns selected — click <strong>Apply &amp; Refresh</strong> to load their data.</span>
                </div>
                <div class="input-group mb-3">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" id="colSearchInput" placeholder="Search columns..." oninput="filterColumnList()">
                </div>
                <div class="border rounded" style="max-height: 360px; overflow-y: auto;">
                    <div class="list-group list-group-flush" id="colToggleList">
                        @{
                            // Tuple: (SqlColName used on <th> data-col, UI label, search keywords, DisplayColumnsString key, IsGroupingLevel, IsDisplayColCandidate)
                            // When IsGroupingLevel = true, the column is controlled solely by Primary/Secondary/Third Group selects (not by DisplayColumns).
                            var visCols = new (string SqlCol, string Label, string Search, string DispKey, bool IsGrouping, bool IsActive, bool CanToggle)[] {
                                ("Level1Description","Group 1","group 1 level1","", true, hasL1, false),
                                ("Level2Description","Group 2","group 2 level2","", true, hasL2, false),
                                ("Level3Description","Group 3","group 3 level3","", true, hasL3, false),
                                ("ItemCode","Code","code itemcode","ItemCode", false, dc("ItemCode"), showItem),
                                ("MainBarcode","Barcode","barcode mainbarcode","MainBarcode", false, dc("MainBarcode"), showItem),
                                ("ItemDescription","Description","description itemname name","ItemName", false, dc("ItemName"), showItem),
                                ("ItemInvoiceDescription","Invoice Description","invoice description detail","ItemInvoiceDescription", false, dc("ItemInvoiceDescription"), showItem),
                                ("Quantity","Qty","qty quantity","Quantity", false, dc("Quantity"), true),
                                ("ValueBeforeDiscount","Value","value before discount","Value", false, dc("Value"), true),
                                ("Discount","Discount","discount","Discount", false, dc("Discount"), true),
                                ("NetValue","Net Value","net value","NetValue", false, dc("NetValue"), true),
                                ("VatAmount","VAT","vat tax","VatAmount", false, dc("VatAmount"), true),
                                ("GrossAmount","Gross Amt","gross amount","GrossAmount", false, dc("GrossAmount"), true),
                                ("ProfitValue","Profit","profit","Profit", false, dc("Profit"), true),
                                ("Markup","Markup %","markup","Markup", false, dc("Markup"), true),
                                ("Margin","Margin %","margin","Margin", false, dc("Margin"), true),
                                ("Cost","Cost","cost","Cost", false, dc("Cost"), true),
                                ("TotalCost","Total Cost","total cost","TotalCost", false, dc("TotalCost"), true),
                                ("TotalStockQty","Stock Qty","stock qty quantity","TotalStockQty", false, dc("TotalStockQty"), true),
                                ("TotalStockValue","Stock Value","stock value","TotalStockValue", false, dc("TotalStockValue"), true),
                                ("EntityCode","Entity Code","entity code customer supplier","EntityCode", false, dc("EntityCode"), true),
                                ("EntityName","Entity Name","entity name customer supplier","EntityName", false, dc("EntityName"), true),
                                ("EntityShortName","Short Name","short name entity","EntityShortName", false, dc("EntityShortName"), true),
                                ("EntityID","Entity ID","entity id customer supplier","EntityID", false, dc("EntityID"), true),
                                ("Sundry","Sundry","sundry notes","Sundry", false, dc("Sundry"), true),
                                ("InvoiceNumber","Invoice No","invoice number no","InvoiceNumber", false, dc("InvoiceNumber"), true),
                                ("InvoiceType","Inv. Type","invoice type","InvoiceType", false, dc("InvoiceType"), true),
                                ("StoreCode","Store Code","store code","StoreCode", false, dc("StoreCode"), true),
                                ("StoreName","Store","store name","StoreName", false, dc("StoreName"), true),
                                ("StationCode","Station","station","StationCode", false, dc("StationCode"), true),
                                ("DateTrans","Date","date transaction","DateTrans", false, dc("DateTrans"), true),
                                ("UserCode","User","user code","UserCode", false, dc("UserCode"), true),
                                ("AgentName","Agent","agent","AgentName", false, dc("AgentName"), true),
                                ("ZReportNumber","Z Report","z report","ZReportNumber", false, dc("ZReportNumber"), true),
                                ("PaymentType","Payment Type","payment type","PaymentType", false, dc("PaymentType"), true),
                                ("ItemCategory","Category","category","ItemCategory", false, dc("ItemCategory"), true),
                                ("ItemDepartment","Department","department","ItemDepartment", false, dc("ItemDepartment"), true),
                                ("Brand","Brand","brand","Brand", false, dc("Brand"), true),
                                ("Season","Season","season","Season", false, dc("Season"), true),
                                ("Model","Model","model","Model", false, dc("Model"), true),
                                ("Colour","Colour","colour color","Colour", false, dc("Colour"), true),
                                ("Size","Size","size","Size", false, dc("Size"), true),
                                ("Franchise","Franchise","franchise","Franchise", false, dc("Franchise"), true),
                                ("CustomerCategory1Descr","Cust Cat 1","customer category 1","CustomerCategory1", false, dc("CustomerCategory1"), true),
                                ("CustomerCategory2Descr","Cust Cat 2","customer category 2","CustomerCategory2", false, dc("CustomerCategory2"), true),
                                ("CustomerCategory3Descr","Cust Cat 3","customer category 3","CustomerCategory3", false, dc("CustomerCategory3"), true),
                                ("ItemSupplier","Supplier","supplier","ItemSupplier", false, dc("ItemSupplier"), true),
                                ("Price1Excl","Price 1 Ex","price 1 excl","Price1Excl", false, dc("Price1Excl"), true),
                                ("Price1Incl","Price 1 In","price 1 incl","Price1Incl", false, dc("Price1Incl"), true),
                                ("Price2Excl","Price 2 Ex","price 2 excl","Price2Excl", false, dc("Price2Excl"), true),
                                ("Price2Incl","Price 2 In","price 2 incl","Price2Incl", false, dc("Price2Incl"), true),
                                ("Price3Excl","Price 3 Ex","price 3 excl","Price3Excl", false, dc("Price3Excl"), true),
                                ("Price3Incl","Price 3 In","price 3 incl","Price3Incl", false, dc("Price3Incl"), true),
                                ("Price4Excl","Price 4 Ex","price 4 excl","Price4Excl", false, dc("Price4Excl"), true),
                                ("Price4Incl","Price 4 In","price 4 incl","Price4Incl", false, dc("Price4Incl"), true),
                                ("Price5Excl","Price 5 Ex","price 5 excl","Price5Excl", false, dc("Price5Excl"), true),
                                ("Price5Incl","Price 5 In","price 5 incl","Price5Incl", false, dc("Price5Incl"), true),
                                ("Price6Excl","Price 6 Ex","price 6 excl","Price6Excl", false, dc("Price6Excl"), true),
                                ("Price6Incl","Price 6 In","price 6 incl","Price6Incl", false, dc("Price6Incl"), true),
                                ("Price7Excl","Price 7 Ex","price 7 excl","Price7Excl", false, dc("Price7Excl"), true),
                                ("Price7Incl","Price 7 In","price 7 incl","Price7Incl", false, dc("Price7Incl"), true),
                                ("Price8Excl","Price 8 Ex","price 8 excl","Price8Excl", false, dc("Price8Excl"), true),
                                ("Price8Incl","Price 8 In","price 8 incl","Price8Incl", false, dc("Price8Incl"), true),
                                ("Price9Excl","Price 9 Ex","price 9 excl","Price9Excl", false, dc("Price9Excl"), true),
                                ("Price9Incl","Price 9 In","price 9 incl","Price9Incl", false, dc("Price9Incl"), true),
                                ("Price10Excl","Price 10 Ex","price 10 excl","Price10Excl", false, dc("Price10Excl"), true),
                                ("Price10Incl","Price 10 In","price 10 incl","Price10Incl", false, dc("Price10Incl"), true),
                                ("InvPriceExcl","Inv. Price Ex","invoice price excl line","InvPriceExcl", false, dc("InvPriceExcl"), true),
                                ("InvPriceIncl","Inv. Price In","invoice price incl line","InvPriceIncl", false, dc("InvPriceIncl"), true),
                                ("ItemAttr1","Attr 1","attribute 1","ItemAttr1", false, dc("ItemAttr1"), true),
                                ("ItemAttr2","Attr 2","attribute 2","ItemAttr2", false, dc("ItemAttr2"), true),
                                ("ItemAttr3","Attr 3","attribute 3","ItemAttr3", false, dc("ItemAttr3"), true),
                                ("ItemAttr4","Attr 4","attribute 4","ItemAttr4", false, dc("ItemAttr4"), true),
                                ("ItemAttr5","Attr 5","attribute 5","ItemAttr5", false, dc("ItemAttr5"), true),
                                ("ItemAttr6","Attr 6","attribute 6","ItemAttr6", false, dc("ItemAttr6"), true)
                            };
                            var togglableCount = visCols.Count(c => c.CanToggle && !c.IsGrouping);
                        }
                        @foreach (var c in visCols)
                        {
                            var disabled = c.IsGrouping || !c.CanToggle;
                            var reorderable = !c.IsGrouping; // grouping cols stay anchored left; everything else can be moved
                            var titleAttr = c.IsGrouping
                                ? "Controlled by the Primary/Secondary/Third Group selector"
                                : (!c.CanToggle ? "Item columns are available in detailed/ungrouped mode only" : "");
                            <label class="list-group-item list-group-item-action d-flex align-items-center @(disabled ? "disabled text-muted" : "") @(reorderable ? "col-reorderable" : "")"
                                   data-col-name="@c.Search"
                                   data-col-sql="@c.SqlCol"
                                   draggable="@(reorderable ? "true" : "false")"
                                   title="@titleAttr">
                                @if (reorderable)
                                {
                                    <span class="col-drag-handle me-2 text-muted" title="Drag to reorder"><i class="bi bi-grip-vertical"></i></span>
                                }
                                else
                                {
                                    <span class="me-2 text-muted" title="Anchored left (grouping column)"><i class="bi bi-lock-fill small"></i></span>
                                }
                                <input class="form-check-input col-toggle me-2"
                                       type="checkbox"
                                       value="@c.SqlCol"
                                       data-disp-key="@c.DispKey"
                                       data-is-grouping="@(c.IsGrouping ? "1" : "0")"
                                       @(c.IsActive ? "checked" : "")
                                       @(disabled ? "disabled" : "")
                                       onchange="onColToggleChange(this)">
                                <span class="flex-grow-1">@c.Label</span>
                                @if (c.IsGrouping)
                                {
                                    <span class="badge bg-info ms-2 small">Grouping</span>
                                }
                                @if (reorderable)
                                {
                                    <span class="btn-group btn-group-sm ms-2" role="group" aria-label="Reorder column">
                                        <button type="button" class="btn btn-outline-secondary btn-sm col-move-up" tabindex="-1"
                                                onclick="moveColumnOrder(this, -1)" title="Move up">
                                            <i class="bi bi-chevron-up"></i>
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary btn-sm col-move-down" tabindex="-1"
                                                onclick="moveColumnOrder(this, 1)" title="Move down">
                                            <i class="bi bi-chevron-down"></i>
                                        </button>
                                    </span>
                                }
                            </label>
                        }
                    </div>
                </div>
                <div class="mt-2 d-flex justify-content-between small text-muted">
                    <span><span id="colVisibleCount">0</span> of @togglableCount columns selected</span>
                    <span id="colDirtyIndicator" class="text-warning" style="display:none;">
                        <i class="bi bi-exclamation-circle me-1"></i>Press <strong>Apply &amp; Refresh</strong> to see changes
                    </span>
                </div>
                <div class="mt-1 small text-muted">
                    <i class="bi bi-info-circle me-1"></i>Drag <i class="bi bi-grip-vertical"></i> or use <i class="bi bi-chevron-up"></i>/<i class="bi bi-chevron-down"></i> to reorder columns. Order applies immediately to the grid and is remembered for this session.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleAllColumns(true)">Select All</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleAllColumns(false)">Deselect All</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="resetDefaultColumns()">Reset to Default</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="applyColumnsBtn" onclick="applyAndRefreshColumns()">
                    <i class="bi bi-arrow-clockwise me-1"></i>Apply &amp; Refresh
                </button>
            </div>
        </div>
    </div>
</div>

<!-- AI Analysis Modal -->
<div class="modal fade" id="aiAnalysisModal" tabindex="-1" aria-labelledby="aiAnalysisModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
