function saveSchedule(){var name=document.getElementById('schedName').value.trim();var recipients=document.getElementById('schedRecipients').value.trim();var alertDiv=document.getElementById('scheduleAlert');if(!name||!recipients){alertDiv.innerHTML='<div class="alert alert-warning mb-0">Please fill in schedule name and recipients.</div>';alertDiv.style.display='';return;}var ev=validateEmailList(recipients);if(!ev.valid){alertDiv.innerHTML='<div class="alert alert-warning mb-0">Invalid email(s): '+ev.errors.join('; ')+'</div>';alertDiv.style.display='';return;}var recurrence=document.getElementById('schedRecurrence').value;if(recurrence==='Once'){var sd=document.getElementById('schedStartDate').value;var today=new Date().toISOString().slice(0,10);if(!sd||sd<today){alertDiv.innerHTML='<div class="alert alert-warning mb-0">Start date must be today or later.</div>';alertDiv.style.display='';return;}}var day=(recurrence==='Monthly')?parseInt(document.getElementById('schedMonthDay').value,10):null;var fd=new FormData();fd.append('scheduleName',name);fd.append('recurrenceType',recurrence);if(day!==null&&!isNaN(day))fd.append('recurrenceDay',day);fd.append('scheduleTime',document.getElementById('schedTime').value);fd.append('exportFormat',document.getElementById('schedFormat').value);fd.append('recipients',recipients);fd.append('emailSubject',document.getElementById('schedSubject').value);fd.append('includeAiAnalysis',document.getElementById('schedIncludeAi').checked);fd.append('aiLocale',document.getElementById('schedAiLocale').value);fd.append('skipIfEmpty',document.getElementById('schedSkipIfEmpty').checked);var dateRangeSel=document.getElementById('schedDateRangeType');var dateRangeOpt=dateRangeSel.options[dateRangeSel.selectedIndex];var reportDateRange={type:dateRangeOpt.value};if(reportDateRange.type==='LastNDays'){reportDateRange.value=parseInt(dateRangeOpt.getAttribute('data-value')||'7',10);}else if(reportDateRange.type==='Custom'){reportDateRange.dateFrom=document.getElementById('schedDateFrom').value;reportDateRange.dateTo=document.getElementById('schedDateTo').value;}var params={reportDateRange:reportDateRange,dateFrom:document.getElementById('DateFrom').value,dateTo:document.getElementById('DateTo').value,reportMode:document.getElementById('ReportMode').value,primaryGroup:document.getElementById('PrimaryGroup').value,secondaryGroup:document.getElementById('SecondaryGroup').value,thirdGroup:document.getElementById('ThirdGroup').value,includeVat:document.getElementById('includeVatCheck').checked,showProfit:document.getElementById('showProfitCheck').checked,showStock:document.getElementById('showStockCheck').checked,showOnOrder:document.getElementById('showOnOrderCheck').checked,showReservation:document.getElementById('showReservationCheck').checked,showAvailable:document.getElementById('showAvailableCheck').checked,includeAdditionalCharges:document.getElementById('includeAdditionalChargesCheck').checked,sortBySizeSequence:document.getElementById('sortBySizeSequenceCheck').checked,storeCodes:typeof getItemsSelectionStoreCodes==='function'?getItemsSelectionStoreCodes():'',itemIds:document.getElementById('selectedItemIdsHidden').value||'',itemsSelectionJson:typeof getItemsSelectionFilter==='function'?JSON.stringify(getItemsSelectionFilter()):'',sortColumn:document.getElementById('sortColumnHidden').value||'ItemCode',sortDirection:document.getElementById('sortDirectionHidden').value||'ASC',reportType:'PurchasesSales'};fd.append('parametersJson',JSON.stringify(params));var startDate=document.getElementById('schedStartDate').value||new Date().toISOString().slice(0,10);var recurrenceJson={type:recurrence,time:document.getElementById('schedTime').value,range:{startDate:startDate,noEndDate:true}};if(recurrence==='Weekly'){var days=[];document.querySelectorAll('.sched-dow:checked').forEach(function(cb){days.push(parseInt(cb.value,10));});recurrenceJson.pattern={interval:1,daysOfWeek:days.length?days:[1]};}else if(recurrence==='Monthly'){recurrenceJson.pattern={dayOfMonth:day!==null?day:1};}fd.append('recurrenceJson',JSON.stringify(recurrenceJson));var sid=document.getElementById('schedId').value;if(sid)fd.append('scheduleId',sid);var saveBtn=document.querySelector('#scheduleModal .btn-primary[onclick="saveSchedule()"]');if(saveBtn)saveBtn.disabled=true;fetch('@Url.Action("SavePsSchedule","Reports")',{method:'POST',body:fd}).then(r=>r.json()).then(function(d){if(saveBtn)saveBtn.disabled=false;if(d.success){alertDiv.innerHTML='<div class="alert alert-success mb-0"><i class="bi bi-check-circle me-1"></i>'+d.message+'</div>';alertDiv.style.display='';loadExistingSchedules();if(d.updated){showScheduleToast('Schedule updated','success');}else{setTimeout(function(){resetScheduleForm();showScheduleToast('Schedule saved successfully','success');},700);}}else{alertDiv.innerHTML='<div class="alert alert-danger mb-0">'+d.message+'</div>';alertDiv.style.display='';}}).catch(function(){if(saveBtn)saveBtn.disabled=false;alertDiv.innerHTML='<div class="alert alert-danger mb-0">Network error.</div>';alertDiv.style.display='';});}
function showScheduleToast(message,type){var existing=document.getElementById('schedToast');if(existing)existing.remove();var div=document.createElement('div');div.id='schedToast';div.className='alert alert-'+type+' alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow';div.style.zIndex='11000';div.innerHTML='<i class="bi bi-'+(type==='success'?'check-circle':'exclamation-triangle')+' me-1"></i>'+message+'<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';document.body.appendChild(div);setTimeout(function(){if(div.parentNode)div.remove();},4000);}
function deleteScheduleRow(scheduleId,scheduleName){if(!confirm('Delete schedule "'+scheduleName+'"?\nThis cannot be undone.'))return;var fd=new FormData();fd.append('scheduleId',scheduleId);fetch('@Url.Action("DeleteSchedule","Reports")',{method:'POST',body:fd}).then(r=>r.json()).then(function(d){if(d.success){showScheduleToast('Schedule deleted','success');loadExistingSchedules();resetScheduleForm();}else{showScheduleToast(d.message||'Failed to delete schedule','danger');}}).catch(function(){showScheduleToast('Network error','danger');});}
function loadExistingSchedules(){fetch('@Url.Action("GetPsSchedules","Reports")').then(r=>r.json()).then(function(data){var c=document.getElementById('existingSchedules');if(!data||data.length===0){c.innerHTML='<em>No schedules configured yet.</em>';return;}var h='<table class="table table-sm mb-0 align-middle"><thead><tr><th>Name</th><th>Report</th><th>Recurrence</th><th>Format</th><th>Time</th><th>Next Run</th><th class="text-end">Actions</th></tr></thead><tbody>';data.forEach(function(s){var safeName=(s.scheduleName||'').replace(/'/g,"\\'").replace(/"/g,'&quot;');h+='<tr data-schedule-id="'+s.scheduleId+'" style="cursor:pointer;" title="Click to load this schedule"><td>'+escapeHtml(s.scheduleName||'')+'</td><td><span class="badge bg-primary">Purchases/Sales</span></td><td>'+s.recurrenceType+'</td><td>'+s.exportFormat+'</td><td>'+s.scheduleTime+'</td><td>'+(s.nextRun||'-')+'</td><td class="text-end"><button type="button" class="btn btn-sm btn-outline-primary me-1" title="Load into form" onclick="event.stopPropagation(); loadScheduleIntoForm('+s.scheduleId+')"><i class="bi bi-pencil"></i></button><button type="button" class="btn btn-sm btn-outline-danger" title="Delete schedule" onclick="event.stopPropagation(); deleteScheduleRow('+s.scheduleId+', \''+safeName+'\')"><i class="bi bi-trash"></i></button></td></tr>';});h+='</tbody></table>';c.innerHTML=h;c.querySelectorAll('tr[data-schedule-id]').forEach(function(tr){tr.addEventListener('click',function(){loadScheduleIntoForm(parseInt(tr.getAttribute('data-schedule-id'),10));});});}).catch(function(){document.getElementById('existingSchedules').innerHTML='<em>Could not load schedules.</em>';});}

// A2: clean-state on modal open + click-to-load existing schedule. Generic GetScheduleById is shared across reports.
function resetScheduleForm(){document.getElementById('schedId').value='';document.getElementById('schedName').value='';document.getElementById('schedRecipients').value='gm@powersoft.com.cy';document.getElementById('schedSubject').value='';document.getElementById('schedFormat').value='Excel';document.getElementById('schedRecurrence').value='Daily';document.getElementById('schedTime').value='08:00';var sd=document.getElementById('schedStartDate');if(sd)sd.value=new Date().toISOString().slice(0,10);document.querySelectorAll('.sched-dow').forEach(function(cb){cb.checked=false;});var skip=document.getElementById('schedSkipIfEmpty');if(skip)skip.checked=false;var ai=document.getElementById('schedIncludeAi');if(ai)ai.checked=false;onRecurrenceChange();onSchedAiToggle();var a=document.getElementById('scheduleAlert');if(a){a.style.display='none';a.innerHTML='';}}

function loadScheduleIntoForm(scheduleId){fetch('@Url.Action("GetScheduleById","Reports")?scheduleId='+scheduleId).then(function(r){return r.json();}).then(function(data){if(!data||!data.success||!data.schedule){showScheduleToast((data&&data.message)||'Could not load schedule','danger');return;}var s=data.schedule;document.getElementById('schedId').value=scheduleId;document.getElementById('schedName').value=s.scheduleName||'';document.getElementById('schedRecipients').value=s.recipients||'';document.getElementById('schedSubject').value=s.emailSubject||'';document.getElementById('schedFormat').value=s.exportFormat||'Excel';document.getElementById('schedRecurrence').value=s.recurrenceType||'Daily';document.getElementById('schedTime').value=s.scheduleTime||'08:00';onRecurrenceChange();if(s.recurrenceJson){try{var rec=typeof s.recurrenceJson==='string'?JSON.parse(s.recurrenceJson):s.recurrenceJson;if(rec&&rec.range&&rec.range.startDate){var sd=document.getElementById('schedStartDate');if(sd)sd.value=rec.range.startDate;}if(rec&&rec.pattern){if(rec.type==='Weekly'&&Array.isArray(rec.pattern.daysOfWeek)){document.querySelectorAll('.sched-dow').forEach(function(cb){cb.checked=rec.pattern.daysOfWeek.indexOf(parseInt(cb.value,10))!==-1;});}else if(rec.type==='Monthly'&&rec.pattern.dayOfMonth){var md=document.getElementById('schedMonthDay');if(md)md.value=String(rec.pattern.dayOfMonth);}}}catch(e){}}var skip=document.getElementById('schedSkipIfEmpty');if(skip)skip.checked=!!s.skipIfEmpty;var ai=document.getElementById('schedIncludeAi');if(ai)ai.checked=!!s.includeAiAnalysis;var al=document.getElementById('schedAiLocale');if(al&&s.aiLocale)al.value=s.aiLocale;onSchedAiToggle();if(s.parametersJson){try{var p=typeof s.parametersJson==='string'?JSON.parse(s.parametersJson):s.parametersJson;var rdrType=document.getElementById('schedDateRangeType');if(rdrType&&p.reportDateRange&&p.reportDateRange.type){var v=p.reportDateRange.value;var targetVal=p.reportDateRange.type;for(var i=0;i<rdrType.options.length;i++){var opt=rdrType.options[i];if(opt.value===targetVal&&(targetVal!=='LastNDays'||String(opt.getAttribute('data-value'))===String(v))){rdrType.selectedIndex=i;break;}}if(p.reportDateRange.type==='Custom'){if(p.reportDateRange.dateFrom)document.getElementById('schedDateFrom').value=p.reportDateRange.dateFrom;if(p.reportDateRange.dateTo)document.getElementById('schedDateTo').value=p.reportDateRange.dateTo;}}onSchedDateRangeTypeChange();}catch(e){}}var a=document.getElementById('scheduleAlert');if(a){a.innerHTML='<div class="alert alert-info mb-0 py-2"><i class="bi bi-pencil-square me-1"></i>Editing <strong>'+escapeHtml(s.scheduleName||'')+'</strong>. Saving will update this schedule in place &mdash; click <em>Reset</em> to start a new one instead.</div>';a.style.display='';}}).catch(function(){showScheduleToast('Network error loading schedule','danger');});}

function collectCurrentLayout(){var p={};var vat=document.getElementById('includeVatCheck');if(vat)p['IncludeVat']=vat.checked?'1':'0';var sp=document.getElementById('showProfitCheck');if(sp)p['ShowProfit']=sp.checked?'1':'0';var ss=document.getElementById('showStockCheck');if(ss)p['ShowStock']=ss.checked?'1':'0';var soo=document.getElementById('showOnOrderCheck');if(soo)p['ShowOnOrder']=soo.checked?'1':'0';var sr=document.getElementById('showReservationCheck');if(sr)p['ShowReservation']=sr.checked?'1':'0';var sav=document.getElementById('showAvailableCheck');if(sav)p['ShowAvailable']=sav.checked?'1':'0';var iac=document.getElementById('includeAdditionalChargesCheck');if(iac)p['IncludeAdditionalCharges']=iac.checked?'1':'0';var sbss=document.getElementById('sortBySizeSequenceCheck');if(sbss)p['SortBySizeSequence']=sbss.checked?'1':'0';var rm=document.getElementById('ReportMode');if(rm)p['ReportMode']=rm.options[rm.selectedIndex].text;var pg=document.getElementById('PrimaryGroup');if(pg)p['PrimaryGroup']=pg.options[pg.selectedIndex].text;var sg=document.getElementById('SecondaryGroup');if(sg)p['SecondaryGroup']=sg.options[sg.selectedIndex].text;var tg=document.getElementById('ThirdGroup');if(tg)p['ThirdGroup']=tg.options[tg.selectedIndex].text;var ps=document.getElementById('PageSize');if(ps)p['PageSize']=ps.value;var hidden=[];document.querySelectorAll('.col-toggle').forEach(function(cb){if(!cb.checked)hidden.push(cb.value);});p['HiddenColumns']=hidden.join(',');if(typeof getItemsSelectionFilter==='function')p['ItemsSelectionJson']=JSON.stringify(getItemsSelectionFilter());return p;}

function applyLayoutParameters(p){
    function chk(id,v){var el=document.getElementById(id);if(el&&v!=null)el.checked=(v==='1'||v===true);}
    function sel(id,v){var el=document.getElementById(id);if(el&&v!=null){for(var i=0;i<el.options.length;i++){if(el.options[i].text===v||el.options[i].value===v){el.selectedIndex=i;break;}};}
    }
    chk('includeVatCheck',p['IncludeVat']);
    chk('showProfitCheck',p['ShowProfit']);
    chk('showStockCheck',p['ShowStock']);
    chk('showOnOrderCheck',p['ShowOnOrder']);
    chk('showReservationCheck',p['ShowReservation']);
    chk('showAvailableCheck',p['ShowAvailable']);
    chk('includeAdditionalChargesCheck',p['IncludeAdditionalCharges']);
    chk('sortBySizeSequenceCheck',p['SortBySizeSequence']);
    sel('ReportMode',p['ReportMode']);
    sel('PrimaryGroup',p['PrimaryGroup']);
    sel('SecondaryGroup',p['SecondaryGroup']);
    sel('ThirdGroup',p['ThirdGroup']);
    if(window.toggleSizeSequenceOption)window.toggleSizeSequenceOption();
    var ps=document.getElementById('PageSize');if(ps&&p['PageSize'])ps.value=p['PageSize'];
    if(p['HiddenColumns']!=null){
        var hidden=p['HiddenColumns'].split(',').filter(function(s){return s.trim();});
        document.querySelectorAll('.col-toggle').forEach(function(cb){cb.checked=hidden.indexOf(cb.value)===-1;});
        applyColumnVisibility();
    }
    if(p['ItemsSelectionJson']!=null&&typeof reloadItemsSelectionFromJson==='function'){
        try{reloadItemsSelectionFromJson(JSON.parse(p['ItemsSelectionJson']));}catch(e){}
    }
}

function initColumnVisibilityFromServer(){var hc='@(Model.HiddenColumns??"")';if(!hc)return;var hidden=hc.split(',').filter(s=>s.trim());if(hidden.length===0)return;hidden.forEach(function(col){var cb=document.querySelector('.col-toggle[value="'+col.trim()+'"]');if(cb)cb.checked=false;});applyColumnVisibility();}

function applyPresetDates(preset){var today=new Date();var from,to;switch(preset){case'today':from=to=today;break;case'yesterday':from=to=new Date(today.getTime()-86400000);break;case'last7':from=new Date(today.getTime()-6*86400000);to=today;break;case'last30':from=new Date(today.getTime()-29*86400000);to=today;break;case'thisMonth':from=new Date(today.getFullYear(),today.getMonth(),1);to=today;break;case'lastMonth':var lm=new Date(today.getFullYear(),today.getMonth()-1,1);from=lm;to=new Date(lm.getFullYear(),lm.getMonth()+1,0);break;case'ytd':from=new Date(today.getFullYear(),0,1);to=today;break;case'lastYear':from=new Date(today.getFullYear()-1,0,1);to=new Date(today.getFullYear()-1,11,31);break;default:return;}function fmt(d){return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}document.getElementById('DateFrom').value=fmt(from);document.getElementById('DateTo').value=fmt(to);}
function resetPage(){document.getElementById('pageNumberHidden').value=1;}
