    function saveAiLang(v) { localStorage.setItem('ps_ai_lang', v); }
    function getAiLang() { return localStorage.getItem('ps_ai_lang') || 'el'; }
    (function() { var s = document.getElementById('aiLangSelect'); if (s) s.value = getAiLang(); })();

    var _aiConversation = [];
    var _aiTotalChatTokens = { input: 0, output: 0 };

    function estimateAiCost(inputTok, outputTok) {
        var cost = (inputTok * 2.5 + outputTok * 10) / 1e6;
        return cost < 0.005 ? '< $0.01' : '$' + cost.toFixed(2);
    }

    function analyzeReport() {
        var modalEl = document.getElementById('aiAnalysisModal');
        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        document.getElementById('aiLoading').classList.remove('d-none');
        document.getElementById('aiError').classList.add('d-none');
        document.getElementById('aiResults').classList.add('d-none');
        document.getElementById('aiPromptEditor').classList.add('d-none');
        document.getElementById('btnReanalyze').style.display = 'none';
        modal.show();

        var fd = new FormData();
        var p = collectCatalogueParams();
        Object.keys(p).forEach(function(k) { fd.append(k, p[k]); });
        fd.append('locale', getAiLang());
        var tplId = document.getElementById('aiPromptTemplateSelect').value;
        if (tplId && tplId !== '0') fd.append('promptTemplateId', tplId);

        fetch('/Reports/AnalyzeCatalogueReport', { method: 'POST', body: fd })
            .then(r => r.json())
            .then(data => {
                document.getElementById('aiLoading').classList.add('d-none');
                if (!data.success) {
                    document.getElementById('aiError').classList.remove('d-none');
                    document.getElementById('aiErrorMsg').textContent = data.message;
                    document.getElementById('btnReanalyze').style.display = 'inline-block';
                    return;
                }
                var a = data.analysis;
                renderAiAnalysis(a);
                initAiConversation(a);
                document.getElementById('aiResults').classList.remove('d-none');
                document.getElementById('btnReanalyze').style.display = 'inline-block';
            })
            .catch(err => {
                document.getElementById('aiLoading').classList.add('d-none');
                document.getElementById('aiError').classList.remove('d-none');
                document.getElementById('aiErrorMsg').textContent = 'Network error: ' + err.message;
                document.getElementById('btnReanalyze').style.display = 'inline-block';
            });
    }

    function renderAiAnalysis(a) {
        var score = parseInt(a.healthScore) || 0;
        var scoreColor = score >= 80 ? '#16a34a' : score >= 60 ? '#ca8a04' : score >= 40 ? '#ea580c' : '#dc2626';
        var badge = document.getElementById('aiHealthBadge');
        badge.style.background = scoreColor; badge.style.color = 'white'; badge.textContent = score;
        document.getElementById('aiHealthLabel').textContent = a.healthLabel || '';
        document.getElementById('aiTrendDesc').textContent = a.trendDescription || '';
        var trendBadge = document.getElementById('aiTrendBadge');
        var dir = (a.trendDirection || 'stable').toLowerCase();
        var trendIcon = dir === 'up' ? 'bi-arrow-up-right' : dir === 'down' ? 'bi-arrow-down-right' : dir === 'mixed' ? 'bi-arrow-left-right' : 'bi-dash';
        trendBadge.className = 'badge fs-6 px-3 py-2 ' + (dir === 'up' ? 'bg-success' : dir === 'down' ? 'bg-danger' : 'bg-secondary');
        trendBadge.innerHTML = '<i class="bi ' + trendIcon + ' me-1"></i>' + dir.charAt(0).toUpperCase() + dir.slice(1);
        document.getElementById('aiExecSummary').innerHTML = '<i class="bi bi-stars me-2 text-primary"></i>' + (a.executiveSummary || a.summary || '');
        var kpisHtml = '';
        (a.kpis || []).forEach(function(k) {
            var ti = k.trend === 'up' ? '<i class="bi bi-caret-up-fill text-success"></i>' : k.trend === 'down' ? '<i class="bi bi-caret-down-fill text-danger"></i>' : '<i class="bi bi-dash text-muted"></i>';
            kpisHtml += '<div class="col-6 col-md-3 col-lg-2"><div class="border rounded p-2 text-center h-100" style="background:#f8fafc;"><div class="text-muted small text-truncate">' + k.label + '</div><div class="fw-bold" style="font-size:1rem;">' + k.value + '</div><div>' + ti + '</div></div></div>';
        });
        document.getElementById('aiKpis').innerHTML = kpisHtml;
        function renderFindings(items, cId, numbered) {
            var html = '';
            (items || []).forEach(function(f, i) {
                var txt = typeof f === 'string' ? f : f.text;
                var sev = typeof f === 'string' ? 'info' : (f.severity || 'info');
                if (numbered) {
                    html += '<div class="d-flex align-items-start gap-2 mb-2"><span class="badge bg-success rounded-circle" style="width:20px;height:20px;font-size:0.65rem;padding:3px;">' + (i+1) + '</span><span class="small">' + txt + '</span></div>';
                } else {
                    var sc = sev === 'high' ? 'border-danger' : sev === 'medium' ? 'border-warning' : 'border-info';
                    var sd = sev === 'high' ? 'text-danger' : sev === 'medium' ? 'text-warning' : 'text-info';
                    html += '<div class="d-flex align-items-start gap-2 mb-2 border-start border-3 ps-2 ' + sc + '"><i class="bi bi-circle-fill ' + sd + '" style="font-size:0.4rem;margin-top:7px;"></i><span class="small">' + txt + '</span></div>';
                }
            });
            document.getElementById(cId).innerHTML = html || '<span class="text-muted small">—</span>';
        }
        renderFindings(a.keyFindings, 'aiKeyFindings', false);
        renderFindings(a.recommendations, 'aiRecs', true);
        function renderPerf(list, cId, secId) {
            var html = '';
            (list || []).forEach(function(p) {
                html += '<div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom"><div><div class="fw-semibold small">' + p.name + '</div><div class="text-muted" style="font-size:0.75rem;">' + (p.detail || '') + '</div></div><div class="fw-bold small text-nowrap ms-2">' + (p.value || '') + '</div></div>';
            });
            document.getElementById(cId).innerHTML = html || '<span class="text-muted small">—</span>';
            document.getElementById(secId).style.display = (list && list.length > 0) ? '' : 'none';
        }
        renderPerf(a.topPerformers, 'aiTopPerformers', 'aiTopSection');
        renderPerf(a.bottomPerformers, 'aiBottomPerformers', 'aiBottomSection');
        var alertsHtml = '';
        (a.alerts || []).forEach(function(al) {
            var txt = typeof al === 'string' ? al : al.text;
            var sev = typeof al === 'string' ? 'warning' : (al.severity || 'warning');
            var cls = sev === 'critical' ? 'alert-danger' : sev === 'warning' ? 'alert-warning' : 'alert-info';
            var ic = sev === 'critical' ? 'bi-exclamation-octagon-fill' : sev === 'warning' ? 'bi-exclamation-triangle-fill' : 'bi-info-circle-fill';
            alertsHtml += '<div class="alert ' + cls + ' py-2 mb-2 small"><i class="bi ' + ic + ' me-2"></i>' + txt + '</div>';
        });
        document.getElementById('aiAlertsSection').innerHTML = alertsHtml;
        document.getElementById('aiModel').textContent = a.modelUsed || '';
        document.getElementById('aiTokens').textContent = estimateAiCost(a.inputTokens || 0, a.outputTokens || 0);
        document.getElementById('aiTime').textContent = ((a.durationMs || 0) / 1000).toFixed(1) + 's';
        document.getElementById('aiChatMessages').innerHTML = '';
        document.getElementById('aiChatInput').value = '';
        document.getElementById('aiChatTokenInfo').style.display = 'none';
        _aiTotalChatTokens = { input: 0, output: 0 };
    }

    function initAiConversation(analysisJson) {
        _aiConversation = [
            { role: 'system', content: 'You are a senior financial data analyst. The user has already received an AI analysis of their catalogue / sales report. Now they want to ask follow-up questions about the same data. Be concise, specific, and reference the data. Respond in the same language as the analysis.' },
            { role: 'assistant', content: JSON.stringify(analysisJson) }
        ];
    }

    function sendAiChat() {
        var input = document.getElementById('aiChatInput');
        var msg = input.value.trim();
        if (!msg) return;
        input.value = '';
        appendChatBubble('user', msg);

        var btn = document.getElementById('btnSendChat');
        btn.disabled = true; input.disabled = true;
        var tId = 'thinking_' + Date.now();
        appendChatBubble('thinking', 'Thinking...', tId);

        fetch('/Reports/AiChatFollowup', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ history: _aiConversation, message: msg })
        })
        .then(r => r.json())
        .then(data => {
            removeChatBubble(tId);
            btn.disabled = false; input.disabled = false; input.focus();
            if (!data.success) { appendChatBubble('error', data.message || 'Failed to get response.'); return; }
            _aiConversation.push({ role: 'user', content: msg });
            _aiConversation.push({ role: 'assistant', content: data.content });
            appendChatBubble('assistant', data.content);
            _aiTotalChatTokens.input += (data.inputTokens || 0);
            _aiTotalChatTokens.output += (data.outputTokens || 0);
            var info = document.getElementById('aiChatTokenInfo');
            info.style.display = '';
            info.innerHTML = '<i class="bi bi-currency-dollar me-1"></i>Chat: ' + estimateAiCost(_aiTotalChatTokens.input, _aiTotalChatTokens.output) +
                ' | <i class="bi bi-clock me-1"></i>' + ((data.durationMs || 0) / 1000).toFixed(1) + 's';
        })
        .catch(err => {
            removeChatBubble(tId);
            btn.disabled = false; input.disabled = false;
            appendChatBubble('error', 'Network error: ' + err.message);
        });
    }

    function appendChatBubble(role, text, id) {
        var c = document.getElementById('aiChatMessages');
        var div = document.createElement('div');
        if (id) div.id = id;
        div.className = 'mb-2 d-flex ' + (role === 'user' ? 'justify-content-end' : 'justify-content-start');
        var b = document.createElement('div');
        b.className = 'px-3 py-2 rounded-3 small';
        b.style.maxWidth = '85%'; b.style.whiteSpace = 'pre-wrap'; b.style.wordBreak = 'break-word';
        if (role === 'user') { b.style.background = '#6366f1'; b.style.color = 'white'; b.textContent = text; }
        else if (role === 'thinking') { b.style.background = '#f1f5f9'; b.style.color = '#94a3b8'; b.innerHTML = '<i class="bi bi-three-dots me-1"></i>' + text; }
        else if (role === 'error') { b.style.background = '#fee2e2'; b.style.color = '#dc2626'; b.textContent = text; }
        else { b.style.background = '#f1f5f9'; b.style.color = '#1e293b'; b.textContent = text; }
        div.appendChild(b); c.appendChild(div); c.scrollTop = c.scrollHeight;
    }

    function removeChatBubble(id) {
        var el = document.getElementById(id); if (el) el.remove();
    }

    // ==================== AI Prompt Templates ====================

    var _editingPromptId = 0;
    var _currentReportType = 'Catalogue';

    function togglePromptEditor() {
        var el = document.getElementById('aiPromptEditor');
        if (el.classList.contains('d-none')) {
            el.classList.remove('d-none');
            loadAiPromptTemplates();
            var sid = parseInt(document.getElementById('aiPromptTemplateSelect').value);
            if (sid > 0) editAiPromptTemplate(sid); else clearPromptEditor();
        } else {
            el.classList.add('d-none');
        }
    }

    function loadAiPromptTemplates() {
        fetch('/Reports/GetAiPromptTemplates?reportType=' + encodeURIComponent(_currentReportType))
            .then(r => r.json())
            .then(function(data) {
                var sel = document.getElementById('aiPromptTemplateSelect');
                var userPicked = sel.getAttribute('data-user-picked') === '1';
                var savedVal = userPicked ? sel.value : null;
                sel.innerHTML = '<option value="0" style="color:#333;">Default Prompt</option>';
                var listHtml = '';
                var defId = null;
                (data || []).forEach(function(t) {
                    sel.innerHTML += '<option value="' + t.templateId + '" style="color:#333;">' + escapeHtml(t.templateName) + (t.isDefault ? ' ★' : '') + '</option>';
                    var match = t.isDefault && (!t.reportType || t.reportType === '' || t.reportType === _currentReportType);
                    if (match) defId = t.templateId;
                    listHtml += '<div class="d-flex justify-content-between align-items-center border-bottom py-2">' +
                        '<div><strong>' + escapeHtml(t.templateName) + '</strong>' +
                        (t.isDefault ? ' <span class="badge bg-primary">Default</span>' : '') +
                        (t.reportType ? ' <span class="badge bg-secondary">' + t.reportType + '</span>' : ' <span class="badge bg-light text-dark">All</span>') +
                        '</div><div>' +
                        '<button class="btn btn-sm btn-outline-primary me-1" onclick="editAiPromptTemplate(' + t.templateId + ')"><i class="bi bi-pencil"></i></button>' +
                        '<button class="btn btn-sm btn-outline-danger" onclick="deleteAiPromptTemplate(' + t.templateId + ')"><i class="bi bi-trash"></i></button>' +
                        '</div></div>';
                });
                document.getElementById('aiPromptTemplatesList').innerHTML = listHtml || '<em>No custom templates yet.</em>';
                if (userPicked && savedVal) sel.value = savedVal;
                else if (defId) sel.value = defId;
            })
            .catch(function() {
                document.getElementById('aiPromptTemplatesList').innerHTML = '<em>Could not load templates.</em>';
            });
    }

    function saveAiPromptTemplate() {
        var name = document.getElementById('aiPromptName').value.trim();
        var prompt = document.getElementById('aiPromptText').value.trim();
        var a = document.getElementById('aiPromptAlert');
        if (!name || !prompt) { a.innerHTML = '<span class="text-danger">Name and prompt are required.</span>'; return; }
        fetch('/Reports/SaveAiPromptTemplate', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                templateId: _editingPromptId, templateName: name,
                reportType: document.getElementById('aiPromptReportType').value || null,
                systemPrompt: prompt,
                isDefault: document.getElementById('aiPromptIsDefault').checked
            })
        })
        .then(r => r.json())
        .then(d => {
            if (d.success) {
                a.innerHTML = '<span class="text-success"><i class="bi bi-check-circle me-1"></i>' + d.message + '</span>';
                clearPromptEditor(); loadAiPromptTemplates();
            } else {
                a.innerHTML = '<span class="text-danger">' + d.message + '</span>';
            }
        })
        .catch(() => { a.innerHTML = '<span class="text-danger">Network error.</span>'; });
    }

    function editAiPromptTemplate(id) {
        fetch('/Reports/GetAiPromptTemplates?reportType=' + encodeURIComponent(_currentReportType))
            .then(r => r.json())
            .then(function(data) {
                var t = (data || []).find(function(x) { return x.templateId === id; });
                if (!t) return;
                _editingPromptId = t.templateId;
                document.getElementById('aiPromptName').value = t.templateName;
                document.getElementById('aiPromptReportType').value = t.reportType || '';
                document.getElementById('aiPromptText').value = t.systemPrompt;
                document.getElementById('aiPromptIsDefault').checked = t.isDefault;
                document.getElementById('aiPromptAlert').innerHTML = '<span class="text-info">Editing: ' + escapeHtml(t.templateName) + '</span>';
            });
    }

    function deleteAiPromptTemplate(id) {
        if (!confirm('Delete this template?')) return;
        fetch('/Reports/DeleteAiPromptTemplate', {
            method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'templateId=' + id
        }).then(r => r.json()).then(() => loadAiPromptTemplates());
    }

    function clearPromptEditor() {
        _editingPromptId = 0;
        document.getElementById('aiPromptName').value = '';
        document.getElementById('aiPromptText').value = '';
        document.getElementById('aiPromptReportType').value = 'Catalogue';
        document.getElementById('aiPromptIsDefault').checked = false;
        document.getElementById('aiPromptAlert').innerHTML = '';
    }

    function escapeHtml(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

    // Load prompt templates when AI modal opens
    (function() {
        var m = document.getElementById('aiAnalysisModal');
        if (m) m.addEventListener('show.bs.modal', function() { loadAiPromptTemplates(); });
    })();

    // ==================== Preview (document-style print view) ====================
    var previewOpen = false;
    function togglePreview() {
        var panel = document.getElementById('previewPanel');
        var grid = document.getElementById('results');
        var btn = document.getElementById('previewToggleBtn');
        if (!panel || !grid || !btn) return;
        previewOpen = !previewOpen;
        if (previewOpen) {
            grid.style.display = 'none';
            panel.style.display = 'block';
            btn.innerHTML = '<i class="bi bi-table me-1"></i>Grid';
            btn.classList.remove('btn-outline-primary');
            btn.classList.add('btn-outline-warning');
            var f = document.getElementById('previewFrame');
            if (!f.src || f.src === 'about:blank' || f.src.endsWith('about:blank')) {
                var qs = '@Url.Action("PrintCataloguePreview")'
                    + '?dateFrom=@(Model.UseDateTime ? Model.DateFrom.ToString("yyyy-MM-ddTHH:mm") : Model.DateFrom.ToString("yyyy-MM-dd"))'
                    + '&dateTo=@(Model.UseDateTime ? Model.DateTo.ToString("yyyy-MM-ddTHH:mm") : Model.DateTo.ToString("yyyy-MM-dd"))'
                    + '&dateBasis=@Model.DateBasis'
                    + '&useDateTime=@Model.UseDateTime'
                    + '&reportMode=@Model.ReportMode'
                    + '&reportOn=@Model.ReportOn'
                    + '&primaryGroup=@Model.PrimaryGroup'
                    + '&secondaryGroup=@Model.SecondaryGroup'
                    + '&thirdGroup=@Model.ThirdGroup'
                    + '&showProfit=@Model.ShowProfit'
                    + '&showStock=@Model.ShowStock'
                    + '&profitBasedOn=@((int)Model.ProfitBasedOn)'
                    + '&profitIncludesVat=@Model.ProfitIncludesVat'
                    + '&stockValueBasedOn=@((int)Model.StockValueBasedOn)'
                    + '&stockValueIncludesVat=@Model.StockValueIncludesVat'
                    + '&costType=@((int)Model.CostType)'
                    + '&displayColumns=' + encodeURIComponent('@(Model.DisplayColumnsString ?? "")')
                    + '&storeCodes=' + encodeURIComponent('@(Model.SelectedStoreCodesString ?? "")')
                    + '&itemsSelection=' + encodeURIComponent('@(Model.ItemsSelectionJson ?? "")')
                    + '&sortColumn=@Model.SortColumn'
                    + '&sortDirection=@Model.SortDirection';
                f.src = qs;
            }
            f.onload = function () {
                try { f.style.height = Math.max(f.contentDocument.documentElement.scrollHeight + 40, 600) + 'px'; } catch (e) {}
            };
        } else {
            grid.style.display = 'block';
            panel.style.display = 'none';
            btn.innerHTML = '<i class="bi bi-eye me-1"></i>Preview';
            btn.classList.remove('btn-outline-warning');
            btn.classList.add('btn-outline-primary');
        }
    }

    // Close preview when iframe (Esc inside) requests it.
    window.addEventListener('message', function (ev) {
        if (ev && ev.data && ev.data.type === 'cataloguePreviewClose' && previewOpen) {
            togglePreview();
        }
    });

    // ==================== Item Detail Modal (Transaction History + Stock Position) ====================
    // Mirrors original Powersoft365 "Item Transactions History" dialog with toggle to "Item Stock Position".
    // Source: restricted/StockControl/ItemStockPosition.aspx (original VB.NET).

    var _itemModalCurrentCode = null;
    var _itemModalCurrentName = '';
    var _itemModalCurrentView = 'trans'; // 'trans' or 'stock'

    function fmt2(n) { return (n || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
    function fmtQ(n) { return (n || 0).toLocaleString(undefined, { maximumFractionDigits: 2 }); }

    // Event delegation for item links (handles any re-rendered rows)
    document.addEventListener('click', function (e) {
        var link = e.target.closest('a.dd-link-item');
        if (!link) return;
        e.preventDefault();
        var code = link.getAttribute('data-item-code') || '';
        var name = link.getAttribute('data-item-name') || '';
        if (code) openItemModal(code, name);
    });

    function openItemModal(itemCode, itemName) {
        if (!itemCode) return;
        _itemModalCurrentCode = itemCode;
        _itemModalCurrentName = itemName || '';
        _itemModalCurrentView = 'trans';

        document.getElementById('itemModalCode').textContent = itemCode;
        document.getElementById('itemModalName').textContent = itemName || '';
        setItemModalView('trans');

        var modal = new bootstrap.Modal(document.getElementById('itemDetailModal'));
        modal.show();
        loadItemTransactions(itemCode);
    }

    function setItemModalView(view) {
        _itemModalCurrentView = view;
        var btnTrans = document.getElementById('itemModalBtnTrans');
        var btnStock = document.getElementById('itemModalBtnStock');
        var viewTrans = document.getElementById('itemModalViewTrans');
        var viewStock = document.getElementById('itemModalViewStock');
        var title = document.getElementById('itemModalViewTitle');
        if (view === 'trans') {
            btnTrans.classList.add('active', 'btn-primary');
            btnTrans.classList.remove('btn-outline-primary');
            btnStock.classList.remove('active', 'btn-primary');
            btnStock.classList.add('btn-outline-primary');
            viewTrans.classList.remove('d-none');
            viewStock.classList.add('d-none');
            if (title) title.textContent = 'Item Transactions History';
        } else {
            btnStock.classList.add('active', 'btn-primary');
            btnStock.classList.remove('btn-outline-primary');
            btnTrans.classList.remove('active', 'btn-primary');
            btnTrans.classList.add('btn-outline-primary');
            viewStock.classList.remove('d-none');
            viewTrans.classList.add('d-none');
            if (title) title.textContent = 'Item Stock Position';
        }
    }

    function toggleItemModalView() {
        if (!_itemModalCurrentCode) return;
        if (_itemModalCurrentView === 'trans') {
            setItemModalView('stock');
            if (!document.getElementById('itemStockLoaded')) loadItemStockPosition(_itemModalCurrentCode);
        } else {
            setItemModalView('trans');
        }
    }

    function loadItemTransactions(itemCode) {
        var tbody = document.getElementById('itemTransTbody');
        var summary = document.getElementById('itemTransSummary');
        var err = document.getElementById('itemTransError');
        tbody.innerHTML = '<tr><td colspan="11" class="text-center py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading transactions...</td></tr>';
        summary.textContent = '';
        err.classList.add('d-none');

        var storeCodes = '';
        if (typeof getItemsSelectionStoreCodes === 'function') storeCodes = getItemsSelectionStoreCodes();

        var url = '/Reports/GetTransactionDetails?itemCode=' + encodeURIComponent(itemCode)
            + '&type=all'
            + '&dateFrom=@Model.DateFrom.ToString("yyyy-MM-dd")'
            + '&dateTo=@Model.DateTo.ToString("yyyy-MM-dd")'
            + '&storeCodes=' + encodeURIComponent(storeCodes);

        fetch(url)
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (!data.success) {
                    tbody.innerHTML = '';
                    err.textContent = data.message || 'Error loading transactions';
                    err.classList.remove('d-none');
                    return;
                }
                if (data.count === 0) {
                    tbody.innerHTML = '<tr><td colspan="11" class="text-center text-muted py-3">No transactions found for this item in the selected period.</td></tr>';
                    summary.textContent = '';
                    return;
                }
                // Kind colour map: P=Purchase, E=PurchReturn, I=Sale, C=Credit
                var kindColors = { 'P': 'bg-info', 'E': 'bg-warning', 'I': 'bg-success', 'C': 'bg-danger' };
                tbody.innerHTML = data.rows.map(function (r) {
                    var bc = kindColors[r.kind] || 'bg-secondary';
                    var docCell = '';
                    if (r.doc && r.kind && 'PEIC'.indexOf(r.kind) >= 0) {
                        var safeDoc = String(r.doc).replace(/'/g, "\\'");
                        docCell = '<a href="#" class="text-primary text-decoration-underline fw-semibold" '
                            + 'onclick="openDocument(\'' + r.kind + '\', \'' + safeDoc + '\'); return false;" '
                            + 'title="View document details">' + r.doc + '</a>';
                    } else {
                        docCell = '<span class="fw-semibold">' + (r.doc || '') + '</span>';
                    }
                    return '<tr class="small">'
                        + '<td class="text-nowrap">' + r.date + '</td>'
                        + '<td><span class="badge ' + bc + '">' + (r.kindDescription || r.kind) + '</span></td>'
                        + '<td>' + docCell + '</td>'
                        + '<td>' + (r.entityCode ? r.entityCode + ' — ' : '') + (r.entityName || '') + '</td>'
                        + '<td>' + (r.store || '') + '</td>'
                        + '<td class="text-end">' + fmtQ(r.qty) + '</td>'
                        + '<td class="text-end">' + fmt2(r.price) + '</td>'
                        + '<td class="text-end">' + fmt2(r.discount) + '</td>'
                        + '<td class="text-end">' + fmt2(r.net) + '</td>'
                        + '<td class="text-end">' + fmt2(r.vat) + '</td>'
                        + '<td class="text-end">' + fmt2(r.gross) + '</td>'
                        + '</tr>';
                }).join('');
                summary.textContent = data.count + ' transactions · Qty: ' + fmtQ(data.totalQty)
                    + ' · Net: ' + fmt2(data.totalNet) + ' · Gross: ' + fmt2(data.totalGross);
            })
            .catch(function (ex) {
                tbody.innerHTML = '';
                err.textContent = 'Network error: ' + ex.message;
                err.classList.remove('d-none');
            });
    }

    function loadItemStockPosition(itemCode) {
        var tbody = document.getElementById('itemStockTbody');
        var tfoot = document.getElementById('itemStockTfoot');
        var summary = document.getElementById('itemStockSummary');
        var err = document.getElementById('itemStockError');
        tbody.innerHTML = '<tr><td colspan="8" class="text-center py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading stock position...</td></tr>';
        tfoot.innerHTML = '';
        summary.textContent = '';
        err.classList.add('d-none');

        fetch('/Reports/GetItemStockPosition?itemCode=' + encodeURIComponent(itemCode))
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (!data.success) {
                    tbody.innerHTML = '';
                    err.textContent = data.message || 'Error loading stock position';
                    err.classList.remove('d-none');
                    return;
                }
                if (!data.rows || data.rows.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-3">No stores found.</td></tr>';
                    return;
                }
                tbody.innerHTML = data.rows.map(function (r) {
                    var negClass = (r.onStock < 0) ? 'text-danger fw-semibold' : '';
                    return '<tr class="small">'
                        + '<td class="fw-semibold">' + (r.storeCode || '') + '</td>'
                        + '<td>' + (r.storeName || '') + '</td>'
                        + '<td class="text-end ' + negClass + '">' + fmtQ(r.onStock) + '</td>'
                        + '<td class="text-end">' + fmtQ(r.onTransfer) + '</td>'
                        + '<td class="text-end">' + fmtQ(r.reserved) + '</td>'
                        + '<td class="text-end">' + fmtQ(r.ordered) + '</td>'
                        + '<td class="text-end fw-semibold">' + fmtQ(r.available) + '</td>'
                        + '<td>' + (r.shelf || '') + '</td>'
                        + '</tr>';
                }).join('');
                tfoot.innerHTML = '<tr class="table-light fw-bold small">'
                    + '<td colspan="2" class="text-end">Totals:</td>'
                    + '<td class="text-end">' + fmtQ(data.totalOnStock) + '</td>'
                    + '<td class="text-end">' + fmtQ(data.totalOnTransfer) + '</td>'
                    + '<td class="text-end">' + fmtQ(data.totalReserved) + '</td>'
                    + '<td class="text-end">' + fmtQ(data.totalOrdered) + '</td>'
                    + '<td class="text-end">' + fmtQ(data.totalAvailable) + '</td>'
                    + '<td></td>'
                    + '</tr>';
                summary.textContent = data.count + ' store(s) · Total On Stock: ' + fmtQ(data.totalOnStock)
                    + ' · Total Available: ' + fmtQ(data.totalAvailable);
                // Mark as loaded so subsequent toggles don't re-fetch
                var marker = document.getElementById('itemStockLoaded');
                if (!marker) {
                    var m = document.createElement('span');
                    m.id = 'itemStockLoaded';
                    m.style.display = 'none';
                    document.body.appendChild(m);
                }
            })
            .catch(function (ex) {
                tbody.innerHTML = '';
                err.textContent = 'Network error: ' + ex.message;
                err.classList.remove('d-none');
            });
    }

    // Reset stock-loaded marker when modal closes so next open re-fetches fresh data
    document.addEventListener('DOMContentLoaded', function () {
        var m = document.getElementById('itemDetailModal');
        if (m) m.addEventListener('hidden.bs.modal', function () {
            var marker = document.getElementById('itemStockLoaded');
            if (marker) marker.remove();
            _itemModalCurrentCode = null;
        });
    });

    // ==================== Document Detail Modal (pattern reused from PurchasesSales.cshtml) ====================
    // Uses /Reports/GetDocumentDetail endpoint (docType: P/E/I/C).
    var _currentDocData = null;
    var _currentDocType = '', _currentDocNumber = '';
    var _docViewMode = 'compact';

    function buildFullViewHtml(d) {
        var isPurch = (d.docType === 'P' || d.docType === 'E');
        var accent = isPurch ? '#2563eb' : '#059669';
        var accentBg = isPurch ? '#eff6ff' : '#ecfdf5';
        var entityLabel = isPurch ? 'Supplier' : 'Customer';
        var fmt2 = function (v) { return (v || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }); };

        return '<div style="text-align:center;margin-bottom:24px;padding-bottom:16px;border-bottom:3px solid ' + accent + '">'
            + '<div style="font-size:20px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:' + accent + '">' + d.docTypeDescription + '</div>'
            + '<div style="font-size:14px;font-weight:600;color:#475569;margin-top:2px">Document #: ' + d.documentNumber + '</div>'
            + '</div>'
            + '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;font-size:12px;margin-bottom:20px;padding:12px 16px;background:' + accentBg + ';border-radius:6px">'
            + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">Date</div><div style="font-weight:500;margin-top:1px">' + d.date + '</div></div>'
            + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">Store</div><div style="font-weight:500;margin-top:1px">' + (d.storeCode || '—') + '</div></div>'
            + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">' + entityLabel + '</div><div style="font-weight:500;margin-top:1px">' + (d.entityCode ? d.entityCode + ' — ' : '') + d.entityName + '</div></div>'
            + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">Line Items</div><div style="font-weight:500;margin-top:1px">' + d.lineCount + '</div></div>'
            + '</div>'
            + '<table style="width:100%;border-collapse:collapse;font-size:11px">'
            + '<thead><tr style="background:#e2e8f0">'
            + '<th style="padding:6px 10px;text-align:left;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Item Code</th>'
            + '<th style="padding:6px 10px;text-align:left;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Description</th>'
            + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Qty</th>'
            + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Unit Price</th>'
            + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Discount</th>'
            + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Net</th>'
            + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">VAT</th>'
            + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Gross</th>'
            + '</tr></thead><tbody>'
            + d.lines.map(function (l) {
                return '<tr>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;font-weight:600">' + l.itemCode + '</td>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9">' + l.itemName + '</td>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">' + l.qty.toLocaleString(undefined, { maximumFractionDigits: 2 }) + '</td>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">' + fmt2(l.price) + '</td>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">' + fmt2(l.discount) + '</td>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">' + fmt2(l.net) + '</td>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">' + fmt2(l.vat) + '</td>'
                    + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">' + fmt2(l.gross) + '</td>'
                    + '</tr>';
            }).join('')
            + '</tbody><tfoot><tr style="font-weight:700;border-top:3px double #1e293b;background:#f1f5f9">'
            + '<td colspan="5" style="padding:8px 10px;text-align:right">Totals</td>'
            + '<td style="padding:8px 10px;text-align:right">' + fmt2(d.totalNet) + '</td>'
            + '<td style="padding:8px 10px;text-align:right">' + fmt2(d.totalVat) + '</td>'
            + '<td style="padding:8px 10px;text-align:right">' + fmt2(d.totalGross) + '</td>'
            + '</tr></tfoot></table>'
            + '<div style="text-align:center;margin-top:24px;padding-top:12px;border-top:1px solid #e2e8f0;font-size:10px;color:#94a3b8">Powersoft Reporting</div>';
    }

    function toggleDocView() {
        if (!_currentDocData) return;
        if (_docViewMode === 'compact') {
            document.getElementById('docCompactView').classList.add('d-none');
            var fv = document.getElementById('docFullView');
            fv.innerHTML = buildFullViewHtml(_currentDocData);
            fv.classList.remove('d-none');
            document.getElementById('btnDocToggleView').innerHTML = '<i class="bi bi-eye-slash me-1"></i>Compact';
            _docViewMode = 'full';
        } else {
            document.getElementById('docFullView').classList.add('d-none');
            document.getElementById('docCompactView').classList.remove('d-none');
            document.getElementById('btnDocToggleView').innerHTML = '<i class="bi bi-eye me-1"></i>Preview';
            _docViewMode = 'compact';
        }
    }

    function printDocFromModal() {
        if (!_currentDocData) return;
        var printWin = window.open('', '_blank', 'width=900,height=700');
        printWin.document.write('<html><head><title>' + _currentDocData.docTypeDescription + ' — ' + _currentDocData.documentNumber + '</title>'
            + '<style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:Segoe UI,system-ui,sans-serif;padding:24px;color:#1e293b}</style>'
            + '</head><body>' + buildFullViewHtml(_currentDocData) + '</body></html>');
        printWin.document.close();
        printWin.focus();
        printWin.print();
    }

    function openDocument(docType, docNumber) {
        _currentDocType = docType;
        _currentDocNumber = docNumber;
        _currentDocData = null;
        _docViewMode = 'compact';
        document.getElementById('docFullView').classList.add('d-none');
        document.getElementById('docFullView').innerHTML = '';
        document.getElementById('btnDocToggleView').innerHTML = '<i class="bi bi-eye me-1"></i>Preview';
        var modal = new bootstrap.Modal(document.getElementById('docDetailModal'));
        var hdr = document.getElementById('docDetailHeader');
        var isPurch = (docType === 'P' || docType === 'E');
        hdr.className = 'modal-header ' + (isPurch ? 'bg-primary bg-opacity-10' : 'bg-success bg-opacity-10');

        document.getElementById('docDetailLoading').classList.remove('d-none');
        document.getElementById('docDetailError').classList.add('d-none');
        document.getElementById('docCompactView').classList.add('d-none');

        var typeNames = { P: 'Purchase Invoice', E: 'Purchase Return', I: 'Sales Invoice', C: 'Credit Note' };
        document.getElementById('docDetailTitle').innerHTML =
            '<i class="bi bi-file-earmark-text me-2"></i>' + (typeNames[docType] || 'Document') + ' — ' + docNumber;

        modal.show();

        fetch('/Reports/GetDocumentDetail?docType=' + encodeURIComponent(docType) + '&docNumber=' + encodeURIComponent(docNumber))
            .then(function (r) { return r.json(); })
            .then(function (data) {
                document.getElementById('docDetailLoading').classList.add('d-none');
                if (!data.success) {
                    document.getElementById('docDetailError').classList.remove('d-none');
                    document.getElementById('docDetailError').textContent = data.message;
                    return;
                }
                var d = data.doc;
                document.getElementById('docDate').textContent = d.date;
                document.getElementById('docStore').textContent = d.storeCode || '—';
                document.getElementById('docEntity').textContent = d.entityCode ? (d.entityCode + ' — ' + d.entityName) : (d.entityName || '—');

                var fmt2 = function (v) { return (v || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }); };
                var tbody = document.getElementById('docDetailLines');
                tbody.innerHTML = d.lines.map(function (l) {
                    return '<tr>'
                        + '<td class="fw-semibold">' + l.itemCode + '</td>'
                        + '<td>' + l.itemName + '</td>'
                        + '<td class="text-end">' + l.qty.toLocaleString(undefined, { maximumFractionDigits: 2 }) + '</td>'
                        + '<td class="text-end">' + fmt2(l.price) + '</td>'
                        + '<td class="text-end">' + fmt2(l.discount) + '</td>'
                        + '<td class="text-end">' + fmt2(l.net) + '</td>'
                        + '<td class="text-end">' + fmt2(l.vat) + '</td>'
                        + '<td class="text-end">' + fmt2(l.gross) + '</td>'
                        + '</tr>';
                }).join('');

                document.getElementById('docTotalNet').textContent = fmt2(d.totalNet);
                document.getElementById('docTotalVat').textContent = fmt2(d.totalVat);
                document.getElementById('docTotalGross').textContent = fmt2(d.totalGross);
                document.getElementById('docLineCount').textContent = d.lineCount + ' line item(s)';

                _currentDocData = d;
                document.getElementById('docCompactView').classList.remove('d-none');
            })
            .catch(function (err) {
                document.getElementById('docDetailLoading').classList.add('d-none');
                document.getElementById('docDetailError').classList.remove('d-none');
                document.getElementById('docDetailError').textContent = 'Network error: ' + err.message;
            });
    }
</script>
}
