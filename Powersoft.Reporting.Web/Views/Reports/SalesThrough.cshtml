// ===== Save / Reset Layout (shared _SaveLayout.cshtml partial) =====
function collectCurrentLayout() {
    function v(id) { var el = document.getElementById(id); return el ? el.value : ''; }
    var p = {};
    p['Summary'] = document.getElementById('summary').checked ? '1' : '0';
    p['PrimaryGroup'] = v('primaryGroup');
    p['SecondaryGroup'] = v('secondaryGroup');
    p['ThirdGroup'] = v('thirdGroup');
    p['IncludeAdditionalCharges'] = document.getElementById('includeAdditionalCharges').checked ? '1' : '0';
    p['SortBySizeSequence'] = document.getElementById('sortBySizeSequence').checked ? '1' : '0';
    p['PageSize'] = v('pageSize');
    if (typeof getItemsSelectionFilter === 'function') {
        var sel = getItemsSelectionFilter();
        if (sel) p['ItemsSelectionJson'] = JSON.stringify(sel);
    }
    return p;
}

function applyLayoutParameters(parms) {
    function setVal(id, v) { var el = document.getElementById(id); if (el && v != null && v !== '') el.value = v; }
    function on(v) { return v === '1' || v === 1 || v === true || v === 'true'; }
    if (parms.Summary != null) document.getElementById('summary').checked = on(parms.Summary);
    setVal('primaryGroup', parms.PrimaryGroup); onGroupChange(1);
    setVal('secondaryGroup', parms.SecondaryGroup); onGroupChange(2);
    setVal('thirdGroup', parms.ThirdGroup);
    if (parms.IncludeAdditionalCharges != null) document.getElementById('includeAdditionalCharges').checked = on(parms.IncludeAdditionalCharges);
    if (parms.SortBySizeSequence != null) document.getElementById('sortBySizeSequence').checked = on(parms.SortBySizeSequence);
    setVal('pageSize', parms.PageSize);
    if (parms.ItemsSelectionJson != null && typeof reloadItemsSelectionFromJson === 'function') {
        try { reloadItemsSelectionFromJson(JSON.parse(parms.ItemsSelectionJson)); } catch (e) {}
    }
}

document.addEventListener('DOMContentLoaded', function() {
    fetch('@Url.Action("GetReportLayout", "Reports")?reportType=SalesThrough')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.success || !data.hasSaved) return;
            applyLayoutParameters(data.parameters || {});
            var btn = document.getElementById('resetLayoutBtn');
            if (btn) btn.style.display = '';
        })
        .catch(function() {});
});

function fmt(v, dec) {
    if (v == null) return '-';
    return v.toLocaleString(undefined, { minimumFractionDigits: dec == null ? 0 : dec, maximumFractionDigits: dec == null ? 2 : dec });
}
function esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }
</script>
