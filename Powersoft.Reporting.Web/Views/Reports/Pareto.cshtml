    document.getElementById('aiPromptText').value = '';
    document.getElementById('aiPromptIsDefault').checked = false;
    document.getElementById('aiPromptAlert').textContent = '';
}

function loadAiPromptTemplates() {
    fetch('@Url.Action("GetAiPromptTemplates", "Reports")' + '?reportType=' + encodeURIComponent(_currentReportType))
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var list = document.getElementById('aiPromptTemplatesList');
            var sel = document.getElementById('aiPromptTemplateSelect');
            sel.innerHTML = '<option value="0" style="color:#333;">Default Prompt</option>';
            if (!data || data.length === 0) { list.innerHTML = '<em>No custom templates.</em>'; return; }
            var html = '<table class="table table-sm mb-0"><thead><tr><th>Name</th><th>Default</th><th></th></tr></thead><tbody>';
            data.forEach(function(t) {
                html += '<tr><td>' + escapeHtml(t.templateName) + '</td><td>' + (t.isDefault ? '<i class="bi bi-check-circle text-success"></i>' : '') + '</td>'
                    + '<td class="text-end"><button class="btn btn-sm btn-outline-danger" onclick="deleteAiPromptTemplate(' + t.templateId + ')"><i class="bi bi-trash"></i></button></td></tr>';
                var opt = document.createElement('option');
                opt.value = t.templateId;
                opt.textContent = t.templateName;
                opt.style.color = '#333';
                sel.appendChild(opt);
                if (t.isDefault) opt.selected = true;
            });
            html += '</tbody></table>';
            list.innerHTML = html;
        })
        .catch(function() { document.getElementById('aiPromptTemplatesList').innerHTML = '<em>Could not load templates.</em>'; });
}

function saveAiPromptTemplate() {
    var name = document.getElementById('aiPromptName').value.trim();
    var prompt = document.getElementById('aiPromptText').value.trim();
    if (!name || !prompt) { document.getElementById('aiPromptAlert').textContent = 'Name and prompt required.'; return; }
    fetch('@Url.Action("SaveAiPromptTemplate", "Reports")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            templateName: name,
            systemPrompt: prompt,
            reportType: document.getElementById('aiPromptReportType').value,
            isDefault: document.getElementById('aiPromptIsDefault').checked
        })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        document.getElementById('aiPromptAlert').innerHTML = data.success
            ? '<span class="text-success">Saved!</span>'
            : '<span class="text-danger">' + data.message + '</span>';
        if (data.success) { clearPromptEditor(); loadAiPromptTemplates(); }
    });
}

function deleteAiPromptTemplate(id) {
    if (!confirm('Delete this template?')) return;
    fetch('@Url.Action("DeleteAiPromptTemplate", "Reports")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ templateId: id })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) { if (data.success) loadAiPromptTemplates(); });
}

// ==================== Layout ====================
function collectCurrentLayout() {
    var parms = {};
    parms['Dimension'] = document.getElementById('dimension').value;
    parms['Metric'] = document.getElementById('metric').value;
    parms['IncludeVat'] = document.getElementById('includeVat').checked ? '1' : '0';
    parms['ExcludeNegative'] = document.getElementById('excludeNegative').checked ? '1' : '0';
    parms['ShowOthers'] = document.getElementById('showOthers').checked ? '1' : '0';
    parms['ProfitBasis'] = document.getElementById('profitBasis').value;
    parms['ClassAThreshold'] = document.getElementById('paretoPercValue').value;
    parms['PriceInterval'] = document.getElementById('priceInterval').value;
    parms['PriceOnIndex'] = document.getElementById('priceOnIndex').value;
    if (typeof getItemsSelectionFilter === 'function') {
        parms['ItemsSelectionJson'] = JSON.stringify(getItemsSelectionFilter());
    }
    return parms;
}

function saveParetoLayout() {
    var parms = collectCurrentLayout();
    fetch('@Url.Action("SaveParetoLayout", "Reports")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(parms)
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) alert('Layout saved successfully.');
        else alert('Failed: ' + data.message);
    })
    .catch(function() { alert('Network error saving layout.'); });
}

function resetParetoLayout() {
    if (!confirm('Reset layout to defaults?')) return;
    fetch('@Url.Action("ResetParetoLayout", "Reports")', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) { alert('Layout reset to defaults. Reload the page to apply.'); location.reload(); }
            else alert(data.message);
        })
        .catch(function() { alert('Network error.'); });
}

function loadSavedLayout() {
    fetch('@Url.Action("GetParetoLayout", "Reports")')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.success || !data.hasSaved) return;
            var p = data.parameters;
            if (p.Dimension) document.getElementById('dimension').value = p.Dimension;
            if (p.Metric) document.getElementById('metric').value = p.Metric;
            if (p.IncludeVat) document.getElementById('includeVat').checked = p.IncludeVat === '1';
            if (p.ExcludeNegative) document.getElementById('excludeNegative').checked = p.ExcludeNegative === '1';
            if (p.ShowOthers) document.getElementById('showOthers').checked = p.ShowOthers === '1';
            if (p.ProfitBasis) document.getElementById('profitBasis').value = p.ProfitBasis;
            if (p.ClassAThreshold) {
                document.getElementById('paretoPercValue').value = p.ClassAThreshold;
                document.getElementById('paretoPercItems').value = 100 - parseInt(p.ClassAThreshold);
            }
            if (p.PriceInterval) document.getElementById('priceInterval').value = p.PriceInterval;
            if (p.PriceOnIndex) document.getElementById('priceOnIndex').value = p.PriceOnIndex;
            if (p.ItemsSelectionJson && typeof reloadItemsSelectionFromJson === 'function') {
                try { reloadItemsSelectionFromJson(JSON.parse(p.ItemsSelectionJson)); } catch (e) {}
            }
            onDimensionChanged();
            onMetricChanged();
        })
        .catch(function() {});
}

document.addEventListener('DOMContentLoaded', function() {
    loadSavedLayout();
    try {
        var savedLang = localStorage.getItem('ai_lang');
        if (savedLang) {
            var sel = document.getElementById('aiLangSelect');
            if (sel) sel.value = savedLang;
        }
    } catch(e) {}
});

// ==================== Item Detail ====================
function showParetoItemDetail(itemCode) {
    document.getElementById('paretoModalCode').textContent = itemCode;
    document.getElementById('paretoModalLoading').style.display = '';
    document.getElementById('paretoModalError').classList.add('d-none');
    document.getElementById('paretoModalTable').style.display = 'none';

    var modal = new bootstrap.Modal(document.getElementById('paretoItemModal'));
    modal.show();

    var dateFrom = document.getElementById('dateFrom').value;
    var dateTo = document.getElementById('dateTo').value;
    var storeCodes = getSelectedStoreCodes();
    var url = '/Reports/GetTransactionDetails?itemCode=' + encodeURIComponent(itemCode)
        + '&type=all&dateFrom=' + dateFrom + '&dateTo=' + dateTo
        + '&storeCodes=' + encodeURIComponent(storeCodes);

    fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            document.getElementById('paretoModalLoading').style.display = 'none';
            if (!data.success) {
                document.getElementById('paretoModalError').textContent = data.message || 'Error loading transactions';
                document.getElementById('paretoModalError').classList.remove('d-none');
                return;
            }
            var tbody = document.getElementById('paretoModalTbody');
            var kindLabels = { 'P': 'Purchase', 'E': 'Purch Return', 'I': 'Sale', 'C': 'Credit' };
            var kindColors = { 'P': 'text-bg-info', 'E': 'text-bg-warning', 'I': 'text-bg-success', 'C': 'text-bg-danger' };
            var fmtN = function(v) { return v != null ? v.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2}) : ''; };
            tbody.innerHTML = data.rows.map(function(r) {
                return '<tr>' +
                    '<td class="text-nowrap">' + (r.date || '') + '</td>' +
                    '<td><span class="badge ' + (kindColors[r.kind] || 'text-bg-secondary') + '">' + (kindLabels[r.kind] || r.kind || '') + '</span></td>' +
                    '<td>' + (r.invoiceNo || '') + '</td>' +
                    '<td>' + (r.customerName || '') + '</td>' +
                    '<td class="text-end">' + (r.quantity != null ? r.quantity : '') + '</td>' +
                    '<td class="text-end">' + fmtN(r.amount) + '</td>' +
                    '<td>' + (r.storeCode || '') + '</td></tr>';
            }).join('');
            document.getElementById('paretoModalTable').style.display = '';
        })
        .catch(function(err) {
            document.getElementById('paretoModalLoading').style.display = 'none';
            document.getElementById('paretoModalError').textContent = 'Network error: ' + err.message;
            document.getElementById('paretoModalError').classList.remove('d-none');
        });
}
</script>
}
