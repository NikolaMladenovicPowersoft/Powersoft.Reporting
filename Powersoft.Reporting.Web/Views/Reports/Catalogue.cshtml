        document.getElementById('schedDayContainer').style.display = 'none';
        document.getElementById('schedWeeklyDaysContainer').style.display = 'none';
        document.getElementById('schedMonthDayContainer').style.display = 'none';
        if (type === 'Weekly') document.getElementById('schedWeeklyDaysContainer').style.display = '';
        else if (type === 'Monthly') document.getElementById('schedMonthDayContainer').style.display = '';
    }

    function validateEmailList(input) {
        if (!input || !input.trim()) return { valid: false, emails: [], errors: ['Please enter at least one email address.'] };
        var emails = input.split(/[,;]/).map(function(e) { return e.trim(); }).filter(function(e) { return e.length > 0; });
        var re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
        var invalid = emails.filter(function(e) { return !re.test(e); });
        if (invalid.length > 0) return { valid: false, emails: emails, errors: invalid.map(function(e) { return 'Invalid: ' + e; }) };
        return { valid: true, emails: emails, errors: [] };
    }

    // ==================== Save / Reset Layout (per-user defaults) ====================

    function collectCurrentLayout() {
        function v(id){var el = document.getElementById(id); return el ? el.value : '';}
        function chk(id){var el = document.getElementById(id); return el ? (el.checked ? '1' : '0') : '0';}
        var p = {};
        p['DateBasis'] = v('DateBasis');
        p['UseDateTime'] = chk('UseDateTime');
        p['ReportMode'] = v('ReportMode');
        p['ReportOn'] = v('ReportOn');
        p['PrimaryGroup'] = v('PrimaryGroup');
        p['SecondaryGroup'] = v('SecondaryGroup');
        p['ThirdGroup'] = v('ThirdGroup');
        p['ProfitBasedOn'] = v('ProfitBasedOn');
        p['ProfitIncludesVat'] = chk('ProfitIncludesVat');
        p['StockValueBasedOn'] = v('StockValueBasedOn');
        p['StockValueIncludesVat'] = chk('StockValueIncludesVat');
        p['CostType'] = v('CostType');
        p['ShowProfit'] = chk('ShowProfit');
        p['ShowStock'] = chk('ShowStock');
        p['PageSize'] = v('PageSize');
        p['DisplayColumns'] = v('displayColumnsHidden') || '';
        // Column order — current "working" order from sessionStorage, or fallback to hidden input
        // (which reflects the order loaded from the layout on last page render).
        var co = '';
        try {
            var raw = sessionStorage.getItem(COL_ORDER_KEY);
            if (raw) {
                var arr = JSON.parse(raw);
                if (Array.isArray(arr)) co = arr.join(',');
            }
        } catch (e) {}
        if (!co) co = v('columnOrderHidden') || '';
        if (co) p['ColumnOrder'] = co;
        var isj = v('itemsSelectionJsonHidden');
        if (isj) p['ItemsSelectionJson'] = isj;
        var rt = v('ReportTitle');
        if (rt) p['ReportTitle'] = rt;
        return p;
    }

    function saveCurrentLayout() {
        var parms = collectCurrentLayout();
        fetch('@Url.Action("SaveCatalogueLayout", "Reports")', {
            method: 'POST',
