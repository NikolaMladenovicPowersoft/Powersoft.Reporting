}
function exportPsReport(format){var actions={csv:'@Url.Action("ExportPsCsv")',excel:'@Url.Action("ExportPsExcel")',pdf:'@Url.Action("ExportPsPdf")'};var url=actions[format];if(!url)return;var f=document.createElement('form');f.method='POST';f.action=url;f.style.display='none';var fields=collectPsParams();Object.keys(fields).forEach(function(k){var inp=document.createElement('input');inp.type='hidden';inp.name=k;inp.value=fields[k];f.appendChild(inp);});document.body.appendChild(f);f.submit();document.body.removeChild(f);}

function togglePreview(){
    var panel=document.getElementById('previewPanel');
    var grid=document.getElementById('results');
    var btn=document.getElementById('previewToggleBtn');
    previewOpen=!previewOpen;
    if(previewOpen){
        grid.style.display='none';
        panel.style.display='block';
        btn.innerHTML='<i class="bi bi-table me-1"></i>Grid';
        btn.classList.remove('btn-outline-primary');
        btn.classList.add('btn-outline-warning');
        var f=document.getElementById('previewFrame');
        var form=document.createElement('form');
        form.method='POST';
        form.action='@Url.Action("PrintPsPreview")';
        form.target='previewFrame';
        form.style.display='none';
        var fields=collectPsParams();
        Object.keys(fields).forEach(function(k){
            var inp=document.createElement('input');
            inp.type='hidden';inp.name=k;inp.value=fields[k]||'';
            form.appendChild(inp);
        });
        document.body.appendChild(form);
        form.submit();
        document.body.removeChild(form);
        f.onload=function(){try{f.style.height=Math.max(f.contentDocument.body.scrollHeight+80,700)+'px';}catch(e){f.style.height='900px';}};
    }else{
        panel.style.display='none';
        grid.style.display='';
        btn.innerHTML='<i class="bi bi-eye me-1"></i>Preview';
        btn.classList.remove('btn-outline-warning');
        btn.classList.add('btn-outline-primary');
    }
}

