@model Powersoft.Reporting.Web.ViewModels.PurchasesSalesViewModel
@using Powersoft.Reporting.Core.Enums
@using Powersoft.Reporting.Core.Models
@{
    ViewData["Title"] = "Purchases vs Sales";
    var filterCols = new[] { "ItemCode", "ItemName", "Level1Value", "Level2Value", "Level3Value",
        "QuantityPurchased", "NetPurchasedValue", "GrossPurchasedValue",
        "QuantitySold", "NetSoldValue", "GrossSoldValue", "Profit", "TotalStockQty" };
    bool hasAnyFilter = Model.FilterValues != null && Model.FilterValues.Any(kv => !string.IsNullOrEmpty(kv.Value));
    bool isMonthly = Model.ReportMode == PsReportMode.Monthly;
    bool hasResults = isMonthly ? Model.MonthlyResults.Any() : Model.Results.Any();
    bool hasL1 = Model.HasPrimaryGroup;
    bool hasL2 = Model.HasSecondaryGroup;
    bool hasL3 = isMonthly ? false : Model.HasThirdGroup;
    bool showItem = isMonthly
        ? (Model.PrimaryGroup == PsGroupBy.None && Model.SecondaryGroup == PsGroupBy.None)
        : (!Model.ToPurchasesSalesFilter().IsSummary || (!hasL1 && !hasL2 && !hasL3));
    bool useGross = Model.IncludeVat;
}

@* report-modern.css + report-modern.js are loaded globally from _Layout *@
<style>
    a.dd-link-purch { color: #2563eb; text-decoration: none; cursor: pointer; border-bottom: 1px dashed #2563eb; }
    a.dd-link-purch:hover { color: #1d4ed8; border-bottom-style: solid; }
    a.dd-link-sales { color: #059669; text-decoration: none; cursor: pointer; border-bottom: 1px dashed #059669; }
    a.dd-link-sales:hover { color: #047857; border-bottom-style: solid; }
    th.col-purch { background: #eff6ff !important; color: #1e40af; }
    th.col-sales { background: #ecfdf5 !important; color: #065f46; }
</style>

<div class="rpt-modern">

<div class="rpt-hero rpt-rise">
    <div class="rpt-hero-left">
        <div class="rpt-hero-icon"><i class="bi bi-arrow-left-right"></i></div>
        <div>
            <div class="rpt-crumbs">
                <a asp-controller="Reports" asp-action="Index">Reports</a>
                <a asp-controller="Reports" asp-action="Index">Stock Control</a>
                <span>Purchases vs Sales</span>
            </div>
            <h2>Purchases vs Sales</h2>
            <p class="rpt-hero-sub">Compare purchasing and selling quantities and values per item</p>
        </div>
    </div>
    <div>
        @await Html.PartialAsync("_TutorialButton", ("Purchases vs Sales", ""))
    </div>
</div>

<div class="card mb-4 rpt-rise rpt-rise-1">
    <div class="card-header"><i class="bi bi-funnel me-2"></i>Report Parameters</div>
    <div class="card-body">
        <form asp-action="PurchasesSales" method="post" id="reportForm">
            <input type="hidden" asp-for="SelectedStoreCodesString" id="selectedStoreCodesHidden" />
            <input type="hidden" asp-for="SelectedItemIdsString" id="selectedItemIdsHidden" />
            <input type="hidden" asp-for="ItemsSelectionJson" id="itemsSelectionJsonHidden" />
            <input type="hidden" asp-for="PageNumber" id="pageNumberHidden" />
            <input type="hidden" asp-for="SortColumn" id="sortColumnHidden" />
            <input type="hidden" asp-for="SortDirection" id="sortDirectionHidden" />
            <input type="hidden" asp-for="HiddenColumns" id="hiddenColumnsInput" />
            @foreach (var col in filterCols)
            {
                <input type="hidden" name="FilterValues[@col]" id="fv_@col" value="@(Model.FilterValues.GetValueOrDefault(col, ""))" />
                <input type="hidden" name="FilterOperators[@col]" id="fo_@col" value="@(Model.FilterOperators.GetValueOrDefault(col, ""))" />
            }

            <div class="row mb-3">
                <div class="col-12">
                    <div class="rpt-eyebrow"><i class="bi bi-lightning-charge"></i>Quick Date Selection</div>
                    <div class="date-presets btn-group flex-wrap" role="group">
                        <input type="radio" class="btn-check" name="DatePreset" id="presetToday" value="today" autocomplete="off">
                        <label class="btn rpt-chip" for="presetToday">Today</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetYesterday" value="yesterday" autocomplete="off">
                        <label class="btn rpt-chip" for="presetYesterday">Yesterday</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLast7" value="last7" autocomplete="off">
                        <label class="btn rpt-chip" for="presetLast7">Last 7 Days</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLast30" value="last30" autocomplete="off">
                        <label class="btn rpt-chip" for="presetLast30">Last 30 Days</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetThisMonth" value="thisMonth" autocomplete="off">
                        <label class="btn rpt-chip" for="presetThisMonth">This Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastMonth" value="lastMonth" autocomplete="off">
                        <label class="btn rpt-chip" for="presetLastMonth">Last Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetYTD" value="ytd" autocomplete="off">
                        <label class="btn rpt-chip" for="presetYTD">Year to Date</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastYear" value="lastYear" autocomplete="off">
                        <label class="btn rpt-chip" for="presetLastYear">Last Year</label>
                    </div>
                </div>
            </div>

            <div class="rpt-eyebrow mt-4"><i class="bi bi-calendar-range"></i>Period, Mode &amp; Grouping</div>

            <div class="row g-3 mb-3 align-items-end">
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date From</label>
                    <input type="date" asp-for="DateFrom" class="form-control" onchange="clearPreset()" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date To</label>
                    <input type="date" asp-for="DateTo" class="form-control" onchange="clearPreset()" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Report Mode</label>
                    <select asp-for="ReportMode" id="ReportMode" class="form-select" asp-items="Html.GetEnumSelectList<PsReportMode>()"></select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Group By</label>
                    <select asp-for="PrimaryGroup" id="PrimaryGroup" class="form-select group-select" asp-items="Html.GetEnumSelectList<PsGroupBy>()"></select>
                    <div class="invalid-feedback" id="primaryGroupError"></div>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Then By</label>
                    <select asp-for="SecondaryGroup" id="SecondaryGroup" class="form-select group-select" asp-items="Html.GetEnumSelectList<PsGroupBy>()"></select>
                    <div class="invalid-feedback" id="secondaryGroupError"></div>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Third Group</label>
                    <select asp-for="ThirdGroup" id="ThirdGroup" class="form-select group-select" asp-items="Html.GetEnumSelectList<PsGroupBy>()"></select>
                    <div class="invalid-feedback" id="thirdGroupError"></div>
                </div>
            </div>


            <div class="rpt-eyebrow"><i class="bi bi-toggles"></i>Display Options</div>

            <div class="rpt-switches mb-4">
                <div class="form-check form-switch">
                    <input type="checkbox" asp-for="IncludeVat" class="form-check-input" id="includeVatCheck" />
                    <label asp-for="IncludeVat" class="form-check-label">Include VAT</label>
                </div>
                <div class="form-check form-switch">
                    <input type="checkbox" asp-for="ShowProfit" class="form-check-input" id="showProfitCheck" />
                    <label asp-for="ShowProfit" class="form-check-label">Show Profit</label>
                </div>
                <div class="form-check form-switch">
                    <input type="checkbox" asp-for="ShowStock" class="form-check-input" id="showStockCheck" />
                    <label asp-for="ShowStock" class="form-check-label">Show Stock</label>
                </div>
                <div class="form-check form-switch">
                    <input type="checkbox" asp-for="ShowOnOrder" class="form-check-input" id="showOnOrderCheck" />
                    <label asp-for="ShowOnOrder" class="form-check-label">Show On Order</label>
                </div>
                <div class="form-check form-switch">
                    <input type="checkbox" asp-for="ShowReservation" class="form-check-input" id="showReservationCheck" />
                    <label asp-for="ShowReservation" class="form-check-label">Show Reserved</label>
                </div>
                <div class="form-check form-switch">
                    <input type="checkbox" asp-for="ShowAvailable" class="form-check-input" id="showAvailableCheck" />
                    <label asp-for="ShowAvailable" class="form-check-label">Show Available</label>
                </div>
                <div class="form-check form-switch">
                    <input type="checkbox" asp-for="IncludeAdditionalCharges" class="form-check-input" id="includeAdditionalChargesCheck" />
                    <label asp-for="IncludeAdditionalCharges" class="form-check-label" title="When off, purchase cost is invoice (wholesale) only, without allocated landed/additional charges">Include Additional Charges</label>
                </div>
                <div id="sortBySizeSequenceWrap" style="display:none;">
                    <div class="form-check form-switch">
                        <input type="checkbox" asp-for="SortBySizeSequence" class="form-check-input" id="sortBySizeSequenceCheck" />
                        <label asp-for="SortBySizeSequence" class="form-check-label" title="Order Size groups by the configured size sequence (e.g. 36.5 before 37) instead of alphabetically">Sort Sizes by Sequence</label>
                    </div>
                </div>
                <div class="ms-md-auto d-flex align-items-center gap-2">
                    <label class="form-label small text-muted mb-0">Rows per page</label>
                    <select asp-for="PageSize" class="form-select form-select-sm w-auto">
                        <option value="50">50</option>
                        <option value="100">100</option>
                        <option value="250">250</option>
                        <option value="500">500</option>
                    </select>
                </div>
            </div>

            <div class="report-form-actions d-flex flex-wrap gap-2 pt-2 border-top">
                <button type="submit" class="btn btn-primary btn-lg btn-generate" id="generateBtn">
                    <span class="btn-text"><i class="bi bi-play-fill me-2"></i>Generate Report</span>
                    <span class="spinner-border spinner-border-sm d-none" role="status"></span>
                </button>
                @if (Model.CanSchedule)
                {
                    <button type="button" class="btn btn-warning btn-lg" data-bs-toggle="modal" data-bs-target="#scheduleModal" title="Schedule recurring report delivery">
                        <i class="bi bi-clock-history me-2"></i>Schedule
                    </button>
                }
                <div class="btn-group ms-auto">
                    <div class="btn-group">
                        <button type="button" class="btn btn-outline-info dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false"
                                title="Saved report layouts" id="layoutsDropdownBtn">
                            <i class="bi bi-bookmark me-1"></i><span id="layoutsCurrentName">Layouts</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" id="layoutsDropdownMenu" style="min-width: 320px;">
                            <li><h6 class="dropdown-header">Loading...</h6></li>
                        </ul>
                    </div>
                    <button type="button" class="btn btn-outline-info" onclick="saveCurrentLayout()" title="Overwrite your default layout with current parameters">
                        <i class="bi bi-save me-1"></i>Save
                    </button>
                    <button type="button" class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#saveLayoutAsModal"
                            title="Save current parameters as a new named layout (optionally shared with all users)">
                        <i class="bi bi-bookmark-plus me-1"></i>Save as...
                    </button>
                    @if (Model.HasSavedLayout)
                    {
                        <button type="button" class="btn btn-outline-secondary" onclick="resetSavedLayout()" title="Discard your saved default layout and restore factory defaults">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Default
                        </button>
                    }
                    <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#columnSettingsModal" title="Choose which columns to show/hide">
                        <i class="bi bi-layout-three-columns me-1"></i>Columns
                    </button>
                </div>
                <a asp-action="PurchasesSales" class="btn btn-outline-secondary btn-reset" title="Clear all filters">
                    <i class="bi bi-funnel me-1"></i>Clear Filters
                </a>
            </div>
            @if (Model.HasSavedLayout)
            {
                <div class="mt-2"><small class="text-info"><i class="bi bi-check-circle me-1"></i>Saved layout loaded</small></div>
            }
        </form>
    </div>
</div>

@{
    var storesJson = System.Text.Json.JsonSerializer.Serialize(Model.AvailableStores.Select(s => new { code = s.StoreCode, name = s.StoreName }));
}
@await Html.PartialAsync("_ItemsSelection", new ItemsSelectionConfig
{
    ShowCategories = true,
    ShowDepartments = true,
    ShowBrands = true,
    ShowSeasons = true,
    ShowSuppliers = true,
    ShowCustomers = true,
    ShowStores = true,
    ShowItems = true,
    ShowModels = Model.ShowModels,
    ShowColours = Model.ShowColours,
    ShowSizes = Model.ShowSizes,
    ShowGroupSizes = Model.ShowGroupSizes,
    ShowFabrics = Model.ShowFabrics,
    ShowAttributes = Model.ShowAttributes,
    StoresJson = storesJson,
    SavedFilterJson = Model.ItemsSelectionJson ?? "",
    ReportType = "PurchasesSales"
})

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <div class="d-flex align-items-start">
            <i class="bi bi-exclamation-triangle-fill me-2 mt-1"></i>
            <div><strong>Unable to generate report</strong><p class="mb-0 mt-1">@Model.ErrorMessage</p></div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (hasResults)
{
    <div class="row mb-4 g-3">
        @if (isMonthly)
        {
            <div class="col-6 col-md-4">
                <div class="rpt-kpi kpi-purch rpt-rise rpt-rise-1">
                    <div class="rpt-kpi-icon"><i class="bi bi-cart-plus"></i></div>
                    <div>
                        <div class="stat-value" data-rm-countup>@Model.MonthlyTotalPurchased.ToString("N2")</div>
                        <div class="stat-label">Total Purchased</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="rpt-kpi kpi-sales rpt-rise rpt-rise-2">
                    <div class="rpt-kpi-icon"><i class="bi bi-cart-check"></i></div>
                    <div>
                        <div class="stat-value" data-rm-countup>@Model.MonthlyTotalSold.ToString("N2")</div>
                        <div class="stat-label">Total Sold</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="rpt-kpi kpi-neutral rpt-rise rpt-rise-3">
                    <div class="rpt-kpi-icon"><i class="bi bi-list-ol"></i></div>
                    <div>
                        <div class="stat-value" data-rm-countup>@Model.TotalCount.ToString("N0")</div>
                        <div class="stat-label">Total Rows</div>
                    </div>
                </div>
            </div>
        }
        else
        {
        <div class="col-6 col-md-3">
            <div class="rpt-kpi kpi-purch rpt-rise rpt-rise-1">
                <div class="rpt-kpi-icon"><i class="bi bi-cart-plus"></i></div>
                <div>
                    <div class="stat-value" data-rm-countup>@Model.TotalPurchasedQty.ToString("N0")</div>
                    <div class="stat-label">Total Qty Purchased</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="rpt-kpi kpi-sales rpt-rise rpt-rise-2">
                <div class="rpt-kpi-icon"><i class="bi bi-cart-check"></i></div>
                <div>
                    <div class="stat-value" data-rm-countup>@Model.TotalSoldQty.ToString("N0")</div>
                    <div class="stat-label">Total Qty Sold</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="rpt-kpi kpi-purch rpt-rise rpt-rise-3">
                <div class="rpt-kpi-icon"><i class="bi bi-wallet2"></i></div>
                <div>
                    <div class="stat-value" data-rm-countup>@Model.TotalPurchasedValue.ToString("N2")</div>
                    <div class="stat-label">@(useGross ? "Gross" : "Net") Purchased</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="rpt-kpi kpi-profit rpt-rise rpt-rise-4">
                <div class="rpt-kpi-icon"><i class="bi bi-graph-up-arrow"></i></div>
                <div>
                    @{var profitColor = Model.TotalProfit >= 0 ? "text-success" : "text-danger";}
                    <div class="stat-value @profitColor" data-rm-countup>@Model.TotalProfit.ToString("N2")</div>
                    <div class="stat-label">Total Profit</div>
                </div>
            </div>
        </div>
        }
    </div>

    <div class="card rpt-rise rpt-rise-2" id="results">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="rpt-results-meta">
                <i class="bi bi-table me-2"></i>Results: @Model.TotalCount.ToString("N0") total rows
                @if (hasL1) { <span class="badge bg-secondary ms-2">Grouped by @Model.PrimaryGroup</span> }
                @if (hasL2) { <span class="badge bg-secondary ms-1">then @Model.SecondaryGroup</span> }
                @if (hasL3) { <span class="badge bg-secondary ms-1">then @Model.ThirdGroup</span> }
            </span>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                @if (hasAnyFilter)
                {
                    <button class="btn btn-sm btn-outline-warning" onclick="clearAllFilters()" title="Clear column filters">
                        <i class="bi bi-funnel me-1"></i>Clear column filters
                    </button>
                }
                <button class="btn btn-sm btn-outline-primary" onclick="togglePreview()" id="previewToggleBtn" title="Toggle document preview">
                    <i class="bi bi-eye me-1"></i>Preview
                </button>
                <div class="btn-group btn-group-sm">
                    <button type="button" class="btn btn-outline-success" onclick="exportPsReport('csv')">
                        <i class="bi bi-filetype-csv me-1"></i>CSV
                    </button>
                    <button type="button" class="btn btn-outline-success" onclick="exportPsReport('excel')">
                        <i class="bi bi-filetype-xlsx me-1"></i>Excel
                    </button>
                    <button type="button" class="btn btn-outline-danger" onclick="exportPsReport('pdf')">
                        <i class="bi bi-filetype-pdf me-1"></i>PDF
                    </button>
                </div>
                <button class="btn btn-sm btn-outline-primary" onclick="openSendEmailModal()" title="Send report via email">
                    <i class="bi bi-envelope me-1"></i>Send to Email
                </button>
                <button class="btn btn-sm btn-outline-info" onclick="openAiAnalysis()" title="AI-powered report analysis" id="btnAnalyzePs">
                    <i class="bi bi-stars me-1"></i>AI Analyze
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive rpt-table-wrap">
            @if (isMonthly)
            {
                var months = new[]{"Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"};
                int fixedCols = (hasL1?1:0)+(hasL2?1:0)+(showItem?2:0)+1;
                int monthlyCols = fixedCols + 13 + 13;
                <table class="table table-hover mb-0 table-sm" id="resultsTable" style="font-size:0.82rem;">
                    <thead>
                        <tr>
                            @if (hasL1) { <th rowspan="2">@Model.PrimaryGroup</th> }
                            @if (hasL2) { <th rowspan="2">@Model.SecondaryGroup</th> }
                            @if (showItem) { <th rowspan="2">Code</th><th rowspan="2">Name</th> }
                            <th rowspan="2" class="text-center">Year</th>
                            <th colspan="13" class="text-center col-purch">Purchased</th>
                            <th colspan="13" class="text-center col-sales">Sold</th>
                        </tr>
                        <tr>
                            @for (int mi=0; mi<12; mi++){<th class="text-end col-purch" style="font-size:0.75rem;">@months[mi]</th>}
                            <th class="text-end col-purch fw-semibold">Total</th>
                            @for (int mi=0; mi<12; mi++){<th class="text-end col-sales" style="font-size:0.75rem;">@months[mi]</th>}
                            <th class="text-end col-sales fw-semibold">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                    @{
                        var monthlyGroups = hasL1 ? Model.MonthlyResults.GroupBy(r => r.Level1Value ?? r.Level1 ?? "N/A") : null;
                    }
                    @if (hasL1 && monthlyGroups != null)
                    {
                        foreach (var l1g in monthlyGroups)
                        {
                            <tr class="group-header-row"><td colspan="@monthlyCols"><i class="bi bi-diagram-3 me-2"></i><strong>@Model.PrimaryGroup:</strong> @l1g.Key</td></tr>
                            var l1rows = l1g.ToList();
                            if (hasL2)
                            {
                                var l2gs = l1rows.GroupBy(r => r.Level2Value ?? "N/A");
                                foreach (var l2g in l2gs)
                                {
                                    <tr class="group-header-row" style="background:#e8f0fe;"><td colspan="@monthlyCols" class="ps-4"><i class="bi bi-chevron-right me-1"></i><strong>@Model.SecondaryGroup:</strong> @l2g.Key</td></tr>
                                    foreach (var row in l2g)
                                    {
                                        <tr>
                                            @if(hasL1){<td>@row.Level1Value</td>}@if(hasL2){<td>@row.Level2Value</td>}
                                            @if(showItem){<td class="fw-semibold">@row.ItemCode</td><td>@row.ItemName</td>}
                                            <td class="text-center">@row.TransYear</td>
                                            @for(int mi=0;mi<12;mi++){<td class="text-end">@row.Purchased[mi].ToString("N2")</td>}
                                            <td class="text-end fw-semibold">@row.TotalPurchased.ToString("N2")</td>
                                            @for(int mi=0;mi<12;mi++){<td class="text-end">@row.Sold[mi].ToString("N2")</td>}
                                            <td class="text-end fw-semibold">@row.TotalSold.ToString("N2")</td>
                                        </tr>
                                    }
                                    var l2p = SumMonthlyPurch(l2g); var l2s = SumMonthlySold(l2g);
                                    <tr class="subtotal-row" style="background:#e8f0fe;">
                                        @for(int c=0;c<fixedCols;c++){<td></td>}
                                        @for(int mi=0;mi<12;mi++){<td class="text-end fw-semibold">@l2p[mi].ToString("N2")</td>}
                                        <td class="text-end fw-bold">@l2p.Sum().ToString("N2")</td>
                                        @for(int mi=0;mi<12;mi++){<td class="text-end fw-semibold">@l2s[mi].ToString("N2")</td>}
                                        <td class="text-end fw-bold">@l2s.Sum().ToString("N2")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                foreach (var row in l1rows)
                                {
                                    <tr>
                                        @if(hasL1){<td>@row.Level1Value</td>}@if(hasL2){<td>@row.Level2Value</td>}
                                        @if(showItem){<td class="fw-semibold">@row.ItemCode</td><td>@row.ItemName</td>}
                                        <td class="text-center">@row.TransYear</td>
                                        @for(int mi=0;mi<12;mi++){<td class="text-end">@row.Purchased[mi].ToString("N2")</td>}
                                        <td class="text-end fw-semibold">@row.TotalPurchased.ToString("N2")</td>
                                        @for(int mi=0;mi<12;mi++){<td class="text-end">@row.Sold[mi].ToString("N2")</td>}
                                        <td class="text-end fw-semibold">@row.TotalSold.ToString("N2")</td>
                                    </tr>
                                }
                            }
                            var l1p = SumMonthlyPurch(l1g); var l1s = SumMonthlySold(l1g);
