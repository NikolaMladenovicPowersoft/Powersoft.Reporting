            </div>
        </div>
    </div>
</div>

<!-- Document Detail Modal -->
<div class="modal fade" id="docDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header" id="docDetailHeader">
                <h5 class="modal-title" id="docDetailTitle">
                    <i class="bi bi-file-earmark-text me-2"></i>Document Detail
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="docDetailLoading" class="text-center py-4">
                    <span class="spinner-border spinner-border-sm me-2"></span>Loading document...
                </div>
                <div id="docDetailError" class="alert alert-danger d-none"></div>
                <!-- Compact view -->
                <div id="docCompactView" class="d-none">
                    <div class="row mb-3 small">
                        <div class="col-md-3"><strong>Date:</strong> <span id="docDate"></span></div>
                        <div class="col-md-3"><strong>Store:</strong> <span id="docStore"></span></div>
                        <div class="col-md-6"><strong>Entity:</strong> <span id="docEntity"></span></div>
                    </div>
                    <table class="table table-sm table-bordered table-hover mb-3">
                        <thead class="table-light">
                            <tr class="small">
                                <th>Item Code</th><th>Item Name</th>
                                <th class="text-end">Qty</th><th class="text-end">Unit Price</th>
                                <th class="text-end">Discount</th><th class="text-end">Net</th>
                                <th class="text-end">VAT</th><th class="text-end">Gross</th>
                            </tr>
                        </thead>
                        <tbody id="docDetailLines" class="small"></tbody>
                        <tfoot>
                            <tr class="fw-bold small table-light">
                                <td colspan="5" class="text-end">Totals:</td>
                                <td class="text-end" id="docTotalNet"></td>
                                <td class="text-end" id="docTotalVat"></td>
                                <td class="text-end" id="docTotalGross"></td>
                            </tr>
                        </tfoot>
                    </table>
                    <div class="text-muted small" id="docLineCount"></div>
                </div>
                <!-- Full view (print-ready, inside same modal) -->
                <div id="docFullView" class="d-none"></div>
            </div>
            <div class="modal-footer" id="docModalFooter">
                <button type="button" class="btn btn-outline-primary btn-sm" id="btnDocToggleView" onclick="toggleDocView()" title="Toggle document preview">
                    <i class="bi bi-eye me-1"></i>Preview
                </button>
                <button type="button" class="btn btn-outline-success btn-sm" onclick="printDocFromModal()">
                    <i class="bi bi-printer me-1"></i>Print
                </button>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Send to Email Modal -->
<div class="modal fade" id="sendEmailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-envelope me-2"></i>Send Report via Email</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">To <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="sendEmailRecipients" placeholder="user@@company.com, manager@@company.com">
                        <small class="text-muted">Comma or semicolon separated</small>
                        <div class="invalid-feedback" id="sendEmailRecipientsError"></div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Template</label>
                        <select class="form-select" id="sendEmailTemplate" onchange="onEmailTemplateChange()">
                            <option value="">-- No template (default) --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">CC <span class="text-muted fw-normal">(optional)</span></label>
                        <input type="text" class="form-control" id="sendEmailCC" placeholder="cc@@example.com">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">BCC <span class="text-muted fw-normal">(optional)</span></label>
                        <input type="text" class="form-control" id="sendEmailBCC" placeholder="bcc@@example.com">
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-semibold">Subject</label>
                        <input type="text" class="form-control" id="sendEmailSubject" value="Purchases vs Sales Report — @Model.DateFrom.ToString("yyyy-MM-dd") to @Model.DateTo.ToString("yyyy-MM-dd")">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Format</label>
                        <select class="form-select" id="sendEmailFormat">
                            <option value="Excel" selected>Excel (.xlsx)</option>
                            <option value="PDF">PDF</option>
                            <option value="CSV">CSV</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Email Message</label>
                        <div class="border rounded" style="max-height:250px;overflow-y:auto;padding:12px;font-family:Arial,sans-serif;font-size:13px;background:#fafafa;" id="sendEmailBodyPreview">
                            <em class="text-muted">Select a template to preview the email body, or the default body will be used.</em>
                        </div>
                    </div>
                </div>
                <div id="sendEmailAlert" class="mt-3" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <a asp-controller="Settings" asp-action="EmailTemplates" class="btn btn-outline-secondary me-auto" title="Manage email templates">
                    <i class="bi bi-gear me-1"></i>Manage Templates
                </a>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="sendEmailBtn" onclick="sendReportEmail()">
                    <span class="spinner-border spinner-border-sm d-none me-1" id="sendEmailSpinner"></span>
                    <i class="bi bi-send me-1" id="sendEmailIcon"></i>Send
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var previewOpen = false;

(function(){
    var pg = document.getElementById('PrimaryGroup');
    var sg = document.getElementById('SecondaryGroup');
    var tg = document.getElementById('ThirdGroup');
    var genBtn = document.getElementById('generateBtn');
    if (!pg || !sg || !tg) return;

    var none = '0';

    function cascade() {
        if (pg.value === none) {
            sg.value = none; sg.disabled = true;
            tg.value = none; tg.disabled = true;
        } else {
            sg.disabled = false;
            if (sg.value === none) { tg.value = none; tg.disabled = true; }
            else { tg.disabled = false; }
        }
    }

    function checkDuplicates() {
        var pv = pg.value, sv = sg.value, tv = tg.value;
        var ok = true;

        sg.classList.remove('is-invalid');
        tg.classList.remove('is-invalid');
        document.getElementById('secondaryGroupError').textContent = '';
        document.getElementById('thirdGroupError').textContent = '';

        if (sv !== none && pv !== none && sv === pv) {
            sg.classList.add('is-invalid');
            document.getElementById('secondaryGroupError').textContent = 'Must be different from Group By';
            ok = false;
        }
        if (tv !== none) {
            if (pv !== none && tv === pv) {
                tg.classList.add('is-invalid');
                document.getElementById('thirdGroupError').textContent = 'Must be different from Group By';
                ok = false;
            } else if (sv !== none && tv === sv) {
                tg.classList.add('is-invalid');
                document.getElementById('thirdGroupError').textContent = 'Must be different from Then By';
                ok = false;
            }
        }

        if (genBtn) {
            genBtn.disabled = !ok;
            if (!ok) genBtn.title = 'Fix duplicate group selections first';
            else genBtn.title = '';
        }
    }

    pg.addEventListener('change', function() { cascade(); checkDuplicates(); });
    sg.addEventListener('change', function() { cascade(); checkDuplicates(); });
    tg.addEventListener('change', checkDuplicates);

    var rm = document.getElementById('ReportMode');
    function toggleMonthlyControls() {
        var isM = rm && rm.value === '2';
        if (document.getElementById('showProfitCheck')) document.getElementById('showProfitCheck').disabled = isM;
        if (document.getElementById('showStockCheck')) document.getElementById('showStockCheck').disabled = isM;
        if (isM) { tg.value = none; tg.disabled = true; }
    }

    if (rm) rm.addEventListener('change', function() { toggleMonthlyControls(); cascade(); checkDuplicates(); });
    cascade();
    checkDuplicates();
    toggleMonthlyControls();
})();

function populateItemsSelectionHidden() {
    if (typeof getItemsSelectionFilter === 'function') {
        document.getElementById('itemsSelectionJsonHidden').value = JSON.stringify(getItemsSelectionFilter());
    }
    if (typeof getItemsSelectionStoreCodes === 'function') {
        document.getElementById('selectedStoreCodesHidden').value = getItemsSelectionStoreCodes();
    }
}

function clearPreset(){document.querySelectorAll('input[name="DatePreset"]').forEach(r=>r.checked=false);}
function submitToResults(){var form=document.getElementById('reportForm');var action=form.getAttribute('action')||'';if(action.indexOf('#')>-1)action=action.substring(0,action.indexOf('#'));form.setAttribute('action',action+'#results');form.submit();}
function goToPage(p){document.getElementById('pageNumberHidden').value=p;submitToResults();}
function sortBy(col){var curCol=document.getElementById('sortColumnHidden').value;var curDir=document.getElementById('sortDirectionHidden').value;document.getElementById('sortColumnHidden').value=col;document.getElementById('sortDirectionHidden').value=(col===curCol&&curDir==='ASC')?'DESC':'ASC';document.getElementById('pageNumberHidden').value=1;submitToResults();}

function togglePreview(){var panel=document.getElementById('previewPanel');var grid=document.getElementById('results');var btn=document.getElementById('previewToggleBtn');previewOpen=!previewOpen;if(previewOpen){grid.style.display='none';panel.style.display='block';btn.innerHTML='<i class="bi bi-table me-1"></i>Grid';btn.classList.remove('btn-outline-primary');btn.classList.add('btn-outline-warning');var f=document.getElementById('previewFrame');if(!f.src||f.src==='about:blank'){f.src='@Url.Action("PrintPsPreview")?dateFrom=@Model.DateFrom.ToString("yyyy-MM-dd")&dateTo=@Model.DateTo.ToString("yyyy-MM-dd")&reportMode=@Model.ReportMode&primaryGroup=@Model.PrimaryGroup&secondaryGroup=@Model.SecondaryGroup&thirdGroup=@Model.ThirdGroup&includeVat=@Model.IncludeVat&showProfit=@Model.ShowProfit&showStock=@Model.ShowStock&storeCodes=@(Model.SelectedStoreCodesString??"")&sortColumn=@Model.SortColumn&sortDirection=@Model.SortDirection';}f.onload=function(){try{f.style.height=Math.max(f.contentDocument.body.scrollHeight+80,700)+'px';}catch(e){f.style.height='900px';}};}else{panel.style.display='none';grid.style.display='';btn.innerHTML='<i class="bi bi-eye me-1"></i>Preview';btn.classList.remove('btn-outline-warning');btn.classList.add('btn-outline-primary');}}

function clearAllFilters(){@foreach(var c in filterCols){<text>document.getElementById('fv_@c').value='';document.getElementById('fo_@c').value='';</text>}document.getElementById('pageNumberHidden').value=1;submitToResults();}

function validateEmailList(input){if(!input||!input.trim())return{valid:false,errors:['Enter at least one email.']};var emails=input.split(/[,;]/).map(e=>e.trim()).filter(e=>e.length>0);var re=/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;var invalid=emails.filter(e=>!re.test(e));if(invalid.length>0)return{valid:false,errors:invalid.map(e=>'Invalid: '+e)};return{valid:true,emails:emails,errors:[]};}

var _emailTemplatesCache = [];
function openSendEmailModal(){document.getElementById('sendEmailRecipients').value='';document.getElementById('sendEmailAlert').style.display='none';document.getElementById('sendEmailRecipients').classList.remove('is-invalid');loadEmailTemplates();var m=new bootstrap.Modal(document.getElementById('sendEmailModal'));m.show();}

function loadEmailTemplates(){fetch('@Url.Action("GetEmailTemplates","Reports")?reportType=PurchasesSales').then(r=>r.json()).then(function(data){_emailTemplatesCache=data||[];var sel=document.getElementById('sendEmailTemplate');sel.innerHTML='<option value="">-- No template (default) --</option>';data.forEach(function(t){var opt=document.createElement('option');opt.value=t.templateId;opt.textContent=t.templateName+(t.isDefault?' (default)':'');opt.dataset.subject=t.emailSubject||'';sel.appendChild(opt);if(t.isDefault)opt.selected=true;});onEmailTemplateChange();}).catch(function(){});}

function onEmailTemplateChange(){var sel=document.getElementById('sendEmailTemplate');var id=parseInt(sel.value,10);var preview=document.getElementById('sendEmailBodyPreview');if(isNaN(id)||!id){preview.innerHTML='<em class="text-muted">Default email body will be used.</em>';return;}var tmpl=_emailTemplatesCache.find(function(t){return t.templateId===id;});if(!tmpl)return;if(tmpl.emailSubject)document.getElementById('sendEmailSubject').value=replaceMergeFieldsPreview(tmpl.emailSubject);if(tmpl.emailBodyHtml)preview.innerHTML=replaceMergeFieldsPreview(tmpl.emailBodyHtml);}

function replaceMergeFieldsPreview(text){return text.replace(/\u00ABReportName\u00BB/g,'Purchases vs Sales').replace(/\u00ABDatabaseName\u00BB/g,'@(Model.ConnectedDatabase??"Unknown")').replace(/\u00ABPeriod\u00BB/g,'@Model.DateFrom.ToString("yyyy-MM-dd") to @Model.DateTo.ToString("yyyy-MM-dd")').replace(/\u00ABRowCount\u00BB/g,'@(Model.Results?.Count??0)').replace(/\u00ABExportFormat\u00BB/g,document.getElementById('sendEmailFormat').value).replace(/\u00ABGeneratedDate\u00BB/g,new Date().toLocaleString()).replace(/\u00ABUserName\u00BB/g,'@(User.Identity?.Name??"Unknown")').replace(/\u00ABCompanyName\u00BB/g,'@(Model.ConnectedDatabase??"")').replace(/\u00AB/g,'').replace(/\u00BB/g,'');}

function sendReportEmail(){var ri=document.getElementById('sendEmailRecipients');var ad=document.getElementById('sendEmailAlert');var v=validateEmailList(ri.value);if(!v.valid){ri.classList.add('is-invalid');document.getElementById('sendEmailRecipientsError').textContent=v.errors.join('; ');return;}ri.classList.remove('is-invalid');var btn=document.getElementById('sendEmailBtn');var sp=document.getElementById('sendEmailSpinner');var ic=document.getElementById('sendEmailIcon');btn.disabled=true;sp.classList.remove('d-none');ic.classList.add('d-none');var fd=new FormData();fd.append('recipients',ri.value.trim());fd.append('cc',(document.getElementById('sendEmailCC').value||'').trim());fd.append('bcc',(document.getElementById('sendEmailBCC').value||'').trim());fd.append('emailSubject',document.getElementById('sendEmailSubject').value);fd.append('exportFormat',document.getElementById('sendEmailFormat').value);fd.append('templateId',document.getElementById('sendEmailTemplate').value||'');fd.append('dateFrom','@Model.DateFrom.ToString("yyyy-MM-dd")');fd.append('dateTo','@Model.DateTo.ToString("yyyy-MM-dd")');fd.append('reportMode','@Model.ReportMode');fd.append('primaryGroup','@Model.PrimaryGroup');fd.append('secondaryGroup','@Model.SecondaryGroup');fd.append('thirdGroup','@Model.ThirdGroup');fd.append('includeVat','@Model.IncludeVat');fd.append('showProfit','@Model.ShowProfit');fd.append('showStock','@Model.ShowStock');fd.append('storeCodes',typeof getItemsSelectionStoreCodes==='function'?getItemsSelectionStoreCodes():'');fd.append('sortColumn','@Model.SortColumn');fd.append('sortDirection','@Model.SortDirection');fetch('@Url.Action("SendPsReportEmail","Reports")',{method:'POST',body:fd}).then(r=>r.json()).then(function(d){btn.disabled=false;sp.classList.add('d-none');ic.classList.remove('d-none');ad.innerHTML='<div class="alert alert-'+(d.success?'success':'danger')+' mb-0">'+(d.success?'<i class="bi bi-check-circle me-1"></i>':'<i class="bi bi-exclamation-triangle me-1"></i>')+d.message+'</div>';ad.style.display='';}).catch(function(){btn.disabled=false;sp.classList.add('d-none');ic.classList.remove('d-none');ad.innerHTML='<div class="alert alert-danger mb-0">Network error.</div>';ad.style.display='';});}

function filterColumnList(){var el=document.getElementById('colSearchInput');if(!el)return;var s=el.value.toLowerCase().trim();document.querySelectorAll('#colToggleList label').forEach(function(lbl){if(!s){lbl.classList.remove('d-none');return;}var name=(lbl.getAttribute('data-col-name')||'').toLowerCase();var text=lbl.querySelector('span')?lbl.querySelector('span').textContent.toLowerCase():'';var match=name.indexOf(s)!==-1||text.indexOf(s)!==-1;if(match)lbl.classList.remove('d-none');else lbl.classList.add('d-none');});}
function toggleAllColumns(chk){document.querySelectorAll('.col-toggle').forEach(function(cb){cb.checked=chk;});applyColumnVisibility();updateColVisibleCount();}
function updateColVisibleCount(){var total=document.querySelectorAll('.col-toggle').length;var vis=document.querySelectorAll('.col-toggle:checked').length;var el=document.getElementById('colVisibleCount');if(el)el.textContent=vis;}

function applyColumnVisibility(){var hidden=[];document.querySelectorAll('.col-toggle').forEach(function(cb){if(!cb.checked)hidden.push(cb.value);});var hi=document.getElementById('hiddenColumnsInput');if(hi)hi.value=hidden.join(',');var styleEl=document.getElementById('colVisibilityStyle');if(!styleEl){styleEl=document.createElement('style');styleEl.id='colVisibilityStyle';document.head.appendChild(styleEl);}var table=document.getElementById('resultsTable');if(!table)return;var rules=[];document.querySelectorAll('.col-toggle').forEach(function(cb){if(!cb.checked){var headers=table.querySelectorAll('thead tr:first-child th');for(var i=0;i<headers.length;i++){if(headers[i].getAttribute('data-col')===cb.value){rules.push('#resultsTable th:nth-child('+(i+1)+'),#resultsTable td:nth-child('+(i+1)+'){display:none;}');break;}}}});styleEl.textContent=rules.join('\n');updateColVisibleCount();}

function autoSelectScheduleDateRange(){var preset=document.querySelector('input[name="DatePreset"]:checked');if(!preset)return;var map={'ytd':'YearToDate','lastYear':'LastYear','thisMonth':'ThisMonth','lastMonth':'LastMonth','last7':'LastNDays_7','last30':'LastNDays_30'};var mapped=map[preset.value];if(!mapped)return;var sel=document.getElementById('schedDateRangeType');for(var i=0;i<sel.options.length;i++){var opt=sel.options[i];if(mapped.startsWith('LastNDays_')){var days=mapped.split('_')[1];if(opt.value==='LastNDays'&&opt.getAttribute('data-value')===days){sel.selectedIndex=i;return;}}else if(opt.value===mapped){sel.selectedIndex=i;return;}}}
function onSchedDateRangeTypeChange(){var sel=document.getElementById('schedDateRangeType');var opt=sel.options[sel.selectedIndex];var isCustom=(opt.value==='Custom');document.getElementById('schedCustomDateFromWrap').style.display=isCustom?'':'none';document.getElementById('schedCustomDateToWrap').style.display=isCustom?'':'none';}
function onSchedAiToggle(){document.getElementById('schedAiDetails').style.display=document.getElementById('schedIncludeAi').checked?'':'none';}
function onRecurrenceChange(){var t=document.getElementById('schedRecurrence').value;document.getElementById('schedWeeklyDaysContainer').style.display=t==='Weekly'?'':'none';document.getElementById('schedMonthDayContainer').style.display=t==='Monthly'?'':'none';}
function saveSchedule(){var name=document.getElementById('schedName').value.trim();var recipients=document.getElementById('schedRecipients').value.trim();var alertDiv=document.getElementById('scheduleAlert');if(!name||!recipients){alertDiv.innerHTML='<div class="alert alert-warning mb-0">Please fill in schedule name and recipients.</div>';alertDiv.style.display='';return;}var ev=validateEmailList(recipients);if(!ev.valid){alertDiv.innerHTML='<div class="alert alert-warning mb-0">Invalid email(s): '+ev.errors.join('; ')+'</div>';alertDiv.style.display='';return;}var recurrence=document.getElementById('schedRecurrence').value;if(recurrence==='Once'){var sd=document.getElementById('schedStartDate').value;var today=new Date().toISOString().slice(0,10);if(!sd||sd<today){alertDiv.innerHTML='<div class="alert alert-warning mb-0">Start date must be today or later.</div>';alertDiv.style.display='';return;}}var day=(recurrence==='Monthly')?parseInt(document.getElementById('schedMonthDay').value,10):null;var fd=new FormData();fd.append('scheduleName',name);fd.append('recurrenceType',recurrence);if(day!==null&&!isNaN(day))fd.append('recurrenceDay',day);fd.append('scheduleTime',document.getElementById('schedTime').value);fd.append('exportFormat',document.getElementById('schedFormat').value);fd.append('recipients',recipients);fd.append('emailSubject',document.getElementById('schedSubject').value);fd.append('includeAiAnalysis',document.getElementById('schedIncludeAi').checked);fd.append('aiLocale',document.getElementById('schedAiLocale').value);fd.append('skipIfEmpty',document.getElementById('schedSkipIfEmpty').checked);var dateRangeSel=document.getElementById('schedDateRangeType');var dateRangeOpt=dateRangeSel.options[dateRangeSel.selectedIndex];var reportDateRange={type:dateRangeOpt.value};if(reportDateRange.type==='LastNDays'){reportDateRange.value=parseInt(dateRangeOpt.getAttribute('data-value')||'7',10);}else if(reportDateRange.type==='Custom'){reportDateRange.dateFrom=document.getElementById('schedDateFrom').value;reportDateRange.dateTo=document.getElementById('schedDateTo').value;}var params={reportDateRange:reportDateRange,dateFrom:document.getElementById('DateFrom').value,dateTo:document.getElementById('DateTo').value,reportMode:document.getElementById('ReportMode').value,primaryGroup:document.getElementById('PrimaryGroup').value,secondaryGroup:document.getElementById('SecondaryGroup').value,thirdGroup:document.getElementById('ThirdGroup').value,includeVat:document.getElementById('includeVatCheck').checked,showProfit:document.getElementById('showProfitCheck').checked,showStock:document.getElementById('showStockCheck').checked,storeCodes:typeof getItemsSelectionStoreCodes==='function'?getItemsSelectionStoreCodes():'',itemIds:document.getElementById('selectedItemIdsHidden').value||'',sortColumn:document.getElementById('sortColumnHidden').value||'ItemCode',sortDirection:document.getElementById('sortDirectionHidden').value||'ASC',reportType:'PurchasesSales'};fd.append('parametersJson',JSON.stringify(params));var startDate=document.getElementById('schedStartDate').value||new Date().toISOString().slice(0,10);var recurrenceJson={type:recurrence,time:document.getElementById('schedTime').value,range:{startDate:startDate,noEndDate:true}};if(recurrence==='Weekly'){var days=[];document.querySelectorAll('.sched-dow:checked').forEach(function(cb){days.push(parseInt(cb.value,10));});recurrenceJson.pattern={interval:1,daysOfWeek:days.length?days:[1]};}else if(recurrence==='Monthly'){recurrenceJson.pattern={dayOfMonth:day!==null?day:1};}fd.append('recurrenceJson',JSON.stringify(recurrenceJson));var sid=document.getElementById('schedId').value;if(sid)fd.append('scheduleId',sid);var saveBtn=document.querySelector('#scheduleModal .btn-primary[onclick="saveSchedule()"]');if(saveBtn)saveBtn.disabled=true;fetch('@Url.Action("SavePsSchedule","Reports")',{method:'POST',body:fd}).then(r=>r.json()).then(function(d){if(saveBtn)saveBtn.disabled=false;if(d.success){alertDiv.innerHTML='<div class="alert alert-success mb-0"><i class="bi bi-check-circle me-1"></i>'+d.message+'</div>';alertDiv.style.display='';loadExistingSchedules();if(d.updated){showScheduleToast('Schedule updated','success');}else{setTimeout(function(){resetScheduleForm();showScheduleToast('Schedule saved successfully','success');},700);}}else{alertDiv.innerHTML='<div class="alert alert-danger mb-0">'+d.message+'</div>';alertDiv.style.display='';}}).catch(function(){if(saveBtn)saveBtn.disabled=false;alertDiv.innerHTML='<div class="alert alert-danger mb-0">Network error.</div>';alertDiv.style.display='';});}
function showScheduleToast(message,type){var existing=document.getElementById('schedToast');if(existing)existing.remove();var div=document.createElement('div');div.id='schedToast';div.className='alert alert-'+type+' alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow';div.style.zIndex='11000';div.innerHTML='<i class="bi bi-'+(type==='success'?'check-circle':'exclamation-triangle')+' me-1"></i>'+message+'<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';document.body.appendChild(div);setTimeout(function(){if(div.parentNode)div.remove();},4000);}
function deleteScheduleRow(scheduleId,scheduleName){if(!confirm('Delete schedule "'+scheduleName+'"?\nThis cannot be undone.'))return;var fd=new FormData();fd.append('scheduleId',scheduleId);fetch('@Url.Action("DeleteSchedule","Reports")',{method:'POST',body:fd}).then(r=>r.json()).then(function(d){if(d.success){showScheduleToast('Schedule deleted','success');loadExistingSchedules();resetScheduleForm();}else{showScheduleToast(d.message||'Failed to delete schedule','danger');}}).catch(function(){showScheduleToast('Network error','danger');});}
function loadExistingSchedules(){fetch('@Url.Action("GetPsSchedules","Reports")').then(r=>r.json()).then(function(data){var c=document.getElementById('existingSchedules');if(!data||data.length===0){c.innerHTML='<em>No schedules configured yet.</em>';return;}var h='<table class="table table-sm mb-0 align-middle"><thead><tr><th>Name</th><th>Report</th><th>Recurrence</th><th>Format</th><th>Time</th><th>Next Run</th><th class="text-end">Actions</th></tr></thead><tbody>';data.forEach(function(s){var safeName=(s.scheduleName||'').replace(/'/g,"\\'").replace(/"/g,'&quot;');h+='<tr data-schedule-id="'+s.scheduleId+'" style="cursor:pointer;" title="Click to load this schedule"><td>'+escapeHtml(s.scheduleName||'')+'</td><td><span class="badge bg-primary">Purchases/Sales</span></td><td>'+s.recurrenceType+'</td><td>'+s.exportFormat+'</td><td>'+s.scheduleTime+'</td><td>'+(s.nextRun||'-')+'</td><td class="text-end"><button type="button" class="btn btn-sm btn-outline-primary me-1" title="Load into form" onclick="event.stopPropagation(); loadScheduleIntoForm('+s.scheduleId+')"><i class="bi bi-pencil"></i></button><button type="button" class="btn btn-sm btn-outline-danger" title="Delete schedule" onclick="event.stopPropagation(); deleteScheduleRow('+s.scheduleId+', \''+safeName+'\')"><i class="bi bi-trash"></i></button></td></tr>';});h+='</tbody></table>';c.innerHTML=h;c.querySelectorAll('tr[data-schedule-id]').forEach(function(tr){tr.addEventListener('click',function(){loadScheduleIntoForm(parseInt(tr.getAttribute('data-schedule-id'),10));});});}).catch(function(){document.getElementById('existingSchedules').innerHTML='<em>Could not load schedules.</em>';});}

// A2: clean-state on modal open + click-to-load existing schedule. Generic GetScheduleById is shared across reports.
function resetScheduleForm(){document.getElementById('schedId').value='';document.getElementById('schedName').value='';document.getElementById('schedRecipients').value='gm@powersoft.com.cy';document.getElementById('schedSubject').value='';document.getElementById('schedFormat').value='Excel';document.getElementById('schedRecurrence').value='Daily';document.getElementById('schedTime').value='08:00';var sd=document.getElementById('schedStartDate');if(sd)sd.value=new Date().toISOString().slice(0,10);document.querySelectorAll('.sched-dow').forEach(function(cb){cb.checked=false;});var skip=document.getElementById('schedSkipIfEmpty');if(skip)skip.checked=false;var ai=document.getElementById('schedIncludeAi');if(ai)ai.checked=false;onRecurrenceChange();onSchedAiToggle();var a=document.getElementById('scheduleAlert');if(a){a.style.display='none';a.innerHTML='';}}

function loadScheduleIntoForm(scheduleId){fetch('@Url.Action("GetScheduleById","Reports")?scheduleId='+scheduleId).then(function(r){return r.json();}).then(function(data){if(!data||!data.success||!data.schedule){showScheduleToast((data&&data.message)||'Could not load schedule','danger');return;}var s=data.schedule;document.getElementById('schedId').value=scheduleId;document.getElementById('schedName').value=s.scheduleName||'';document.getElementById('schedRecipients').value=s.recipients||'';document.getElementById('schedSubject').value=s.emailSubject||'';document.getElementById('schedFormat').value=s.exportFormat||'Excel';document.getElementById('schedRecurrence').value=s.recurrenceType||'Daily';document.getElementById('schedTime').value=s.scheduleTime||'08:00';onRecurrenceChange();if(s.recurrenceJson){try{var rec=typeof s.recurrenceJson==='string'?JSON.parse(s.recurrenceJson):s.recurrenceJson;if(rec&&rec.range&&rec.range.startDate){var sd=document.getElementById('schedStartDate');if(sd)sd.value=rec.range.startDate;}if(rec&&rec.pattern){if(rec.type==='Weekly'&&Array.isArray(rec.pattern.daysOfWeek)){document.querySelectorAll('.sched-dow').forEach(function(cb){cb.checked=rec.pattern.daysOfWeek.indexOf(parseInt(cb.value,10))!==-1;});}else if(rec.type==='Monthly'&&rec.pattern.dayOfMonth){var md=document.getElementById('schedMonthDay');if(md)md.value=String(rec.pattern.dayOfMonth);}}}catch(e){}}var skip=document.getElementById('schedSkipIfEmpty');if(skip)skip.checked=!!s.skipIfEmpty;var ai=document.getElementById('schedIncludeAi');if(ai)ai.checked=!!s.includeAiAnalysis;var al=document.getElementById('schedAiLocale');if(al&&s.aiLocale)al.value=s.aiLocale;onSchedAiToggle();if(s.parametersJson){try{var p=typeof s.parametersJson==='string'?JSON.parse(s.parametersJson):s.parametersJson;var rdrType=document.getElementById('schedDateRangeType');if(rdrType&&p.reportDateRange&&p.reportDateRange.type){var v=p.reportDateRange.value;var targetVal=p.reportDateRange.type;for(var i=0;i<rdrType.options.length;i++){var opt=rdrType.options[i];if(opt.value===targetVal&&(targetVal!=='LastNDays'||String(opt.getAttribute('data-value'))===String(v))){rdrType.selectedIndex=i;break;}}if(p.reportDateRange.type==='Custom'){if(p.reportDateRange.dateFrom)document.getElementById('schedDateFrom').value=p.reportDateRange.dateFrom;if(p.reportDateRange.dateTo)document.getElementById('schedDateTo').value=p.reportDateRange.dateTo;}}onSchedDateRangeTypeChange();}catch(e){}}var a=document.getElementById('scheduleAlert');if(a){a.innerHTML='<div class="alert alert-info mb-0 py-2"><i class="bi bi-pencil-square me-1"></i>Editing <strong>'+escapeHtml(s.scheduleName||'')+'</strong>. Saving will update this schedule in place &mdash; click <em>Reset</em> to start a new one instead.</div>';a.style.display='';}}).catch(function(){showScheduleToast('Network error loading schedule','danger');});}

function collectCurrentLayout(){var p={};var vat=document.getElementById('includeVatCheck');if(vat)p['IncludeVat']=vat.checked?'1':'0';var sp=document.getElementById('showProfitCheck');if(sp)p['ShowProfit']=sp.checked?'1':'0';var ss=document.getElementById('showStockCheck');if(ss)p['ShowStock']=ss.checked?'1':'0';var rm=document.getElementById('ReportMode');if(rm)p['ReportMode']=rm.options[rm.selectedIndex].text;var pg=document.getElementById('PrimaryGroup');if(pg)p['PrimaryGroup']=pg.options[pg.selectedIndex].text;var sg=document.getElementById('SecondaryGroup');if(sg)p['SecondaryGroup']=sg.options[sg.selectedIndex].text;var tg=document.getElementById('ThirdGroup');if(tg)p['ThirdGroup']=tg.options[tg.selectedIndex].text;var ps=document.getElementById('PageSize');if(ps)p['PageSize']=ps.value;var hidden=[];document.querySelectorAll('.col-toggle').forEach(function(cb){if(!cb.checked)hidden.push(cb.value);});p['HiddenColumns']=hidden.join(',');if(typeof getItemsSelectionFilter==='function')p['ItemsSelectionJson']=JSON.stringify(getItemsSelectionFilter());return p;}

// Guards against 302-to-login on expired cookie (otherwise we'd try to parse the login HTML as JSON and silently fail).
function isAuthRedirect(r){if(!r)return false;if(r.status===401||r.status===403)return true;if(r.redirected&&/\/Account\/Login/i.test(r.url||''))return true;var ct=r.headers&&r.headers.get?r.headers.get('content-type'):'';if(ct&&ct.indexOf('text/html')!==-1)return true;return false;}
function showSessionExpiredToast(){showLayoutToast('Session expired — please reload the page and sign in again.','warning');}

function saveCurrentLayout(){var p=collectCurrentLayout();fetch('@Url.Action("SavePsLayout","Reports")',{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/json'},body:JSON.stringify(p)}).then(function(r){if(isAuthRedirect(r)){showSessionExpiredToast();return null;}return r.json();}).then(function(d){if(d==null)return;showLayoutToast(d.success?'Layout saved successfully':(d.message||'Failed'),d.success?'success':'danger');}).catch(function(){showLayoutToast('Network error','danger');});}

function resetSavedLayout(){if(!confirm('Reset your saved layout to factory defaults?'))return;fetch('@Url.Action("ResetPsLayout","Reports")',{method:'POST',credentials:'same-origin'}).then(function(r){if(isAuthRedirect(r)){showSessionExpiredToast();return null;}return r.json();}).then(function(d){if(d==null)return;if(d.success){showLayoutToast('Layout reset — reloading...','success');setTimeout(function(){window.location.href='@Url.Action("PurchasesSales")';},800);}else{showLayoutToast(d.message||'Failed','danger');}}).catch(function(){showLayoutToast('Network error','danger');});}

function showLayoutToast(msg,type){var ex=document.getElementById('layoutToast');if(ex)ex.remove();var d=document.createElement('div');d.id='layoutToast';d.className='alert alert-'+type+' alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow';d.style.zIndex='9999';d.innerHTML='<i class="bi bi-'+(type==='success'?'check-circle':'exclamation-triangle')+' me-1"></i>'+msg+'<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';document.body.appendChild(d);setTimeout(function(){if(d.parentNode)d.remove();},4000);}

function initColumnVisibilityFromServer(){var hc='@(Model.HiddenColumns??"")';if(!hc)return;var hidden=hc.split(',').filter(s=>s.trim());if(hidden.length===0)return;hidden.forEach(function(col){var cb=document.querySelector('.col-toggle[value="'+col.trim()+'"]');if(cb)cb.checked=false;});applyColumnVisibility();}

function applyPresetDates(preset){var today=new Date();var from,to;switch(preset){case'today':from=to=today;break;case'yesterday':from=to=new Date(today.getTime()-86400000);break;case'last7':from=new Date(today.getTime()-6*86400000);to=today;break;case'last30':from=new Date(today.getTime()-29*86400000);to=today;break;case'thisMonth':from=new Date(today.getFullYear(),today.getMonth(),1);to=today;break;case'lastMonth':var lm=new Date(today.getFullYear(),today.getMonth()-1,1);from=lm;to=new Date(lm.getFullYear(),lm.getMonth()+1,0);break;case'ytd':from=new Date(today.getFullYear(),0,1);to=today;break;case'lastYear':from=new Date(today.getFullYear()-1,0,1);to=new Date(today.getFullYear()-1,11,31);break;default:return;}function fmt(d){return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}document.getElementById('DateFrom').value=fmt(from);document.getElementById('DateTo').value=fmt(to);}
function resetPage(){document.getElementById('pageNumberHidden').value=1;}
function showLoading(){var btn=document.getElementById('generateBtn');btn.querySelector('.btn-text').classList.add('d-none');btn.querySelector('.spinner-border').classList.remove('d-none');btn.disabled=true;}
document.addEventListener('DOMContentLoaded',function(){initColumnVisibilityFromServer();updateColVisibleCount();var colSearch=document.getElementById('colSearchInput');if(colSearch){colSearch.addEventListener('input',filterColumnList);colSearch.addEventListener('keyup',filterColumnList);}var savedPreset='@(Model.DatePreset??"")';if(savedPreset){var pr=document.querySelector('input[name="DatePreset"][value="'+savedPreset+'"]');if(pr)pr.checked=true;}document.querySelectorAll('input[name="DatePreset"]').forEach(function(r){r.addEventListener('change',function(){applyPresetDates(this.value);});});var form=document.getElementById('reportForm');form.addEventListener('submit',function(){populateItemsSelectionHidden();showLoading();});document.getElementById('generateBtn').addEventListener('click',function(){resetPage();});var schedModal=document.getElementById('scheduleModal');if(schedModal){schedModal.addEventListener('show.bs.modal',function(){resetScheduleForm();loadExistingSchedules();autoSelectScheduleDateRange();onSchedDateRangeTypeChange();});}
    fetch('/Reports/GetAiStatus').then(r=>r.json()).then(d=>{if(!d.configured){var btn=document.getElementById('btnAnalyzePs');if(btn){btn.title='AI not configured — set API key in Settings';btn.classList.add('disabled');}var schedAi=document.getElementById('schedIncludeAi');if(schedAi){schedAi.disabled=true;schedAi.parentElement.title='AI not configured — set API key in Settings';}}}).catch(()=>{});
});

var _expandedRows = {};

function drillDown(itemCode, type) {
    var key = itemCode + '_' + type;
    var existing = document.querySelectorAll('.dd-row[data-key="' + key + '"]');
    if (existing.length > 0) {
        existing.forEach(function(r) { r.remove(); });
        delete _expandedRows[key];
        return;
    }

    Object.keys(_expandedRows).forEach(function(k) {
        document.querySelectorAll('.dd-row[data-key="' + k + '"]').forEach(function(r) { r.remove(); });
        delete _expandedRows[k];
    });

    var clickedLink = event.target.closest('a');
    var parentRow = clickedLink ? clickedLink.closest('tr') : null;
    if (!parentRow) return;

    var colSpan = parentRow.cells.length;
    var loadingRow = document.createElement('tr');
    loadingRow.className = 'dd-row';
    loadingRow.dataset.key = key;
    loadingRow.innerHTML = '<td colspan="' + colSpan + '" class="bg-light py-2 text-center"><span class="spinner-border spinner-border-sm me-2"></span>Loading transaction details...</td>';
    parentRow.after(loadingRow);
    _expandedRows[key] = true;

    var url = '/Reports/GetTransactionDetails?itemCode=' + encodeURIComponent(itemCode)
        + '&type=' + type
        + '&dateFrom=@Model.DateFrom.ToString("yyyy-MM-dd")'
        + '&dateTo=@Model.DateTo.ToString("yyyy-MM-dd")'
        + '&storeCodes=' + (typeof getItemsSelectionStoreCodes === 'function' ? encodeURIComponent(getItemsSelectionStoreCodes()) : '');

    fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            loadingRow.remove();
            if (!_expandedRows[key]) return;

            if (!data.success) {
                var errRow = document.createElement('tr');
                errRow.className = 'dd-row';
                errRow.dataset.key = key;
                errRow.innerHTML = '<td colspan="' + colSpan + '" class="bg-danger bg-opacity-10 text-danger py-2 px-3"><i class="bi bi-exclamation-triangle me-1"></i>' + data.message + '</td>';
                parentRow.after(errRow);
                return;
            }

            if (data.count === 0) {
                var emptyRow = document.createElement('tr');
                emptyRow.className = 'dd-row';
                emptyRow.dataset.key = key;
                emptyRow.innerHTML = '<td colspan="' + colSpan + '" class="bg-light text-muted py-2 px-3">No transactions found for this item in the selected period.</td>';
                parentRow.after(emptyRow);
                return;
            }

            var kindColors = { 'P': 'bg-info', 'E': 'bg-warning', 'I': 'bg-success', 'C': 'bg-danger' };
            var typeLabels = { purchases: 'Purchase', sales: 'Sales', all: 'All' };
            var headerTheme = type === 'purchases'
                ? { bg: 'background:#e8f0fe;border-color:#2563eb;', border: 'border-color:#2563eb;', tblBg: '#f0f4ff' }
                : type === 'sales'
                ? { bg: 'background:#d1fae5;border-color:#059669;', border: 'border-color:#059669;', tblBg: '#f0fdf4' }
                : { bg: 'background:#e8f0fe;border-color:#6366f1;', border: 'border-color:#6366f1;', tblBg: '#f5f3ff' };

            var headerRow = document.createElement('tr');
            headerRow.className = 'dd-row';
            headerRow.dataset.key = key;
            headerRow.innerHTML = '<td colspan="' + colSpan + '" class="p-0">'
                + '<div style="' + headerTheme.bg + 'padding:8px 12px;border-top:2px solid;border-bottom:2px solid;' + headerTheme.border + '">'
                + '<strong><i class="bi bi-list-columns-reverse me-1"></i>' + (typeLabels[type] || '') + ' Transactions for ' + itemCode + '</strong>'
                + '<span class="ms-3 text-muted">' + data.count + ' transactions | Qty: ' + data.totalQty.toLocaleString(undefined,{maximumFractionDigits:2})
                + ' | Net: ' + data.totalNet.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})
                + '</span>'
                + '<button class="btn btn-sm btn-outline-secondary float-end py-0" onclick="drillDown(\'' + itemCode + '\',\'' + type + '\')"><i class="bi bi-x-lg"></i></button>'
                + '</div>'
                + '<table class="table table-sm table-bordered mb-0" style="background:' + headerTheme.tblBg + ';">'
                + '<thead><tr class="table-light small">'
                + '<th>Date</th><th>Type</th><th>Doc #</th><th>Entity</th><th>Store</th>'
                + '<th class="text-end">Qty</th><th class="text-end">Price</th><th class="text-end">Discount</th>'
                + '<th class="text-end">Net</th><th class="text-end">VAT</th><th class="text-end">Gross</th>'
                + '</tr></thead><tbody>'
                + data.rows.map(function(r) {
                    var bc = kindColors[r.kind] || 'bg-secondary';
                    return '<tr class="small">'
                        + '<td>' + r.date + '</td>'
                        + '<td><span class="badge ' + bc + ' badge-sm">' + r.kindDescription + '</span></td>'
                        + '<td class="fw-semibold"><a href="#" class="text-primary text-decoration-underline" onclick="openDocument(\'' + r.kind + '\',\'' + r.doc.replace(/'/g, "\\'") + '\');return false;" title="View document details">' + r.doc + '</a></td>'
                        + '<td>' + (r.entityCode ? r.entityCode + ' — ' : '') + r.entityName + '</td>'
                        + '<td>' + r.store + '</td>'
                        + '<td class="text-end">' + r.qty.toLocaleString(undefined,{maximumFractionDigits:2}) + '</td>'
                        + '<td class="text-end">' + r.price.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                        + '<td class="text-end">' + r.discount.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                        + '<td class="text-end">' + r.net.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                        + '<td class="text-end">' + r.vat.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                        + '<td class="text-end">' + r.gross.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                        + '</tr>';
                }).join('')
                + '</tbody></table></td>';
            parentRow.after(headerRow);
        })
        .catch(function(err) {
            loadingRow.remove();
            var errRow = document.createElement('tr');
            errRow.className = 'dd-row';
            errRow.dataset.key = key;
            errRow.innerHTML = '<td colspan="' + colSpan + '" class="bg-danger bg-opacity-10 text-danger py-2 px-3"><i class="bi bi-exclamation-triangle me-1"></i>Network error: ' + err.message + '</td>';
            parentRow.after(errRow);
        });
}

function saveAiLang(v) { localStorage.setItem('ps_ai_lang', v); }
function getAiLang() { return localStorage.getItem('ps_ai_lang') || 'el'; }
(function() { var s = document.getElementById('aiLangSelect'); if (s) s.value = getAiLang(); })();

function analyzePsReport() {
    var modalEl = document.getElementById('aiAnalysisModal');
    var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
    document.getElementById('aiLoading').classList.remove('d-none');
    document.getElementById('aiError').classList.add('d-none');
    document.getElementById('aiResults').classList.add('d-none');
    document.getElementById('aiPromptEditor').classList.add('d-none');
    document.getElementById('btnReanalyze').style.display = 'none';
    modal.show();

    var form = document.getElementById('reportForm');
    var formData = new FormData(form);
    formData.append('storeCodes', typeof getItemsSelectionStoreCodes === 'function' ? getItemsSelectionStoreCodes() : '');
    formData.append('itemIds', '@(Model.SelectedItemIdsString ?? "")');
    formData.append('sortColumn', '@Model.SortColumn');
    formData.append('sortDirection', '@Model.SortDirection');
    formData.append('locale', getAiLang());
    var promptTplId = document.getElementById('aiPromptTemplateSelect').value;
    if (promptTplId && promptTplId !== '0') formData.append('promptTemplateId', promptTplId);

    fetch('/Reports/AnalyzePsReport', { method: 'POST', body: formData })
        .then(r => r.json())
        .then(data => {
            document.getElementById('aiLoading').classList.add('d-none');
            if (!data.success) {
                document.getElementById('aiError').classList.remove('d-none');
                document.getElementById('aiErrorMsg').textContent = data.message;
                document.getElementById('btnReanalyze').style.display = 'inline-block';
                return;
            }
            var a = data.analysis;
            renderAiAnalysis(a);
            initAiConversation(a, data.csvPreview);
            document.getElementById('aiResults').classList.remove('d-none');
            document.getElementById('btnReanalyze').style.display = 'inline-block';
        })
        .catch(err => {
            document.getElementById('aiLoading').classList.add('d-none');
            document.getElementById('aiError').classList.remove('d-none');
            document.getElementById('aiErrorMsg').textContent = 'Network error: ' + err.message;
            document.getElementById('btnReanalyze').style.display = 'inline-block';
        });
}

var _currentDocType = '', _currentDocNumber = '';

function buildFullViewHtml(d) {
    var isPurch = (d.docType === 'P' || d.docType === 'E');
    var accent = isPurch ? '#2563eb' : '#059669';
    var accentBg = isPurch ? '#eff6ff' : '#ecfdf5';
    var entityLabel = isPurch ? 'Supplier' : 'Customer';
    var fmt2 = function(v) { return v.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}); };

    return '<div style="text-align:center;margin-bottom:24px;padding-bottom:16px;border-bottom:3px solid '+accent+'">'
        + '<div style="font-size:20px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:'+accent+'">'+d.docTypeDescription+'</div>'
        + '<div style="font-size:14px;font-weight:600;color:#475569;margin-top:2px">Document #: '+d.documentNumber+'</div>'
        + '</div>'
        + '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;font-size:12px;margin-bottom:20px;padding:12px 16px;background:'+accentBg+';border-radius:6px">'
        + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">Date</div><div style="font-weight:500;margin-top:1px">'+d.date+'</div></div>'
        + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">Store</div><div style="font-weight:500;margin-top:1px">'+(d.storeCode||'—')+'</div></div>'
        + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">'+entityLabel+'</div><div style="font-weight:500;margin-top:1px">'+(d.entityCode ? d.entityCode+' — ' : '')+d.entityName+'</div></div>'
        + '<div><div style="color:#64748b;font-size:10px;text-transform:uppercase;font-weight:600">Line Items</div><div style="font-weight:500;margin-top:1px">'+d.lineCount+'</div></div>'
        + '</div>'
        + '<table style="width:100%;border-collapse:collapse;font-size:11px">'
        + '<thead><tr style="background:#e2e8f0">'
        + '<th style="padding:6px 10px;text-align:left;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Item Code</th>'
        + '<th style="padding:6px 10px;text-align:left;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Description</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Qty</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Unit Price</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Discount</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Net</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">VAT</th>'
        + '<th style="padding:6px 10px;text-align:right;font-weight:700;font-size:10px;text-transform:uppercase;border-bottom:2px solid #94a3b8">Gross</th>'
        + '</tr></thead><tbody>'
        + d.lines.map(function(l){
            return '<tr>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;font-weight:600">'+l.itemCode+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9">'+l.itemName+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">'+l.qty.toLocaleString(undefined,{maximumFractionDigits:2})+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">'+fmt2(l.price)+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">'+fmt2(l.discount)+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">'+fmt2(l.net)+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">'+fmt2(l.vat)+'</td>'
                + '<td style="padding:5px 10px;border-bottom:1px solid #f1f5f9;text-align:right">'+fmt2(l.gross)+'</td>'
