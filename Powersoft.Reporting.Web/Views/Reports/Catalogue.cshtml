    // -------------------- Named / public layouts (multi per user) --------------------

    var __layoutsCache = null; // last server response, used to look up canEdit etc.

    // Detects when a JSON endpoint silently 302'd to the login page (auth cookie expired).
    // Returns true if the caller should short-circuit with a "session expired" toast/UI and skip JSON parsing.
    function isAuthRedirect(response) {
        if (!response) return false;
        if (response.status === 401 || response.status === 403) return true;
        if (response.redirected && /\/Account\/Login/i.test(response.url || '')) return true;
        // Fetch follows 3xx transparently; the only reliable non-OK signal for an HTML login body is content-type.
        var ct = response.headers && response.headers.get ? response.headers.get('content-type') : '';
        if (ct && ct.indexOf('text/html') !== -1) return true;
        return false;
    }

    function showSessionExpiredToast() {
        showLayoutToast('Session expired — please reload the page and sign in again.', 'warning');
    }

    function loadLayoutsList() {
        var menu = document.getElementById('layoutsDropdownMenu');
        if (menu) menu.innerHTML = '<li><h6 class="dropdown-header">Loading...</h6></li>';
        return fetch('@Url.Action("ListCatalogueLayouts", "Reports")', { method: 'GET', credentials: 'same-origin' })
            .then(function(r) {
                if (isAuthRedirect(r)) {
                    if (menu) menu.innerHTML = '<li><h6 class="dropdown-header text-danger">Session expired</h6></li>';
                    showSessionExpiredToast();
                    return null;
                }
                return r.json();
            })
            .then(function(data) {
                if (data == null) return;
                __layoutsCache = data && data.layouts ? data.layouts : [];
                renderLayoutsDropdown(__layoutsCache);
            })
            .catch(function() {
                if (menu) menu.innerHTML = '<li><h6 class="dropdown-header text-danger">Failed to load</h6></li>';
            });
    }

    function renderLayoutsDropdown(layouts) {
        var menu = document.getElementById('layoutsDropdownMenu');
        if (!menu) return;
        if (!layouts || layouts.length === 0) {
            menu.innerHTML =
                '<li><h6 class="dropdown-header">No saved layouts</h6></li>' +
                '<li><span class="dropdown-item-text small text-muted">Use "Save as..." to create one.</span></li>';
            return;
        }

        // Group: own (private) first, then public.
        var own = layouts.filter(function(l) { return !l.isPublic; });
        var pub = layouts.filter(function(l) { return  l.isPublic; });

        var html = '';
        function renderGroup(label, items) {
            if (!items.length) return;
            html += '<li><h6 class="dropdown-header">' + label + '</h6></li>';
            items.forEach(function(l) {
                var safeName = String(l.name || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
                var publicBadge = l.isPublic ? '<span class="badge bg-secondary ms-2" title="Visible to all users">Public</span>' : '';
                var editorBadge = l.isPublic && l.createdBy
                    ? '<span class="text-muted small ms-2">by ' + String(l.createdBy).replace(/</g,'&lt;') + '</span>'
                    : '';
                html += '<li class="d-flex align-items-center px-2 py-1 layout-row">' +
                            '<a href="#" class="flex-grow-1 text-decoration-none text-body" onclick="loadNamedLayout(\'' +
                                String(l.headerCode).replace(/'/g, "\\'") + '\'); return false;">' +
                                '<i class="bi bi-bookmark me-1"></i>' + safeName + publicBadge + editorBadge +
                            '</a>';
                if (l.canEdit) {
                    html += '<button type="button" class="btn btn-sm btn-link text-danger p-0 ms-2" ' +
                                'title="Delete this layout" onclick="deleteNamedLayout(\'' +
                                String(l.headerCode).replace(/'/g, "\\'") + '\', \'' +
                                safeName.replace(/'/g, "\\'") + '\'); return false;">' +
                                '<i class="bi bi-trash"></i>' +
                            '</button>';
                }
                html += '</li>';
            });
        }
        renderGroup('Your layouts', own);
        renderGroup('Public layouts', pub);
        menu.innerHTML = html;
    }

    function loadNamedLayout(headerCode) {
        if (!headerCode) return;
        // NOTE: deliberately does NOT auto-submit the form. Auto-submit was causing users to land on
        // the login page when the auth cookie had expired between the save and the reload (ASP.NET
        // cookie-auth responds to POST with a 302 to /Account/Login, which the browser follows as a
        // navigation). Layout load now behaves like Reset Default: apply parameters in-place and let
        // the user press Generate explicitly.
        fetch('@Url.Action("LoadCatalogueLayout", "Reports")?headerCode=' + encodeURIComponent(headerCode),
              { method: 'POST', credentials: 'same-origin' })
            .then(function(r) {
                if (isAuthRedirect(r)) { showSessionExpiredToast(); return null; }
                return r.json();
            })
            .then(function(data) {
                if (data == null) return;
                if (!data.success) {
                    showLayoutToast(data.message || 'Failed to load layout', 'danger');
                    return;
                }
                applyLayoutParameters(data.parameters || {});
                var label = document.getElementById('layoutsCurrentName');
                if (label && __layoutsCache) {
                    var match = __layoutsCache.find(function(l) { return l.headerCode === headerCode; });
                    if (match) label.textContent = match.name;
                }
                showLayoutToast('Layout loaded — click Generate to run.', 'success');
            })
            .catch(function() { showLayoutToast('Network error loading layout', 'danger'); });
    }

    function applyLayoutParameters(parms) {
        // Mirror the server-side parsing in LoadCatalogueSavedLayoutAsync. Apply to form controls in-place,
        // then reapply downstream UI handlers (column toggles, items selection JSON, etc.).
        function setVal(id, v) { var el = document.getElementById(id); if (el && v != null && v !== '') el.value = v; }
        function setChk(id, v) { var el = document.getElementById(id); if (el && v != null) el.checked = (v === '1' || v === 1 || v === true); }

        setVal('DateBasis',          parms.DateBasis);
        setChk('UseDateTime',        parms.UseDateTime);
        setVal('ReportMode',         parms.ReportMode);
        setVal('ReportOn',           parms.ReportOn);
        setVal('PrimaryGroup',       parms.PrimaryGroup);
        setVal('SecondaryGroup',     parms.SecondaryGroup);
        setVal('ThirdGroup',         parms.ThirdGroup);
        setVal('ProfitBasedOn',      parms.ProfitBasedOn);
        setChk('ProfitIncludesVat',  parms.ProfitIncludesVat);
        setVal('StockValueBasedOn',  parms.StockValueBasedOn);
        setChk('StockValueIncludesVat', parms.StockValueIncludesVat);
        setVal('CostType',           parms.CostType);
        setChk('ShowProfit',         parms.ShowProfit);
        setChk('ShowStock',          parms.ShowStock);
        setVal('PageSize',           parms.PageSize);

        if (parms.ReportTitle != null) {
            setVal('ReportTitle', parms.ReportTitle);
            var hdr = document.getElementById('resultsTitle');
            if (hdr) hdr.textContent = parms.ReportTitle || 'Results';
        }
        if (parms.DisplayColumns != null) {
            var hidden = document.getElementById('displayColumnsHidden');
            if (hidden) hidden.value = parms.DisplayColumns;
            if (typeof syncDisplayColumnCheckboxes === 'function') syncDisplayColumnCheckboxes();
        }
        if (parms.ColumnOrder != null) {
            // Persist the layout's column order to sessionStorage so the grid picks it up after the
            // form submit below re-renders. Also write to the hidden input so it round-trips.
            var coHidden = document.getElementById('columnOrderHidden');
            if (coHidden) coHidden.value = parms.ColumnOrder;
            try {
                var arr = String(parms.ColumnOrder).split(',').map(function(s){return s.trim();}).filter(function(s){return s.length>0;});
                if (arr.length) sessionStorage.setItem(COL_ORDER_KEY, JSON.stringify(arr));
                else sessionStorage.removeItem(COL_ORDER_KEY);
            } catch (e) {}
        }
        if (parms.ItemsSelectionJson != null) {
            var isj = document.getElementById('itemsSelectionJsonHidden');
            if (isj) isj.value = parms.ItemsSelectionJson;
            // Trigger items-selection partial to re-hydrate from the new JSON, if available.
            if (typeof reloadItemsSelectionFromHidden === 'function') reloadItemsSelectionFromHidden();
        }
        // Bidirectional sync: ShowProfit/ShowStock <-> column visibility (existing handlers handle this).
        if (typeof onShowProfitToggle === 'function') onShowProfitToggle();
        if (typeof onShowStockToggle === 'function')  onShowStockToggle();
    }

    function saveLayoutAsConfirm() {
        var nameEl = document.getElementById('saveLayoutAsName');
        var pubEl  = document.getElementById('saveLayoutAsPublic');
        var alertEl = document.getElementById('saveLayoutAsAlert');
        var btn = document.getElementById('saveLayoutAsConfirmBtn');
        var spinner = document.getElementById('saveLayoutAsSpinner');
        if (alertEl) { alertEl.classList.add('d-none'); alertEl.textContent = ''; }

        var name = (nameEl.value || '').trim();
        if (!name) {
            alertEl.textContent = 'Layout name is required.';
            alertEl.className = 'alert alert-warning';
            return;
        }

        btn.disabled = true; spinner.classList.remove('d-none');

        var parms = collectCurrentLayout();
        fetch('@Url.Action("SaveCatalogueLayoutAs", "Reports")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: name, isPublic: !!(pubEl && pubEl.checked), parameters: parms })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            btn.disabled = false; spinner.classList.add('d-none');
            if (data.success) {
                bootstrap.Modal.getInstance(document.getElementById('saveLayoutAsModal')).hide();
                showLayoutToast('Layout saved', 'success');
                loadLayoutsList();
                var label = document.getElementById('layoutsCurrentName');
                if (label) label.textContent = name;
            } else {
                alertEl.textContent = data.message || 'Failed to save';
                alertEl.className = 'alert alert-danger';
            }
        })
        .catch(function() {
            btn.disabled = false; spinner.classList.add('d-none');
            alertEl.textContent = 'Network error.';
            alertEl.className = 'alert alert-danger';
        });
    }

    function deleteNamedLayout(headerCode, displayName) {
        if (!confirm('Delete layout "' + displayName + '"?')) return;
        fetch('@Url.Action("DeleteCatalogueLayout", "Reports")?headerCode=' + encodeURIComponent(headerCode), { method: 'POST' })
