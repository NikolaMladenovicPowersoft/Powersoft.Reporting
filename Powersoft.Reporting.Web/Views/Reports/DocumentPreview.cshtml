@model Powersoft.Reporting.Core.Models.DocumentDetailResult
@{
    Layout = null;
    var isPurch = Model.DocType is "P" or "E";
    var accentColor = isPurch ? "#2563eb" : "#059669";
    var accentBg = isPurch ? "#eff6ff" : "#ecfdf5";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@Model.DocTypeDescription — @Model.DocumentNumber</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', system-ui, sans-serif; background: #525659; color: #1e293b; }
        .toolbar { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: #2c3e50; color: white; padding: 6px 16px; display: flex; align-items: center; gap: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.3); font-size: 13px; }
        .toolbar .title { font-weight: 600; margin-right: auto; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .toolbar button { background: none; border: 1px solid rgba(255,255,255,0.25); color: white; padding: 5px 12px; border-radius: 4px; cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 5px; white-space: nowrap; }
        .toolbar button:hover { background: rgba(255,255,255,0.1); }
        .zoom-controls { display: flex; align-items: center; gap: 4px; }
        .zoom-controls button { padding: 5px 8px; }
        .zoom-level { min-width: 42px; text-align: center; font-size: 12px; color: rgba(255,255,255,0.8); }
        .paper-container { margin: 56px auto 40px; padding: 20px; }
        .paper { background: white; margin: 0 auto; padding: 48px 56px; box-shadow: 0 2px 12px rgba(0,0,0,0.3); transform-origin: top center; transition: transform 0.2s ease; max-width: 900px; }
        .doc-header { text-align: center; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 3px solid @accentColor; }
        .doc-header .doc-type { font-size: 20px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: @accentColor; }
        .doc-header .doc-number { font-size: 14px; font-weight: 600; color: #475569; margin-top: 2px; }
        .doc-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; font-size: 12px; margin-bottom: 20px; padding: 12px 16px; background: @accentBg; border-radius: 6px; }
        .doc-meta .label { color: #64748b; font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; }
        .doc-meta .value { color: #1e293b; font-weight: 500; margin-top: 1px; }
        .doc-table { width: 100%; border-collapse: collapse; font-size: 11px; }
        .doc-table thead th { background: #e2e8f0; padding: 6px 10px; text-align: right; font-weight: 700; font-size: 10px; text-transform: uppercase; letter-spacing: 0.3px; color: #334155; border-bottom: 2px solid #94a3b8; white-space: nowrap; }
        .doc-table thead th:first-child, .doc-table thead th:nth-child(2) { text-align: left; }
        .doc-table tbody td { padding: 5px 10px; text-align: right; border-bottom: 1px solid #f1f5f9; color: #334155; }
        .doc-table tbody td:first-child, .doc-table tbody td:nth-child(2) { text-align: left; }
        .doc-table tbody tr:hover td { background: #fafbfd; }
        .doc-table tbody td:first-child { font-weight: 600; color: #1e293b; }
        .doc-table .total-row td { font-weight: 700; border-top: 3px double #1e293b; padding: 8px 10px; background: #f1f5f9; font-size: 12px; color: #0f172a; }
        .doc-footer { text-align: center; margin-top: 24px; padding-top: 12px; border-top: 1px solid #e2e8f0; font-size: 10px; color: #94a3b8; }
        @@media print {
            body { background: white; }
            .toolbar { display: none; }
            .paper-container { margin: 0; padding: 0; }
            .paper { box-shadow: none; padding: 24px; max-width: none; }
        }
    </style>
</head>
<body>

<div class="toolbar">
    <span class="title"><i class="bi bi-file-earmark-text me-1"></i>@Model.DocTypeDescription — @Model.DocumentNumber</span>
    <div class="zoom-controls">
        <button onclick="zoom(-10)" title="Zoom out"><i class="bi bi-dash"></i></button>
        <span class="zoom-level" id="zoomLevel">100%</span>
        <button onclick="zoom(10)" title="Zoom in"><i class="bi bi-plus"></i></button>
    </div>
    <button onclick="window.print()"><i class="bi bi-printer"></i> Print</button>
    <button onclick="window.close()"><i class="bi bi-x-lg"></i> Close</button>
</div>

<div class="paper-container">
    <div class="paper" id="paper">

        <div class="doc-header">
            <div class="doc-type">@Model.DocTypeDescription</div>
            <div class="doc-number">Document #: @Model.DocumentNumber</div>
        </div>

        <div class="doc-meta">
            <div>
                <div class="label">Date</div>
                <div class="value">@Model.DocumentDate.ToString("dd MMM yyyy")</div>
            </div>
            <div>
                <div class="label">Store</div>
                <div class="value">@(string.IsNullOrEmpty(Model.StoreCode) ? "—" : Model.StoreCode)</div>
            </div>
            <div>
                <div class="label">@(isPurch ? "Supplier" : "Customer")</div>
                <div class="value">
                    @if (!string.IsNullOrEmpty(Model.EntityCode))
                    {
                        <span>@Model.EntityCode — </span>
                    }
                    @(string.IsNullOrEmpty(Model.EntityName) ? "—" : Model.EntityName)
                </div>
            </div>
            <div>
                <div class="label">Line Items</div>
                <div class="value">@Model.Lines.Count</div>
            </div>
        </div>

        <table class="doc-table">
            <thead>
                <tr>
                    <th>Item Code</th>
                    <th>Description</th>
                    <th>Qty</th>
                    <th>Unit Price</th>
                    <th>Discount</th>
                    <th>Net</th>
                    <th>VAT</th>
                    <th>Gross</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var line in Model.Lines)
                {
                    <tr>
                        <td>@line.ItemCode</td>
                        <td>@line.ItemName</td>
                        <td>@line.Quantity.ToString("N2")</td>
                        <td>@line.UnitPrice.ToString("N2")</td>
                        <td>@line.Discount.ToString("N2")</td>
                        <td>@line.NetAmount.ToString("N2")</td>
                        <td>@line.VatAmount.ToString("N2")</td>
                        <td>@line.GrossAmount.ToString("N2")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="total-row">
                    <td colspan="5" style="text-align:right;">Totals</td>
                    <td>@Model.TotalNet.ToString("N2")</td>
                    <td>@Model.TotalVat.ToString("N2")</td>
                    <td>@Model.TotalGross.ToString("N2")</td>
                </tr>
            </tfoot>
        </table>

        <div class="doc-footer">
            Generated @DateTime.Now.ToString("dd/MM/yyyy HH:mm") — Powersoft Reporting
        </div>

    </div>
</div>

<script>
var currentZoom = 100;
function zoom(delta) {
    currentZoom = Math.max(50, Math.min(200, currentZoom + delta));
    document.getElementById('paper').style.transform = 'scale(' + (currentZoom / 100) + ')';
    document.getElementById('zoomLevel').textContent = currentZoom + '%';
}
</script>
</body>
</html>
