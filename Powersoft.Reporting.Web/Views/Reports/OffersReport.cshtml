    return p;
}
// Host hook: called when loading an existing schedule into the form.
function onScheduleParametersLoaded(p) {
    if (!p) return;
    if (p.dateFrom) document.getElementById('dateFrom').value = p.dateFrom;
    if (p.dateTo) document.getElementById('dateTo').value = p.dateTo;
    if (p.dateField) document.getElementById('dateField').value = p.dateField;
    if (p.primaryGroup) document.getElementById('primaryGroup').value = p.primaryGroup;
    if (p.secondaryGroup) document.getElementById('secondaryGroup').value = p.secondaryGroup;
    if (p.thirdGroup) document.getElementById('thirdGroup').value = p.thirdGroup;
    if (p.maxRecords) document.getElementById('maxRecords').value = p.maxRecords;
    try { if (p.statusCodesJson) setCheckedValues('offerStatusCb','statusFilterLabel','Statuses', JSON.parse(p.statusCodesJson)); } catch(e) {}
    try { if (p.storeCodesJson)  setCheckedValues('offerStoreCb','storeFilterLabel','Stores', JSON.parse(p.storeCodesJson)); } catch(e) {}
    try { if (p.agentCodesJson)  setCheckedValues('offerAgentCb','agentFilterLabel','Agents', JSON.parse(p.agentCodesJson)); } catch(e) {}
    if (p.customerCodesJson && typeof reloadCustomerSelectionFromJson === 'function') {
        try { reloadCustomerSelectionFromJson({ codes: JSON.parse(p.customerCodesJson), excludeMode: p.customerExcludeMode === 'true' || p.customerExcludeMode === true }); } catch(e) {}
    }
    if (p.itemsSelectionJson && typeof applyItemsSelectionJson === 'function') {
        try { applyItemsSelectionJson(p.itemsSelectionJson); } catch(e) {}
    }
}

