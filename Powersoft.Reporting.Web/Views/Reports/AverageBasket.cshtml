// ==================== Layout Save/Load/Reset ====================

function collectCurrentLayout() {
    var parms = {};
    var vat = document.getElementById('includeVatCheck');
    if (vat) parms['IncludeVat'] = vat.checked ? '1' : '0';
    var cly = document.getElementById('compareLyCheck');
    if (cly) parms['CompareLastYear'] = cly.checked ? '1' : '0';
    var bd = document.getElementById('Breakdown');
    if (bd) parms['Breakdown'] = bd.value;
    var gb = document.getElementById('GroupBy');
    if (gb) parms['GroupBy'] = gb.value;
    var sgb = document.getElementById('SecondaryGroupBy');
    if (sgb) parms['SecondaryGroupBy'] = sgb.value;
    var ps = document.getElementById('PageSize');
    if (ps) parms['PageSize'] = ps.value;
    var layoutAb = document.getElementById('layoutAvgBasket');
    if (layoutAb) parms['ReportLayout'] = layoutAb.checked ? 'AverageBasket' : 'PeopleCount';
    var stq = document.getElementById('showTotalQtyCheck');
    if (stq) parms['ShowTotalQty'] = stq.checked ? '1' : '0';

    var preset = document.querySelector('input[name="DatePreset"]:checked');
    if (preset) parms['DatePreset'] = preset.value;

    // Column visibility
    var hidden = [];
    document.querySelectorAll('.col-toggle').forEach(function(cb) {
        if (!cb.checked) hidden.push(cb.value);
    });
    parms['HiddenColumns'] = hidden.join(',');

    // Items selection filters
    if (typeof getItemsSelectionFilter === 'function') {
        parms['ItemsSelectionJson'] = JSON.stringify(getItemsSelectionFilter());
    }

    return parms;
}

// Detects the case where [Authorize] sent us a 302 to /Account/Login after the cookie expired,
// so we don't end up trying to JSON.parse a login page (which just fails silently otherwise).
function isAuthRedirect(response) {
    if (!response) return false;
    if (response.status === 401 || response.status === 403) return true;
    if (response.redirected && /\/Account\/Login/i.test(response.url || '')) return true;
    var ct = response.headers && response.headers.get ? response.headers.get('content-type') : '';
    if (ct && ct.indexOf('text/html') !== -1) return true;
    return false;
}

function showSessionExpiredToast() {
    showLayoutToast('Session expired — please reload the page and sign in again.', 'warning');
}

function saveCurrentLayout() {
    var parms = collectCurrentLayout();
    fetch('@Url.Action("SaveLayout", "Reports")', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(parms)
    })
    .then(function(r) {
        if (isAuthRedirect(r)) { showSessionExpiredToast(); return null; }
        return r.json();
    })
    .then(function(data) {
        if (data == null) return;
        if (data.success) {
            showLayoutToast('Layout saved successfully', 'success');
        } else {
            showLayoutToast(data.message || 'Failed to save layout', 'danger');
        }
    })
    .catch(function() {
        showLayoutToast('Network error saving layout', 'danger');
    });
}

function resetSavedLayout() {
    if (!confirm('Reset your saved layout to factory defaults?')) return;
    fetch('@Url.Action("ResetLayout", "Reports")', { method: 'POST', credentials: 'same-origin' })
    .then(function(r) {
        if (isAuthRedirect(r)) { showSessionExpiredToast(); return null; }
        return r.json();
    })
    .then(function(data) {
        if (data == null) return;
        if (data.success) {
            showLayoutToast('Layout reset — reloading...', 'success');
            setTimeout(function() { window.location.href = '@Url.Action("AverageBasket", new { layoutReset = true })'; }, 800);
        } else {
            showLayoutToast(data.message || 'Failed to reset layout', 'danger');
        }
    })
    .catch(function() {
        showLayoutToast('Network error', 'danger');
    });
}

function showLayoutToast(message, type) {
    var existing = document.getElementById('layoutToast');
    if (existing) existing.remove();
    var div = document.createElement('div');
    div.id = 'layoutToast';
    div.className = 'alert alert-' + type + ' alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow';
    div.style.zIndex = '9999';
    div.innerHTML = '<i class="bi bi-' + (type === 'success' ? 'check-circle' : 'exclamation-triangle') + ' me-1"></i>' + message +
        '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    document.body.appendChild(div);
    setTimeout(function() { if (div.parentNode) div.remove(); }, 4000);
}

// ==================== Named Layouts (multi-layout) ====================

var __abLayoutsCache = [];

function loadAbLayoutsList() {
    var menu = document.getElementById('layoutsDropdownMenu');
    if (menu) menu.innerHTML = '<li><h6 class="dropdown-header">Loading...</h6></li>';
    return fetch('@Url.Action("ListAbLayouts", "Reports")', { method: 'GET', credentials: 'same-origin' })
        .then(function(r) {
            if (isAuthRedirect(r)) {
                if (menu) menu.innerHTML = '<li><h6 class="dropdown-header text-danger">Session expired</h6></li>';
                showSessionExpiredToast();
                return null;
            }
            return r.json();
        })
        .then(function(data) {
            if (data == null) return;
            __abLayoutsCache = data && data.layouts ? data.layouts : [];
            renderAbLayoutsDropdown(__abLayoutsCache);
        })
        .catch(function() {
            if (menu) menu.innerHTML = '<li><h6 class="dropdown-header text-danger">Error loading layouts</h6></li>';
        });
}

function renderAbLayoutsDropdown(layouts) {
    var menu = document.getElementById('layoutsDropdownMenu');
    if (!menu) return;
    if (!layouts || layouts.length === 0) {
        menu.innerHTML =
            '<li><h6 class="dropdown-header">No saved layouts</h6></li>' +
            '<li><span class="dropdown-item-text small text-muted">Use "Save as..." to create one.</span></li>';
        return;
    }

    var own = layouts.filter(function(l) { return !l.isPublic; });
    var pub = layouts.filter(function(l) { return  l.isPublic; });

    var html = '';
    function renderGroup(label, items) {
        if (!items.length) return;
        html += '<li><h6 class="dropdown-header">' + label + '</h6></li>';
        items.forEach(function(l) {
            var safeName = String(l.name || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            var publicBadge = l.isPublic ? '<span class="badge bg-secondary ms-2" title="Visible to all users">Public</span>' : '';
            var editorBadge = l.isPublic && l.createdBy
                ? '<span class="text-muted small ms-2">by ' + String(l.createdBy).replace(/</g,'&lt;') + '</span>'
                : '';
            html += '<li class="d-flex align-items-center px-2 py-1 layout-row">' +
                        '<a href="#" class="flex-grow-1 text-decoration-none text-body" onclick="loadAbNamedLayout(\'' +
                            String(l.headerCode).replace(/'/g, "\\'") + '\'); return false;">' +
                            '<i class="bi bi-bookmark me-1"></i>' + safeName + publicBadge + editorBadge +
                        '</a>';
            if (l.canEdit) {
                html += '<button type="button" class="btn btn-sm btn-link text-danger p-0 ms-2" ' +
                            'title="Delete this layout" onclick="deleteAbNamedLayout(\'' +
                            String(l.headerCode).replace(/'/g, "\\'") + '\', \'' +
                            safeName.replace(/'/g, "\\'") + '\'); return false;">' +
                            '<i class="bi bi-trash"></i>' +
                        '</button>';
            }
            html += '</li>';
        });
    }
    renderGroup('Your layouts', own);
    renderGroup('Public layouts', pub);
    menu.innerHTML = html;
}

function loadAbNamedLayout(headerCode) {
    if (!headerCode) return;
    fetch('@Url.Action("LoadAbLayout", "Reports")?headerCode=' + encodeURIComponent(headerCode),
          { method: 'POST', credentials: 'same-origin' })
        .then(function(r) {
            if (isAuthRedirect(r)) { showSessionExpiredToast(); return null; }
            return r.json();
        })
        .then(function(data) {
            if (data == null) return;
            if (!data.success) {
                showLayoutToast(data.message || 'Failed to load layout', 'danger');
                return;
            }
            applyAbLayoutParameters(data.parameters || {});
            var label = document.getElementById('layoutsCurrentName');
            if (label && __abLayoutsCache) {
                var match = __abLayoutsCache.find(function(l) { return l.headerCode === headerCode; });
                if (match) label.textContent = match.name;
            }
            showLayoutToast('Layout loaded — click Generate to run.', 'success');
        })
        .catch(function() { showLayoutToast('Network error loading layout', 'danger'); });
}

function applyAbLayoutParameters(parms) {
    function setVal(id, v) { var el = document.getElementById(id); if (el && v != null && v !== '') el.value = v; }
    function setChk(id, v) { var el = document.getElementById(id); if (el && v != null) el.checked = (v === '1' || v === 1 || v === true); }

    setVal('Breakdown',        parms.Breakdown);
    setVal('GroupBy',          parms.GroupBy);
    setVal('SecondaryGroupBy', parms.SecondaryGroupBy);
    setVal('PageSize',         parms.PageSize);
    setChk('includeVatCheck',  parms.IncludeVat);
    setChk('compareLyCheck',   parms.CompareLastYear);
    setChk('showTotalQtyCheck', parms.ShowTotalQty);

    if (parms.ReportLayout) {
        var abRadio = document.getElementById('layoutAvgBasket');
        var pcRadio = document.getElementById('layoutPeopleCount');
        if (parms.ReportLayout === 'PeopleCount') {
            if (pcRadio) pcRadio.checked = true;
        } else {
            if (abRadio) abRadio.checked = true;
        }
        if (typeof onLayoutChange === 'function') onLayoutChange();
    }

    if (parms.DatePreset) {
        document.querySelectorAll('input[name="DatePreset"]').forEach(function(r) { r.checked = false; });
        var presetRadio = document.querySelector('input[name="DatePreset"][value="' + parms.DatePreset + '"]');
        if (presetRadio) {
            presetRadio.checked = true;
            presetRadio.dispatchEvent(new Event('change'));
        }
    }

    if (parms.HiddenColumns != null) {
        var cols = parms.HiddenColumns ? parms.HiddenColumns.split(',') : [];
        document.querySelectorAll('.col-toggle').forEach(function(cb) {
            cb.checked = cols.indexOf(cb.value) === -1;
        });
        if (typeof applyColumnVisibility === 'function') applyColumnVisibility();
    }

    if (parms.ItemsSelectionJson) {
        var isHidden = document.getElementById('itemsSelectionJsonHidden');
        if (isHidden) isHidden.value = parms.ItemsSelectionJson;
        if (typeof applyItemsSelectionFromJson === 'function') {
            try { applyItemsSelectionFromJson(parms.ItemsSelectionJson); } catch(e) {}
        }
    }
}

function saveLayoutAsConfirm() {
    var nameEl = document.getElementById('saveLayoutAsName');
    var pubEl  = document.getElementById('saveLayoutAsPublic');
    var alertEl = document.getElementById('saveLayoutAsAlert');
    var btn = document.getElementById('saveLayoutAsConfirmBtn');
    var spinner = document.getElementById('saveLayoutAsSpinner');
    if (alertEl) { alertEl.classList.add('d-none'); alertEl.textContent = ''; }

    var name = (nameEl.value || '').trim();
    if (!name) {
        alertEl.textContent = 'Please enter a layout name.';
        alertEl.classList.remove('d-none');
        alertEl.className = 'alert alert-warning';
        nameEl.focus();
        return;
    }

    btn.disabled = true;
    spinner.classList.remove('d-none');

    var parms = collectCurrentLayout();
    fetch('@Url.Action("SaveAbLayoutAs", "Reports")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ name: name, isPublic: !!(pubEl && pubEl.checked), parameters: parms })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        btn.disabled = false; spinner.classList.add('d-none');
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('saveLayoutAsModal')).hide();
            showLayoutToast('Layout saved', 'success');
            loadAbLayoutsList();
            var label = document.getElementById('layoutsCurrentName');
            if (label) label.textContent = name;
        } else {
            alertEl.textContent = data.message || 'Failed to save';
            alertEl.classList.remove('d-none');
            alertEl.className = 'alert alert-danger';
        }
    })
    .catch(function() {
        btn.disabled = false; spinner.classList.add('d-none');
        alertEl.textContent = 'Network error';
        alertEl.classList.remove('d-none');
        alertEl.className = 'alert alert-danger';
    });
}

function deleteAbNamedLayout(headerCode, displayName) {
    if (!confirm('Delete layout "' + displayName + '"?')) return;
    fetch('@Url.Action("DeleteAbLayout", "Reports")?headerCode=' + encodeURIComponent(headerCode),
          { method: 'POST', credentials: 'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                showLayoutToast('Layout deleted', 'success');
                loadAbLayoutsList();
            } else {
                showLayoutToast(data.message || 'Failed to delete', 'danger');
            }
        })
        .catch(function() { showLayoutToast('Network error', 'danger'); });
}

// ==================== Column Visibility ====================

function applyColumnVisibility() {
    var hidden = [];
    document.querySelectorAll('.col-toggle').forEach(function(cb) {
        if (!cb.checked) hidden.push(cb.value);
    });
    var hiddenInput = document.getElementById('hiddenColumnsInput');
    if (hiddenInput) hiddenInput.value = hidden.join(',');

    var styleEl = document.getElementById('colVisibilityStyle');
    if (!styleEl) {
        styleEl = document.createElement('style');
        styleEl.id = 'colVisibilityStyle';
        document.head.appendChild(styleEl);
    }

    var table = document.getElementById('resultsTable');
    if (!table) return;

    var rules = [];
    document.querySelectorAll('.col-toggle').forEach(function(cb) {
        var colKey = cb.value;
        if (!cb.checked) {
            var headers = table.querySelectorAll('thead tr:first-child th');
            for (var i = 0; i < headers.length; i++) {
                if (headers[i].getAttribute('data-col') === colKey) {
                    var colIdx = i + 1;
                    rules.push('#resultsTable th:nth-child(' + colIdx + '), #resultsTable td:nth-child(' + colIdx + ') { display: none; }');
                    break;
                }
            }
        }
    });

    styleEl.textContent = rules.join('\n');
    updateColVisibleCount();
}

function resetColumnVisibility() {
    document.querySelectorAll('.col-toggle').forEach(function(cb) { cb.checked = true; });
    applyColumnVisibility();
    updateColVisibleCount();
}

function initColumnVisibilityFromServer() {
    var hiddenCols = '@(Model.HiddenColumns ?? "")';
    if (!hiddenCols) return;
    var hidden = hiddenCols.split(',').filter(function(s) { return s.trim(); });
    if (hidden.length === 0) return;
    hidden.forEach(function(col) {
        var cb = document.querySelector('.col-toggle[value="' + col.trim() + '"]');
        if (cb) cb.checked = false;
    });
    applyColumnVisibility();
}

    // Initialize on load
document.addEventListener('DOMContentLoaded', function() {
    onLayoutChange();
    initColumnVisibilityFromServer();
    updateColVisibleCount();

    // Wire column search with live filtering
    var colSearch = document.getElementById('colSearchInput');
    if (colSearch) {
        colSearch.addEventListener('input', filterColumnList);
        colSearch.addEventListener('keyup', filterColumnList);
    }
    
    // Restore filter operator selections and wire live filtering
    document.querySelectorAll('.filter-op').forEach(function(select) {
        var col = select.dataset.col;
        var hidden = document.getElementById('fo_' + col);
        if (hidden && hidden.value) {
            select.value = hidden.value;
        }
    });
    
    // Live filter: debounced input on every keystroke
    document.querySelectorAll('.col-filter').forEach(function(input) {
        input.addEventListener('input', scheduleFilterApply);
        input.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                applyColumnFilters(); // immediate on Enter
            }
        });
        // Mark active filters on load
        if (input.value.trim() !== '') input.classList.add('filter-active');
    });
    
    // Restore date preset selection from model
    var savedPreset = '@(Model.DatePreset ?? "")';
    if (savedPreset) {
        var presetRadio = document.querySelector('input[name="DatePreset"][value="' + savedPreset + '"]');
        if (presetRadio) presetRadio.checked = true;
    }

    // Wire preset radios to update date fields
    document.querySelectorAll('input[name="DatePreset"]').forEach(function(radio) {
        radio.addEventListener('change', function() {
            applyPresetDates(this.value);
        });
    });
    
    const form = document.getElementById('reportForm');
    form.addEventListener('submit', function() {
        populateItemsSelectionHidden();
        document.querySelectorAll('#reportForm select[disabled], #reportForm input[disabled]').forEach(function(el) { el.disabled = false; });
        showLoading();
    });
    
    var generateBtn = document.getElementById('generateBtn');
    generateBtn.addEventListener('click', function() {
        resetPage();
    });

    // Lazy-load named layouts list on first dropdown open
    var layoutBtn = document.getElementById('layoutsDropdownBtn');
    if (layoutBtn) {
        var layoutsLoadedOnce = false;
        layoutBtn.addEventListener('show.bs.dropdown', function() {
            if (!layoutsLoadedOnce) { layoutsLoadedOnce = true; loadAbLayoutsList(); }
        });
    }

    // Reset "Save as..." modal each time it opens
    var saveAsModal = document.getElementById('saveLayoutAsModal');
    if (saveAsModal) {
        saveAsModal.addEventListener('show.bs.modal', function() {
            document.getElementById('saveLayoutAsName').value = '';
            document.getElementById('saveLayoutAsPublic').checked = false;
            var alertEl = document.getElementById('saveLayoutAsAlert');
            if (alertEl) { alertEl.classList.add('d-none'); alertEl.textContent = ''; }
        });
    }

});

// ==================== AI Analysis (via shared partial) ====================

function collectAiFormData() {
    var form = document.getElementById('reportForm');
    document.querySelectorAll('#reportForm select[disabled], #reportForm input[disabled]').forEach(function(el) { el.disabled = false; });
    if (typeof populateItemsSelectionHidden === 'function') populateItemsSelectionHidden();
    var formData = new FormData(form);
    onLayoutChange();
    formData.append('storeCodes', typeof getItemsSelectionStoreCodes === 'function' ? getItemsSelectionStoreCodes() : (document.getElementById('selectedStoreCodesHidden').value || ''));
    formData.append('itemIds', typeof getItemsSelectionItemIds === 'function' ? getItemsSelectionItemIds() : (document.getElementById('selectedItemIdsHidden').value || ''));
    formData.append('sortColumn', document.getElementById('sortColumnHidden').value || 'Period');
    formData.append('sortDirection', document.getElementById('sortDirectionHidden').value || 'ASC');
    return formData;
}

