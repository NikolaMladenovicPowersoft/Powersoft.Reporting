@using Powersoft.Reporting.Core.Models
@model ItemsSelectionConfig

<style>
    /* Collapsible header — distinct from page background so it reads as a clickable bar. */
    .is-collapse-header {
        cursor: pointer;
        background: #eef2f7;
        border-bottom: 1px solid #d7dee8;
        transition: background-color .12s ease-in-out;
    }
    .is-collapse-header:hover { background: #e2e8f1; }

    /* Inactive include/exclude buttons stay coloured but lower-intensity: reduced saturation
       (softer green/red, not gray, not "disabled-looking") + a touch of opacity. They snap to
       full intensity on hover. No colour override, so Bootstrap's native hover fill works. */
    .dim-col .btn-group.dim-inactive .btn {
        filter: saturate(.55);
        opacity: .8;
        transition: filter .12s ease-in-out, opacity .12s ease-in-out;
    }
    .dim-col .btn-group.dim-inactive .btn:hover {
        filter: none;
        opacity: 1;
    }

    /* On hover the outline trigger fills with its colour — force the label + icons white so
       text never sits red-on-red / green-on-green. */
    #itemsSelectionCard .dim-col > .btn:hover .dim-text,
    #itemsSelectionCard .dim-col > .btn:hover .bi {
        color: #fff !important;
    }

    /* Trigger label must never blow out the row width. */
    #itemsSelectionCard .dim-col .dim-text {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 100%;
    }

    /* Visually de-emphasise the whole filter body when filters are paused. */
    #itemsSelectionCard.filters-paused #isBody { opacity: .55; }
</style>

<div class="card mb-3" id="itemsSelectionCard" data-report-type="@Model.ReportType">
    <div class="card-header is-collapse-header py-2 d-flex align-items-center"
         onclick="toggleItemsSelection()">
        <i class="bi bi-funnel me-2"></i>
        <strong class="small">Items Selection</strong>
        <span id="isActiveBadge" class="badge bg-primary ms-2 d-none">0 filters</span>
        <span id="isInactiveBadge" class="badge bg-secondary ms-2 d-none" title="Filters are kept but not applied to the report">
            <i class="bi bi-pause-fill"></i> Not applied
        </span>
        <span class="ms-2 me-auto" onclick="event.stopPropagation();">
            <div class="btn-group btn-group-sm">
                <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle py-0 px-2" data-bs-toggle="dropdown" id="presetDropdown" title="Filter Presets">
                    <i class="bi bi-bookmark me-1"></i><span class="small">Presets</span>
                </button>
                <ul class="dropdown-menu" id="presetMenu" style="min-width:250px;">
                    <li><span class="dropdown-item-text text-muted small">Loading...</span></li>
                </ul>
            </div>
            <button type="button" class="btn btn-outline-primary btn-sm py-0 px-2 ms-1" onclick="saveCurrentPreset()" title="Save current filters as preset">
                <i class="bi bi-bookmark-plus"></i>
            </button>
            <button type="button" class="btn btn-outline-danger btn-sm py-0 px-2 ms-1" onclick="clearAllItemsSelection()" title="Clear all filters">
                <i class="bi bi-eraser me-1"></i><span class="small">Clear All</span>
            </button>
        </span>
        <span class="form-check form-switch me-3 mb-0" onclick="event.stopPropagation();" title="When off, your selections are kept but the report runs without applying them">
            <input class="form-check-input" type="checkbox" id="isFiltersActive" checked onchange="setFiltersActive(this.checked)">
            <label class="form-check-label small" for="isFiltersActive">Apply filters</label>
        </span>
        <span class="small text-primary" id="isToggleText">
            <i class="bi bi-eye me-1"></i>Show Filters
        </span>
    </div>
    <div class="card-body py-2 d-none" id="isBody">
        <div class="row g-2">
            @if (Model.ShowCategories) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("category", "Category", "bi-tag"))</div>
            }
            @if (Model.ShowDepartments) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("department", "Department", "bi-grid"))</div>
            }
            @if (Model.ShowBrands) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("brand", "Brand", "bi-bookmark"))</div>
            }
            @if (Model.ShowSeasons) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("season", "Season", "bi-calendar3"))</div>
            }
            @{
                var _isViewSup = User.FindFirst("ps:viewsupplier")?.Value;
                bool _canViewSupplier = _isViewSup == null || _isViewSup != "False";
            }
            @if (Model.ShowSuppliers && _canViewSupplier) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("supplier", "Supplier", "bi-truck"))</div>
            }
            @if (Model.ShowCustomers) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("customer", "Customer", "bi-people"))</div>
            }
            @if (Model.ShowAgents) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("agent", "Agent", "bi-person-badge"))</div>
            }
            @if (Model.ShowPostalCodes) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("postalcode", "Postal Code", "bi-mailbox"))</div>
            }
            @if (Model.ShowTowns) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("town", "Town", "bi-geo-alt"))</div>
            }
            @if (Model.ShowPaymentTypes) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("paymenttype", "Payment Type", "bi-credit-card"))</div>
            }
            @if (Model.ShowZReports) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("zreport", "Z Report", "bi-receipt"))</div>
            }
            @if (Model.ShowUsers) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("user", "User", "bi-person-circle"))</div>
            }
            @if (Model.ShowStores) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("store", "Store", "bi-shop"))</div>
            }
            @if (Model.ShowItems) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("item", "Items", "bi-box-seam"))</div>
            }
            @if (Model.ShowModels) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("model", "Model", "bi-diagram-3"))</div>
            }
            @if (Model.ShowColours) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("colour", "Colour", "bi-palette"))</div>
            }
            @if (Model.ShowSizes) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("size", "Size", "bi-rulers"))</div>
            }
            @if (Model.ShowGroupSizes) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("groupsize", "Group Size", "bi-collection"))</div>
            }
            @if (Model.ShowFabrics) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("fabric", "Fabric", "bi-layers"))</div>
            }
            @if (Model.ShowAttributes) {
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("attr1", "Attribute 1", "bi-tags"))</div>
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("attr2", "Attribute 2", "bi-tags"))</div>
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("attr3", "Attribute 3", "bi-tags"))</div>
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("attr4", "Attribute 4", "bi-tags"))</div>
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("attr5", "Attribute 5", "bi-tags"))</div>
                <div class="col-lg-3 col-md-4 col-sm-6">@await Html.PartialAsync("_DimensionFilter", ("attr6", "Attribute 6", "bi-tags"))</div>
            }
        </div>

        <div id="isSelectedSummary" class="mt-2 d-none">
            <div class="small fw-semibold text-muted mb-1"><i class="bi bi-check2-square me-1"></i>Selected filters</div>
            <div id="isSelectedSummaryBody" class="d-flex flex-wrap"></div>
        </div>

        @if (Model.ShowStockFilter || Model.ShowECommerce || Model.ShowModifiedDate)
        {
            <hr class="my-2" />
            <div class="row g-2 align-items-end">
                @if (Model.ShowStockFilter)
                {
                    <div class="col-lg-2 col-md-3 col-sm-4">
                        <label class="form-label fw-semibold mb-1 small">
                            <i class="bi bi-box-seam me-1"></i>Stock
                        </label>
                        <select id="isPropStock" class="form-select form-select-sm" onchange="updatePropBadge()">
                            <option value="all" selected>All</option>
                            <option value="withStock">With Stock</option>
                            <option value="withoutStock">Without Stock</option>
                        </select>
                    </div>
                }
                @if (Model.ShowECommerce)
                {
                    <div class="col-lg-2 col-md-3 col-sm-4">
                        <label class="form-label fw-semibold mb-1 small">
                            <i class="bi bi-globe me-1"></i>E-Commerce
                        </label>
                        <div class="form-check form-switch mt-1">
                            <input class="form-check-input" type="checkbox" id="isPropEcommerce" onchange="updatePropBadge()">
                            <label class="form-check-label small" for="isPropEcommerce">E-shop items only</label>
                        </div>
                    </div>
                }
                @if (Model.ShowModifiedDate)
                {
                    <div class="col-lg-4 col-md-6 col-sm-12">
                        <label class="form-label fw-semibold mb-1 small"><i class="bi bi-pencil-square me-1"></i>Modified</label>
                        <div class="input-group input-group-sm">
                            <input type="date" class="form-control form-control-sm" id="isPropModifiedFrom" onchange="updatePropBadge()" title="From">
                            <span class="input-group-text px-1 small">to</span>
                            <input type="date" class="form-control form-control-sm" id="isPropModifiedTo" onchange="updatePropBadge()" title="To">
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6 col-sm-12">
                        <label class="form-label fw-semibold mb-1 small"><i class="bi bi-plus-circle me-1"></i>Created</label>
                        <div class="input-group input-group-sm">
                            <input type="date" class="form-control form-control-sm" id="isPropCreatedFrom" onchange="updatePropBadge()" title="From">
                            <span class="input-group-text px-1 small">to</span>
                            <input type="date" class="form-control form-control-sm" id="isPropCreatedTo" onchange="updatePropBadge()" title="To">
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6 col-sm-12">
                        <label class="form-label fw-semibold mb-1 small"><i class="bi bi-calendar-check me-1"></i>Released</label>
                        <div class="input-group input-group-sm">
                            <input type="date" class="form-control form-control-sm" id="isPropReleasedFrom" onchange="updatePropBadge()" title="From">
                            <span class="input-group-text px-1 small">to</span>
                            <input type="date" class="form-control form-control-sm" id="isPropReleasedTo" onchange="updatePropBadge()" title="To">
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Shared modal for dimension selection -->
<div class="modal fade" id="dimModal" tabindex="-1" aria-hidden="true" data-bs-focus="false">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title d-flex align-items-center" id="dimModalTitle">
                    <i class="bi bi-funnel me-1"></i>Select Items
                    <span id="dimModalMode" class="badge bg-success ms-2" style="font-size:.65rem;">INCLUDE</span>
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="p-2 border-bottom bg-light">
                    <input type="text" class="form-control form-control-sm" id="dimModalSearch"
                           placeholder="Search..." oninput="filterDimModalList(this.value)" />
                </div>
                <div class="p-2 border-bottom d-flex justify-content-between align-items-center">
                    <div class="btn-group btn-group-sm">
                        <button type="button" class="btn btn-outline-primary btn-sm" onclick="selectAllDimModal()">
                            <i class="bi bi-check-all me-1"></i>Select All
                        </button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="selectNoneDimModal()">
                            <i class="bi bi-x-lg me-1"></i>Clear All
                        </button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="dimModalSelectedToggle"
                                onclick="toggleDimModalSelectedOnly(this)" title="Show only selected / show all">
                            <i class="bi bi-funnel me-1"></i>Selected only
                        </button>
                    </div>
                    <span class="text-muted small" id="dimModalCount">0 items</span>
                </div>
                <div id="dimModalList" style="max-height:400px; overflow-y:auto;"></div>
            </div>
            <div class="modal-footer py-2">
                <div class="me-auto" style="min-width:0;">
                    <div class="small fw-semibold" id="dimModalSelected">0 selected</div>
                    <div class="small text-muted text-truncate" id="dimModalSelectedNames" style="max-width:380px;"></div>
                </div>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" onclick="applyDimModal()">
                    <i class="bi bi-check-lg me-1"></i>Apply
                </button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/items-selection.js" asp-append-version="true"></script>
<script>
    window.ItemsSelectionInit({
        storesJson: @Html.Raw(string.IsNullOrWhiteSpace(Model.StoresJson) ? "[]" : Model.StoresJson),
        savedFilterJson: '@Html.Raw((Model.SavedFilterJson ?? "").Replace("\\", "\\\\").Replace("'", "\\'"))'
    });
</script>
