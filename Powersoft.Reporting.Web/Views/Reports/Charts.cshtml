@using Powersoft.Reporting.Core.Models
@{
    ViewData["Title"] = "Charts & Dashboards";
    var stores = ViewBag.Stores as List<Store> ?? new List<Store>();
    var dbName = ViewBag.ConnectedDatabase as string ?? "Unknown";
}

<div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span><i class="bi bi-pie-chart me-2"></i>Charts & Dashboards — @dbName</span>
    </div>
    <div class="card-body">
        <form id="chartForm" class="row g-3 mb-4">
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Date From</label>
                <input type="date" class="form-control form-control-sm" name="dateFrom" id="dateFrom"
                       value="@DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Date To</label>
                <input type="date" class="form-control form-control-sm" name="dateTo" id="dateTo"
                       value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Dimension</label>
                <select class="form-select form-select-sm" name="dimension" id="dimension">
                    <option value="Category">Category</option>
                    <option value="Store">Store / Shop</option>
                    <option value="Brand">Brand</option>
                    <option value="Customer">Customer</option>
                    <option value="Item">Item</option>
                    <option value="Supplier">Supplier</option>
                    <option value="Department">Department</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Metric</label>
                <select class="form-select form-select-sm" name="metric" id="metric">
                    <option value="Value">Value (€)</option>
                    <option value="Quantity">Quantity</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Chart Type</label>
                <select class="form-select form-select-sm" name="chartType" id="chartType">
                    <option value="pie">Pie Chart</option>
                    <option value="doughnut">Doughnut</option>
                    <option value="bar">Bar Chart</option>
                    <option value="horizontalBar">Horizontal Bar</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Top N</label>
                <select class="form-select form-select-sm" name="topN" id="topN">
                    <option value="5">Top 5</option>
                    <option value="10" selected>Top 10</option>
                    <option value="15">Top 15</option>
                    <option value="20">Top 20</option>
                </select>
            </div>

            @if (stores.Any())
            {
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Store Filter</label>
                    <select class="form-select form-select-sm" id="storeFilter" multiple size="3">
                        @foreach (var s in stores)
                        {
                            <option value="@s.StoreCode">@s.DisplayName</option>
                        }
                    </select>
                    <div class="form-text">Hold Ctrl to select multiple. Empty = all stores.</div>
                </div>
            }

            <div class="col-md-4 d-flex align-items-end gap-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="showOthers" checked>
                    <label class="form-check-label small" for="showOthers">Show Others</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="compareLastYear">
                    <label class="form-check-label small" for="compareLastYear">Compare LY</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="includeVat">
                    <label class="form-check-label small" for="includeVat">Inc. VAT</label>
                </div>
            </div>

            <div class="col-md-4 d-flex align-items-end">
                <button type="button" class="btn btn-primary" onclick="loadChart()">
                    <i class="bi bi-bar-chart me-1"></i>Generate Chart
                </button>
            </div>
        </form>

        <div id="chartLoading" class="text-center py-5 d-none">
            <div class="spinner-border text-primary"></div>
            <p class="text-muted mt-2">Loading chart data...</p>
        </div>
        <div id="chartError" class="alert alert-danger d-none"></div>

        <div id="chartArea" class="d-none">
            <div class="row">
                <div class="col-lg-8">
                    <div class="card">
                        <div class="card-body" style="position:relative;height:500px;">
                            <canvas id="mainChart"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header small fw-semibold">
                            <i class="bi bi-table me-1"></i>Data Summary
                        </div>
                        <div class="card-body p-0" style="max-height:460px;overflow-y:auto;">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light sticky-top">
                                    <tr class="small">
                                        <th>#</th>
                                        <th>Label</th>
                                        <th class="text-end">Value</th>
                                        <th class="text-end">%</th>
                                    </tr>
                                </thead>
                                <tbody id="dataSummary" class="small"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="emptyState" class="text-center py-5 text-muted">
            <i class="bi bi-pie-chart" style="font-size:3rem;"></i>
            <p class="mt-3">Select your parameters and click <strong>Generate Chart</strong> to begin.</p>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
var _chart = null;

var COLORS = [
    '#2563eb','#059669','#d97706','#dc2626','#7c3aed',
    '#0891b2','#be185d','#65a30d','#ea580c','#4f46e5',
    '#0d9488','#c026d3','#ca8a04','#e11d48','#2dd4bf',
    '#f97316','#8b5cf6','#14b8a6','#f43f5e','#6366f1',
    '#94a3b8'
];

function loadChart() {
    var dateFrom = document.getElementById('dateFrom').value;
    var dateTo = document.getElementById('dateTo').value;
    if (!dateFrom || !dateTo) { alert('Please select dates.'); return; }

    var storeEl = document.getElementById('storeFilter');
    var storeCodes = storeEl ? Array.from(storeEl.selectedOptions).map(o => o.value).join(',') : '';

    document.getElementById('chartLoading').classList.remove('d-none');
    document.getElementById('chartError').classList.add('d-none');
    document.getElementById('chartArea').classList.add('d-none');
    document.getElementById('emptyState').classList.add('d-none');

    var formData = new FormData();
    formData.append('dateFrom', dateFrom);
    formData.append('dateTo', dateTo);
    formData.append('dimension', document.getElementById('dimension').value);
    formData.append('metric', document.getElementById('metric').value);
    formData.append('topN', document.getElementById('topN').value);
    formData.append('showOthers', document.getElementById('showOthers').checked);
    formData.append('compareLastYear', document.getElementById('compareLastYear').checked);
    formData.append('includeVat', document.getElementById('includeVat').checked);
    formData.append('storeCodes', storeCodes);
    formData.append('chartType', document.getElementById('chartType').value);

    fetch('/Reports/GetChartData', { method: 'POST', body: formData })
        .then(r => r.json())
        .then(result => {
            document.getElementById('chartLoading').classList.add('d-none');
            if (!result.success) {
                document.getElementById('chartError').textContent = result.message;
                document.getElementById('chartError').classList.remove('d-none');
                return;
            }
            renderChart(result.data, result.chartType);
        })
        .catch(err => {
            document.getElementById('chartLoading').classList.add('d-none');
            document.getElementById('chartError').textContent = 'Network error: ' + err.message;
            document.getElementById('chartError').classList.remove('d-none');
        });
}

function renderChart(data, chartType) {
    if (!data || data.length === 0) {
        document.getElementById('chartError').textContent = 'No data found for the selected criteria.';
        document.getElementById('chartError').classList.remove('d-none');
        return;
    }

    document.getElementById('chartArea').classList.remove('d-none');
    var labels = data.map(d => d.label);
    var values = data.map(d => d.value);
    var total = values.reduce((a, b) => a + b, 0);
    var hasCompare = data.some(d => d.compareValue !== null && d.compareValue !== undefined);
    var compareValues = hasCompare ? data.map(d => d.compareValue || 0) : null;

    var colors = labels.map((_, i) => COLORS[i % COLORS.length]);
    var isPie = chartType === 'pie' || chartType === 'doughnut';
    var isHoriz = chartType === 'horizontalBar';
    var cjsType = isHoriz ? 'bar' : (isPie ? chartType : 'bar');

    if (_chart) _chart.destroy();

    var datasets = [{
        label: document.getElementById('metric').value === 'Quantity' ? 'Quantity' : 'Value',
        data: values,
        backgroundColor: isPie ? colors : colors.map(c => c + 'CC'),
        borderColor: isPie ? '#fff' : colors,
        borderWidth: isPie ? 2 : 1
    }];

    if (hasCompare) {
        datasets.push({
            label: 'Last Year',
            data: compareValues,
            backgroundColor: isPie ? colors.map(c => c + '66') : colors.map(c => c + '44'),
            borderColor: colors.map(c => c + '88'),
            borderWidth: 1
        });
    }

    var ctx = document.getElementById('mainChart').getContext('2d');
    _chart = new Chart(ctx, {
        type: cjsType,
        data: { labels: labels, datasets: datasets },
        options: {
            indexAxis: isHoriz ? 'y' : 'x',
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: isPie ? 'right' : 'top', labels: { font: { size: 11 } } },
                tooltip: {
                    callbacks: {
                        label: function(ctx) {
                            var v = ctx.parsed !== undefined ? (isPie ? ctx.parsed : (isHoriz ? ctx.parsed.x : ctx.parsed.y)) : 0;
                            var pct = total > 0 ? ((v / total) * 100).toFixed(1) : '0';
                            var metric = document.getElementById('metric').value;
                            return metric === 'Quantity'
                                ? ctx.dataset.label + ': ' + v.toLocaleString() + ' (' + pct + '%)'
                                : ctx.dataset.label + ': €' + v.toLocaleString(undefined, {minimumFractionDigits:2}) + ' (' + pct + '%)';
                        }
                    }
                }
            },
            scales: isPie ? {} : {
                y: { beginAtZero: true, ticks: { font: { size: 11 } } },
                x: { ticks: { font: { size: 10 }, maxRotation: 45 } }
            }
        }
    });

    var tbody = document.getElementById('dataSummary');
    tbody.innerHTML = '';
    data.forEach(function(d, i) {
        var pct = total > 0 ? ((d.value / total) * 100).toFixed(1) : '0.0';
        var metric = document.getElementById('metric').value;
        var valStr = metric === 'Quantity' ? d.value.toLocaleString() : '€' + d.value.toLocaleString(undefined, {minimumFractionDigits:2});
        var colorDot = '<span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:' + COLORS[i % COLORS.length] + ';margin-right:6px;"></span>';
        var row = '<tr><td>' + (i + 1) + '</td><td>' + colorDot + d.label + '</td><td class="text-end">' + valStr + '</td><td class="text-end">' + pct + '%</td></tr>';
        if (hasCompare && d.compareValue !== null && d.compareValue !== undefined) {
            var lyStr = metric === 'Quantity' ? d.compareValue.toLocaleString() : '€' + d.compareValue.toLocaleString(undefined, {minimumFractionDigits:2});
            var diff = d.compareValue > 0 ? (((d.value - d.compareValue) / d.compareValue) * 100).toFixed(1) : 'N/A';
            var diffClass = diff !== 'N/A' && parseFloat(diff) >= 0 ? 'text-success' : 'text-danger';
            row = '<tr><td>' + (i + 1) + '</td><td>' + colorDot + d.label + '</td><td class="text-end">' + valStr + '<br><small class="text-muted">LY: ' + lyStr + '</small></td><td class="text-end">' + pct + '%<br><small class="' + diffClass + '">' + (diff !== 'N/A' ? diff + '%' : diff) + '</small></td></tr>';
        }
        tbody.innerHTML += row;
    });

    var totalRow = '<tr class="fw-bold table-light"><td></td><td>Total</td><td class="text-end">'
        + (document.getElementById('metric').value === 'Quantity' ? total.toLocaleString() : '€' + total.toLocaleString(undefined, {minimumFractionDigits:2}))
        + '</td><td class="text-end">100%</td></tr>';
    tbody.innerHTML += totalRow;
}
</script>
}
