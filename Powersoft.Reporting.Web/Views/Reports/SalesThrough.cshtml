@using Powersoft.Reporting.Core.Models
@{
    ViewData["Title"] = "Sales Through";
    var storesJson = ViewBag.StoresJson as string ?? "[]";
    var today = DateTime.Today;
    var defFrom = new DateTime(today.Year, 1, 1);
    var canSchedule = (bool)(ViewBag.CanSchedule ?? false);
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-start">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">Reports</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">Stock Control</a></li>
                    <li class="breadcrumb-item active">Sales Through</li>
                </ol>
            </nav>
            <h2 class="mb-0">
                <i class="bi bi-graph-up-arrow me-2 text-primary"></i>Sales Through
            </h2>
            <p class="text-muted mb-0">Intake (net purchases) vs sales vs current stock with sell-through and mix percentages</p>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-funnel me-2"></i>Report Parameters
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-12">
                <label class="form-label fw-semibold mb-2">Quick Date Selection</label>
                <div class="date-presets btn-group flex-wrap" role="group">
                    <input type="radio" class="btn-check" name="DatePreset" id="presetToday" value="today" autocomplete="off" onchange="applyPresetDates('today')">
                    <label class="btn btn-outline-secondary btn-sm" for="presetToday">Today</label>
                    <input type="radio" class="btn-check" name="DatePreset" id="presetYesterday" value="yesterday" autocomplete="off" onchange="applyPresetDates('yesterday')">
                    <label class="btn btn-outline-secondary btn-sm" for="presetYesterday">Yesterday</label>
                    <input type="radio" class="btn-check" name="DatePreset" id="presetLast7" value="last7" autocomplete="off" onchange="applyPresetDates('last7')">
                    <label class="btn btn-outline-secondary btn-sm" for="presetLast7">Last 7 Days</label>
                    <input type="radio" class="btn-check" name="DatePreset" id="presetLast30" value="last30" autocomplete="off" onchange="applyPresetDates('last30')">
                    <label class="btn btn-outline-secondary btn-sm" for="presetLast30">Last 30 Days</label>
                    <input type="radio" class="btn-check" name="DatePreset" id="presetThisMonth" value="thisMonth" autocomplete="off" onchange="applyPresetDates('thisMonth')">
                    <label class="btn btn-outline-secondary btn-sm" for="presetThisMonth">This Month</label>
                    <input type="radio" class="btn-check" name="DatePreset" id="presetLastMonth" value="lastMonth" autocomplete="off" onchange="applyPresetDates('lastMonth')">
                    <label class="btn btn-outline-secondary btn-sm" for="presetLastMonth">Last Month</label>
                    <input type="radio" class="btn-check" name="DatePreset" id="presetYTD" value="ytd" autocomplete="off" onchange="applyPresetDates('ytd')">
                    <label class="btn btn-outline-secondary btn-sm" for="presetYTD">Year to Date</label>
                    <input type="radio" class="btn-check" name="DatePreset" id="presetLastYear" value="lastYear" autocomplete="off" onchange="applyPresetDates('lastYear')">
                    <label class="btn btn-outline-secondary btn-sm" for="presetLastYear">Last Year</label>
                </div>
            </div>
        </div>
        <hr class="my-3">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label small fw-bold">Date from</label>
                <input type="date" class="form-control" id="dateFrom" value="@defFrom.ToString("yyyy-MM-dd")" onchange="clearPreset()" />
                <div class="form-text">Intake and sales are both measured in this period.</div>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold">to</label>
                <input type="date" class="form-control" id="dateTo" value="@today.ToString("yyyy-MM-dd")" onchange="clearPreset()" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">Primary group</label>
                <select class="form-select" id="primaryGroup" onchange="onGroupChange(1)">
                    <option value="None" selected>None</option>
                    <option value="Category">Category</option>
                    <option value="Department">Department</option>
                    <option value="Brand">Brand</option>
                    <option value="Season">Season</option>
                    <option value="Supplier">Supplier</option>
                    <option value="Store">Store</option>
                    <option value="Model">Model / Style</option>
                    <option value="Colour">Colour</option>
                    <option value="Size">Size</option>
                    <option value="GroupSize">Size Group</option>
                    <option value="Fabric">Fabric</option>
                    <option value="Franchise">Franchise</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">Secondary group</label>
                <select class="form-select" id="secondaryGroup" onchange="onGroupChange(2)" disabled>
                    <option value="None" selected>None</option>
                    <option value="Category">Category</option>
                    <option value="Department">Department</option>
                    <option value="Brand">Brand</option>
                    <option value="Season">Season</option>
                    <option value="Supplier">Supplier</option>
                    <option value="Store">Store</option>
                    <option value="Model">Model / Style</option>
                    <option value="Colour">Colour</option>
                    <option value="Size">Size</option>
                    <option value="GroupSize">Size Group</option>
                    <option value="Fabric">Fabric</option>
                    <option value="Franchise">Franchise</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">Third group</label>
                <select class="form-select" id="thirdGroup" disabled>
                    <option value="None" selected>None</option>
                    <option value="Category">Category</option>
                    <option value="Department">Department</option>
                    <option value="Brand">Brand</option>
                    <option value="Season">Season</option>
                    <option value="Supplier">Supplier</option>
                    <option value="Store">Store</option>
                    <option value="Model">Model / Style</option>
                    <option value="Colour">Colour</option>
                    <option value="Size">Size</option>
                    <option value="GroupSize">Size Group</option>
                    <option value="Fabric">Fabric</option>
                    <option value="Franchise">Franchise</option>
                </select>
            </div>
        </div>
        <div class="row g-3 mt-1">
            <div class="col-md-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="summary" />
                    <label class="form-check-label small" for="summary">
                        Summary (one row per group, no item detail)
                    </label>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="includeAdditionalCharges" checked />
                    <label class="form-check-label small" for="includeAdditionalCharges">
                        Include additional/landed charges in intake cost
                    </label>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="sortBySizeSequence" />
                    <label class="form-check-label small" for="sortBySizeSequence">
                        Order sizes by size sequence
                    </label>
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold mb-0">Page size</label>
                <select class="form-select form-select-sm" id="pageSize" onchange="_page=1;">
                    <option value="50">50</option>
                    <option value="100" selected>100</option>
                    <option value="250">250</option>
                    <option value="500">500</option>
                </select>
            </div>
        </div>

        <div class="report-form-actions d-flex flex-wrap gap-2 pt-3 mt-2 border-top">
            <button type="button" class="btn btn-primary btn-lg btn-generate" id="generateBtn" onclick="_page=1;generateReport()">
                <span class="btn-text"><i class="bi bi-play-fill me-2"></i>Generate Report</span>
                <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
            </button>
            @if (canSchedule)
            {
                <button type="button" class="btn btn-warning btn-lg" data-bs-toggle="modal" data-bs-target="#scheduleModal" title="Schedule recurring report delivery">
                    <i class="bi bi-clock-history me-2"></i>Schedule
                </button>
            }
            <div class="btn-group ms-auto">
                <div class="btn-group">
                    <button type="button" class="btn btn-outline-info dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false"
                            title="Saved report layouts" id="layoutsDropdownBtn">
                        <i class="bi bi-bookmark me-1"></i><span id="layoutsCurrentName">Layouts</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" id="layoutsDropdownMenu" style="min-width: 320px;">
                        <li><h6 class="dropdown-header">Loading...</h6></li>
                    </ul>
                </div>
                <button type="button" class="btn btn-outline-info" onclick="saveCurrentLayout()" title="Overwrite your default layout with current parameters">
                    <i class="bi bi-save me-1"></i>Save
                </button>
                <button type="button" class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#saveLayoutAsModal"
                        title="Save current parameters as a new named layout (optionally shared with all users)">
                    <i class="bi bi-bookmark-plus me-1"></i>Save as...
                </button>
                <button type="button" class="btn btn-outline-secondary" id="resetLayoutBtn" onclick="resetSavedLayout()" title="Discard your saved default layout and restore factory defaults" style="display:none;">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Default
                </button>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_ItemsSelection", new ItemsSelectionConfig
{
    ShowCategories = true,
    ShowDepartments = true,
    ShowBrands = true,
    ShowSeasons = true,
    ShowSuppliers = true,
    ShowStores = true,
    ShowItems = true,
    ShowCustomers = false,
    ShowStockFilter = false,
    ShowECommerce = false,
    ShowModifiedDate = false,
    StoresJson = storesJson,
    ReportType = "SalesThrough"
})

<div id="reportAlert" style="display:none;"></div>

<div id="reportLoading" style="display:none;" class="text-center py-5">
    <div class="spinner-border text-primary" role="status"></div>
    <p class="mt-2 text-muted">Loading report data...</p>
</div>

<div id="reportResults" style="display:none;">
    <div class="card" id="results">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span><i class="bi bi-table me-2"></i>Results: <span id="rowCountInfo"></span></span>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <button class="btn btn-sm btn-outline-primary" onclick="togglePreview()" id="previewToggleBtn" title="Toggle print preview">
                    <i class="bi bi-eye me-1"></i>Preview
                </button>
                <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-success" onclick="exportServerExcel()" title="Export Excel">
                        <i class="bi bi-filetype-xlsx me-1"></i>Excel
                    </button>
                    <button class="btn btn-outline-secondary" onclick="exportServerCsv()" title="Export CSV">
                        <i class="bi bi-filetype-csv me-1"></i>CSV
                    </button>
                    <button class="btn btn-outline-danger" onclick="exportServerPdf()" title="Export PDF">
                        <i class="bi bi-filetype-pdf me-1"></i>PDF
                    </button>
                </div>
                <button class="btn btn-sm btn-outline-primary" onclick="openSendEmailModal()" title="Send report via email">
                    <i class="bi bi-envelope me-1"></i>Send to Email
                </button>
                <button class="btn btn-sm btn-outline-info" onclick="if(!_lastData.length){alert('Generate a report first.');return;}openAiAnalysis()" title="AI-powered report analysis" id="btnAnalyze">
                    <i class="bi bi-stars me-1"></i>AI Analyze
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-striped table-hover mb-0" id="reportTable">
                    <thead class="table-light">
                        <tr id="reportHead"></tr>
                    </thead>
                    <tbody id="reportBody"></tbody>
                    <tfoot id="reportFoot" class="fw-bold" style="background:#dbeafe;"></tfoot>
                </table>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between align-items-center" id="pagerBar" style="display:none;">
            <span class="small text-muted" id="pagerInfo"></span>
            <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-secondary" id="pagerPrev" onclick="if(_page>1){_page--;generateReport();}">
                    <i class="bi bi-chevron-left"></i> Prev
                </button>
                <button class="btn btn-outline-secondary" id="pagerNext" onclick="if(_page<_totalPages){_page++;generateReport();}">
                    Next <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Inline Print Preview Panel (hidden by default) -->
<div id="previewPanel" style="display:none;" class="mt-3">
    <div class="card border-primary">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-2">
            <span><i class="bi bi-file-earmark-text me-2"></i>Print Preview</span>
            <button class="btn btn-sm btn-outline-light" onclick="togglePreview()" title="Close preview">
                <i class="bi bi-x-lg me-1"></i>Back to Grid
            </button>
        </div>
        <div class="card-body p-0">
            <iframe id="previewFrame" style="width:100%; border:none; min-height:700px; background:#525659;"></iframe>
        </div>
    </div>
</div>

@await Html.PartialAsync("_Schedule", new Powersoft.Reporting.Web.ViewModels.SchedulePartialModel
{
    SaveAction = "SaveStSchedule",
    ListAction = "GetStSchedules",
    ReportBadge = "Sales Through",
    NamePlaceholder = "e.g. Weekly Sell-Through by Category",
    SubjectPlaceholder = "Sales Through Report - {date}"
})

@await Html.PartialAsync("_SendEmail", new Powersoft.Reporting.Web.ViewModels.SendEmailPartialModel {
    SendAction = "SendSalesThroughReportEmail",
    ReportType = "SalesThrough",
    SubjectDefault = "Sales Through Report"
})

@await Html.PartialAsync("_AiAnalyze", new Powersoft.Reporting.Web.ViewModels.AiAnalyzePartialModel {
    AnalyzeActionUrl = Url.Action("AnalyzeSalesThroughReport", "Reports"),
    ReportType = "SalesThrough"
})

@await Html.PartialAsync("_SaveLayout", new Powersoft.Reporting.Web.ViewModels.SaveLayoutPartialModel
{
    ReportType     = Powersoft.Reporting.Core.Constants.ReportTypeConstants.SalesThrough,
    HasSavedLayout = false,
    ReportViewUrl  = Url.Action("SalesThrough", "Reports") ?? ""
})

<script>
var _sortCol = 'ItemCode';
var _sortDir = 'ASC';
var _lastData = [];
var _lastTotals = null;
var _page = 1;
var _totalPages = 1;

// Quick Date Selection — identical shared behaviour to other reports. Selecting a preset only
// fills dateFrom/dateTo; the user then clicks Generate.
function _stFmtDate(d){ return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }
function _stAddDays(d, n){ var r = new Date(d); r.setDate(r.getDate() + n); return r; }
function clearPreset(){ document.querySelectorAll('input[name="DatePreset"]').forEach(function(r){ r.checked = false; }); }
function applyPresetDates(preset){
    var today = new Date(); today.setHours(0,0,0,0);
    var from, to;
    switch (preset) {
        case 'today': from = to = today; break;
        case 'yesterday': from = to = _stAddDays(today, -1); break;
        case 'last7': from = _stAddDays(today, -6); to = today; break;
        case 'last30': from = _stAddDays(today, -29); to = today; break;
        case 'thisMonth': from = new Date(today.getFullYear(), today.getMonth(), 1); to = today; break;
        case 'lastMonth': var lm = new Date(today.getFullYear(), today.getMonth() - 1, 1); from = lm; to = new Date(lm.getFullYear(), lm.getMonth() + 1, 0); break;
        case 'ytd': from = new Date(today.getFullYear(), 0, 1); to = today; break;
        case 'lastYear': from = new Date(today.getFullYear() - 1, 0, 1); to = new Date(today.getFullYear() - 1, 11, 31); break;
        default: return;
    }
    document.getElementById('dateFrom').value = _stFmtDate(from);
    document.getElementById('dateTo').value = _stFmtDate(to);
}

// Strict cascade: Secondary enabled only when Primary set; Third only when Secondary set.
function onGroupChange(level) {
    var p = document.getElementById('primaryGroup');
    var s = document.getElementById('secondaryGroup');
    var t = document.getElementById('thirdGroup');
    if (level === 1) {
        if (p.value === 'None') { s.value = 'None'; s.disabled = true; t.value = 'None'; t.disabled = true; }
        else s.disabled = false;
    }
    if (level === 1 || level === 2) {
        if (s.value === 'None' || s.disabled) { t.value = 'None'; t.disabled = true; }
        else t.disabled = false;
    }
}

function collectParams() {
    return {
        dateFrom: document.getElementById('dateFrom').value,
        dateTo: document.getElementById('dateTo').value,
        summary: document.getElementById('summary').checked,
        primaryGroup: document.getElementById('primaryGroup').value,
        secondaryGroup: document.getElementById('secondaryGroup').value,
        thirdGroup: document.getElementById('thirdGroup').value,
        includeAdditionalCharges: document.getElementById('includeAdditionalCharges').checked,
        sortBySizeSequence: document.getElementById('sortBySizeSequence').checked,
        storeCodes: (typeof getItemsSelectionStoreCodes === 'function') ? getItemsSelectionStoreCodes() : '',
        itemsSelection: (typeof getItemsSelectionFilter === 'function') ? JSON.stringify(getItemsSelectionFilter()) : '',
        sortColumn: _sortCol,
        sortDirection: _sortDir
    };
}

function activeGroups() {
    var g = [];
    var p = collectParams();
    if (p.primaryGroup !== 'None') g.push({ key: 'level1Value', label: document.querySelector('#primaryGroup option:checked').text });
    if (p.secondaryGroup !== 'None') g.push({ key: 'level2Value', label: document.querySelector('#secondaryGroup option:checked').text });
    if (p.thirdGroup !== 'None') g.push({ key: 'level3Value', label: document.querySelector('#thirdGroup option:checked').text });
    return g;
}
function showItemCols() {
    var p = collectParams();
    return !(p.summary && activeGroups().length > 0);
}

function generateReport() {
    var alertEl = document.getElementById('reportAlert');
    alertEl.style.display = 'none';
    document.getElementById('reportResults').style.display = 'none';
    document.getElementById('reportLoading').style.display = '';

    var btn = document.getElementById('generateBtn');
    btn.querySelector('.btn-text').classList.add('d-none');
    btn.querySelector('.spinner-border').classList.remove('d-none');
    btn.disabled = true;

    var p = collectParams();
    var fd = new FormData();
    Object.keys(p).forEach(function (k) { fd.append(k, p[k]); });
    fd.append('pageNumber', _page);
    fd.append('pageSize', document.getElementById('pageSize').value || '100');

    fetch('@Url.Action("GetSalesThroughData", "Reports")', { method: 'POST', body: fd })
        .then(function (r) { return r.json(); })
        .then(function (d) {
            document.getElementById('reportLoading').style.display = 'none';
            btn.querySelector('.btn-text').classList.remove('d-none');
            btn.querySelector('.spinner-border').classList.add('d-none');
            btn.disabled = false;

            if (!d.success) {
                alertEl.innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>' + esc(d.message) + '</div>';
                alertEl.style.display = '';
                return;
            }
            _lastData = d.data || [];
            _lastTotals = d.totals || null;
            _totalPages = d.totalPages || 1;
            renderTable(_lastData, _lastTotals);
            document.getElementById('rowCountInfo').textContent = (d.totalRows || _lastData.length) + ' row(s)';

            var pager = document.getElementById('pagerBar');
            if (_totalPages > 1) {
                pager.style.display = '';
                document.getElementById('pagerInfo').textContent = 'Page ' + (d.pageNumber || _page) + ' of ' + _totalPages;
                document.getElementById('pagerPrev').disabled = _page <= 1;
                document.getElementById('pagerNext').disabled = _page >= _totalPages;
            } else {
                pager.style.display = 'none';
            }

            document.getElementById('reportResults').style.display = '';
            if (_lastData.length === 0) {
                alertEl.innerHTML = '<div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>No data for the selected filters.</div>';
                alertEl.style.display = '';
            }
        })
        .catch(function (err) {
            document.getElementById('reportLoading').style.display = 'none';
            btn.querySelector('.btn-text').classList.remove('d-none');
            btn.querySelector('.spinner-border').classList.add('d-none');
            btn.disabled = false;
            alertEl.innerHTML = '<div class="alert alert-danger"><i class="bi bi-wifi-off me-2"></i>Network error: ' + esc(err.message) + '</div>';
            alertEl.style.display = '';
        });
}

function renderTable(data, totals) {
    var groups = activeGroups();
    var withItem = showItemCols();

    var head = '';
    groups.forEach(function (g) { head += '<th>' + esc(g.label) + '</th>'; });
    if (withItem) {
        head += '<th style="cursor:pointer" onclick="sortBy(\'ItemCode\')">Item Code <i class="bi bi-arrow-down-up text-muted"></i></th>';
        head += '<th style="cursor:pointer" onclick="sortBy(\'ItemName\')">Item Name <i class="bi bi-arrow-down-up text-muted"></i></th>';
    }
    head += '<th class="text-end" style="cursor:pointer" onclick="sortBy(\'IntakeQty\')">Intake Qty <i class="bi bi-arrow-down-up text-muted"></i></th>';
    head += '<th class="text-end" style="cursor:pointer" onclick="sortBy(\'IntakeValue\')">Intake Value <i class="bi bi-arrow-down-up text-muted"></i></th>';
    head += '<th class="text-end" style="cursor:pointer" onclick="sortBy(\'SalesQty\')">Sales Qty <i class="bi bi-arrow-down-up text-muted"></i></th>';
    head += '<th class="text-end" style="cursor:pointer" onclick="sortBy(\'SalesNet\')">Sales Net <i class="bi bi-arrow-down-up text-muted"></i></th>';
    head += '<th class="text-end" style="cursor:pointer" onclick="sortBy(\'SalesGross\')">Sales Gross <i class="bi bi-arrow-down-up text-muted"></i></th>';
    head += '<th class="text-end" title="Sales Qty / Intake Qty">ST Qty %</th>';
    head += '<th class="text-end" title="Sales Net / Intake Value">ST Value %</th>';
    head += '<th class="text-end" style="cursor:pointer" onclick="sortBy(\'CurrentStock\')">Current Stock <i class="bi bi-arrow-down-up text-muted"></i></th>';
    head += '<th class="text-end" title="Row share of total sales qty">Sales Mix %</th>';
    head += '<th class="text-end" title="Row share of total intake qty">Intake Mix %</th>';
    head += '<th class="text-end" title="Row share of total current stock">Stock Mix %</th>';
    document.getElementById('reportHead').innerHTML = head;

    var colCount = groups.length + (withItem ? 2 : 0) + 11;
    var body = document.getElementById('reportBody');
    if (!data.length) {
        body.innerHTML = '<tr><td colspan="' + colCount + '" class="text-center text-muted py-4">No data</td></tr>';
        document.getElementById('reportFoot').innerHTML = '';
        return;
    }

    // Nested group rendering — same pattern as Purchases vs Sales: L1/L2/L3 group header
    // rows (indented, with icons) + subtotal rows per level, data rows keep the group columns.
    var html = '';
    if (groups.length > 0) {
        stGroupRows(data, 'level1Value', 'level1').forEach(function (g1) {
            html += '<tr class="group-header-row"><td colspan="' + colCount + '"><i class="bi bi-diagram-3 me-2"></i><strong>' + esc(groups[0].label) + ':</strong> ' + esc(g1.key) + '</td></tr>';
            if (groups.length > 1) {
                stGroupRows(g1.rows, 'level2Value', 'level2').forEach(function (g2) {
                    html += '<tr class="group-header-row" style="background:#e8f0fe;"><td colspan="' + colCount + '" class="ps-4"><i class="bi bi-chevron-right me-1"></i><strong>' + esc(groups[1].label) + ':</strong> ' + esc(g2.key) + '</td></tr>';
                    if (groups.length > 2) {
                        stGroupRows(g2.rows, 'level3Value', 'level3').forEach(function (g3) {
                            html += '<tr class="group-header-row" style="background:#f0f4f8;"><td colspan="' + colCount + '" class="ps-5"><i class="bi bi-dash me-1"></i><strong>' + esc(groups[2].label) + ':</strong> ' + esc(g3.key) + '</td></tr>';
                            g3.rows.forEach(function (r) { html += stDataRow(r, groups, withItem); });
                            html += stSubtotalRow(g3.key + ' subtotal', g3.rows, groups, withItem, '#f0f4f8', 'fw-semibold text-muted small');
                        });
                    } else {
                        g2.rows.forEach(function (r) { html += stDataRow(r, groups, withItem); });
                    }
                    html += stSubtotalRow(g2.key + ' subtotal', g2.rows, groups, withItem, '#e8f0fe', 'fw-semibold text-muted');
                });
            } else {
                g1.rows.forEach(function (r) { html += stDataRow(r, groups, withItem); });
            }
            html += stSubtotalRow(g1.key + ' total', g1.rows, groups, withItem, '', 'fw-semibold text-uppercase text-muted');
        });
    } else {
        data.forEach(function (r) { html += stDataRow(r, groups, withItem); });
    }
    body.innerHTML = html;

    var foot = '';
    if (totals) {
        foot = '<tr class="grand-total-row">';
        var labelSpan = groups.length + (withItem ? 2 : 0);
        if (labelSpan > 0) foot += '<td colspan="' + labelSpan + '"><i class="bi bi-calculator me-1"></i>GRAND TOTAL</td>';
        foot += '<td class="text-end">' + fmt(totals.totalIntakeQty, 0) + '</td>';
        foot += '<td class="text-end">' + fmt(totals.totalIntakeValue, 2) + '</td>';
        foot += '<td class="text-end">' + fmt(totals.totalSalesQty, 0) + '</td>';
        foot += '<td class="text-end">' + fmt(totals.totalSalesNet, 2) + '</td>';
        foot += '<td class="text-end">' + fmt(totals.totalSalesGross, 2) + '</td>';
        foot += '<td class="text-end">' + fmt(totals.sellThroughQtyPct, 1) + '%</td>';
        foot += '<td class="text-end">' + fmt(totals.sellThroughValuePct, 1) + '%</td>';
        foot += '<td class="text-end">' + fmt(totals.totalCurrentStock, 0) + '</td>';
        foot += '<td class="text-end">100%</td><td class="text-end">100%</td><td class="text-end">100%</td>';
        foot += '</tr>';
    }
    document.getElementById('reportFoot').innerHTML = foot;
}

// Order-preserving grouping (SQL already sorts by group levels; do not re-sort here).
function stGroupRows(rows, key, fallbackKey) {
    var order = [], map = {};
    rows.forEach(function (r) {
        var k = r[key] || r[fallbackKey] || 'N/A';
        if (!Object.prototype.hasOwnProperty.call(map, k)) { map[k] = []; order.push(k); }
        map[k].push(r);
    });
    return order.map(function (k) { return { key: k, rows: map[k] }; });
}

function stDataRow(r, groups, withItem) {
    var stCls = r.sellThroughQtyPct >= 100 ? 'text-success' : (r.sellThroughQtyPct < 50 ? 'text-danger' : '');
    var html = '<tr>';
    groups.forEach(function (g, i) {
        html += '<td class="' + (i === 0 ? 'fw-semibold text-info' : 'text-info') + '">' + esc(r[g.key] || 'N/A') + '</td>';
    });
    if (withItem) {
        html += '<td class="text-nowrap"><code>' + esc(r.itemCode || '') + '</code></td>';
        html += '<td>' + esc(r.itemName || '') + '</td>';
    }
    html += '<td class="text-end">' + fmt(r.intakeQty, 0) + '</td>';
    html += '<td class="text-end">' + fmt(r.intakeValue, 2) + '</td>';
    html += '<td class="text-end">' + fmt(r.salesQty, 0) + '</td>';
    html += '<td class="text-end">' + fmt(r.salesNet, 2) + '</td>';
    html += '<td class="text-end">' + fmt(r.salesGross, 2) + '</td>';
    html += '<td class="text-end ' + stCls + '">' + fmt(r.sellThroughQtyPct, 1) + '%</td>';
    html += '<td class="text-end">' + fmt(r.sellThroughValuePct, 1) + '%</td>';
    html += '<td class="text-end">' + fmt(r.currentStock, 0) + '</td>';
    html += '<td class="text-end">' + fmt(r.salesMixPct, 1) + '%</td>';
    html += '<td class="text-end">' + fmt(r.intakeMixPct, 1) + '%</td>';
    html += '<td class="text-end">' + fmt(r.stockMixPct, 1) + '%</td>';
    html += '</tr>';
    return html;
}

// Subtotal row: sums per level; sell-through % recomputed from the sums (not averaged);
// mix % sums add up to the group's share of the grand total.
function stSubtotalRow(label, rows, groups, withItem, bg, labelCls) {
    var iq = 0, iv = 0, sq = 0, sn = 0, sg = 0, cs = 0, sm = 0, im = 0, km = 0;
    rows.forEach(function (r) {
        iq += r.intakeQty || 0; iv += r.intakeValue || 0;
        sq += r.salesQty || 0; sn += r.salesNet || 0; sg += r.salesGross || 0;
        cs += r.currentStock || 0;
        sm += r.salesMixPct || 0; im += r.intakeMixPct || 0; km += r.stockMixPct || 0;
    });
    var stq = iq !== 0 ? sq / iq * 100 : 100;
    var stv = iv !== 0 ? sn / iv * 100 : 100;

    var html = '<tr class="group-subtotal-row"' + (bg ? ' style="background:' + bg + ';"' : '') + '>';
    groups.forEach(function () { html += '<td></td>'; });
    if (withItem) html += '<td class="' + labelCls + '">' + esc(label) + '</td><td></td>';
    html += '<td class="text-end fw-semibold">' + fmt(iq, 0) + '</td>';
    html += '<td class="text-end fw-semibold">' + fmt(iv, 2) + '</td>';
    html += '<td class="text-end fw-semibold">' + fmt(sq, 0) + '</td>';
    html += '<td class="text-end fw-semibold">' + fmt(sn, 2) + '</td>';
    html += '<td class="text-end fw-semibold">' + fmt(sg, 2) + '</td>';
    html += '<td class="text-end fw-semibold">' + fmt(stq, 1) + '%</td>';
    html += '<td class="text-end fw-semibold">' + fmt(stv, 1) + '%</td>';
    html += '<td class="text-end fw-semibold">' + fmt(cs, 0) + '</td>';
    html += '<td class="text-end fw-semibold">' + fmt(sm, 1) + '%</td>';
    html += '<td class="text-end fw-semibold">' + fmt(im, 1) + '%</td>';
    html += '<td class="text-end fw-semibold">' + fmt(km, 1) + '%</td>';
    html += '</tr>';
    return html;
}

function sortBy(col) {
    if (_sortCol === col) _sortDir = _sortDir === 'ASC' ? 'DESC' : 'ASC';
    else { _sortCol = col; _sortDir = 'ASC'; }
    _page = 1;
    generateReport();
}

// ===== Server exports (Excel/CSV/PDF) — share the exact on-screen filter selection =====
function stQuery() {
    var p = collectParams();
    var qs = new URLSearchParams();
    qs.append('dateFrom', p.dateFrom);
    qs.append('dateTo', p.dateTo);
    qs.append('summary', p.summary);
    qs.append('primaryGroup', p.primaryGroup);
    qs.append('secondaryGroup', p.secondaryGroup);
    qs.append('thirdGroup', p.thirdGroup);
    qs.append('includeAdditionalCharges', p.includeAdditionalCharges);
    qs.append('sortBySizeSequence', p.sortBySizeSequence);
    qs.append('storeCodes', p.storeCodes);
    qs.append('itemsSelectionJson', p.itemsSelection);
    qs.append('sortColumn', p.sortColumn);
    qs.append('sortDirection', p.sortDirection);
    return qs;
}
function buildExportUrl(action) { return '/Reports/' + action + '?' + stQuery().toString(); }
function exportServerExcel() { if (!_lastData.length) { alert('Generate a report first.'); return; } window.location.href = buildExportUrl('ExportSalesThroughExcel'); }
function exportServerCsv() { if (!_lastData.length) { alert('Generate a report first.'); return; } window.location.href = buildExportUrl('ExportSalesThroughCsv'); }
function exportServerPdf() { if (!_lastData.length) { alert('Generate a report first.'); return; } window.location.href = buildExportUrl('ExportSalesThroughPdf'); }

// ===== Print preview (iframe) =====
var previewOpen = false;
function togglePreview() {
    if (!_lastData.length) { alert('Generate a report first.'); return; }
    var panel = document.getElementById('previewPanel');
    var gridCard = document.getElementById('results');
    var btn = document.getElementById('previewToggleBtn');
    previewOpen = !previewOpen;
    if (previewOpen) {
        gridCard.style.display = 'none';
        panel.style.display = 'block';
        btn.innerHTML = '<i class="bi bi-table me-1"></i>Grid';
        btn.classList.remove('btn-outline-primary');
        btn.classList.add('btn-outline-warning');
        var frame = document.getElementById('previewFrame');
        frame.src = buildExportUrl('SalesThroughPrintPreview');
        frame.onload = function() {
            try { frame.style.height = Math.max(frame.contentDocument.body.scrollHeight + 80, 700) + 'px'; }
            catch (e) { frame.style.height = '900px'; }
        };
    } else {
        panel.style.display = 'none';
        gridCard.style.display = '';
        btn.innerHTML = '<i class="bi bi-eye me-1"></i>Preview';
        btn.classList.remove('btn-outline-warning');
        btn.classList.add('btn-outline-primary');
    }
}

// ===== SCHEDULE (shared _Schedule.cshtml partial) =====
function autoSelectScheduleDateRange() {
    var df = document.getElementById('dateFrom').value;
    var dt = document.getElementById('dateTo').value;
    if (!df || !dt) return;
    var sel = document.getElementById('schedDateRangeType');
    if (!sel) return;
    for (var i = 0; i < sel.options.length; i++) {
        if (sel.options[i].value === 'Custom') { sel.selectedIndex = i; break; }
    }
    var schedFrom = document.getElementById('schedDateFrom');
    var schedTo = document.getElementById('schedDateTo');
    if (schedFrom) schedFrom.value = df;
    if (schedTo) schedTo.value = dt;
    if (typeof onSchedDateRangeTypeChange === 'function') onSchedDateRangeTypeChange();
}

function collectScheduleParameters() {
    var p = {
        reportType: 'SalesThrough',
        dateFrom: document.getElementById('dateFrom').value,
        dateTo: document.getElementById('dateTo').value,
        stSummary: document.getElementById('summary').checked,
        stPrimaryGroup: document.getElementById('primaryGroup').value,
        stSecondaryGroup: document.getElementById('secondaryGroup').value,
        stThirdGroup: document.getElementById('thirdGroup').value,
        stIncludeAdditionalCharges: document.getElementById('includeAdditionalCharges').checked,
        stSortBySizeSequence: document.getElementById('sortBySizeSequence').checked,
        storeCodes: (typeof getItemsSelectionStoreCodes === 'function') ? getItemsSelectionStoreCodes() : '',
        sortColumn: _sortCol,
        sortDirection: _sortDir
    };
    if (typeof getItemsSelectionFilter === 'function') p.itemsSelectionJson = JSON.stringify(getItemsSelectionFilter());
    return p;
}

function onScheduleParametersLoaded(p) {
    if (!p) return;
    function truthy(v) { return v === true || v === 'true' || v === 1 || v === '1'; }
    if (typeof p.stSummary !== 'undefined') document.getElementById('summary').checked = truthy(p.stSummary);
    if (p.stPrimaryGroup) { document.getElementById('primaryGroup').value = p.stPrimaryGroup; onGroupChange(1); }
    if (p.stSecondaryGroup) { document.getElementById('secondaryGroup').value = p.stSecondaryGroup; onGroupChange(2); }
    if (p.stThirdGroup) document.getElementById('thirdGroup').value = p.stThirdGroup;
    if (typeof p.stIncludeAdditionalCharges !== 'undefined')
        document.getElementById('includeAdditionalCharges').checked = truthy(p.stIncludeAdditionalCharges);
    if (typeof p.stSortBySizeSequence !== 'undefined')
        document.getElementById('sortBySizeSequence').checked = truthy(p.stSortBySizeSequence);
}

