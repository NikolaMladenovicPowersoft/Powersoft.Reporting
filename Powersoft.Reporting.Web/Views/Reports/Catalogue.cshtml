    function showLayoutToast(message, type) {
        var existing = document.getElementById('layoutToast');
        if (existing) existing.remove();
        var div = document.createElement('div');
        div.id = 'layoutToast';
        div.className = 'alert alert-' + type + ' alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow';
        div.style.zIndex = '9999';
        div.innerHTML = '<i class="bi bi-' + (type === 'success' ? 'check-circle' : 'exclamation-triangle') + ' me-1"></i>' + message +
            '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
        document.body.appendChild(div);
        setTimeout(function() { if (div.parentNode) div.remove(); }, 4000);
    }

    function collectColumnFiltersJson() {
        var values = {}, operators = {}, hasAny = false;
        document.querySelectorAll('input[id^="fv_"]').forEach(function(el) {
            var col = el.id.substring(3);
            if (el.value) { values[col] = el.value; hasAny = true; }
        });
        document.querySelectorAll('input[id^="fo_"]').forEach(function(el) {
            var col = el.id.substring(3);
            if (el.value) operators[col] = el.value;
        });
        return hasAny ? JSON.stringify({ values: values, operators: operators }) : '';
    }

    function collectCatalogueParams() {
        function v(id){var el = document.getElementById(id); return el ? el.value : '';}
        function chk(id){var el = document.getElementById(id); return el ? el.checked : false;}
        var p = {
            dateFrom: v('DateFrom'),
            dateTo: v('DateTo'),
            dateBasis: v('DateBasis'),
            useDateTime: chk('UseDateTime'),
            reportMode: v('ReportMode'),
            reportOn: v('ReportOn'),
            primaryGroup: v('PrimaryGroup'),
            secondaryGroup: v('SecondaryGroup'),
            thirdGroup: v('ThirdGroup'),
            profitBasedOn: v('ProfitBasedOn'),
            profitIncludesVat: chk('ProfitIncludesVat'),
            stockValueBasedOn: v('StockValueBasedOn'),
            stockValueIncludesVat: chk('StockValueIncludesVat'),
            costType: v('CostType'),
            displayColumns: v('displayColumnsHidden') || '',
            showProfit: chk('ShowProfit'),
            showStock: chk('ShowStock'),
            storeCodes: v('selectedStoreCodesHidden'),
            itemsSelection: v('itemsSelectionJsonHidden'),
            sortColumn: v('sortColumnHidden') || 'ItemCode',
            sortDirection: v('sortDirectionHidden') || 'ASC'
        };
        var cf = collectColumnFiltersJson();
        if (cf) p.columnFilters = cf;
        return p;
    }

    function exportCatalogue(format) {
        var action = format === 'csv' ? '@Url.Action("ExportCatalogueCsv", "Reports")' : '@Url.Action("ExportCatalogueExcel", "Reports")';
        var p = collectCatalogueParams();
        var qs = Object.keys(p).map(function(k) { return encodeURIComponent(k) + '=' + encodeURIComponent(p[k]); }).join('&');
        window.location.href = action + '?' + qs;
    }

    function saveSchedule() {
        var name = document.getElementById('schedName').value.trim();
        var recipients = document.getElementById('schedRecipients').value.trim();
        var alertDiv = document.getElementById('scheduleAlert');

        if (!name || !recipients) {
            alertDiv.innerHTML = '<div class="alert alert-warning mb-0">Please fill in schedule name and recipients.</div>';
            alertDiv.style.display = ''; return;
        }
        var ev = validateEmailList(recipients);
        if (!ev.valid) {
            alertDiv.innerHTML = '<div class="alert alert-warning mb-0">Invalid email address(es): ' + ev.errors.join('; ') + '</div>';
            alertDiv.style.display = ''; return;
        }

        var recurrence = document.getElementById('schedRecurrence').value;
        if (recurrence === 'Once') {
            var startDate = document.getElementById('schedStartDate').value;
            var today = new Date().toISOString().slice(0, 10);
            if (!startDate || startDate < today) {
                alertDiv.innerHTML = '<div class="alert alert-warning mb-0">For "Run once", start date must be today or in the future.</div>';
                alertDiv.style.display = ''; return;
            }
        }

        var day = (recurrence === 'Monthly') ? parseInt(document.getElementById('schedMonthDay').value, 10) : null;

        var fd = new FormData();
        fd.append('scheduleName', name);
        fd.append('recurrenceType', recurrence);
        if (day !== null && !isNaN(day)) fd.append('recurrenceDay', day);
        fd.append('scheduleTime', document.getElementById('schedTime').value);
        fd.append('exportFormat', document.getElementById('schedFormat').value);
        fd.append('recipients', recipients);
        fd.append('emailSubject', document.getElementById('schedSubject').value);
        fd.append('includeAiAnalysis', document.getElementById('schedIncludeAi').checked);
        fd.append('aiLocale', document.getElementById('schedAiLocale').value);
        fd.append('skipIfEmpty', document.getElementById('schedSkipIfEmpty').checked);

        var dsel = document.getElementById('schedDateRangeType');
        var dopt = dsel.options[dsel.selectedIndex];
        var reportDateRange = { type: dopt.value };
        if (reportDateRange.type === 'LastNDays') reportDateRange.value = parseInt(dopt.getAttribute('data-value') || '7', 10);
        else if (reportDateRange.type === 'Custom') {
            reportDateRange.dateFrom = document.getElementById('schedDateFrom').value;
            reportDateRange.dateTo = document.getElementById('schedDateTo').value;
        }

        var params = collectCatalogueParams();
        params.reportDateRange = reportDateRange;
        fd.append('parametersJson', JSON.stringify(params));

        var startDateSc = document.getElementById('schedStartDate').value || new Date().toISOString().slice(0, 10);
        var recurrenceJson = {
            type: recurrence,
            time: document.getElementById('schedTime').value,
            range: { startDate: startDateSc, noEndDate: true }
        };
        if (recurrence === 'Weekly') {
            var days = [];
            document.querySelectorAll('.sched-dow:checked').forEach(function(cb) { days.push(parseInt(cb.value, 10)); });
            recurrenceJson.pattern = { interval: 1, daysOfWeek: days.length ? days : [1] };
        } else if (recurrence === 'Monthly') {
            recurrenceJson.pattern = { dayOfMonth: day !== null ? day : 1 };
        }
        fd.append('recurrenceJson', JSON.stringify(recurrenceJson));

        // Edit mode: if the form was loaded from an existing schedule, send the id so the server
        // performs an UPDATE instead of inserting a duplicate record.
        var sid = document.getElementById('schedId').value;
        if (sid) fd.append('scheduleId', sid);

        var saveBtn = document.querySelector('#scheduleModal .btn-primary[onclick="saveSchedule()"]');
        if (saveBtn) saveBtn.disabled = true;

        fetch('@Url.Action("SaveCatalogueSchedule", "Reports")', { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (saveBtn) saveBtn.disabled = false;
                if (data.success) {
                    alertDiv.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle me-1"></i>' + data.message + '</div>';
                    alertDiv.style.display = '';
                    loadExistingSchedules();
                    if (data.updated) {
                        // Update: keep the form populated so the user can tweak again or close the modal manually.
                        showScheduleToast('Schedule updated', 'success');
                    } else {
                        // New schedule: clear the form after a beat so the user can queue another one.
                        setTimeout(function() {
                            resetScheduleForm();
                            showScheduleToast('Schedule saved successfully', 'success');
                        }, 700);
                    }
                } else {
                    alertDiv.innerHTML = '<div class="alert alert-danger mb-0">' + data.message + '</div>';
                    alertDiv.style.display = '';
                }
            })
            .catch(function() {
                if (saveBtn) saveBtn.disabled = false;
                alertDiv.innerHTML = '<div class="alert alert-danger mb-0">Network error. Please try again.</div>';
                alertDiv.style.display = '';
            });
    }

    function showScheduleToast(message, type) {
        var existing = document.getElementById('schedToast');
        if (existing) existing.remove();
        var div = document.createElement('div');
        div.id = 'schedToast';
        div.className = 'alert alert-' + type + ' alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow';
        div.style.zIndex = '11000';
        div.innerHTML = '<i class="bi bi-' + (type === 'success' ? 'check-circle' : 'exclamation-triangle') + ' me-1"></i>' + message +
            '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
        document.body.appendChild(div);
        setTimeout(function() { if (div.parentNode) div.remove(); }, 4000);
    }

    function deleteScheduleRow(scheduleId, scheduleName) {
        if (!confirm('Delete schedule "' + scheduleName + '"?\nThis cannot be undone.')) return;
        var fd = new FormData();
        fd.append('scheduleId', scheduleId);
        fetch('@Url.Action("DeleteSchedule", "Reports")', { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    showScheduleToast('Schedule deleted', 'success');
                    loadExistingSchedules();
                    // If the form still held the deleted schedule's data (after a prior Load), wipe it so
                    // the user isn't left editing a record that no longer exists.
                    resetScheduleForm();
                } else {
                    showScheduleToast(data.message || 'Failed to delete schedule', 'danger');
                }
            })
            .catch(function() { showScheduleToast('Network error', 'danger'); });
    }

    function loadExistingSchedules() {
        fetch('@Url.Action("GetCatalogueSchedules", "Reports")')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var c = document.getElementById('existingSchedules');
                if (!data || data.length === 0) { c.innerHTML = '<em>No schedules configured yet.</em>'; return; }
                var html = '<table class="table table-sm mb-0 align-middle"><thead><tr><th>Name</th><th>Recurrence</th><th>Format</th><th>Time</th><th>Next Run</th><th class="text-end">Actions</th></tr></thead><tbody>';
                data.forEach(function(s) {
                    var safeName = (s.scheduleName || '').replace(/'/g, "\\'").replace(/"/g, '&quot;');
                    html += '<tr data-schedule-id="' + s.scheduleId + '" style="cursor:pointer;" title="Click to load this schedule">'
                        + '<td>' + escapeHtml(s.scheduleName || '') + '</td>'
                        + '<td>' + s.recurrenceType + '</td>'
                        + '<td>' + s.exportFormat + '</td>'
                        + '<td>' + s.scheduleTime + '</td>'
                        + '<td>' + (s.nextRun || '-') + '</td>'
                        + '<td class="text-end">'
                        +   '<button type="button" class="btn btn-sm btn-outline-primary me-1" title="Load into form" onclick="event.stopPropagation(); loadScheduleIntoForm(' + s.scheduleId + ')"><i class="bi bi-pencil"></i></button>'
                        +   '<button type="button" class="btn btn-sm btn-outline-danger" title="Delete schedule" onclick="event.stopPropagation(); deleteScheduleRow(' + s.scheduleId + ', \'' + safeName + '\')"><i class="bi bi-trash"></i></button>'
                        + '</td>'
                        + '</tr>';
                });
                html += '</tbody></table>';
                c.innerHTML = html;
                c.querySelectorAll('tr[data-schedule-id]').forEach(function(tr) {
                    tr.addEventListener('click', function() {
                        loadScheduleIntoForm(parseInt(tr.getAttribute('data-schedule-id'), 10));
                    });
                });
            })
            .catch(function() { document.getElementById('existingSchedules').innerHTML = '<em>Could not load schedules.</em>'; });
    }

    // A2 (2026-04-17): clean state + click-to-load, mirrored from AverageBasket.
    function resetScheduleForm() {
        var setVal = function(id, v) { var el = document.getElementById(id); if (el) el.value = v; };
        var setChk = function(id, v) { var el = document.getElementById(id); if (el) el.checked = !!v; };
        setVal('schedId', '');
        setVal('schedName', '');
        setVal('schedRecipients', 'gm@powersoft.com.cy');
        setVal('schedSubject', '');
        setVal('schedFormat', 'Excel');
        setVal('schedRecurrence', 'Daily');
        setVal('schedTime', '08:00');
        setVal('schedStartDate', new Date().toISOString().slice(0, 10));
        document.querySelectorAll('.sched-dow').forEach(function(cb) { cb.checked = false; });
        setChk('schedSkipIfEmpty', false);
        setChk('schedIncludeAi', false);
        if (typeof onRecurrenceChange === 'function') onRecurrenceChange();
        if (typeof onSchedAiToggle === 'function') onSchedAiToggle();
        var alertDiv = document.getElementById('scheduleAlert');
        if (alertDiv) { alertDiv.style.display = 'none'; alertDiv.innerHTML = ''; }
    }

    function loadScheduleIntoForm(scheduleId) {
        fetch('@Url.Action("GetScheduleById", "Reports")?scheduleId=' + scheduleId)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!data || !data.success || !data.schedule) {
                    showScheduleToast((data && data.message) || 'Could not load schedule', 'danger');
                    return;
                }
                var s = data.schedule;
                var setVal = function(id, v) { var el = document.getElementById(id); if (el) el.value = v || ''; };
                var setChk = function(id, v) { var el = document.getElementById(id); if (el) el.checked = !!v; };
                // Remember the id so a subsequent Save updates this schedule instead of cloning it.
                document.getElementById('schedId').value = scheduleId;
                setVal('schedName', s.scheduleName);
                setVal('schedRecipients', s.recipients);
                setVal('schedSubject', s.emailSubject);
                setVal('schedFormat', s.exportFormat);
                setVal('schedRecurrence', s.recurrenceType);
                setVal('schedTime', s.scheduleTime);
                if (typeof onRecurrenceChange === 'function') onRecurrenceChange();

                if (s.recurrenceJson) {
                    try {
                        var rec = typeof s.recurrenceJson === 'string' ? JSON.parse(s.recurrenceJson) : s.recurrenceJson;
                        if (rec && rec.range && rec.range.startDate) setVal('schedStartDate', rec.range.startDate);
                        if (rec && rec.pattern) {
                            if (rec.type === 'Weekly' && Array.isArray(rec.pattern.daysOfWeek)) {
                                document.querySelectorAll('.sched-dow').forEach(function(cb) {
                                    cb.checked = rec.pattern.daysOfWeek.indexOf(parseInt(cb.value, 10)) !== -1;
                                });
                            } else if (rec.type === 'Monthly' && rec.pattern.dayOfMonth) {
                                setVal('schedMonthDay', String(rec.pattern.dayOfMonth));
                            }
                        }
                    } catch (e) { /* best-effort */ }
                }

                setChk('schedSkipIfEmpty', s.skipIfEmpty);
                setChk('schedIncludeAi', s.includeAiAnalysis);
                if (s.aiLocale) setVal('schedAiLocale', s.aiLocale);
                if (typeof onSchedAiToggle === 'function') onSchedAiToggle();

                var alertDiv = document.getElementById('scheduleAlert');
                if (alertDiv) {
                    alertDiv.innerHTML = '<div class="alert alert-info mb-0 py-2"><i class="bi bi-pencil-square me-1"></i>Editing <strong>' + escapeHtml(s.scheduleName || '') + '</strong>. Saving will update this schedule in place &mdash; click <em>Reset</em> to start a new one instead.</div>';
                    alertDiv.style.display = '';
                }
            })
            .catch(function() { showScheduleToast('Network error loading schedule', 'danger'); });
    }

    // Load schedules and init date range visibility when modal opens
    document.addEventListener('DOMContentLoaded', function() {
        var scheduleModal = document.getElementById('scheduleModal');
        if (scheduleModal) {
            scheduleModal.addEventListener('show.bs.modal', function() {
                resetScheduleForm();               // A2: always start clean
                loadExistingSchedules();
                autoSelectScheduleDateRange();
                onSchedDateRangeTypeChange();
            });
        }
    });

    // ==================== Send to Email ====================

    var _emailTemplatesCache = [];

    function openSendEmailModal() {
        document.getElementById('sendEmailRecipients').value = '';
        document.getElementById('sendEmailAlert').style.display = 'none';
        document.getElementById('sendEmailRecipients').classList.remove('is-invalid');
        loadEmailTemplates();
        var m = new bootstrap.Modal(document.getElementById('sendEmailModal'));
        m.show();
    }

    function loadEmailTemplates() {
        fetch('@Url.Action("GetEmailTemplates", "Reports")?reportType=Catalogue')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                _emailTemplatesCache = data || [];
                var sel = document.getElementById('sendEmailTemplate');
                sel.innerHTML = '<option value="">-- No template (default) --</option>';
                data.forEach(function(t) {
                    var opt = document.createElement('option');
                    opt.value = t.templateId;
                    opt.textContent = t.templateName + (t.isDefault ? ' (default)' : '');
                    opt.dataset.subject = t.emailSubject || '';
                    sel.appendChild(opt);
                    if (t.isDefault) opt.selected = true;
                });
                onEmailTemplateChange();
            })
            .catch(function() {});
    }

    function onEmailTemplateChange() {
        var sel = document.getElementById('sendEmailTemplate');
        var id = parseInt(sel.value, 10);
        var preview = document.getElementById('sendEmailBodyPreview');
        if (isNaN(id) || !id) {
            preview.innerHTML = '<em class="text-muted">Default email body will be used.</em>';
            return;
        }
        var t = _emailTemplatesCache.find(function(x) { return x.templateId === id; });
        if (!t) return;
        if (t.emailSubject) document.getElementById('sendEmailSubject').value = replaceMergeFieldsPreview(t.emailSubject);
        if (t.emailBodyHtml) preview.innerHTML = replaceMergeFieldsPreview(t.emailBodyHtml);
    }

    function replaceMergeFieldsPreview(text) {
        return text
            .replace(/\u00ABReportName\u00BB/g, 'Catalogue')
            .replace(/\u00ABDatabaseName\u00BB/g, '@(Model.ConnectedDatabase ?? "Unknown")')
            .replace(/\u00ABPeriod\u00BB/g, '@Model.DateFrom.ToString("yyyy-MM-dd") to @Model.DateTo.ToString("yyyy-MM-dd")')
            .replace(/\u00ABRowCount\u00BB/g, '@(Model.Results?.Count ?? 0)')
            .replace(/\u00ABExportFormat\u00BB/g, document.getElementById('sendEmailFormat').value)
            .replace(/\u00ABGeneratedDate\u00BB/g, new Date().toLocaleString())
            .replace(/\u00ABUserName\u00BB/g, '@(User.Identity?.Name ?? "Unknown")')
            .replace(/\u00ABCompanyName\u00BB/g, '@(Model.ConnectedDatabase ?? "")')
            .replace(/\u00AB/g, '').replace(/\u00BB/g, '');
    }

    function sendReportEmail() {
        var ri = document.getElementById('sendEmailRecipients');
        var alertDiv = document.getElementById('sendEmailAlert');
        var v = validateEmailList(ri.value);
        if (!v.valid) {
            ri.classList.add('is-invalid');
            document.getElementById('sendEmailRecipientsError').textContent = v.errors.join('; ');
            return;
        }
        ri.classList.remove('is-invalid');

        var btn = document.getElementById('sendEmailBtn');
        var spinner = document.getElementById('sendEmailSpinner');
        var icon = document.getElementById('sendEmailIcon');
        btn.disabled = true; spinner.classList.remove('d-none'); icon.classList.add('d-none');

        var fd = new FormData();
        fd.append('recipients', ri.value.trim());
        fd.append('cc', (document.getElementById('sendEmailCC').value || '').trim());
        fd.append('bcc', (document.getElementById('sendEmailBCC').value || '').trim());
        fd.append('emailSubject', document.getElementById('sendEmailSubject').value);
        fd.append('exportFormat', document.getElementById('sendEmailFormat').value);
        fd.append('templateId', document.getElementById('sendEmailTemplate').value || '');

        var p = collectCatalogueParams();
        Object.keys(p).forEach(function(k) { fd.append(k, p[k]); });

        fetch('@Url.Action("SendCatalogueEmail", "Reports")', { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                btn.disabled = false; spinner.classList.add('d-none'); icon.classList.remove('d-none');
                if (data.success) alertDiv.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle me-1"></i>' + data.message + '</div>';
                else alertDiv.innerHTML = '<div class="alert alert-danger mb-0"><i class="bi bi-exclamation-triangle me-1"></i>' + data.message + '</div>';
                alertDiv.style.display = '';
            })
            .catch(function() {
                btn.disabled = false; spinner.classList.add('d-none'); icon.classList.remove('d-none');
                alertDiv.innerHTML = '<div class="alert alert-danger mb-0">Network error. Please try again.</div>';
                alertDiv.style.display = '';
            });
    }

    // ==================== Column Selection (drives DisplayColumnsString on server) ====================

    function filterColumnList() {
        var el = document.getElementById('colSearchInput');
        if (!el) return;
        var s = el.value.toLowerCase().trim();
        document.querySelectorAll('#colToggleList label').forEach(function(label) {
            if (!s) { label.classList.remove('d-none'); return; }
            var name = (label.getAttribute('data-col-name') || '').toLowerCase();
            var sp = label.querySelector('span'); var text = sp ? sp.textContent.toLowerCase() : '';
            var cv = label.querySelector('input') ? label.querySelector('input').value.toLowerCase() : '';
            label.classList.toggle('d-none', !(name.indexOf(s) !== -1 || text.indexOf(s) !== -1 || cv.indexOf(s) !== -1));
        });
    }

    function toggleAllColumns(checked) {
        document.querySelectorAll('.col-toggle:not([disabled])').forEach(function(cb) {
            if (cb.checked !== checked) { cb.checked = checked; onColToggleChange(cb); }
        });
    }

    function resetDefaultColumns() {
        var defaults = ['ItemCode','ItemName','Quantity','Value','Discount','NetValue','VatAmount','GrossAmount'];
        document.querySelectorAll('.col-toggle:not([disabled])').forEach(function(cb) {
            var key = cb.getAttribute('data-disp-key') || '';
            var shouldCheck = defaults.indexOf(key) >= 0;
            if (cb.checked !== shouldCheck) { cb.checked = shouldCheck; onColToggleChange(cb); }
        });
    }

    function updateColVisibleCount() {
        var visible = document.querySelectorAll('.col-toggle[data-is-grouping="0"]:not([disabled]):checked').length;
        var el = document.getElementById('colVisibleCount');
        if (el) el.textContent = visible;
    }

    // Returns true if the given SQL column name is currently rendered in the grid (<th data-col="X"> exists).
    function _isColumnInGrid(sqlCol) {
        return !!document.querySelector('#resultsTable thead th[data-col="' + sqlCol + '"]');
    }

    // Returns the list of SQL columns that the user has checked in the modal but that are NOT yet in the grid.
    // These require a server round-trip (Apply & Refresh) because we don't have their data client-side.
    function _getColumnsNeedingRefresh() {
        var out = [];
        document.querySelectorAll('.col-toggle[data-is-grouping="0"]:checked:not([disabled])').forEach(function(cb) {
            if (!_isColumnInGrid(cb.value)) out.push(cb.value);
        });
        return out;
    }

    // Updates the "add column needs refresh" UI: label highlight, banner, and Apply button pulse.
    function _updateNeedsRefreshUi() {
        // Mark individual labels
        document.querySelectorAll('#colToggleList label').forEach(function(lbl) {
            var cb = lbl.querySelector('input.col-toggle');
            if (!cb || cb.disabled) { lbl.classList.remove('col-needs-refresh'); return; }
            var needs = cb.checked && !_isColumnInGrid(cb.value);
            lbl.classList.toggle('col-needs-refresh', needs);
        });
        // Banner + Apply button pulse
        var missing = _getColumnsNeedingRefresh();
        var banner = document.getElementById('colAddBanner');
        var bannerText = document.getElementById('colAddBannerText');
        var btn = document.getElementById('applyColumnsBtn');
        if (missing.length > 0) {
            if (banner) banner.classList.remove('d-none');
            if (bannerText) {
                var labels = missing.slice(0, 3).map(function(sql) {
                    var cb = document.querySelector('.col-toggle[value="' + sql + '"]');
                    var lbl = cb && cb.closest('label'); var sp = lbl && lbl.querySelector('span.flex-grow-1');
                    return sp ? sp.textContent.trim() : sql;
                });
                var more = missing.length > 3 ? ' (+' + (missing.length - 3) + ' more)' : '';
                bannerText.innerHTML = '<strong>' + missing.length + '</strong> new column' + (missing.length > 1 ? 's' : '')
                    + ' selected: <em>' + labels.join(', ') + more + '</em>. '
                    + 'Click <strong>Apply &amp; Refresh</strong> to load their data.';
            }
            if (btn) btn.classList.add('needs-refresh');
        } else {
            if (banner) banner.classList.add('d-none');
            if (btn) btn.classList.remove('needs-refresh');
        }
    }

    // Rebuild DisplayColumnsString hidden input from modal checkboxes.
    function rebuildDisplayColumnsFromModal() {
        var keys = [];
        document.querySelectorAll('.col-toggle[data-is-grouping="0"]:checked').forEach(function(cb) {
            var k = cb.getAttribute('data-disp-key') || '';
            if (k && keys.indexOf(k) < 0) keys.push(k);
        });
        var hidden = document.getElementById('displayColumnsHidden');
        if (hidden) hidden.value = keys.join(',');
    }

    // Track whether the user changed the selection since the report was generated.
    var _colsInitialSig = '';
    function currentColsSignature() {
        var keys = [];
        document.querySelectorAll('.col-toggle[data-is-grouping="0"]').forEach(function(cb) {
            keys.push(cb.getAttribute('data-disp-key') + ':' + (cb.checked ? '1' : '0'));
        });
        return keys.join('|');
    }
    function updateDirtyIndicator() {
        var el = document.getElementById('colDirtyIndicator');
        if (!el) return;
        el.style.display = (currentColsSignature() !== _colsInitialSig) ? '' : 'none';
    }

    function onColToggleChange(cb) {
        // Immediate visual feedback: hide the corresponding <th>/<td> if it is currently rendered.
        try {
            var table = document.getElementById('resultsTable');
            if (table) {
                var headers = table.querySelectorAll('thead tr:first-child th');
                for (var i = 0; i < headers.length; i++) {
                    if (headers[i].getAttribute('data-col') === cb.value) {
                        var colIdx = i + 1;
                        var styleId = 'colHide_' + cb.value;
                        var existing = document.getElementById(styleId);
                        if (!cb.checked) {
                            if (!existing) {
                                var s = document.createElement('style');
                                s.id = styleId;
                                s.textContent = '#resultsTable th:nth-child(' + colIdx + '), #resultsTable td:nth-child(' + colIdx + '){display:none;}';
                                document.head.appendChild(s);
                            }
                        } else if (existing) {
                            existing.remove();
                        }
                        break;
                    }
                }
            }
        } catch (e) {}

        rebuildDisplayColumnsFromModal();
        syncQuickTogglesFromColToggles();
        updateColVisibleCount();
        updateDirtyIndicator();
        _updateNeedsRefreshUi();
    }

    function applyAndRefreshColumns() {
        rebuildDisplayColumnsFromModal();
        try { sessionStorage.setItem('catalogue_scroll_to_results', '1'); } catch (e) {}
        document.getElementById('pageNumberHidden').value = '1';
        document.getElementById('reportForm').submit();
    }

    // ==================== COLUMN REORDER (Phase 1 - client-side, session-scoped) ====================
    // Scope:
    //   - Grouping columns (L1/L2/L3) and Item columns (Code/Description) stay anchored LEFT
    //     (data-fixed-left="1"). Everything to the right of them is user-reorderable.
    //   - Order is persisted in sessionStorage under COL_ORDER_KEY per-tenant/per-session.
    //   - Order is applied to: thead <th>, tbody .data-row <td>, .group-subtotal-row metric <td>,
    //     tfoot .grand-total-row metric <td>. group-header-row is a single colspan cell and is skipped.
    //   - Does NOT affect CSV/Excel/PDF export yet (server-side, fixed order). Phase 2.
    var COL_ORDER_KEY = 'catalogue_col_order_v1';

    function _getReorderableThs() {
        var table = document.getElementById('resultsTable');
        if (!table) return [];
        var all = Array.from(table.querySelectorAll('thead tr:first-child th'));
        return all.filter(function(th) { return th.getAttribute('data-fixed-left') !== '1'; });
    }

    function _getFixedLeftCount() {
        var table = document.getElementById('resultsTable');
        if (!table) return 0;
        return table.querySelectorAll('thead tr:first-child th[data-fixed-left="1"]').length;
    }

    // Read the current order from the modal list (source of truth while user edits).
    function getColumnOrderFromModal() {
        var out = [];
        document.querySelectorAll('#colToggleList label.col-reorderable').forEach(function(lbl) {
            var sql = lbl.getAttribute('data-col-sql');
            if (sql) out.push(sql);
        });
        return out;
    }

    // Compute the index permutation that maps original reorderable <th> order -> requested order.
    function _computeReorderIndices(sqlOrder) {
        var reorderableTh = _getReorderableThs();
        var origIdxBySql = {};
        reorderableTh.forEach(function(th, i) { origIdxBySql[th.getAttribute('data-col')] = i; });

        var result = [];
        var added = new Set();
        for (var i = 0; i < sqlOrder.length; i++) {
            var sql = sqlOrder[i];
            if (origIdxBySql[sql] !== undefined && !added.has(sql)) {
                result.push(origIdxBySql[sql]);
                added.add(sql);
            }
        }
        // Append any reorderable columns not mentioned (new cols, forward compat) in their original order.
        reorderableTh.forEach(function(th, i) {
            var sql = th.getAttribute('data-col');
            if (!added.has(sql)) { result.push(i); added.add(sql); }
        });
        return result;
    }

    function _reorderCells(parent, startIdx, permutation) {
        var children = Array.from(parent.children);
        var reorderable = children.slice(startIdx);
        if (reorderable.length !== permutation.length) return false; // row shape mismatch, skip
        var frag = document.createDocumentFragment();
        for (var i = 0; i < permutation.length; i++) frag.appendChild(reorderable[permutation[i]]);
        parent.appendChild(frag);
        return true;
    }

    // Count leading "fixed" cells in a subtotal row: the leading empty <td>s (indent) + 1 colspan label cell.
    function _subtotalFixedCount(tr) {
        var cells = tr.children;
        var fixed = 0;
        for (var i = 0; i < cells.length; i++) {
            var c = cells[i];
            if (c.hasAttribute('colspan')) { fixed = i + 1; break; }
            fixed = i + 1;
        }
        return fixed;
    }

    // Apply the requested SQL-column order to the grid (header + all row types).
    function applyColumnOrderToGrid(sqlOrder) {
        var table = document.getElementById('resultsTable');
        if (!table || !sqlOrder || !sqlOrder.length) return;

        var perm = _computeReorderIndices(sqlOrder);
        var fixedLeft = _getFixedLeftCount();

        // 1. Header
        var theadRow = table.querySelector('thead tr:first-child');
        if (theadRow) _reorderCells(theadRow, fixedLeft, perm);

        // 2. Data rows (exactly one <td> per <th>)
        table.querySelectorAll('tbody tr.data-row').forEach(function(tr) {
            _reorderCells(tr, fixedLeft, perm);
        });

        // 3. Subtotal rows (leading indent <td>s + colspan label + metric <td>s matching reorderable <th>s)
        table.querySelectorAll('tbody tr.group-subtotal-row').forEach(function(tr) {
            _reorderCells(tr, _subtotalFixedCount(tr), perm);
        });

        // 4. Grand total (1 colspan label + metric <td>s). Skip if spanCols == 0 (no group/item cols).
        table.querySelectorAll('tfoot tr.grand-total-row').forEach(function(tr) {
            var first = tr.firstElementChild;
            var leading = (first && first.hasAttribute('colspan')) ? 1 : 0;
            _reorderCells(tr, leading, perm);
        });

        // 5. Rebuild any hide-column <style> tags: they reference <th>/<td>:nth-child(N) which
        //    must now point to the new DOM position of each hidden column.
        _rebuildHideStyles();
    }

    // After any reorder (drag or up/down), update <style id="colHide_X"> tags to use the new nth-child.
    function _rebuildHideStyles() {
        var table = document.getElementById('resultsTable');
        if (!table) return;
        var headers = Array.from(table.querySelectorAll('thead tr:first-child th'));
        document.querySelectorAll('style[id^="colHide_"]').forEach(function(s) {
            var sql = s.id.substring('colHide_'.length);
            var idx = -1;
            for (var i = 0; i < headers.length; i++) {
                if (headers[i].getAttribute('data-col') === sql) { idx = i + 1; break; }
            }
            if (idx > 0) {
                s.textContent = '#resultsTable th:nth-child(' + idx + '), #resultsTable td:nth-child(' + idx + '){display:none;}';
            }
        });
    }

    function _saveColumnOrder() {
        try {
            var order = getColumnOrderFromModal();
            sessionStorage.setItem(COL_ORDER_KEY, JSON.stringify(order));
            // Keep the hidden input in sync so subsequent form submits (report generate,
            // save layout, save-as) pick up the current order without extra round-trips.
            var hidden = document.getElementById('columnOrderHidden');
            if (hidden) hidden.value = order.join(',');
        } catch (e) { /* sessionStorage blocked */ }
    }

    // Load order with priority: sessionStorage (current working) > Model.ColumnOrder (from saved layout)
    function _loadColumnOrder() {
        try {
            var raw = sessionStorage.getItem(COL_ORDER_KEY);
            if (raw) {
                var arr = JSON.parse(raw);
                if (Array.isArray(arr) && arr.length) return arr;
            }
        } catch (e) {}
        // Fall back to server-provided layout order (Model.ColumnOrder → hidden input)
        var hidden = document.getElementById('columnOrderHidden');
        var val = hidden ? (hidden.value || '') : '';
        if (val) {
            var fromModel = val.split(',').map(function(s) { return s.trim(); }).filter(function(s) { return s.length > 0; });
            if (fromModel.length) return fromModel;
        }
        return null;
    }

    // Re-sort modal items to match a given SQL order. Non-reorderable items (grouping) keep their spots at the top.
    function _applyOrderToModal(sqlOrder) {
        var list = document.getElementById('colToggleList');
        if (!list) return;
        var items = Array.from(list.children);
        var bySql = {};
        var fixedItems = [];
        items.forEach(function(el) {
            var sql = el.getAttribute('data-col-sql');
            if (!sql) return;
            if (el.classList.contains('col-reorderable')) bySql[sql] = el;
            else fixedItems.push(el);
        });

        var frag = document.createDocumentFragment();
        fixedItems.forEach(function(el) { frag.appendChild(el); });

        var added = new Set();
        sqlOrder.forEach(function(sql) {
            if (bySql[sql] && !added.has(sql)) { frag.appendChild(bySql[sql]); added.add(sql); }
        });
        // Append any leftover reorderable (new cols) in original order.
        Object.keys(bySql).forEach(function(sql) {
            if (!added.has(sql)) frag.appendChild(bySql[sql]);
        });
        list.appendChild(frag);
    }

    // ---- ↑/↓ buttons ----
    function moveColumnOrder(btn, delta) {
        var lbl = btn.closest('label.col-reorderable');
        if (!lbl) return;
        var sibling = delta < 0 ? lbl.previousElementSibling : lbl.nextElementSibling;
        // Only swap with another reorderable item — do not cross the grouping/fixed boundary.
        while (sibling && !sibling.classList.contains('col-reorderable')) {
            sibling = delta < 0 ? sibling.previousElementSibling : sibling.nextElementSibling;
        }
        if (!sibling) return;
        if (delta < 0) lbl.parentNode.insertBefore(lbl, sibling);
        else lbl.parentNode.insertBefore(lbl, sibling.nextElementSibling);

        _onColumnOrderChanged();
    }

    // ---- HTML5 drag&drop ----
    var _dragSrc = null;
    function _onDragStart(e) {
        var lbl = e.target.closest('label.col-reorderable');
        if (!lbl) return;
        _dragSrc = lbl;
        lbl.classList.add('dragging');
        try { e.dataTransfer.effectAllowed = 'move'; e.dataTransfer.setData('text/plain', lbl.getAttribute('data-col-sql') || ''); } catch (_) {}
    }
    function _onDragEnd(e) {
        if (_dragSrc) _dragSrc.classList.remove('dragging');
        document.querySelectorAll('#colToggleList .drop-before, #colToggleList .drop-after')
            .forEach(function(el) { el.classList.remove('drop-before', 'drop-after'); });
        _dragSrc = null;
    }
    function _onDragOver(e) {
        if (!_dragSrc) return;
        var lbl = e.target.closest('label.col-reorderable');
        if (!lbl || lbl === _dragSrc) return;
        e.preventDefault();
        try { e.dataTransfer.dropEffect = 'move'; } catch (_) {}
        var rect = lbl.getBoundingClientRect();
        var before = (e.clientY - rect.top) < rect.height / 2;
        document.querySelectorAll('#colToggleList .drop-before, #colToggleList .drop-after')
            .forEach(function(el) { el.classList.remove('drop-before', 'drop-after'); });
        lbl.classList.add(before ? 'drop-before' : 'drop-after');
    }
    function _onDrop(e) {
        if (!_dragSrc) return;
        var lbl = e.target.closest('label.col-reorderable');
        if (!lbl || lbl === _dragSrc) { _onDragEnd(e); return; }
        e.preventDefault();
        var rect = lbl.getBoundingClientRect();
        var before = (e.clientY - rect.top) < rect.height / 2;
        if (before) lbl.parentNode.insertBefore(_dragSrc, lbl);
        else lbl.parentNode.insertBefore(_dragSrc, lbl.nextElementSibling);
        _onDragEnd(e);
        _onColumnOrderChanged();
    }

    function _onColumnOrderChanged() {
        _saveColumnOrder();
        applyColumnOrderToGrid(getColumnOrderFromModal());
    }

    function _initColumnReorder() {
        var list = document.getElementById('colToggleList');
        if (!list) return;
        list.addEventListener('dragstart', _onDragStart);
        list.addEventListener('dragend', _onDragEnd);
        list.addEventListener('dragover', _onDragOver);
        list.addEventListener('drop', _onDrop);
        list.addEventListener('dragleave', function(e) {
            var lbl = e.target.closest && e.target.closest('label.col-reorderable');
            if (lbl) lbl.classList.remove('drop-before', 'drop-after');
        });

        // Apply any previously saved order to BOTH the modal list and the grid.
        var saved = _loadColumnOrder();
        if (saved && saved.length) {
            _applyOrderToModal(saved);
            applyColumnOrderToGrid(saved);
        }
    }

    // Hook Reset to Default: wipe session-scoped order AND the hidden input, so defaults are genuine
    // on the next "Apply & Refresh" (the form post will carry ColumnOrder = empty => Model.ColumnOrder null).
    (function _extendResetDefaults() {
        var orig = window.resetDefaultColumns;
        window.resetDefaultColumns = function() {
            if (typeof orig === 'function') orig();
            try { sessionStorage.removeItem(COL_ORDER_KEY); } catch (_) {}
            var hidden = document.getElementById('columnOrderHidden');
            if (hidden) hidden.value = '';
        };
    })();

    // Also clear column order when the user resets their SAVED layout (server-side). The page
    // reloads immediately after so we don't need to touch the hidden input here.
    (function _extendResetSavedLayout() {
        var orig = window.resetSavedLayout;
        if (typeof orig !== 'function') return;
        window.resetSavedLayout = function() {
            try { sessionStorage.removeItem(COL_ORDER_KEY); } catch (_) {}
            return orig.apply(this, arguments);
        };
    })();
    // ==================== END COLUMN REORDER ====================

    // ==================== Show Profit / Show Stock <-> Display Columns sync ====================
    // Mapping of "quick toggle" -> Display Columns names (server) and col-toggle values (client visibility modal).
    // Display Columns names ("Profit") differ slightly from col-toggle values ("ProfitValue").
    var SYNC_GROUPS = {
        showProfitToggle: { display: ['Profit','Markup','Margin'], colToggle: ['ProfitValue','Markup','Margin'] },
        showStockToggle:  { display: ['TotalStockQty','TotalStockValue'], colToggle: ['TotalStockQty','TotalStockValue'] }
    };

    function _getDisplayColsArr() {
        var hidden = document.getElementById('displayColumnsHidden');
        if (!hidden) return [];
        return (hidden.value || '').split(',').map(function(s){ return s.trim(); }).filter(function(s){ return s.length > 0; });
    }
    function _setDisplayColsArr(cols) {
        var hidden = document.getElementById('displayColumnsHidden');
        if (hidden) hidden.value = cols.join(',');
    }
    function _hasAnyCi(arr, names) {
        var lower = arr.map(function(s){ return s.toLowerCase(); });
        for (var i = 0; i < names.length; i++) {
            if (lower.indexOf(names[i].toLowerCase()) >= 0) return true;
        }
        return false;
    }
    function _addUniqueCi(arr, name) {
        var exists = arr.some(function(s){ return s.toLowerCase() === name.toLowerCase(); });
        if (!exists) arr.push(name);
        return arr;
    }
    function _removeCi(arr, name) {
        return arr.filter(function(s){ return s.toLowerCase() !== name.toLowerCase(); });
    }

    // When Show Profit / Show Stock toggle is changed by the user.
    function onQuickToggleChange(toggleId) {
        var toggle = document.getElementById(toggleId);
        var grp = SYNC_GROUPS[toggleId];
        if (!toggle || !grp) return;
        var checked = toggle.checked;

        // 1) Update server-side DisplayColumns hidden input
        var cols = _getDisplayColsArr();
        if (checked) {
            grp.display.forEach(function(n){ cols = _addUniqueCi(cols, n); });
        } else {
            grp.display.forEach(function(n){ cols = _removeCi(cols, n); });
        }
        _setDisplayColsArr(cols);

        // 2) Sync modal col-toggle checkboxes so the two UIs stay consistent.
        grp.colToggle.forEach(function(v){
            var cb = document.querySelector('.col-toggle[value="' + v + '"]');
            if (cb && cb.checked !== checked) {
                cb.checked = checked;
                if (typeof onColToggleChange === 'function') onColToggleChange(cb);
            }
        });
        if (typeof updateDirtyIndicator === 'function') updateDirtyIndicator();
    }

    // When user toggles a col-toggle checkbox in the visibility modal: refresh quick-toggle states.
    function syncQuickTogglesFromColToggles() {
        Object.keys(SYNC_GROUPS).forEach(function(id) {
            var toggle = document.getElementById(id);
            if (!toggle) return;
            var grp = SYNC_GROUPS[id];
            var anyChecked = grp.colToggle.some(function(v) {
                var cb = document.querySelector('.col-toggle[value="' + v + '"]');
                return cb && cb.checked;
            });
            // Only flip if a corresponding column actually exists in DOM (i.e. server returned it),
            // otherwise rely on DisplayColumns-based init below.
            var anyExists = grp.colToggle.some(function(v) {
                return !!document.querySelector('.col-toggle[value="' + v + '"]');
            });
            if (anyExists) toggle.checked = anyChecked;
        });
    }

    // Initial sync on page load: derive quick-toggle state from current DisplayColumns.
    function initQuickTogglesFromDisplayCols() {
        var cols = _getDisplayColsArr();
        Object.keys(SYNC_GROUPS).forEach(function(id) {
            var toggle = document.getElementById(id);
            if (!toggle) return;
            toggle.checked = _hasAnyCi(cols, SYNC_GROUPS[id].display);
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        updateColVisibleCount();
        _colsInitialSig = currentColsSignature();

        // Column reorder (drag + up/down) — restores saved order from sessionStorage and wires listeners.
        _initColumnReorder();
        _updateNeedsRefreshUi();

        // Wire bidirectional sync between quick-toggles and Display Columns / col-toggle modal
        initQuickTogglesFromDisplayCols();
        ['showProfitToggle','showStockToggle'].forEach(function(id) {
            var t = document.getElementById(id);
            if (t) t.addEventListener('change', function() { onQuickToggleChange(id); });
        });

        var colSearch = document.getElementById('colSearchInput');
        if (colSearch) {
            colSearch.addEventListener('input', filterColumnList);
            colSearch.addEventListener('keyup', filterColumnList);
        }
        // Check AI status
        fetch('/Reports/GetAiStatus')
            .then(r => r.json())
            .then(d => {
                if (!d.configured) {
                    var btn = document.getElementById('btnAnalyze');
                    if (btn) { btn.title = 'AI not configured — set API key in Settings'; btn.classList.add('disabled'); }
                    var sa = document.getElementById('schedIncludeAi');
                    if (sa) { sa.disabled = true; sa.parentElement.title = 'AI not configured'; }
                }
            }).catch(() => {});
    });

    // ==================== AI Analysis ====================

    function saveAiLang(v) { localStorage.setItem('ps_ai_lang', v); }
    function getAiLang() { return localStorage.getItem('ps_ai_lang') || 'el'; }
    (function() { var s = document.getElementById('aiLangSelect'); if (s) s.value = getAiLang(); })();

    var _aiConversation = [];
    var _aiTotalChatTokens = { input: 0, output: 0 };

    function estimateAiCost(inputTok, outputTok) {
        var cost = (inputTok * 2.5 + outputTok * 10) / 1e6;
        return cost < 0.005 ? '< $0.01' : '$' + cost.toFixed(2);
    }

    function analyzeReport() {
        var modalEl = document.getElementById('aiAnalysisModal');
        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        document.getElementById('aiLoading').classList.remove('d-none');
        document.getElementById('aiError').classList.add('d-none');
        document.getElementById('aiResults').classList.add('d-none');
        document.getElementById('aiPromptEditor').classList.add('d-none');
        document.getElementById('btnReanalyze').style.display = 'none';
        modal.show();

        var fd = new FormData();
        var p = collectCatalogueParams();
        Object.keys(p).forEach(function(k) { fd.append(k, p[k]); });
        fd.append('locale', getAiLang());
        var tplId = document.getElementById('aiPromptTemplateSelect').value;
        if (tplId && tplId !== '0') fd.append('promptTemplateId', tplId);

        fetch('/Reports/AnalyzeCatalogueReport', { method: 'POST', body: fd })
            .then(r => r.json())
            .then(data => {
                document.getElementById('aiLoading').classList.add('d-none');
                if (!data.success) {
                    document.getElementById('aiError').classList.remove('d-none');
                    document.getElementById('aiErrorMsg').textContent = data.message;
                    document.getElementById('btnReanalyze').style.display = 'inline-block';
                    return;
                }
                var a = data.analysis;
                renderAiAnalysis(a);
                initAiConversation(a, data.csvPreview);
                document.getElementById('aiResults').classList.remove('d-none');
                document.getElementById('btnReanalyze').style.display = 'inline-block';
            })
            .catch(err => {
                document.getElementById('aiLoading').classList.add('d-none');
                document.getElementById('aiError').classList.remove('d-none');
                document.getElementById('aiErrorMsg').textContent = 'Network error: ' + err.message;
                document.getElementById('btnReanalyze').style.display = 'inline-block';
            });
    }

    function renderAiAnalysis(a) {
        var score = parseInt(a.healthScore) || 0;
        var scoreColor = score >= 80 ? '#16a34a' : score >= 60 ? '#ca8a04' : score >= 40 ? '#ea580c' : '#dc2626';
        var badge = document.getElementById('aiHealthBadge');
        badge.style.background = scoreColor; badge.style.color = 'white'; badge.textContent = score;
        document.getElementById('aiHealthLabel').textContent = a.healthLabel || '';
        document.getElementById('aiTrendDesc').textContent = a.trendDescription || '';
        var trendBadge = document.getElementById('aiTrendBadge');
        var dir = (a.trendDirection || 'stable').toLowerCase();
        var trendIcon = dir === 'up' ? 'bi-arrow-up-right' : dir === 'down' ? 'bi-arrow-down-right' : dir === 'mixed' ? 'bi-arrow-left-right' : 'bi-dash';
        trendBadge.className = 'badge fs-6 px-3 py-2 ' + (dir === 'up' ? 'bg-success' : dir === 'down' ? 'bg-danger' : 'bg-secondary');
        trendBadge.innerHTML = '<i class="bi ' + trendIcon + ' me-1"></i>' + dir.charAt(0).toUpperCase() + dir.slice(1);
        document.getElementById('aiExecSummary').innerHTML = '<i class="bi bi-stars me-2 text-primary"></i>' + (a.executiveSummary || a.summary || '');
        var kpisHtml = '';
        (a.kpis || []).forEach(function(k) {
            var ti = k.trend === 'up' ? '<i class="bi bi-caret-up-fill text-success"></i>' : k.trend === 'down' ? '<i class="bi bi-caret-down-fill text-danger"></i>' : '<i class="bi bi-dash text-muted"></i>';
            kpisHtml += '<div class="col-6 col-md-3 col-lg-2"><div class="border rounded p-2 text-center h-100" style="background:#f8fafc;"><div class="text-muted small text-truncate">' + k.label + '</div><div class="fw-bold" style="font-size:1rem;">' + k.value + '</div><div>' + ti + '</div></div></div>';
        });
        document.getElementById('aiKpis').innerHTML = kpisHtml;
        function renderFindings(items, cId, numbered) {
            var html = '';
            (items || []).forEach(function(f, i) {
                var txt = typeof f === 'string' ? f : f.text;
                var sev = typeof f === 'string' ? 'info' : (f.severity || 'info');
                if (numbered) {
                    html += '<div class="d-flex align-items-start gap-2 mb-2"><span class="badge bg-success rounded-circle" style="width:20px;height:20px;font-size:0.65rem;padding:3px;">' + (i+1) + '</span><span class="small">' + txt + '</span></div>';
                } else {
                    var sc = sev === 'high' ? 'border-danger' : sev === 'medium' ? 'border-warning' : 'border-info';
                    var sd = sev === 'high' ? 'text-danger' : sev === 'medium' ? 'text-warning' : 'text-info';
                    html += '<div class="d-flex align-items-start gap-2 mb-2 border-start border-3 ps-2 ' + sc + '"><i class="bi bi-circle-fill ' + sd + '" style="font-size:0.4rem;margin-top:7px;"></i><span class="small">' + txt + '</span></div>';
                }
            });
            document.getElementById(cId).innerHTML = html || '<span class="text-muted small">—</span>';
        }
        renderFindings(a.keyFindings, 'aiKeyFindings', false);
        renderFindings(a.recommendations, 'aiRecs', true);
        function renderPerf(list, cId, secId) {
            var html = '';
            (list || []).forEach(function(p) {
                html += '<div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom"><div><div class="fw-semibold small">' + p.name + '</div><div class="text-muted" style="font-size:0.75rem;">' + (p.detail || '') + '</div></div><div class="fw-bold small text-nowrap ms-2">' + (p.value || '') + '</div></div>';
            });
            document.getElementById(cId).innerHTML = html || '<span class="text-muted small">—</span>';
            document.getElementById(secId).style.display = (list && list.length > 0) ? '' : 'none';
        }
        renderPerf(a.topPerformers, 'aiTopPerformers', 'aiTopSection');
        renderPerf(a.bottomPerformers, 'aiBottomPerformers', 'aiBottomSection');
        var alertsHtml = '';
        (a.alerts || []).forEach(function(al) {
            var txt = typeof al === 'string' ? al : al.text;
            var sev = typeof al === 'string' ? 'warning' : (al.severity || 'warning');
            var cls = sev === 'critical' ? 'alert-danger' : sev === 'warning' ? 'alert-warning' : 'alert-info';
            var ic = sev === 'critical' ? 'bi-exclamation-octagon-fill' : sev === 'warning' ? 'bi-exclamation-triangle-fill' : 'bi-info-circle-fill';
            alertsHtml += '<div class="alert ' + cls + ' py-2 mb-2 small"><i class="bi ' + ic + ' me-2"></i>' + txt + '</div>';
        });
        document.getElementById('aiAlertsSection').innerHTML = alertsHtml;
        document.getElementById('aiModel').textContent = a.modelUsed || '';
        document.getElementById('aiTokens').textContent = estimateAiCost(a.inputTokens || 0, a.outputTokens || 0);
        document.getElementById('aiTime').textContent = ((a.durationMs || 0) / 1000).toFixed(1) + 's';
        document.getElementById('aiChatMessages').innerHTML = '';
        document.getElementById('aiChatInput').value = '';
        document.getElementById('aiChatTokenInfo').style.display = 'none';
        _aiTotalChatTokens = { input: 0, output: 0 };
    }

    function initAiConversation(analysisJson, csvData) {
        _aiConversation = [
            { role: 'system', content: 'You are a senior financial data analyst. The user has already received an AI analysis of their catalogue / sales report. The raw CSV data is included below so you can reference specific numbers when answering follow-up questions. Be concise, specific, and cite actual values from the data. Respond in the same language as the analysis.' }
        ];
        if (csvData) _aiConversation.push({ role: 'user', content: 'Here is the raw report data for reference:\n' + csvData });
        _aiConversation.push({ role: 'assistant', content: JSON.stringify(analysisJson) });
    }

    function sendAiChat() {
        var input = document.getElementById('aiChatInput');
        var msg = input.value.trim();
        if (!msg) return;
        input.value = '';
        appendChatBubble('user', msg);

        var btn = document.getElementById('btnSendChat');
        btn.disabled = true; input.disabled = true;
        var tId = 'thinking_' + Date.now();
        appendChatBubble('thinking', 'Thinking...', tId);

        fetch('/Reports/AiChatFollowup', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ history: _aiConversation, message: msg })
        })
        .then(r => r.json())
        .then(data => {
            removeChatBubble(tId);
            btn.disabled = false; input.disabled = false; input.focus();
            if (!data.success) { appendChatBubble('error', data.message || 'Failed to get response.'); return; }
            _aiConversation.push({ role: 'user', content: msg });
            _aiConversation.push({ role: 'assistant', content: data.content });
            appendChatBubble('assistant', data.content);
            _aiTotalChatTokens.input += (data.inputTokens || 0);
            _aiTotalChatTokens.output += (data.outputTokens || 0);
            var info = document.getElementById('aiChatTokenInfo');
            info.style.display = '';
            info.innerHTML = '<i class="bi bi-currency-dollar me-1"></i>Chat: ' + estimateAiCost(_aiTotalChatTokens.input, _aiTotalChatTokens.output) +
                ' | <i class="bi bi-clock me-1"></i>' + ((data.durationMs || 0) / 1000).toFixed(1) + 's';
        })
        .catch(err => {
            removeChatBubble(tId);
            btn.disabled = false; input.disabled = false;
            appendChatBubble('error', 'Network error: ' + err.message);
        });
    }

    function appendChatBubble(role, text, id) {
        var c = document.getElementById('aiChatMessages');
        var div = document.createElement('div');
        if (id) div.id = id;
        div.className = 'mb-2 d-flex ' + (role === 'user' ? 'justify-content-end' : 'justify-content-start');
        var b = document.createElement('div');
        b.className = 'px-3 py-2 rounded-3 small';
        b.style.maxWidth = '85%'; b.style.whiteSpace = 'pre-wrap'; b.style.wordBreak = 'break-word';
        if (role === 'user') { b.style.background = '#6366f1'; b.style.color = 'white'; b.textContent = text; }
        else if (role === 'thinking') { b.style.background = '#f1f5f9'; b.style.color = '#94a3b8'; b.innerHTML = '<i class="bi bi-three-dots me-1"></i>' + text; }
        else if (role === 'error') { b.style.background = '#fee2e2'; b.style.color = '#dc2626'; b.textContent = text; }
        else { b.style.background = '#f1f5f9'; b.style.color = '#1e293b'; b.textContent = text; }
        div.appendChild(b); c.appendChild(div); c.scrollTop = c.scrollHeight;
    }

    function removeChatBubble(id) {
        var el = document.getElementById(id); if (el) el.remove();
    }

    // ==================== AI Prompt Templates ====================

    var _editingPromptId = 0;
    var _currentReportType = 'Catalogue';

    function togglePromptEditor() {
        var el = document.getElementById('aiPromptEditor');
        if (el.classList.contains('d-none')) {
            el.classList.remove('d-none');
            loadAiPromptTemplates();
            var sid = parseInt(document.getElementById('aiPromptTemplateSelect').value);
            if (sid > 0) editAiPromptTemplate(sid); else clearPromptEditor();
        } else {
            el.classList.add('d-none');
        }
    }

    function loadAiPromptTemplates() {
        fetch('/Reports/GetAiPromptTemplates?reportType=' + encodeURIComponent(_currentReportType))
            .then(r => r.json())
            .then(function(data) {
                var sel = document.getElementById('aiPromptTemplateSelect');
                var userPicked = sel.getAttribute('data-user-picked') === '1';
                var savedVal = userPicked ? sel.value : null;
                sel.innerHTML = '<option value="0" style="color:#333;">Default Prompt</option>';
                var listHtml = '';
                var defId = null;
                (data || []).forEach(function(t) {
                    sel.innerHTML += '<option value="' + t.templateId + '" style="color:#333;">' + escapeHtml(t.templateName) + (t.isDefault ? ' ★' : '') + '</option>';
                    var match = t.isDefault && (!t.reportType || t.reportType === '' || t.reportType === _currentReportType);
                    if (match) defId = t.templateId;
                    listHtml += '<div class="d-flex justify-content-between align-items-center border-bottom py-2">' +
                        '<div><strong>' + escapeHtml(t.templateName) + '</strong>' +
                        (t.isDefault ? ' <span class="badge bg-primary">Default</span>' : '') +
                        (t.reportType ? ' <span class="badge bg-secondary">' + t.reportType + '</span>' : ' <span class="badge bg-light text-dark">All</span>') +
                        '</div><div>' +
                        '<button class="btn btn-sm btn-outline-primary me-1" onclick="editAiPromptTemplate(' + t.templateId + ')"><i class="bi bi-pencil"></i></button>' +
                        '<button class="btn btn-sm btn-outline-danger" onclick="deleteAiPromptTemplate(' + t.templateId + ')"><i class="bi bi-trash"></i></button>' +
                        '</div></div>';
                });
                document.getElementById('aiPromptTemplatesList').innerHTML = listHtml || '<em>No custom templates yet.</em>';
                if (userPicked && savedVal) sel.value = savedVal;
                else if (defId) sel.value = defId;
            })
            .catch(function() {
                document.getElementById('aiPromptTemplatesList').innerHTML = '<em>Could not load templates.</em>';
            });
    }

    function saveAiPromptTemplate() {
        var name = document.getElementById('aiPromptName').value.trim();
        var prompt = document.getElementById('aiPromptText').value.trim();
        var a = document.getElementById('aiPromptAlert');
        if (!name || !prompt) { a.innerHTML = '<span class="text-danger">Name and prompt are required.</span>'; return; }
        fetch('/Reports/SaveAiPromptTemplate', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                templateId: _editingPromptId, templateName: name,
                reportType: document.getElementById('aiPromptReportType').value || null,
                systemPrompt: prompt,
                isDefault: document.getElementById('aiPromptIsDefault').checked
            })
        })
        .then(r => r.json())
        .then(d => {
            if (d.success) {
                a.innerHTML = '<span class="text-success"><i class="bi bi-check-circle me-1"></i>' + d.message + '</span>';
                clearPromptEditor(); loadAiPromptTemplates();
            } else {
                a.innerHTML = '<span class="text-danger">' + d.message + '</span>';
            }
        })
        .catch(() => { a.innerHTML = '<span class="text-danger">Network error.</span>'; });
    }

    function editAiPromptTemplate(id) {
        fetch('/Reports/GetAiPromptTemplates?reportType=' + encodeURIComponent(_currentReportType))
            .then(r => r.json())
            .then(function(data) {
                var t = (data || []).find(function(x) { return x.templateId === id; });
                if (!t) return;
                _editingPromptId = t.templateId;
                document.getElementById('aiPromptName').value = t.templateName;
                document.getElementById('aiPromptReportType').value = t.reportType || '';
                document.getElementById('aiPromptText').value = t.systemPrompt;
                document.getElementById('aiPromptIsDefault').checked = t.isDefault;
                document.getElementById('aiPromptAlert').innerHTML = '<span class="text-info">Editing: ' + escapeHtml(t.templateName) + '</span>';
            });
    }

    function deleteAiPromptTemplate(id) {
        if (!confirm('Delete this template?')) return;
        fetch('/Reports/DeleteAiPromptTemplate', {
            method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'templateId=' + id
        }).then(r => r.json()).then(() => loadAiPromptTemplates());
    }

    function clearPromptEditor() {
        _editingPromptId = 0;
        document.getElementById('aiPromptName').value = '';
        document.getElementById('aiPromptText').value = '';
        document.getElementById('aiPromptReportType').value = 'Catalogue';
        document.getElementById('aiPromptIsDefault').checked = false;
        document.getElementById('aiPromptAlert').innerHTML = '';
    }

    function escapeHtml(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

    // Load prompt templates when AI modal opens
    (function() {
        var m = document.getElementById('aiAnalysisModal');
        if (m) m.addEventListener('show.bs.modal', function() { loadAiPromptTemplates(); });
    })();

    // ==================== Preview (document-style print view) ====================
    var previewOpen = false;
    function togglePreview() {
        var panel = document.getElementById('previewPanel');
        var grid = document.getElementById('results');
        var btn = document.getElementById('previewToggleBtn');
        if (!panel || !grid || !btn) return;
        previewOpen = !previewOpen;
        if (previewOpen) {
            grid.style.display = 'none';
            panel.style.display = 'block';
            btn.innerHTML = '<i class="bi bi-table me-1"></i>Grid';
            btn.classList.remove('btn-outline-primary');
            btn.classList.add('btn-outline-warning');
            var f = document.getElementById('previewFrame');
            if (!f.src || f.src === 'about:blank' || f.src.endsWith('about:blank')) {
                var p = collectCatalogueParams();
                var qs = '@Url.Action("PrintCataloguePreview")' + '?' +
                    Object.keys(p).map(function(k) { return encodeURIComponent(k) + '=' + encodeURIComponent(p[k]); }).join('&');
                f.src = qs;
            }
            f.onload = function () {
                try { f.style.height = Math.max(f.contentDocument.documentElement.scrollHeight + 40, 600) + 'px'; } catch (e) {}
            };
        } else {
            grid.style.display = 'block';
            panel.style.display = 'none';
            btn.innerHTML = '<i class="bi bi-eye me-1"></i>Preview';
            btn.classList.remove('btn-outline-warning');
            btn.classList.add('btn-outline-primary');
        }
    }

    // Close preview when iframe (Esc inside) requests it.
    window.addEventListener('message', function (ev) {
        if (ev && ev.data && ev.data.type === 'cataloguePreviewClose' && previewOpen) {
            togglePreview();
        }
    });

    // ==================== Item Detail Modal (Transaction History + Stock Position) ====================
    // Mirrors original Powersoft365 "Item Transactions History" dialog with toggle to "Item Stock Position".
    // Source: restricted/StockControl/ItemStockPosition.aspx (original VB.NET).

    var _itemModalCurrentCode = null;
    var _itemModalCurrentName = '';
    var _itemModalCurrentView = 'trans'; // 'trans' or 'stock'

    function fmt2(n) { return (n || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
    function fmtQ(n) { return (n || 0).toLocaleString(undefined, { maximumFractionDigits: 2 }); }

    // Event delegation for item links (handles any re-rendered rows)
    document.addEventListener('click', function (e) {
        var link = e.target.closest('a.dd-link-item');
        if (!link) return;
        e.preventDefault();
        var code = link.getAttribute('data-item-code') || '';
        var name = link.getAttribute('data-item-name') || '';
        if (code) openItemModal(code, name);
    });

    // Event delegation for entity (customer/supplier) links
    document.addEventListener('click', function (e) {
        var link = e.target.closest('a.dd-link-entity');
        if (!link) return;
        e.preventDefault();
        var code = link.getAttribute('data-entity-code') || '';
        var etype = link.getAttribute('data-entity-type') || 'customer';
        if (code) openEntityModal(code, etype);
    });

    function openEntityModal(entityCode, entityType) {
        if (!entityCode) return;
        var loading = document.getElementById('entityModalLoading');
        var content = document.getElementById('entityModalContent');
        var error = document.getElementById('entityModalError');
        var typeLabel = document.getElementById('entityModalType');
        typeLabel.textContent = entityType === 'supplier' ? 'Supplier' : 'Customer';
        loading.classList.remove('d-none');
        content.classList.add('d-none');
        error.classList.add('d-none');

        var modal = new bootstrap.Modal(document.getElementById('entityDetailModal'));
        modal.show();

        fetch('/Reports/GetEntityDetail?code=' + encodeURIComponent(entityCode) + '&type=' + encodeURIComponent(entityType))
            .then(function (r) { return r.json(); })
            .then(function (data) {
                loading.classList.add('d-none');
                if (!data.success) {
                    error.textContent = data.message || 'Entity not found';
                    error.classList.remove('d-none');
                    return;
                }
                var d = data.data;
                var left = document.getElementById('entityModalInfoLeft');
                var right = document.getElementById('entityModalInfoRight');
                var row = function (lbl, val) { return '<tr><td class="text-muted small fw-semibold" style="width:120px">' + lbl + '</td><td>' + (val || '-') + '</td></tr>'; };
                left.innerHTML = row('Code', d.Code) + row('Full Name', d.FullName) + row('Short Name', d.ShortName)
                    + row('Entity ID', d.EntityId) + row('VAT No', d.VatNo) + row('Status', d.Status);
                right.innerHTML = row('Address', d.Address1) + row('', d.Address2) + row('Town', d.Town)
                    + row('Post Code', d.PostalCode) + row('Phone', d.Phone) + row('Mobile', d.Mobile) + row('Email', d.Email);
                content.classList.remove('d-none');
            })
            .catch(function () {
                loading.classList.add('d-none');
                error.textContent = 'Failed to load entity details';
                error.classList.remove('d-none');
            });
    }

    function openItemModal(itemCode, itemName) {
        if (!itemCode) return;
        _itemModalCurrentCode = itemCode;
        _itemModalCurrentName = itemName || '';
        _itemModalCurrentView = 'trans';

        document.getElementById('itemModalCode').textContent = itemCode;
        document.getElementById('itemModalName').textContent = itemName || '';
        setItemModalView('trans');

        var modal = new bootstrap.Modal(document.getElementById('itemDetailModal'));
        modal.show();
        loadItemTransactions(itemCode);
    }

    function setItemModalView(view) {
        _itemModalCurrentView = view;
        var btnTrans = document.getElementById('itemModalBtnTrans');
        var btnStock = document.getElementById('itemModalBtnStock');
        var viewTrans = document.getElementById('itemModalViewTrans');
        var viewStock = document.getElementById('itemModalViewStock');
        var title = document.getElementById('itemModalViewTitle');
        if (view === 'trans') {
            btnTrans.classList.add('active', 'btn-primary');
            btnTrans.classList.remove('btn-outline-primary');
            btnStock.classList.remove('active', 'btn-primary');
            btnStock.classList.add('btn-outline-primary');
            viewTrans.classList.remove('d-none');
            viewStock.classList.add('d-none');
            if (title) title.textContent = 'Item Transactions History';
        } else {
            btnStock.classList.add('active', 'btn-primary');
            btnStock.classList.remove('btn-outline-primary');
            btnTrans.classList.remove('active', 'btn-primary');
            btnTrans.classList.add('btn-outline-primary');
            viewStock.classList.remove('d-none');
            viewTrans.classList.add('d-none');
            if (title) title.textContent = 'Item Stock Position';
        }
    }

    function toggleItemModalView() {
        if (!_itemModalCurrentCode) return;
        if (_itemModalCurrentView === 'trans') {
            setItemModalView('stock');
            if (!document.getElementById('itemStockLoaded')) loadItemStockPosition(_itemModalCurrentCode);
        } else {
            setItemModalView('trans');
        }
    }

    function loadItemTransactions(itemCode) {
        var tbody = document.getElementById('itemTransTbody');
        var summary = document.getElementById('itemTransSummary');
        var err = document.getElementById('itemTransError');
        tbody.innerHTML = '<tr><td colspan="11" class="text-center py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading transactions...</td></tr>';
        summary.textContent = '';
        err.classList.add('d-none');

        var storeCodes = '';
        if (typeof getItemsSelectionStoreCodes === 'function') storeCodes = getItemsSelectionStoreCodes();

        var url = '/Reports/GetTransactionDetails?itemCode=' + encodeURIComponent(itemCode)
            + '&type=all'
            + '&dateFrom=@Model.DateFrom.ToString("yyyy-MM-dd")'
            + '&dateTo=@Model.DateTo.ToString("yyyy-MM-dd")'
            + '&storeCodes=' + encodeURIComponent(storeCodes);

        fetch(url)
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (!data.success) {
                    tbody.innerHTML = '';
                    err.textContent = data.message || 'Error loading transactions';
                    err.classList.remove('d-none');
                    return;
                }
                if (data.count === 0) {
                    tbody.innerHTML = '<tr><td colspan="11" class="text-center text-muted py-3">No transactions found for this item in the selected period.</td></tr>';
                    summary.textContent = '';
                    return;
                }
                // Kind colour map: P=Purchase, E=PurchReturn, I=Sale, C=Credit
                var kindColors = { 'P': 'bg-info', 'E': 'bg-warning', 'I': 'bg-success', 'C': 'bg-danger' };
                tbody.innerHTML = data.rows.map(function (r) {
                    var bc = kindColors[r.kind] || 'bg-secondary';
                    var docCell = '';
                    if (r.doc && r.kind && 'PEIC'.indexOf(r.kind) >= 0) {
                        var safeDoc = String(r.doc).replace(/'/g, "\\'");
                        docCell = '<a href="#" class="text-primary text-decoration-underline fw-semibold" '
                            + 'onclick="openDocument(\'' + r.kind + '\', \'' + safeDoc + '\'); return false;" '
                            + 'title="View document details">' + r.doc + '</a>';
                    } else {
                        docCell = '<span class="fw-semibold">' + (r.doc || '') + '</span>';
                    }
                    return '<tr class="small">'
                        + '<td class="text-nowrap">' + r.date + '</td>'
                        + '<td><span class="badge ' + bc + '">' + (r.kindDescription || r.kind) + '</span></td>'
                        + '<td>' + docCell + '</td>'
                        + '<td>' + (r.entityCode ? r.entityCode + ' — ' : '') + (r.entityName || '') + '</td>'
                        + '<td>' + (r.store || '') + '</td>'
                        + '<td class="text-end">' + fmtQ(r.qty) + '</td>'
                        + '<td class="text-end">' + fmt2(r.price) + '</td>'
                        + '<td class="text-end">' + fmt2(r.discount) + '</td>'
                        + '<td class="text-end">' + fmt2(r.net) + '</td>'
                        + '<td class="text-end">' + fmt2(r.vat) + '</td>'
                        + '<td class="text-end">' + fmt2(r.gross) + '</td>'
                        + '</tr>';
                }).join('');
                summary.textContent = data.count + ' transactions · Qty: ' + fmtQ(data.totalQty)
                    + ' · Net: ' + fmt2(data.totalNet) + ' · Gross: ' + fmt2(data.totalGross);
            })
            .catch(function (ex) {
                tbody.innerHTML = '';
                err.textContent = 'Network error: ' + ex.message;
                err.classList.remove('d-none');
            });
    }

    function loadItemStockPosition(itemCode) {
        var tbody = document.getElementById('itemStockTbody');
        var tfoot = document.getElementById('itemStockTfoot');
        var summary = document.getElementById('itemStockSummary');
        var err = document.getElementById('itemStockError');
        tbody.innerHTML = '<tr><td colspan="8" class="text-center py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading stock position...</td></tr>';
        tfoot.innerHTML = '';
        summary.textContent = '';
        err.classList.add('d-none');

        fetch('/Reports/GetItemStockPosition?itemCode=' + encodeURIComponent(itemCode))
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (!data.success) {
                    tbody.innerHTML = '';
                    err.textContent = data.message || 'Error loading stock position';
                    err.classList.remove('d-none');
                    return;
                }
                if (!data.rows || data.rows.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-3">No stores found.</td></tr>';
                    return;
                }
                tbody.innerHTML = data.rows.map(function (r) {
                    var negClass = (r.onStock < 0) ? 'text-danger fw-semibold' : '';
                    return '<tr class="small">'
                        + '<td class="fw-semibold">' + (r.storeCode || '') + '</td>'
                        + '<td>' + (r.storeName || '') + '</td>'
                        + '<td class="text-end ' + negClass + '">' + fmtQ(r.onStock) + '</td>'
                        + '<td class="text-end">' + fmtQ(r.onTransfer) + '</td>'
                        + '<td class="text-end">' + fmtQ(r.reserved) + '</td>'
                        + '<td class="text-end">' + fmtQ(r.ordered) + '</td>'
                        + '<td class="text-end fw-semibold">' + fmtQ(r.available) + '</td>'
                        + '<td>' + (r.shelf || '') + '</td>'
                        + '</tr>';
                }).join('');
                tfoot.innerHTML = '<tr class="table-light fw-bold small">'
                    + '<td colspan="2" class="text-end">Totals:</td>'
                    + '<td class="text-end">' + fmtQ(data.totalOnStock) + '</td>'
                    + '<td class="text-end">' + fmtQ(data.totalOnTransfer) + '</td>'
                    + '<td class="text-end">' + fmtQ(data.totalReserved) + '</td>'
                    + '<td class="text-end">' + fmtQ(data.totalOrdered) + '</td>'
                    + '<td class="text-end">' + fmtQ(data.totalAvailable) + '</td>'
                    + '<td></td>'
                    + '</tr>';
                summary.textContent = data.count + ' store(s) · Total On Stock: ' + fmtQ(data.totalOnStock)
                    + ' · Total Available: ' + fmtQ(data.totalAvailable);
                // Mark as loaded so subsequent toggles don't re-fetch
                var marker = document.getElementById('itemStockLoaded');
                if (!marker) {
                    var m = document.createElement('span');
                    m.id = 'itemStockLoaded';
                    m.style.display = 'none';
                    document.body.appendChild(m);
                }
            })
            .catch(function (ex) {
                tbody.innerHTML = '';
                err.textContent = 'Network error: ' + ex.message;
                err.classList.remove('d-none');
            });
    }

    // Reset stock-loaded marker when modal closes so next open re-fetches fresh data
    document.addEventListener('DOMContentLoaded', function () {
        var m = document.getElementById('itemDetailModal');
        if (m) m.addEventListener('hidden.bs.modal', function () {
            var marker = document.getElementById('itemStockLoaded');
            if (marker) marker.remove();
            _itemModalCurrentCode = null;
        });
    });

    // ==================== Document Detail Modal (pattern reused from PurchasesSales.cshtml) ====================
    // Uses /Reports/GetDocumentDetail endpoint (docType: P/E/I/C).
    var _currentDocData = null;
    var _currentDocType = '', _currentDocNumber = '';
    var _docViewMode = 'compact';

    function buildFullViewHtml(d) {
