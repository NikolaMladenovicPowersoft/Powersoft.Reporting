                        <div class="col-md-6"><strong>Entity:</strong> <span id="docEntity"></span></div>
                    </div>
                    <table class="table table-sm table-bordered table-hover mb-3">
                        <thead class="table-light">
                            <tr class="small">
                                <th>Item Code</th><th>Item Name</th>
                                <th class="text-end">Qty</th><th class="text-end">Unit Price</th>
                                <th class="text-end">Discount</th><th class="text-end">Net</th>
                                <th class="text-end">VAT</th><th class="text-end">Gross</th>
                            </tr>
                        </thead>
                        <tbody id="docDetailLines" class="small"></tbody>
                        <tfoot>
                            <tr class="fw-bold small table-light">
                                <td colspan="5" class="text-end">Totals:</td>
                                <td class="text-end" id="docTotalNet"></td>
                                <td class="text-end" id="docTotalVat"></td>
                                <td class="text-end" id="docTotalGross"></td>
                            </tr>
                        </tfoot>
                    </table>
                    <div class="text-muted small" id="docLineCount"></div>
                </div>
                @* Full (print-ready) view *@
                <div id="docFullView" class="d-none"></div>
            </div>
            <div class="modal-footer" id="docModalFooter">
                <button type="button" class="btn btn-outline-primary btn-sm" id="btnDocToggleView" onclick="toggleDocView()" title="Toggle document preview">
                    <i class="bi bi-eye me-1"></i>Preview
                </button>
                <button type="button" class="btn btn-outline-success btn-sm" onclick="printDocFromModal()">
                    <i class="bi bi-printer me-1"></i>Print
                </button>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Send to Email Modal (shared partial) -->
@await Html.PartialAsync("_SendEmail", new Powersoft.Reporting.Web.ViewModels.SendEmailPartialModel {
    SendAction = "SendCatalogueEmail",
    ReportType = "Catalogue",
    SubjectDefault = "Power Reports Catalogue"
})

@await Html.PartialAsync("_SaveLayout", new Powersoft.Reporting.Web.ViewModels.SaveLayoutPartialModel
{
    ReportType     = Powersoft.Reporting.Core.Constants.ReportTypeConstants.Catalogue,
    HasSavedLayout = Model.HasSavedLayout,
    ReportViewUrl  = Url.Action("Catalogue", "Reports", new { layoutReset = true }) ?? ""
})

@section Scripts {
<script>
    var _viewCost     = @(ViewBag.ViewCost     != null ? (ViewBag.ViewCost     ? "true" : "false") : "true");
    var _viewSupplier = @(ViewBag.ViewSupplier != null ? (ViewBag.ViewSupplier ? "true" : "false") : "true");

    // Permission enforcement in the UI (server-side is authoritative in BuildCatalogueFilterFromParams):
    // no-cost users can only Report On Sale; no-supplier users cannot group by Supplier.
    document.addEventListener('DOMContentLoaded', function () {
        if (!_viewCost) {
            var ro = document.querySelector('[name="ReportOn"]');
            if (ro) {
                Array.prototype.slice.call(ro.options).forEach(function (o) {
                    // CatalogueReportOn: Sale=0, Purchase=1, Both=2
                    if (o.value === '1' || o.value === '2') o.remove();
                });
                ro.value = '0';
            }
        }
        if (!_viewSupplier) {
            // Remove the Supplier grouping option (CatalogueGroupBy.Supplier = 4) from all group selects
            ['PrimaryGroup', 'SecondaryGroup', 'ThirdGroup'].forEach(function (n) {
                var sel = document.querySelector('[name="' + n + '"]');
                if (!sel) return;
                Array.prototype.slice.call(sel.options).forEach(function (o) {
                    if (o.value === '4') {
                        if (o.selected) sel.value = '0';
                        o.remove();
                    }
                });
            });
        }
    });

    function getSelectedDisplayCols() {
        return document.getElementById('displayColumnsHidden').value
            .split(',').filter(c => c.length > 0);
    }

    function setSelectedDisplayCols(cols) {
        document.getElementById('displayColumnsHidden').value = cols.join(',');
    }

    function clearPreset() {
        document.querySelectorAll('input[name="DatePreset"]').forEach(r => r.checked = false);
    }

    // Toggle between date-only and datetime-local inputs preserving the current value.
    // Browsers accept value in ISO (yyyy-MM-dd or yyyy-MM-ddTHH:mm) for those input types.
    function onUseDateTimeToggle(useTime) {
        var from = document.getElementById('DateFrom');
        var to = document.getElementById('DateTo');
        if (!from || !to) return;
        if (useTime) {
            var fv = (from.value || '').length >= 10 ? from.value.substring(0, 10) + 'T00:00' : from.value;
            var tv = (to.value || '').length >= 10 ? to.value.substring(0, 10) + 'T23:59' : to.value;
            from.type = 'datetime-local'; from.value = fv;
            to.type = 'datetime-local'; to.value = tv;
        } else {
            var fv2 = (from.value || '').substring(0, 10);
            var tv2 = (to.value || '').substring(0, 10);
            from.type = 'date'; from.value = fv2;
            to.type = 'date'; to.value = tv2;
        }
    }

    document.querySelectorAll('.date-presets input[type="radio"]').forEach(radio => {
        radio.addEventListener('change', function () {
            const today = new Date();
            let from, to;
            switch (this.value) {
                case 'today': from = to = today; break;
                case 'yesterday': from = to = new Date(today.getFullYear(), today.getMonth(), today.getDate() - 1); break;
                case 'last7': from = new Date(today.getFullYear(), today.getMonth(), today.getDate() - 6); to = today; break;
                case 'last30': from = new Date(today.getFullYear(), today.getMonth(), today.getDate() - 29); to = today; break;
                case 'thisMonth': from = new Date(today.getFullYear(), today.getMonth(), 1); to = today; break;
                case 'lastMonth': from = new Date(today.getFullYear(), today.getMonth() - 1, 1); to = new Date(today.getFullYear(), today.getMonth(), 0); break;
                case 'ytd': from = new Date(today.getFullYear(), 0, 1); to = today; break;
                case 'lastYear': from = new Date(today.getFullYear() - 1, 0, 1); to = new Date(today.getFullYear() - 1, 11, 31); break;
            }
            if (from && to) {
                // Local yyyy-MM-dd (avoid UTC shift from toISOString()).
                function pad(n){return n<10?'0'+n:''+n;}
                function localDate(d){return d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate());}
                var fInp = document.getElementById('DateFrom');
                var tInp = document.getElementById('DateTo');
                var useTime = fInp && fInp.type === 'datetime-local';
                if (useTime) {
                    fInp.value = localDate(from) + 'T00:00';
                    tInp.value = localDate(to)   + 'T23:59';
                } else {
                    fInp.value = localDate(from);
                    tInp.value = localDate(to);
                }
            }
        });
    });

    // A6 (2026-04-17, George feedback): group selects are independent.
    // User may leave any level as "None"; on submit we shift non-None values up so
    // the backend always gets a compact hierarchy (no gaps, no "None → Category → None").
    // The dropdowns stay enabled; only warn if all three are None and user hits Generate.
    const pg = document.getElementById('PrimaryGroup');
    const sg = document.getElementById('SecondaryGroup');
    const tg = document.getElementById('ThirdGroup');

    function normalizeGroupsBeforeSubmit() {
        var vals = [pg.value, sg.value, tg.value].filter(function(v) { return v && v !== '0'; });
        while (vals.length < 3) vals.push('0');
        pg.value = vals[0];
        sg.value = vals[1];
        tg.value = vals[2];
    }

    var _catalogueReportForm = document.getElementById('reportForm');
    if (_catalogueReportForm) {
        _catalogueReportForm.addEventListener('submit', normalizeGroupsBeforeSubmit, { capture: true });
    }

    function goToPage(p) {
        document.getElementById('pageNumberHidden').value = p;
        try { sessionStorage.setItem('catalogue_scroll_to_results', '1'); } catch (e) {}
        document.getElementById('reportForm').submit();
    }

    // Sticky-sort: mark that a sort click happened so we can anchor the
    // results table at the top of the viewport after the page reloads.
    document.querySelectorAll('th.sortable').forEach(th => {
        th.addEventListener('click', function () {
            const col = this.dataset.col;
            const curCol = document.getElementById('sortColumnHidden').value;
            const curDir = document.getElementById('sortDirectionHidden').value;
            document.getElementById('sortColumnHidden').value = col;
            document.getElementById('sortDirectionHidden').value = (col === curCol && curDir === 'ASC') ? 'DESC' : 'ASC';
            document.getElementById('pageNumberHidden').value = '1';
            try { sessionStorage.setItem('catalogue_scroll_to_results', '1'); } catch (e) {}
            document.getElementById('reportForm').submit();
        });
    });

    document.getElementById('reportForm').addEventListener('submit', function () {
        // Sync the live Items Selection widget into the posted hidden field so Generate
        // (and the sort/page reposts that submit this form) apply the same filter the user sees.
        try {
            if (typeof getItemsSelectionFilter === 'function') {
                var f = getItemsSelectionFilter();
                document.getElementById('itemsSelectionJsonHidden').value =
                    Object.keys(f).length > 0 ? JSON.stringify(f) : '';
            }
        } catch (e) {}
        const btn = document.getElementById('generateBtn');
        btn.querySelector('.btn-text').classList.add('d-none');
        btn.querySelector('.spinner-border').classList.remove('d-none');
        btn.disabled = true;
    });

    // After a sort-triggered reload, anchor the results table at the top of the viewport
    // instead of letting the browser jump to the top of the page.
    // We use window.load (not DOMContentLoaded) so all sizes are settled, and also run
    // once on DOMContentLoaded to minimise perceived jump.
    function scrollResultsIntoView() {
        try {
            if (sessionStorage.getItem('catalogue_scroll_to_results') !== '1') return;
            var el = document.getElementById('results');
            if (!el) return;
            el.scrollIntoView({ behavior: 'auto', block: 'start' });
        } catch (e) {}
    }
    document.addEventListener('DOMContentLoaded', scrollResultsIntoView);
    window.addEventListener('load', function () {
        scrollResultsIntoView();
        try { sessionStorage.removeItem('catalogue_scroll_to_results'); } catch (e) {}
    });

    // ==================== VAT cascade (mirrors original repPowerReportCatalogue.aspx.vb:1913-1914) ====================
    // "Includes VAT" checkbox is disabled when basis is a cost value (no Excl/Incl variant exists).
    // Disabled IDs match original Powersoft365 PriceID: 99=LatestCost, 98=CostOnSale, 88=AverageCost, 87=WeightedAverageCost.
    function updateVatEnabledState(selectId, checkboxId) {
        var sel = document.getElementById(selectId);
        var chk = document.getElementById(checkboxId);
        if (!sel || !chk) return;
        var v = String(sel.value);
        var isCostBasis = (v === '99' || v === '98' || v === '88' || v === '87');
        chk.disabled = isCostBasis;
        var lbl = document.querySelector('label[for="' + checkboxId + '"]');
        if (lbl) lbl.style.opacity = isCostBasis ? '0.5' : '1';
        var wrapper = chk.closest('.form-check');
        if (wrapper) wrapper.title = isCostBasis ? 'VAT toggle not applicable to cost values' : '';
    }

    window.addEventListener('DOMContentLoaded', function () {
        var pairs = [
            ['ProfitBasedOn', 'ProfitIncludesVat'],
            ['StockValueBasedOn', 'StockValueIncludesVat']
        ];
        pairs.forEach(function (p) {
            updateVatEnabledState(p[0], p[1]);
            var sel = document.getElementById(p[0]);
            if (sel) sel.addEventListener('change', function () { updateVatEnabledState(p[0], p[1]); });
        });
    });

    // ==================== Schedule ====================

    function onSchedAiToggle() {
        document.getElementById('schedAiDetails').style.display =
            document.getElementById('schedIncludeAi').checked ? '' : 'none';
    }

    function autoSelectScheduleDateRange() {
        var preset = document.querySelector('input[name="DatePreset"]:checked');
        if (!preset) return;
        var map = {
            'ytd': 'YearToDate', 'lastYear': 'LastYear', 'thisMonth': 'ThisMonth',
            'lastMonth': 'LastMonth', 'last7': 'LastNDays_7', 'last30': 'LastNDays_30'
        };
        var mapped = map[preset.value];
        if (!mapped) return;
        var sel = document.getElementById('schedDateRangeType');
        for (var i = 0; i < sel.options.length; i++) {
            var opt = sel.options[i];
            if (mapped.startsWith('LastNDays_')) {
                var days = mapped.split('_')[1];
                if (opt.value === 'LastNDays' && opt.getAttribute('data-value') === days) { sel.selectedIndex = i; return; }
            } else if (opt.value === mapped) { sel.selectedIndex = i; return; }
        }
    }

    function validateEmailList(input) {
        if (!input || !input.trim()) return { valid: false, emails: [], errors: ['Please enter at least one email address.'] };
        var emails = input.split(/[,;]/).map(function(e) { return e.trim(); }).filter(function(e) { return e.length > 0; });
        var re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
        var invalid = emails.filter(function(e) { return !re.test(e); });
        if (invalid.length > 0) return { valid: false, emails: emails, errors: invalid.map(function(e) { return 'Invalid: ' + e; }) };
        return { valid: true, emails: emails, errors: [] };
    }

    // ==================== Save / Reset Layout (per-user defaults) ====================

    function collectCurrentLayout() {
        function v(id){var el = document.getElementById(id); return el ? el.value : '';}
        function chk(id){var el = document.getElementById(id); return el ? (el.checked ? '1' : '0') : '0';}
        var p = {};
        p['DateBasis'] = v('DateBasis');
        p['UseDateTime'] = chk('UseDateTime');
        p['ReportMode'] = v('ReportMode');
        p['ReportOn'] = v('ReportOn');
        p['PrimaryGroup'] = v('PrimaryGroup');
        p['SecondaryGroup'] = v('SecondaryGroup');
        p['ThirdGroup'] = v('ThirdGroup');
        p['ProfitBasedOn'] = v('ProfitBasedOn');
        p['ProfitIncludesVat'] = chk('ProfitIncludesVat');
        p['StockValueBasedOn'] = v('StockValueBasedOn');
        p['StockValueIncludesVat'] = chk('StockValueIncludesVat');
        p['CostType'] = v('CostType');
        p['ShowProfit'] = chk('ShowProfit');
        p['ShowStock'] = chk('ShowStock');
        p['PageSize'] = v('PageSize');
        p['DisplayColumns'] = v('displayColumnsHidden') || '';
        // Column order — current "working" order from sessionStorage, or fallback to hidden input
        // (which reflects the order loaded from the layout on last page render).
        var co = '';
        try {
            var raw = sessionStorage.getItem(COL_ORDER_KEY);
            if (raw) {
                var arr = JSON.parse(raw);
                if (Array.isArray(arr)) co = arr.join(',');
            }
        } catch (e) {}
        if (!co) co = v('columnOrderHidden') || '';
        if (co) p['ColumnOrder'] = co;
        var isj = v('itemsSelectionJsonHidden');
        if (isj) p['ItemsSelectionJson'] = isj;
        var rt = v('ReportTitle');
        if (rt) p['ReportTitle'] = rt;
        return p;
    }

    function applyLayoutParameters(parms) {
        // Mirror the server-side parsing in LoadCatalogueSavedLayoutAsync. Apply to form controls in-place,
        // then reapply downstream UI handlers (column toggles, items selection JSON, etc.).
        function setVal(id, v) { var el = document.getElementById(id); if (el && v != null && v !== '') el.value = v; }
        function setChk(id, v) { var el = document.getElementById(id); if (el && v != null) el.checked = (v === '1' || v === 1 || v === true); }

        setVal('DateBasis',          parms.DateBasis);
        setChk('UseDateTime',        parms.UseDateTime);
        setVal('ReportMode',         parms.ReportMode);
        setVal('ReportOn',           parms.ReportOn);
        setVal('PrimaryGroup',       parms.PrimaryGroup);
        setVal('SecondaryGroup',     parms.SecondaryGroup);
        setVal('ThirdGroup',         parms.ThirdGroup);
        setVal('ProfitBasedOn',      parms.ProfitBasedOn);
        setChk('ProfitIncludesVat',  parms.ProfitIncludesVat);
        setVal('StockValueBasedOn',  parms.StockValueBasedOn);
        setChk('StockValueIncludesVat', parms.StockValueIncludesVat);
        setVal('CostType',           parms.CostType);
        setChk('ShowProfit',         parms.ShowProfit);
        setChk('ShowStock',          parms.ShowStock);
        setVal('PageSize',           parms.PageSize);

        if (parms.ReportTitle != null) {
            setVal('ReportTitle', parms.ReportTitle);
            var hdr = document.getElementById('resultsTitle');
            if (hdr) hdr.textContent = parms.ReportTitle || 'Results';
        }
        if (parms.DisplayColumns != null) {
            var hidden = document.getElementById('displayColumnsHidden');
            if (hidden) hidden.value = parms.DisplayColumns;
            if (typeof syncDisplayColumnCheckboxes === 'function') syncDisplayColumnCheckboxes();
        }
        if (parms.ColumnOrder != null) {
            // Persist the layout's column order to sessionStorage so the grid picks it up after the
            // form submit below re-renders. Also write to the hidden input so it round-trips.
            var coHidden = document.getElementById('columnOrderHidden');
            if (coHidden) coHidden.value = parms.ColumnOrder;
            try {
                var arr = String(parms.ColumnOrder).split(',').map(function(s){return s.trim();}).filter(function(s){return s.length>0;});
                if (arr.length) sessionStorage.setItem(COL_ORDER_KEY, JSON.stringify(arr));
                else sessionStorage.removeItem(COL_ORDER_KEY);
            } catch (e) {}
        }
        if (parms.ItemsSelectionJson != null) {
            var isj = document.getElementById('itemsSelectionJsonHidden');
            if (isj) isj.value = parms.ItemsSelectionJson;
            // Re-hydrate the live Items Selection widget from the restored JSON.
            if (typeof reloadItemsSelectionFromJson === 'function') {
                try {
                    var obj = parms.ItemsSelectionJson ? JSON.parse(parms.ItemsSelectionJson) : {};
                    reloadItemsSelectionFromJson(obj);
                } catch (e) {}
            }
        }
        // Bidirectional sync: ShowProfit/ShowStock <-> column visibility (existing handlers handle this).
        if (typeof onShowProfitToggle === 'function') onShowProfitToggle();
        if (typeof onShowStockToggle === 'function')  onShowStockToggle();
    }

    function collectColumnFiltersJson() {
        var values = {}, operators = {}, hasAny = false;
        document.querySelectorAll('input[id^="fv_"]').forEach(function(el) {
            var col = el.id.substring(3);
            if (el.value) { values[col] = el.value; hasAny = true; }
        });
        document.querySelectorAll('input[id^="fo_"]').forEach(function(el) {
            var col = el.id.substring(3);
            if (el.value) operators[col] = el.value;
        });
        return hasAny ? JSON.stringify({ values: values, operators: operators }) : '';
    }

    function collectCatalogueParams() {
        function v(id){var el = document.getElementById(id); return el ? el.value : '';}
        function chk(id){var el = document.getElementById(id); return el ? el.checked : false;}
        var p = {
            dateFrom: v('DateFrom'),
            dateTo: v('DateTo'),
            dateBasis: v('DateBasis'),
            useDateTime: chk('UseDateTime'),
            reportMode: v('ReportMode'),
            reportOn: v('ReportOn'),
            primaryGroup: v('PrimaryGroup'),
            secondaryGroup: v('SecondaryGroup'),
            thirdGroup: v('ThirdGroup'),
            profitBasedOn: v('ProfitBasedOn'),
            profitIncludesVat: chk('ProfitIncludesVat'),
            stockValueBasedOn: v('StockValueBasedOn'),
            stockValueIncludesVat: chk('StockValueIncludesVat'),
            costType: v('CostType'),
            displayColumns: v('displayColumnsHidden') || '',
            showProfit: chk('ShowProfit'),
            showStock: chk('ShowStock'),
            storeCodes: v('selectedStoreCodesHidden'),
            itemsSelection: (function () {
                // Read the LIVE widget so exports match the current screen selection even when
                // the user hasn't re-clicked Generate (the hidden field only syncs on form submit).
                if (typeof getItemsSelectionFilter === 'function') {
                    var f = getItemsSelectionFilter();
                    return Object.keys(f).length > 0 ? JSON.stringify(f) : '';
                }
                return v('itemsSelectionJsonHidden');
            })(),
            sortColumn: v('sortColumnHidden') || 'ItemCode',
            sortDirection: v('sortDirectionHidden') || 'ASC'
        };
        var cf = collectColumnFiltersJson();
        if (cf) p.columnFilters = cf;
        return p;
    }

    // ===== Shared schedule partial API =====

    // Called by _Schedule.cshtml saveSchedule() — must return report-specific params object.
    // The partial merges reportDateRange on top before posting.
    function collectScheduleParameters() {
        return collectCatalogueParams();
    }

    // Called by _Schedule.cshtml loadScheduleIntoForm() to restore report-specific UI fields
    // when editing an existing schedule. Best-effort: silently skip missing elements.
    function onScheduleParametersLoaded(p) {
        if (!p) return;
        function sv(id, val) { var el = document.getElementById(id); if (el && val != null) el.value = val; }
        function sc(id, val) { var el = document.getElementById(id); if (el && val != null) el.checked = !!val; }
        sv('ReportMode',    p.reportMode);
        sv('ReportOn',      p.reportOn);
        sv('PrimaryGroup',  p.primaryGroup);
        sv('SecondaryGroup', p.secondaryGroup);
        sv('ThirdGroup',    p.thirdGroup);
        sv('DateBasis',     p.dateBasis);
        sc('UseDateTime',   p.useDateTime);
        sv('ProfitBasedOn', p.profitBasedOn);
        sc('ProfitIncludesVat', p.profitIncludesVat);
        sv('StockValueBasedOn', p.stockValueBasedOn);
        sc('StockValueIncludesVat', p.stockValueIncludesVat);
        sv('CostType',      p.costType);
        sc('ShowProfit',    p.showProfit);
        sc('ShowStock',     p.showStock);
        if (p.displayColumns) {
            var dcHid = document.getElementById('displayColumnsHidden');
            if (dcHid) dcHid.value = p.displayColumns;
        }
        if (p.itemsSelection && typeof reloadItemsSelectionFromJson === 'function') {
            try { reloadItemsSelectionFromJson(typeof p.itemsSelection === 'string' ? JSON.parse(p.itemsSelection) : p.itemsSelection); } catch (e) {}
        }
    }

    // Pre-fills the shared schedule modal's date range to Custom using the current screen dates.
    function autoSelectScheduleDateRange() {
        var df = document.getElementById('DateFrom') ? document.getElementById('DateFrom').value
                 : (document.getElementById('dateFrom') ? document.getElementById('dateFrom').value : '');
        var dt = document.getElementById('DateTo') ? document.getElementById('DateTo').value
                 : (document.getElementById('dateTo') ? document.getElementById('dateTo').value : '');
        if (!df || !dt) return;
        var sel = document.getElementById('schedDateRangeType');
        if (!sel) return;
        for (var i = 0; i < sel.options.length; i++) {
            if (sel.options[i].value === 'Custom') { sel.selectedIndex = i; break; }
        }
        var schedFrom = document.getElementById('schedDateFrom');
        var schedTo   = document.getElementById('schedDateTo');
        if (schedFrom) schedFrom.value = df;
        if (schedTo)   schedTo.value   = dt;
        if (typeof onSchedDateRangeTypeChange === 'function') onSchedDateRangeTypeChange();
    }

    // ===== End shared schedule partial API =====

    function exportCatalogue(format) {
        var action = format === 'csv' ? '@Url.Action("ExportCatalogueCsv", "Reports")' : '@Url.Action("ExportCatalogueExcel", "Reports")';
        var p = collectCatalogueParams();
        var qs = Object.keys(p).map(function(k) { return encodeURIComponent(k) + '=' + encodeURIComponent(p[k]); }).join('&');
        window.location.href = action + '?' + qs;
    }

    function saveSchedule() {
        var name = document.getElementById('schedName').value.trim();
        var recipients = document.getElementById('schedRecipients').value.trim();
        var alertDiv = document.getElementById('scheduleAlert');

        if (!name || !recipients) {
            alertDiv.innerHTML = '<div class="alert alert-warning mb-0">Please fill in schedule name and recipients.</div>';
            alertDiv.style.display = ''; return;
        }
        var ev = validateEmailList(recipients);
        if (!ev.valid) {
            alertDiv.innerHTML = '<div class="alert alert-warning mb-0">Invalid email address(es): ' + ev.errors.join('; ') + '</div>';
            alertDiv.style.display = ''; return;
        }

        var recurrence = document.getElementById('schedRecurrence').value;
        if (recurrence === 'Once') {
            var startDate = document.getElementById('schedStartDate').value;
            var today = new Date().toISOString().slice(0, 10);
            if (!startDate || startDate < today) {
                alertDiv.innerHTML = '<div class="alert alert-warning mb-0">For "Run once", start date must be today or in the future.</div>';
                alertDiv.style.display = ''; return;
            }
        }

        var day = (recurrence === 'Monthly') ? parseInt(document.getElementById('schedMonthDay').value, 10) : null;

        var fd = new FormData();
        fd.append('scheduleName', name);
        fd.append('recurrenceType', recurrence);
        if (day !== null && !isNaN(day)) fd.append('recurrenceDay', day);
        fd.append('scheduleTime', document.getElementById('schedTime').value);
        fd.append('exportFormat', document.getElementById('schedFormat').value);
        fd.append('recipients', recipients);
        fd.append('emailSubject', document.getElementById('schedSubject').value);
        fd.append('includeAiAnalysis', document.getElementById('schedIncludeAi').checked);
        fd.append('aiLocale', document.getElementById('schedAiLocale').value);
        fd.append('skipIfEmpty', document.getElementById('schedSkipIfEmpty').checked);

        var dsel = document.getElementById('schedDateRangeType');
        var dopt = dsel.options[dsel.selectedIndex];
        var reportDateRange = { type: dopt.value };
        if (reportDateRange.type === 'LastNDays') reportDateRange.value = parseInt(dopt.getAttribute('data-value') || '7', 10);
        else if (reportDateRange.type === 'Custom') {
            reportDateRange.dateFrom = document.getElementById('schedDateFrom').value;
            reportDateRange.dateTo = document.getElementById('schedDateTo').value;
        }

        var params = collectCatalogueParams();
        params.reportDateRange = reportDateRange;
        fd.append('parametersJson', JSON.stringify(params));

        var startDateSc = document.getElementById('schedStartDate').value || new Date().toISOString().slice(0, 10);
        var recurrenceJson = {
            type: recurrence,
            time: document.getElementById('schedTime').value,
            range: { startDate: startDateSc, noEndDate: true }
        };
        if (recurrence === 'Weekly') {
            var days = [];
            document.querySelectorAll('.sched-dow:checked').forEach(function(cb) { days.push(parseInt(cb.value, 10)); });
            recurrenceJson.pattern = { interval: 1, daysOfWeek: days.length ? days : [1] };
        } else if (recurrence === 'Monthly') {
            recurrenceJson.pattern = { dayOfMonth: day !== null ? day : 1 };
        }
        fd.append('recurrenceJson', JSON.stringify(recurrenceJson));

        // Edit mode: if the form was loaded from an existing schedule, send the id so the server
        // performs an UPDATE instead of inserting a duplicate record.
        var sid = document.getElementById('schedId').value;
        if (sid) fd.append('scheduleId', sid);

        var saveBtn = document.querySelector('#scheduleModal .btn-primary[onclick="saveSchedule()"]');
        if (saveBtn) saveBtn.disabled = true;

        fetch('@Url.Action("SaveCatalogueSchedule", "Reports")', { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (saveBtn) saveBtn.disabled = false;
                if (data.success) {
                    alertDiv.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle me-1"></i>' + data.message + '</div>';
                    alertDiv.style.display = '';
                    loadExistingSchedules();
                    if (data.updated) {
                        // Update: keep the form populated so the user can tweak again or close the modal manually.
                        showScheduleToast('Schedule updated', 'success');
                    } else {
                        // New schedule: clear the form after a beat so the user can queue another one.
                        setTimeout(function() {
                            resetScheduleForm();
                            showScheduleToast('Schedule saved successfully', 'success');
                        }, 700);
                    }
                } else {
                    alertDiv.innerHTML = '<div class="alert alert-danger mb-0">' + data.message + '</div>';
                    alertDiv.style.display = '';
                }
            })
            .catch(function() {
                if (saveBtn) saveBtn.disabled = false;
                alertDiv.innerHTML = '<div class="alert alert-danger mb-0">Network error. Please try again.</div>';
                alertDiv.style.display = '';
            });
    }

    function showScheduleToast(message, type) {
        var existing = document.getElementById('schedToast');
        if (existing) existing.remove();
        var div = document.createElement('div');
        div.id = 'schedToast';
        div.className = 'alert alert-' + type + ' alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow';
        div.style.zIndex = '11000';
        div.innerHTML = '<i class="bi bi-' + (type === 'success' ? 'check-circle' : 'exclamation-triangle') + ' me-1"></i>' + message +
            '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
        document.body.appendChild(div);
        setTimeout(function() { if (div.parentNode) div.remove(); }, 4000);
    }

    function deleteScheduleRow(scheduleId, scheduleName) {
        if (!confirm('Delete schedule "' + scheduleName + '"?\nThis cannot be undone.')) return;
        var fd = new FormData();
        fd.append('scheduleId', scheduleId);
        fetch('@Url.Action("DeleteSchedule", "Reports")', { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    showScheduleToast('Schedule deleted', 'success');
                    loadExistingSchedules();
                    // If the form still held the deleted schedule's data (after a prior Load), wipe it so
                    // the user isn't left editing a record that no longer exists.
                    resetScheduleForm();
                } else {
                    showScheduleToast(data.message || 'Failed to delete schedule', 'danger');
                }
            })
            .catch(function() { showScheduleToast('Network error', 'danger'); });
    }

    function loadExistingSchedules() {
        fetch('@Url.Action("GetCatalogueSchedules", "Reports")')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var c = document.getElementById('existingSchedules');
                if (!data || data.length === 0) { c.innerHTML = '<em>No schedules configured yet.</em>'; return; }
                var html = '<table class="table table-sm mb-0 align-middle"><thead><tr><th>Name</th><th>Recurrence</th><th>Format</th><th>Time</th><th>Next Run</th><th class="text-end">Actions</th></tr></thead><tbody>';
                data.forEach(function(s) {
                    var safeName = (s.scheduleName || '').replace(/'/g, "\\'").replace(/"/g, '&quot;');
                    html += '<tr data-schedule-id="' + s.scheduleId + '" style="cursor:pointer;" title="Click to load this schedule">'
                        + '<td>' + escapeHtml(s.scheduleName || '') + '</td>'
                        + '<td>' + s.recurrenceType + '</td>'
                        + '<td>' + s.exportFormat + '</td>'
                        + '<td>' + s.scheduleTime + '</td>'
                        + '<td>' + (s.nextRun || '-') + '</td>'
                        + '<td class="text-end">'
                        +   '<button type="button" class="btn btn-sm btn-outline-primary me-1" title="Load into form" onclick="event.stopPropagation(); loadScheduleIntoForm(' + s.scheduleId + ')"><i class="bi bi-pencil"></i></button>'
                        +   '<button type="button" class="btn btn-sm btn-outline-danger" title="Delete schedule" onclick="event.stopPropagation(); deleteScheduleRow(' + s.scheduleId + ', \'' + safeName + '\')"><i class="bi bi-trash"></i></button>'
                        + '</td>'
                        + '</tr>';
                });
                html += '</tbody></table>';
                c.innerHTML = html;
                c.querySelectorAll('tr[data-schedule-id]').forEach(function(tr) {
                    tr.addEventListener('click', function() {
                        loadScheduleIntoForm(parseInt(tr.getAttribute('data-schedule-id'), 10));
                    });
                });
            })
            .catch(function() { document.getElementById('existingSchedules').innerHTML = '<em>Could not load schedules.</em>'; });
    }

    // A2 (2026-04-17): clean state + click-to-load, mirrored from AverageBasket.
    function resetScheduleForm() {
        var setVal = function(id, v) { var el = document.getElementById(id); if (el) el.value = v; };
        var setChk = function(id, v) { var el = document.getElementById(id); if (el) el.checked = !!v; };
        setVal('schedId', '');
        setVal('schedName', '');
        setVal('schedRecipients', 'gm@powersoft.com.cy');
        setVal('schedSubject', '');
        setVal('schedFormat', 'Excel');
        setVal('schedRecurrence', 'Daily');
        setVal('schedTime', '08:00');
        setVal('schedStartDate', new Date().toISOString().slice(0, 10));
        document.querySelectorAll('.sched-dow').forEach(function(cb) { cb.checked = false; });
        setChk('schedSkipIfEmpty', false);
        setChk('schedIncludeAi', false);
        if (typeof onRecurrenceChange === 'function') onRecurrenceChange();
        if (typeof onSchedAiToggle === 'function') onSchedAiToggle();
        var alertDiv = document.getElementById('scheduleAlert');
        if (alertDiv) { alertDiv.style.display = 'none'; alertDiv.innerHTML = ''; }
    }

    function loadScheduleIntoForm(scheduleId) {
        fetch('@Url.Action("GetScheduleById", "Reports")?scheduleId=' + scheduleId)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!data || !data.success || !data.schedule) {
                    showScheduleToast((data && data.message) || 'Could not load schedule', 'danger');
                    return;
                }
                var s = data.schedule;
                var setVal = function(id, v) { var el = document.getElementById(id); if (el) el.value = v || ''; };
                var setChk = function(id, v) { var el = document.getElementById(id); if (el) el.checked = !!v; };
                // Remember the id so a subsequent Save updates this schedule instead of cloning it.
                document.getElementById('schedId').value = scheduleId;
                setVal('schedName', s.scheduleName);
                setVal('schedRecipients', s.recipients);
                setVal('schedSubject', s.emailSubject);
                setVal('schedFormat', s.exportFormat);
                setVal('schedRecurrence', s.recurrenceType);
                setVal('schedTime', s.scheduleTime);
                if (typeof onRecurrenceChange === 'function') onRecurrenceChange();

                if (s.recurrenceJson) {
                    try {
                        var rec = typeof s.recurrenceJson === 'string' ? JSON.parse(s.recurrenceJson) : s.recurrenceJson;
                        if (rec && rec.range && rec.range.startDate) setVal('schedStartDate', rec.range.startDate);
                        if (rec && rec.pattern) {
                            if (rec.type === 'Weekly' && Array.isArray(rec.pattern.daysOfWeek)) {
                                document.querySelectorAll('.sched-dow').forEach(function(cb) {
                                    cb.checked = rec.pattern.daysOfWeek.indexOf(parseInt(cb.value, 10)) !== -1;
                                });
                            } else if (rec.type === 'Monthly' && rec.pattern.dayOfMonth) {
                                setVal('schedMonthDay', String(rec.pattern.dayOfMonth));
                            }
                        }
                    } catch (e) { /* best-effort */ }
                }

                setChk('schedSkipIfEmpty', s.skipIfEmpty);
                setChk('schedIncludeAi', s.includeAiAnalysis);
                if (s.aiLocale) setVal('schedAiLocale', s.aiLocale);
                if (typeof onSchedAiToggle === 'function') onSchedAiToggle();

                var alertDiv = document.getElementById('scheduleAlert');
                if (alertDiv) {
                    alertDiv.innerHTML = '<div class="alert alert-info mb-0 py-2"><i class="bi bi-pencil-square me-1"></i>Editing <strong>' + escapeHtml(s.scheduleName || '') + '</strong>. Saving will update this schedule in place &mdash; click <em>Reset</em> to start a new one instead.</div>';
                    alertDiv.style.display = '';
                }
            })
            .catch(function() { showScheduleToast('Network error loading schedule', 'danger'); });
    }

    // Load schedules and init date range visibility when modal opens
    document.addEventListener('DOMContentLoaded', function() {
        var scheduleModal = document.getElementById('scheduleModal');
        if (scheduleModal) {
            scheduleModal.addEventListener('show.bs.modal', function() {
                resetScheduleForm();               // A2: always start clean
                loadExistingSchedules();
                autoSelectScheduleDateRange();
                onSchedDateRangeTypeChange();
            });
        }
    });

    // ==================== Send to Email (shared _SendEmail partial) ====================
    // Host hook: the partial calls collectEmailParameters() to get the report params.
    // recipients/cc/bcc/emailSubject/exportFormat/templateId are appended by the partial itself.
    window.collectEmailParameters = function() {
        return collectCatalogueParams();
    };
    // Host hook: reproduces the original dynamic "Power Reports Catalogue — {from} to {to}" subject.
    window.getEmailDefaultSubject = function() {
        var df = document.getElementById('DateFrom');
        var dt = document.getElementById('DateTo');
        return 'Power Reports Catalogue \u2014 ' + (df ? df.value : '') + ' to ' + (dt ? dt.value : '');
