@using Powersoft.Reporting.Core.Models
@using System.Text.Json
@{
    ViewData["Title"] = "Pareto 80/20 Analysis";
    var stores = ViewBag.Stores as List<Store> ?? new List<Store>();
    var dbName = ViewBag.ConnectedDatabase as string ?? "Unknown";
    var storesJson = JsonSerializer.Serialize(stores.Select(s => new { s.StoreCode, s.StoreName }));
    var canSchedule = (bool)(ViewBag.CanSchedule ?? false);
    var dateFromDefault = ViewBag.DateFrom as string ?? DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd");
    var dateToDefault = ViewBag.DateTo as string ?? DateTime.Today.ToString("yyyy-MM-dd");
    bool viewCost = ViewBag.ViewCost == null || (bool)ViewBag.ViewCost;
}

<style>
    .class-a { background: #dcfce7 !important; }
    .class-b { background: #fef9c3 !important; }
    .class-c { background: #fee2e2 !important; }
    .badge-a { background: #16a34a; }
    .badge-b { background: #ca8a04; }
    .badge-c { background: #dc2626; }
    .stat-card { border-radius: 8px; padding: 16px; text-align: center; }
    .stat-card h3 { margin: 0; font-size: 1.5rem; }
    .stat-card .label { font-size: 0.8rem; color: #6b7280; }
</style>

<div class="rpt-modern">

<div class="rpt-hero rpt-rise">
    <div class="rpt-hero-left">
        <div class="rpt-hero-icon"><i class="bi bi-funnel"></i></div>
        <div>
            <div class="rpt-crumbs">
                <a asp-controller="Reports" asp-action="Index">Reports</a>
                <a asp-controller="Reports" asp-action="Index">Stock Control</a>
                <span>Pareto 80/20</span>
            </div>
            <h2>Pareto 80/20 Analysis</h2>
            <p class="rpt-hero-sub">ABC classification of sales data — @dbName</p>
        </div>
    </div>
    <div>
        @await Html.PartialAsync("_TutorialButton", ("Pareto Analysis", ""))
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-funnel me-2"></i>Report Parameters
    </div>
    <div class="card-body">
        <form id="paretoForm">
            <div class="row mb-3">
                <div class="col-12">
                    <div class="rpt-eyebrow"><i class="bi bi-lightning-charge"></i>Quick Date Selection</div>
                    <div class="date-presets btn-group flex-wrap" role="group">
                        <input type="radio" class="btn-check" name="DatePreset" id="presetToday" value="today" autocomplete="off">
                        <label class="btn rpt-chip" for="presetToday">Today</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLast30" value="last30" autocomplete="off">
                        <label class="btn rpt-chip" for="presetLast30">Last 30 Days</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetThisMonth" value="thisMonth" autocomplete="off" checked>
                        <label class="btn rpt-chip" for="presetThisMonth">This Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastMonth" value="lastMonth" autocomplete="off">
                        <label class="btn rpt-chip" for="presetLastMonth">Last Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetYTD" value="ytd" autocomplete="off">
                        <label class="btn rpt-chip" for="presetYTD">Year to Date</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastYear" value="lastYear" autocomplete="off">
                        <label class="btn rpt-chip" for="presetLastYear">Last Year</label>
                    </div>
                </div>
            </div>

            <hr class="my-3">

            <div class="row g-3 mb-3 align-items-end">
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date From</label>
                    <input type="date" class="form-control" id="dateFrom" onchange="clearPreset()"
                           value="@DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date To</label>
                    <input type="date" class="form-control" id="dateTo" onchange="clearPreset()"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Dimension (By)</label>
                    <select class="form-select" id="dimension" onchange="onDimensionChanged()">
                        <option value="Item" selected>By Item</option>
                        <option value="Customer">By Customer</option>
                        <option value="CustomerCategory1">By Customer Category 1</option>
                        <option value="CustomerCategory2">By Customer Category 2</option>
                        <option value="Category">By Item Category</option>
                        <option value="Department">By Department</option>
                        <option value="Brand">By Brand</option>
                        <option value="Season">By Season</option>
                        <option value="Supplier" data-perm-opt="supplier">By Supplier</option>
                        <option value="Model">By Model</option>
                        <option value="Colour">By Colour</option>
                        <option value="Size">By Size</option>
                        <option value="GroupSize">By Group Size</option>
                        <option value="Fabric">By Fabric</option>
                        <option value="Store">By Store</option>
                        <option value="User">By User</option>
                        <option value="ByPrice">By Price Range</option>
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Report On</label>
                    <select class="form-select" id="metric" onchange="onMetricChanged()">
                        <option value="Value" selected>Value</option>
                        <option value="Quantity">Quantity</option>
                        <option value="Profit" data-perm-opt="cost">Profit</option>
                    </select>
                </div>
                <div class="col-6 col-md-2" id="profitBasisGroup" style="display:none;">
                    <label class="form-label fw-semibold">Profit Based On</label>
                    <select class="form-select" id="profitBasis">
                        <option value="0">Default Price</option>
                        <option value="1">Price 1</option>
                        <option value="2">Price 2</option>
                        <option value="3">Price 3</option>
                        <option value="4">Price 4</option>
                        <option value="5">Price 5</option>
                        <option value="6">Price 6</option>
                        <option value="7">Price 7</option>
                        <option value="8">Price 8</option>
                        <option value="9">Price 9</option>
                        <option value="10">Price 10</option>
                        <option value="99" selected>Latest Cost</option>
                        <option value="88">Average Cost</option>
                        <option value="87">Weighted Average Cost</option>
                    </select>
                </div>
                <div class="col-6 col-md-2" id="priceIntervalGroup" style="display:none;">
                    <label class="form-label fw-semibold">Price Interval</label>
                    <input type="number" class="form-control" id="priceInterval" value="10" min="0.01" step="1">
                </div>
                <div class="col-6 col-md-2" id="priceOnGroup" style="display:none;">
                    <label class="form-label fw-semibold">Based On Price</label>
                    <select class="form-select" id="priceOnIndex">
                        <option value="0" selected>Transaction Price</option>
                        <option value="1">Price 1</option>
                        <option value="2">Price 2</option>
                        <option value="3">Price 3</option>
                        <option value="4">Price 4</option>
                        <option value="5">Price 5</option>
                        <option value="6">Price 6</option>
                        <option value="7">Price 7</option>
                        <option value="8">Price 8</option>
                        <option value="9">Price 9</option>
                        <option value="10">Price 10</option>
                    </select>
                </div>
            </div>

            <div class="row g-3 mb-4 align-items-center">
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="includeVat">
                        <label class="form-check-label" for="includeVat">Include VAT</label>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="excludeNegative" checked>
                        <label class="form-check-label" for="excludeNegative">Exclude Negative Amounts</label>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="showOthers">
                        <label class="form-check-label" for="showOthers">Show Others</label>
                    </div>
                </div>
            </div>

            <div class="row g-2 mb-4 align-items-center">
                <div class="col-auto">
                    <span class="fw-semibold small text-muted">Pareto Threshold:</span>
                </div>
                <div class="col-auto">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text">Top</span>
                        <input type="number" class="form-control text-end" id="paretoPercItems" value="20" min="1" max="99" style="width:56px;" onchange="syncParetoPerc('items')">
                        <span class="input-group-text">% of items gives</span>
                        <input type="number" class="form-control text-end" id="paretoPercValue" value="80" min="1" max="99" style="width:56px;" onchange="syncParetoPerc('value')">
                        <span class="input-group-text">% of value</span>
                    </div>
                </div>
            </div>

            <div class="report-form-actions d-flex flex-wrap gap-2 pt-2 border-top">
                <button type="button" class="btn btn-primary btn-lg" onclick="loadPareto()" id="generateBtn">
                    <i class="bi bi-play-fill me-2"></i>Generate Report
                </button>
                @if (canSchedule)
                {
                    <button type="button" class="btn btn-warning btn-lg" data-bs-toggle="modal" data-bs-target="#scheduleModal" title="Schedule recurring report delivery">
                        <i class="bi bi-clock-history me-2"></i>Schedule
                    </button>
                }
                <div class="btn-group ms-auto">
                    <div class="btn-group">
                        <button type="button" class="btn btn-outline-info dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false"
                                title="Saved report layouts" id="layoutsDropdownBtn">
                            <i class="bi bi-bookmark me-1"></i><span id="layoutsCurrentName">Layouts</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" id="layoutsDropdownMenu" style="min-width: 320px;">
                            <li><h6 class="dropdown-header">Loading...</h6></li>
                        </ul>
                    </div>
                    <button type="button" class="btn btn-outline-info" onclick="saveCurrentLayout()" title="Overwrite your default layout with current parameters">
                        <i class="bi bi-save me-1"></i>Save
                    </button>
                    <button type="button" class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#saveLayoutAsModal"
                            title="Save current parameters as a new named layout (optionally shared with all users)">
                        <i class="bi bi-bookmark-plus me-1"></i>Save as...
                    </button>
                    <button type="button" class="btn btn-outline-secondary" id="resetLayoutBtn" onclick="resetSavedLayout()" title="Discard your saved default layout and restore factory defaults" style="display:none;">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Default
                    </button>
                </div>
                <a asp-action="Pareto" class="btn btn-outline-secondary btn-reset" title="Clear all filters">
                    <i class="bi bi-funnel me-1"></i>Clear Filters
                </a>
            </div>
        </form>
    </div>
</div>

@await Html.PartialAsync("_ItemsSelection", new ItemsSelectionConfig
{
    ShowCategories = true,
    ShowDepartments = true,
    ShowBrands = true,
    ShowSeasons = true,
    ShowSuppliers = true,
    ShowCustomers = true,
    ShowStores = true,
    StoresJson = storesJson,
    ReportType = "Pareto"
})

<div id="paretoLoading" class="text-center py-5 d-none">
    <div class="spinner-border text-primary"></div>
    <p class="text-muted mt-2">Calculating Pareto analysis...</p>
</div>
<div id="paretoError" class="alert alert-danger d-none"></div>

<div id="paretoResults" class="d-none">
    <div class="row g-3 mb-4" id="summaryCards"></div>

    <div class="card mb-4">
        <div class="card-header">
            <i class="bi bi-bar-chart me-2"></i>Pareto Chart
        </div>
        <div class="card-body" style="position:relative;height:400px;">
            <canvas id="paretoChart"></canvas>
        </div>
    </div>

    <div class="card mb-4" id="paretoGridCard">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>
                <i class="bi bi-table me-2"></i>Detailed Breakdown
                <span id="rowCountBadge" class="badge bg-secondary ms-2"></span>
            </span>
            <div class="d-flex gap-2 flex-wrap align-items-center" id="resultsActions" style="display:none !important;">
                <button class="btn btn-sm btn-outline-primary" onclick="toggleParetoPreview()" id="previewToggleBtn" title="Toggle document preview">
                    <i class="bi bi-eye me-1"></i>Preview
                </button>
                <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-success" onclick="exportPareto('csv')">
                        <i class="bi bi-filetype-csv me-1"></i>CSV
                    </button>
                    <button class="btn btn-outline-success" onclick="exportPareto('excel')">
                        <i class="bi bi-filetype-xlsx me-1"></i>Excel
                    </button>
                    <button class="btn btn-outline-danger" onclick="exportPareto('pdf')">
                        <i class="bi bi-filetype-pdf me-1"></i>PDF
                    </button>
                </div>
                <button class="btn btn-sm btn-outline-primary" onclick="openSendEmailModal()" title="Send report via email">
                    <i class="bi bi-envelope me-1"></i>Send to Email
                </button>
                <button class="btn btn-sm btn-outline-info" onclick="openAiAnalysis()" title="AI-powered report analysis" id="btnAnalyze">
                    <i class="bi bi-stars me-1"></i>AI Analyze
                </button>
            </div>
        </div>
        <div class="card-body p-0" style="max-height:500px;overflow-y:auto;">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light sticky-top">
                    <tr class="small">
                        <th>#</th>
                        <th>Code</th>
                        <th>Name</th>
                        <th class="text-end">Quantity</th>
                        <th class="text-end">Subtotal</th>
                        @if (viewCost) { <th class="text-end">Profit</th> }
                        <th class="text-end">%</th>
                        <th class="text-end">Cumul. %</th>
                        <th class="text-center">Class</th>
                    </tr>
                </thead>
                <tbody id="paretoTable" class="small"></tbody>
            </table>
        </div>
    </div>

    <!-- Inline Preview Panel (hidden by default) -->
    <div id="paretoPreviewPanel" style="display:none;" class="mt-3">
        <div class="card border-primary">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-2">
                <span><i class="bi bi-file-earmark-text me-2"></i>Document Preview</span>
                <button class="btn btn-sm btn-outline-light" onclick="toggleParetoPreview()" title="Close preview">
                    <i class="bi bi-x-lg me-1"></i>Back to Grid
                </button>
            </div>
            <div class="card-body p-0">
                <iframe id="paretoPreviewFrame" style="width:100%; border:none; min-height:700px; background:#525659;"></iframe>
            </div>
        </div>
    </div>
</div>

<div id="emptyState" class="text-center py-5 text-muted">
    <i class="bi bi-funnel" style="font-size:3rem;opacity:0.3;"></i>
    <p class="mt-3">Select parameters and click <strong>Generate Report</strong> for Pareto 80/20 analysis.</p>
    <p class="small">The Pareto principle: ~20% of items generate ~80% of value.</p>
</div>

<div class="modal fade" id="paretoItemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title"><i class="bi bi-clock-history me-2"></i>Transaction History — <span id="paretoModalCode"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div id="paretoModalLoading" class="text-center py-4"><div class="spinner-border spinner-border-sm"></div> Loading...</div>
                <div id="paretoModalError" class="alert alert-danger m-3 d-none"></div>
                <table class="table table-sm table-hover mb-0" id="paretoModalTable" style="display:none;">
                    <thead class="table-light">
                        <tr class="small">
                            <th>Date</th><th>Type</th><th>Invoice</th><th>Customer</th>
                            <th class="text-end">Qty</th><th class="text-end">Amount</th><th>Store</th>
                        </tr>
                    </thead>
                    <tbody id="paretoModalTbody" class="small"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* Schedule Modal — shared partial *@
