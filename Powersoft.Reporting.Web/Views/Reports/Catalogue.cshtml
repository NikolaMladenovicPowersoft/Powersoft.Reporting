            if (data.success) {
                showLayoutToast('Layout reset — reloading...', 'success');
                setTimeout(function() { window.location.href = '@Url.Action("Catalogue", new { layoutReset = true })'; }, 800);
            } else {
                showLayoutToast(data.message || 'Failed to reset layout', 'danger');
