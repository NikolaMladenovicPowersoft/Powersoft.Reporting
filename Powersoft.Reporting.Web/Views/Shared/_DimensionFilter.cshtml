@model (string DimType, string Label, string Icon)

<div class="dim-col d-flex align-items-center gap-1 py-1" data-dim="@Model.DimType">
    <button type="button" class="btn btn-outline-secondary btn-sm flex-grow-1 text-start text-truncate" id="dimTrigger_@Model.DimType"
            onclick="openDimModal('@Model.DimType', '@Model.Label')" title="Select @Model.Label">
        <i class="bi @Model.Icon me-1 text-muted"></i>
        <span class="dim-text text-muted small">@Model.Label</span>
        <i class="bi bi-chevron-right float-end mt-1 text-muted small"></i>
    </button>
    <div class="btn-group btn-group-sm flex-shrink-0 dim-inactive" role="group">
        <button type="button" class="btn btn-outline-success btn-sm px-2" data-mode="include" onclick="setDimMode('@Model.DimType',this)" title="Include selected">
            <i class="bi bi-plus-circle"></i>
        </button>
        <button type="button" class="btn btn-outline-danger btn-sm px-2" data-mode="exclude" onclick="setDimMode('@Model.DimType',this)" title="Exclude selected">
            <i class="bi bi-dash-circle"></i>
        </button>
    </div>
    <button type="button" class="btn btn-sm text-muted px-1 d-none" id="dimClear_@Model.DimType"
            onclick="clearDimFilter('@Model.DimType')" title="Clear filter">
        <i class="bi bi-x-lg"></i>
    </button>
</div>
