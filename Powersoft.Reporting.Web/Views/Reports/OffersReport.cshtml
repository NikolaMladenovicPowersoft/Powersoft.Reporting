<script>
var _sortCol = 'DateTrans';
var _sortDir = 'DESC';
var _lastData = [];
var _lastTotalRecords = 0;
var _aiConversation = [];
var _aiTotalChatTokens = { input: 0, output: 0 };
var _emailTemplatesCache = [];
var _statusLookup = {};

(function init() {
    var today = new Date();
    var y = today.getFullYear();
    document.getElementById('dateFrom').value = y+'-01-01';
    document.getElementById('dateTo').value = fmtDate(today);
    document.querySelectorAll('input[name="DatePreset"]').forEach(function(r) {
        r.addEventListener('change', function() { applyPresetDates(this.value); });
    });
    document.getElementById('scheduleModal').addEventListener('show.bs.modal', function() { loadSchedules(); });
    fetch('/Reports/GetAiStatus').then(r=>r.json()).then(d=>{
        if(!d.configured){var btn=document.getElementById('btnAnalyze');if(btn){btn.title='AI not configured';btn.classList.add('disabled');}}
    }).catch(()=>{});
    loadFilterDropdowns();
})();

function loadFilterDropdowns() {
    fetch('@Url.Action("GetOffersReportLookups","Reports")', { credentials:'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.statuses) {
                var sel = document.getElementById('statusFilter');
                d.statuses.forEach(function(s) {
                    var opt = document.createElement('option');
                    opt.value = s.code; opt.textContent = s.name;
                    sel.appendChild(opt);
                    _statusLookup[s.code] = s.color;
                    _statusLookup[s.name] = s.color;
                });
            }
            if (d.stores) {
                var selSt = document.getElementById('storeFilter');
                d.stores.forEach(function(s) {
                    var opt = document.createElement('option');
                    opt.value = s.id; opt.textContent = s.name;
                    selSt.appendChild(opt);
                });
            }
            if (d.agents) {
                var selAg = document.getElementById('agentFilter');
                d.agents.forEach(function(a) {
                    var opt = document.createElement('option');
                    opt.value = a.id; opt.textContent = a.name;
                    selAg.appendChild(opt);
                });
            }
            @if (hasSavedLayout && savedLayout != null) {
                <text>applyLayoutParameters(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(savedLayout)));</text>
            }
        }).catch(function(){});
}

function escapeHtml(s) { if (!s) return ''; var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
function statusBadgeStyle(hex) {
    hex = (hex||'#999').replace('#','');
    if (hex.length === 3) hex = hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
    var r = parseInt(hex.substr(0,2),16), g = parseInt(hex.substr(2,2),16), b = parseInt(hex.substr(4,2),16);
    var lum = (0.299*r + 0.587*g + 0.114*b) / 255;
    if (lum > 0.85) return 'background:'+('#'+hex)+';color:#1e293b;border-color:rgba(0,0,0,.25);';
    if (lum > 0.6) return 'background:'+('#'+hex)+';color:#1e293b;';
    return 'background:'+('#'+hex)+';color:#fff;';
}
function fmtDate(d) { return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }
function fmtInt(v) { if (v==null) return '0'; return Number(v).toLocaleString(undefined,{maximumFractionDigits:0}); }
function formatNumber(v) { if (v === 0) return '0.00'; return Number(v).toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2}); }

function clearPreset() { document.querySelectorAll('input[name="DatePreset"]').forEach(r=>r.checked=false); }

function resetFilters() {
    var today = new Date(), y = today.getFullYear();
    document.getElementById('dateFrom').value = y+'-01-01';
    document.getElementById('dateTo').value = fmtDate(today);
    document.getElementById('dateField').value = 'DateTrans';
    document.getElementById('statusFilter').value = 'All';
    document.getElementById('storeFilter').value = 'All';
    document.getElementById('agentFilter').value = 'All';
    document.getElementById('offerTypeFilter').value = 'All';
    document.getElementById('includeHistory').checked = false;
    document.getElementById('primaryGroup').value = 'NONE';
    document.getElementById('secondaryGroup').value = 'NONE';
    document.getElementById('maxRecords').value = '50000';
    clearPreset();
    _sortCol = 'DateTrans'; _sortDir = 'DESC';
    document.getElementById('reportResults').style.display = 'none';
    document.getElementById('kpiCards').style.display = 'none';
    document.getElementById('reportAlert').style.display = 'none';
    _lastData = [];
    document.getElementById('layoutsCurrentName').textContent = 'Layouts';
    resetColumnVisibility();
}

function applyPresetDates(preset) {
    var today = new Date(), y = today.getFullYear(), m = today.getMonth(), d = today.getDate();
    var from, to;
    switch(preset) {
        case 'today': from = to = today; break;
        case 'yesterday': from = to = new Date(y,m,d-1); break;
        case 'last7': from = new Date(y,m,d-7); to = today; break;
        case 'last30': from = new Date(y,m,d-30); to = today; break;
        case 'thisMonth': from = new Date(y,m,1); to = today; break;
        case 'lastMonth': from = new Date(y,m-1,1); to = new Date(y,m,0); break;
        case 'ytd': from = new Date(y,0,1); to = today; break;
        case 'lastYear': from = new Date(y-1,0,1); to = new Date(y-1,11,31); break;
        default: return;
    }
    document.getElementById('dateFrom').value = fmtDate(from);
    document.getElementById('dateTo').value = fmtDate(to);
}

function showAlert(id, type, msg) {
    var el = document.getElementById(id);
    el.innerHTML = '<div class="alert alert-'+type+' alert-dismissible fade show"><i class="bi bi-info-circle me-2"></i>'+escapeHtml(msg)+'<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
    el.style.display = '';
}

function getFilterParams() {
    return {
        dateFrom: document.getElementById('dateFrom').value,
        dateTo: document.getElementById('dateTo').value,
        dateField: document.getElementById('dateField').value,
        statusFilter: document.getElementById('statusFilter').value,
        storeFilter: document.getElementById('storeFilter').value,
        agentFilter: document.getElementById('agentFilter').value,
        primaryGroup: document.getElementById('primaryGroup').value,
        secondaryGroup: document.getElementById('secondaryGroup').value,
        maxRecords: document.getElementById('maxRecords').value,
        sortColumn: _sortCol,
        sortDirection: _sortDir,
        offerType: document.getElementById('offerTypeFilter').value,
        includeHistory: document.getElementById('includeHistory').checked
    };
}

function buildExportUrl(action) {
    var p = getFilterParams();
    var qs = 'dateFrom='+p.dateFrom+'&dateTo='+p.dateTo+'&dateField='+p.dateField
        +'&statusFilter='+encodeURIComponent(p.statusFilter)+'&storeFilter='+encodeURIComponent(p.storeFilter)
        +'&agentFilter='+encodeURIComponent(p.agentFilter)
        +'&primaryGroup='+p.primaryGroup+'&secondaryGroup='+p.secondaryGroup
        +'&maxRecords='+p.maxRecords+'&sortColumn='+p.sortColumn+'&sortDirection='+p.sortDirection
        +'&offerType='+encodeURIComponent(p.offerType)+'&includeHistory='+p.includeHistory;
    return '/Reports/' + action + '?' + qs;
}

function exportServerCsv() { if(!_lastData.length){alert('Generate a report first.');return;} window.location.href=buildExportUrl('ExportOffersReportCsv'); }
function exportServerExcel() { if(!_lastData.length){alert('Generate a report first.');return;} window.location.href=buildExportUrl('ExportOffersReportExcel'); }
function exportServerPdf() { if(!_lastData.length){alert('Generate a report first.');return;} window.location.href=buildExportUrl('ExportOffersReportPdf'); }

var previewOpen = false;
function togglePreview() {
    if (!_lastData.length) { alert('Generate a report first.'); return; }
    var panel = document.getElementById('previewPanel');
    var gridCard = document.getElementById('results');
    var btn = document.getElementById('previewToggleBtn');
    previewOpen = !previewOpen;
    if (previewOpen) {
        gridCard.style.display = 'none';
        panel.style.display = 'block';
        btn.innerHTML = '<i class="bi bi-table me-1"></i>Grid';
        btn.classList.remove('btn-outline-primary'); btn.classList.add('btn-outline-warning');
        var frame = document.getElementById('previewFrame');
        frame.src = buildExportUrl('OffersReportPrintPreview');
        frame.onload = function() { try { var h = frame.contentDocument.body.scrollHeight+80; frame.style.height=Math.max(h,700)+'px'; } catch(e){frame.style.height='900px';} };
    } else {
        panel.style.display = 'none'; gridCard.style.display = '';
        btn.innerHTML = '<i class="bi bi-eye me-1"></i>Preview';
        btn.classList.remove('btn-outline-warning'); btn.classList.add('btn-outline-primary');
    }
}

function generateReport() {
    var dateFrom = document.getElementById('dateFrom').value;
    var dateTo = document.getElementById('dateTo').value;
    if (!dateFrom || !dateTo) { showAlert('reportAlert','danger','Please select both From and To dates.'); return; }
    if (dateFrom > dateTo) { showAlert('reportAlert','danger','Date From cannot be after Date To.'); return; }
    var pg = document.getElementById('primaryGroup').value;
    var sg = document.getElementById('secondaryGroup').value;
    if (pg !== 'NONE' && sg !== 'NONE' && pg === sg) { showAlert('reportAlert','danger','Primary and Secondary groups must be different.'); return; }

    document.getElementById('reportAlert').style.display = 'none';
    document.getElementById('reportResults').style.display = 'none';
    document.getElementById('kpiCards').style.display = 'none';
    document.getElementById('reportLoading').style.display = '';

    var btn = document.getElementById('generateBtn');
    btn.querySelector('.btn-text').classList.add('d-none');
    btn.querySelector('.spinner-border').classList.remove('d-none');
    btn.disabled = true;

    var fd = new FormData();
    var p = getFilterParams();
    Object.keys(p).forEach(function(k) { fd.append(k, p[k]); });

    fetch('@Url.Action("GetOffersReportData","Reports")', { method:'POST', body:fd, credentials:'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            document.getElementById('reportLoading').style.display = 'none';
            btn.querySelector('.btn-text').classList.remove('d-none');
            btn.querySelector('.spinner-border').classList.add('d-none');
            btn.disabled = false;
            if (!d.success) { showAlert('reportAlert','danger',d.message); return; }
            _lastData = d.data || [];
            _lastTotalRecords = d.totalRecords || _lastData.length;
            renderKpis(_lastData);
            renderTable(_lastData);
            var info = _lastData.length + ' row(s)';
            if (_lastTotalRecords > _lastData.length) info += ' (limited from ' + fmtInt(_lastTotalRecords) + ')';
            document.getElementById('rowCountInfo').textContent = info;
            var badges = '';
            if (pg !== 'NONE') badges += '<span class="badge bg-secondary ms-2">Grouped by '+pg+'</span>';
            if (sg !== 'NONE') badges += '<span class="badge bg-secondary ms-1">then '+sg+'</span>';
            document.getElementById('groupBadges').innerHTML = badges;
            document.getElementById('reportResults').style.display = '';
            if (_lastData.length === 0) showAlert('reportAlert','info','No offers found for the selected criteria.');
        })
        .catch(function(e) {
            document.getElementById('reportLoading').style.display = 'none';
            btn.querySelector('.btn-text').classList.remove('d-none');
            btn.querySelector('.spinner-border').classList.add('d-none');
            btn.disabled = false;
            showAlert('reportAlert','danger','Request failed: '+e.message);
        });
}

function renderKpis(data) {
    var cards = document.getElementById('kpiCards');
    if (!data.length) { cards.style.display = 'none'; return; }

    var totalGrand = 0, totalDisc = 0, totalVat = 0, totalCost = 0, totalItems = 0;
    var statusCounts = {};
    data.forEach(function(r) {
        totalGrand += (r.invoiceGrandTotal||0);
        totalDisc += (r.invoiceTotalDiscount||0);
        totalVat += (r.invoiceVat||0);
        totalCost += (r.totalItemCost||0);
        totalItems += (r.itemCount||0);
        var s = r.statusName || 'Unknown';
        statusCounts[s] = (statusCounts[s]||0) + 1;
    });

    var html = '<div class="col-6 col-md-2"><div class="stat-card text-center"><div class="stat-value" style="color:#7c3aed;">'+fmtInt(data.length)+'</div><div class="stat-label">Total Offers</div></div></div>';
    html += '<div class="col-6 col-md-2"><div class="stat-card text-center"><div class="stat-value text-success">'+formatNumber(totalGrand)+'</div><div class="stat-label">Grand Total</div></div></div>';
    html += '<div class="col-6 col-md-2"><div class="stat-card text-center"><div class="stat-value text-warning">'+formatNumber(totalDisc)+'</div><div class="stat-label">Total Discount</div></div></div>';
    html += '<div class="col-6 col-md-2"><div class="stat-card text-center"><div class="stat-value text-info">'+formatNumber(totalVat)+'</div><div class="stat-label">Total VAT</div></div></div>';
    html += '<div class="col-6 col-md-2"><div class="stat-card text-center"><div class="stat-value text-danger">'+formatNumber(totalCost)+'</div><div class="stat-label">Total Cost</div></div></div>';
    html += '<div class="col-6 col-md-2"><div class="stat-card text-center"><div class="stat-value text-primary">'+fmtInt(totalItems)+'</div><div class="stat-label">Total Items</div></div></div>';

    Object.keys(statusCounts).forEach(function(s) {
        var color = _statusLookup[s] || '#64748b';
        html += '<div class="col-6 col-md-2"><div class="stat-card text-center"><div class="stat-value" style="color:'+color+'">'+fmtInt(statusCounts[s])+'</div><div class="stat-label">'+escapeHtml(s)+'</div></div></div>';
    });

    cards.innerHTML = html;
    cards.style.display = '';
}

function renderTable(data) {
    var thead = document.getElementById('reportHead');
    var tbody = document.getElementById('reportBody');
    var hasPrimary = document.getElementById('primaryGroup').value !== 'NONE';
    var hasSecondary = document.getElementById('secondaryGroup').value !== 'NONE';
    var pgLabel = document.getElementById('primaryGroup').selectedOptions[0].textContent;
    var sgLabel = document.getElementById('secondaryGroup').selectedOptions[0].textContent;

    function sth(label, col, align, dataCol) {
        var dc = dataCol || col;
        var cls = 'sortable' + (align ? ' text-end' : '');
        if (_sortCol === col) cls += _sortDir === 'ASC' ? ' sort-asc' : ' sort-desc';
        var icon = _sortCol === col ? (_sortDir === 'ASC' ? 'bi-caret-up-fill' : 'bi-caret-down-fill') : 'bi-caret-up-fill';
        return '<th data-col="'+dc+'" class="'+cls+'" onclick="sortBy(\''+col+'\')">'+label+'<i class="bi '+icon+' sort-icon"></i></th>';
    }
    var hdr = '<tr>';
    if (hasPrimary) hdr += sth(escapeHtml(pgLabel), 'level1Descr');
    if (hasSecondary) hdr += sth(escapeHtml(sgLabel), 'level2Descr');
    hdr += sth('Offer No','offerNo','','OfferNo') + sth('Date','dateTrans','','DateTrans') + sth('Valid Until','validUntil','','ValidUntil');
    hdr += sth('Status','statusName','','StatusName') + sth('Customer','customerName','','CustomerName') + sth('Store','storeName','','StoreName') + sth('Agent','agentName','','AgentName');
    hdr += sth('Items','itemCount',true,'ItemCount') + sth('Qty','totalQuantity',true,'TotalQuantity');
    hdr += sth('Subtotal','invoiceTotal',true,'InvoiceTotal') + sth('Discount','invoiceTotalDiscount',true,'InvoiceTotalDiscount');
    hdr += sth('VAT','invoiceVat',true,'InvoiceVat') + sth('Grand Total','invoiceGrandTotal',true,'InvoiceGrandTotal');
    hdr += sth('Cost','totalItemCost',true,'TotalItemCost') + sth('Order %','orderPercentage',true,'OrderPercentage');
    hdr += '<th data-col="LinkedLead">Lead</th><th data-col="Comments">Comments</th><th data-col="InternalNotes">Internal Notes</th>';
    hdr += sth('Source','source','','Source');
    hdr += '</tr>';
    thead.innerHTML = hdr;
    applyColumnVisibility();

    if (hasPrimary) {
        tbody.innerHTML = renderGroupedRows(data, hasPrimary, hasSecondary, pgLabel, sgLabel);
    } else {
        tbody.innerHTML = renderRows(data, hasPrimary, hasSecondary);
    }
}

function renderGroupedRows(data, hasPrimary, hasSecondary, pgLabel, sgLabel) {
    var colCount = 20 + (hasPrimary?1:0) + (hasSecondary?1:0);
    var groups = groupBy(data, 'level1Descr');
    var html = '';
    groups.forEach(function(g) {
        html += '<tr class="group-header-row"><td colspan="'+colCount+'"><i class="bi bi-diagram-3 me-2"></i><strong>'+escapeHtml(pgLabel)+':</strong> '+escapeHtml(g.key)+' <span class="badge bg-secondary">'+g.items.length+'</span></td></tr>';
        if (hasSecondary) {
            var subGroups = groupBy(g.items, 'level2Descr');
            subGroups.forEach(function(sg2) {
                html += '<tr class="group-header-row l2"><td colspan="'+colCount+'" class="ps-4"><i class="bi bi-chevron-right me-1"></i><strong>'+escapeHtml(sgLabel)+':</strong> '+escapeHtml(sg2.key)+' <span class="badge bg-info">'+sg2.items.length+'</span></td></tr>';
                html += renderRows(sg2.items, hasPrimary, hasSecondary);
            });
        } else {
            html += renderRows(g.items, hasPrimary, hasSecondary);
        }
    });
    return html;
}

function renderRows(items, hasPrimary, hasSecondary) {
    var html = '';
    for (var i = 0; i < items.length; i++) {
        var r = items[i];
        var dateTr = r.dateTrans ? new Date(r.dateTrans).toLocaleDateString() : '';
        var validUntil = r.validUntil ? new Date(r.validUntil).toLocaleDateString() : '';
        html += '<tr>';
        if (hasPrimary) html += '<td class="text-info fw-semibold">'+escapeHtml(r.level1Descr)+'</td>';
        if (hasSecondary) html += '<td class="text-info">'+escapeHtml(r.level2Descr)+'</td>';
        html += '<td class="text-nowrap">'+escapeHtml(r.offerNo)+'</td>';
        html += '<td class="text-nowrap">'+escapeHtml(dateTr)+'</td>';
        html += '<td class="text-nowrap">'+escapeHtml(validUntil)+'</td>';
        html += '<td><span class="status-badge" style="'+statusBadgeStyle(r.statusColor)+'">'+escapeHtml(r.statusName)+'</span></td>';
        html += '<td>'+escapeHtml(r.customerName)+'</td>';
        html += '<td>'+escapeHtml(r.storeName)+'</td>';
        html += '<td>'+escapeHtml(r.agentName)+'</td>';
        html += '<td class="text-end">'+(r.itemCount||0)+'</td>';
        html += '<td class="text-end">'+formatNumber(r.totalQuantity||0)+'</td>';
        html += '<td class="text-end">'+formatNumber(r.invoiceTotal||0)+'</td>';
        html += '<td class="text-end">'+formatNumber(r.invoiceTotalDiscount||0)+'</td>';
        html += '<td class="text-end">'+formatNumber(r.invoiceVat||0)+'</td>';
        html += '<td class="text-end fw-semibold">'+formatNumber(r.invoiceGrandTotal||0)+'</td>';
        html += '<td class="text-end">'+formatNumber(r.totalItemCost||0)+'</td>';
        html += '<td class="text-end">'+(r.orderPercentage||0).toFixed(1)+'%</td>';
        html += '<td>'+escapeHtml(r.linkedLead||'')+'</td>';
        html += '<td style="white-space:normal;word-break:break-word;">'+escapeHtml(r.comments||'')+'</td>';
        html += '<td style="white-space:normal;word-break:break-word;">'+escapeHtml(r.internalNotes||'')+'</td>';
        var srcCls = r.source === 'History' ? 'bg-secondary' : (r.source === 'Standard Offer' ? 'bg-info text-dark' : 'bg-primary');
        html += '<td><span class="badge '+srcCls+'">'+escapeHtml(r.source||'Offer')+'</span></td>';
        html += '</tr>';
    }
    return html;
}

function sortBy(col) {
    if (_sortCol === col) { _sortDir = _sortDir === 'ASC' ? 'DESC' : 'ASC'; }
    else { _sortCol = col; _sortDir = 'ASC'; }
    var dateFields = { dateTrans:1, validUntil:1, deliveryDate:1 };
    var numFields = { itemCount:1, totalQuantity:1, invoiceTotal:1, invoiceTotalDiscount:1, invoiceVat:1, invoiceGrandTotal:1, totalItemCost:1, orderPercentage:1, invoiceDiscountPerc:1 };
    _lastData.sort(function(a, b) {
        var va = a[col], vb = b[col];
        if (va == null) va = ''; if (vb == null) vb = '';
        var cmp;
        if (dateFields[col]) { cmp = new Date(va||0) - new Date(vb||0); }
        else if (numFields[col]) { cmp = Number(va) - Number(vb); }
        else { cmp = String(va).localeCompare(String(vb)); }
        return _sortDir === 'ASC' ? cmp : -cmp;
    });
    renderTable(_lastData);
}

function groupBy(arr, key) {
    var map = {}, order = [];
    arr.forEach(function(item) {
        var k = item[key] || '';
        if (!map[k]) { map[k] = []; order.push(k); }
        map[k].push(item);
    });
    return order.map(function(k) { return { key: k, items: map[k] }; });
}

// ========== SCHEDULE ==========
function loadSchedules() {
    fetch('@Url.Action("GetOffersReportSchedules","Reports")', { credentials:'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            var container = document.getElementById('existingSchedules');
            var list = d.schedules || [];
            if (!list.length) { container.innerHTML = '<p class="text-muted">No schedules configured yet.</p>'; return; }
            var html = '<table class="table table-sm table-bordered mb-0"><thead class="table-light"><tr><th>Name</th><th>Recurrence</th><th>Time</th><th>Format</th><th>Next Run</th><th></th></tr></thead><tbody>';
            for (var i = 0; i < list.length; i++) {
                var s = list[i];
                html += '<tr><td>'+escapeHtml(s.scheduleName)+'</td><td>'+escapeHtml(s.recurrenceType)+'</td><td>'+escapeHtml(s.scheduleTime)+'</td><td>'+escapeHtml(s.exportFormat)+'</td><td>'+escapeHtml(s.nextRun||'-')+'</td>';
                html += '<td class="text-nowrap"><button class="btn btn-sm btn-outline-primary me-1" onclick="loadScheduleIntoForm('+s.scheduleId+')"><i class="bi bi-pencil"></i></button>';
                html += '<button class="btn btn-sm btn-outline-danger" onclick="deleteSchedule('+s.scheduleId+')"><i class="bi bi-trash"></i></button></td></tr>';
            }
            html += '</tbody></table>';
            container.innerHTML = html;
        }).catch(function() { document.getElementById('existingSchedules').innerHTML = '<p class="text-danger">Failed to load schedules.</p>'; });
}
function resetScheduleForm() {
    document.getElementById('schedId').value = '';
    document.getElementById('schedName').value = '';
    document.getElementById('schedRecipients').value = '';
    document.getElementById('schedRecurrence').value = 'Daily';
    document.getElementById('schedTime').value = '08:00';
    document.getElementById('schedFormat').value = 'CSV';
    document.getElementById('schedSkipIfEmpty').checked = true;
    document.getElementById('schedIncludeAi').checked = false;
    document.getElementById('scheduleAlert').style.display = 'none';
}
function saveSchedule() {
    var name = document.getElementById('schedName').value.trim();
    var recipients = document.getElementById('schedRecipients').value.trim();
    if (!name) { showAlert('scheduleAlert','danger','Schedule name is required.'); return; }
    if (!recipients) { showAlert('scheduleAlert','danger','At least one recipient is required.'); return; }
    var fd = new FormData();
    fd.append('scheduleName',name);
    fd.append('recurrenceType',document.getElementById('schedRecurrence').value);
    fd.append('exportFormat',document.getElementById('schedFormat').value);
    fd.append('scheduleTime',document.getElementById('schedTime').value);
    fd.append('recipients',recipients);
    fd.append('skipIfEmpty',document.getElementById('schedSkipIfEmpty').checked);
    fd.append('includeAiAnalysis',document.getElementById('schedIncludeAi').checked);
    var sid = document.getElementById('schedId').value;
    if (sid) fd.append('scheduleId', sid);
    var filterData = JSON.stringify(getFilterParams());
    fd.append('filterJson', filterData);
    fetch('@Url.Action("SaveOffersReportSchedule","Reports")', { method:'POST', body:fd, credentials:'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (!d.success) { showAlert('scheduleAlert','danger',d.message); return; }
            showAlert('scheduleAlert','success','Schedule saved.');
            resetScheduleForm(); loadSchedules();
        }).catch(function(e) { showAlert('scheduleAlert','danger','Save failed: '+e.message); });
}
function loadScheduleIntoForm(id) {
    fetch('@Url.Action("GetScheduleById","Reports")?scheduleId='+id, { credentials:'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(s) {
            if (!s || s.error) return;
            document.getElementById('schedId').value = s.scheduleId;
            document.getElementById('schedName').value = s.scheduleName||'';
            document.getElementById('schedRecipients').value = s.recipients||'';
            document.getElementById('schedRecurrence').value = s.recurrenceType||'Daily';
            document.getElementById('schedTime').value = s.scheduleTime||'08:00';
            document.getElementById('schedFormat').value = s.exportFormat||'CSV';
            document.getElementById('schedSkipIfEmpty').checked = s.skipIfEmpty !== false;
            showAlert('scheduleAlert','info','Editing: '+escapeHtml(s.scheduleName));
        });
}
function deleteSchedule(id) {
    if (!confirm('Delete this schedule?')) return;
    fetch('@Url.Action("DeleteSchedule","Reports")?scheduleId='+id, { method:'POST', credentials:'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) { if (d.success) { loadSchedules(); resetScheduleForm(); } else showAlert('scheduleAlert','danger',d.message||'Delete failed.'); });
}

// ========== SEND EMAIL ==========
function validateEmailList(input) {
    if(!input||!input.trim()) return {valid:false,errors:['Enter at least one email.']};
    var emails = input.split(/[,;]/).map(function(e){return e.trim();}).filter(function(e){return e.length>0;});
    var re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
    var invalid = emails.filter(function(e){return !re.test(e);});
    if(invalid.length>0) return {valid:false,errors:invalid.map(function(e){return 'Invalid: '+e;})};
    return {valid:true,emails:emails,errors:[]};
}
function openSendEmailModal() {
    if (!_lastData.length) { alert('Generate a report first.'); return; }
    document.getElementById('sendEmailRecipients').value = '';
    document.getElementById('sendEmailAlert').style.display = 'none';
    document.getElementById('sendEmailRecipients').classList.remove('is-invalid');
    document.getElementById('sendEmailSubject').value = 'Offers Report \u2014 '+document.getElementById('dateFrom').value+' to '+document.getElementById('dateTo').value;
    loadEmailTemplates();
    var m = new bootstrap.Modal(document.getElementById('sendEmailModal')); m.show();
}
function loadEmailTemplates() {
    fetch('@Url.Action("GetEmailTemplates","Reports")?reportType=OffersReport').then(r=>r.json()).then(function(data) {
        _emailTemplatesCache = data||[];
        var sel = document.getElementById('sendEmailTemplate');
        sel.innerHTML = '<option value="">-- No template (default) --</option>';
        data.forEach(function(t) {
            var opt = document.createElement('option'); opt.value=t.templateId; opt.textContent=t.templateName+(t.isDefault?' (default)':'');
            if(t.isDefault) opt.selected=true; sel.appendChild(opt);
        });
        onEmailTemplateChange();
    }).catch(function(){});
}
function onEmailTemplateChange() {
    var sel = document.getElementById('sendEmailTemplate');
    var id = parseInt(sel.value,10);
    var preview = document.getElementById('sendEmailBodyPreview');
    if(isNaN(id)||!id) { preview.innerHTML='<em class="text-muted">Default email body will be used.</em>'; return; }
    var tmpl = _emailTemplatesCache.find(function(t){return t.templateId===id;});
    if(!tmpl) return;
    if(tmpl.emailSubject) document.getElementById('sendEmailSubject').value = tmpl.emailSubject;
    if(tmpl.emailBodyHtml) preview.innerHTML = tmpl.emailBodyHtml;
}
function sendReportEmail() {
    var ri = document.getElementById('sendEmailRecipients');
    var ad = document.getElementById('sendEmailAlert');
    var v = validateEmailList(ri.value);
    if(!v.valid) { ri.classList.add('is-invalid'); document.getElementById('sendEmailRecipientsError').textContent=v.errors.join('; '); return; }
    ri.classList.remove('is-invalid');
    var btn = document.getElementById('sendEmailBtn');
    var sp = document.getElementById('sendEmailSpinner');
    var ic = document.getElementById('sendEmailIcon');
    btn.disabled=true; sp.classList.remove('d-none'); ic.classList.add('d-none');
    var fd = new FormData();
    fd.append('recipients',ri.value.trim());
    fd.append('cc',(document.getElementById('sendEmailCC').value||'').trim());
    fd.append('bcc',(document.getElementById('sendEmailBCC').value||'').trim());
    fd.append('emailSubject',document.getElementById('sendEmailSubject').value);
    fd.append('exportFormat',document.getElementById('sendEmailFormat').value);
    fd.append('templateId',document.getElementById('sendEmailTemplate').value||'');
    var p = getFilterParams();
    Object.keys(p).forEach(function(k) { fd.append(k, p[k]); });
    fetch('@Url.Action("SendOffersReportEmail","Reports")', { method:'POST', body:fd })
        .then(r=>r.json())
        .then(function(d) {
            btn.disabled=false; sp.classList.add('d-none'); ic.classList.remove('d-none');
            ad.innerHTML='<div class="alert alert-'+(d.success?'success':'danger')+' mb-0">'+(d.success?'<i class="bi bi-check-circle me-1"></i>':'<i class="bi bi-exclamation-triangle me-1"></i>')+escapeHtml(d.message)+'</div>';
            ad.style.display='';
        }).catch(function() {
            btn.disabled=false; sp.classList.add('d-none'); ic.classList.remove('d-none');
            ad.innerHTML='<div class="alert alert-danger mb-0">Network error.</div>'; ad.style.display='';
        });
}

// ========== AI ANALYSIS ==========
function saveAiLang(v) { localStorage.setItem('or_ai_lang', v); }
function getAiLang() { return localStorage.getItem('or_ai_lang') || 'el'; }
(function() { var s = document.getElementById('aiLangSelect'); if (s) s.value = getAiLang(); })();

function analyzeReport() {
    if (!_lastData.length) { alert('Generate a report first.'); return; }
    var modalEl = document.getElementById('aiAnalysisModal');
    var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
    document.getElementById('aiLoading').classList.remove('d-none');
    document.getElementById('aiError').classList.add('d-none');
    document.getElementById('aiResults').classList.add('d-none');
    document.getElementById('aiPromptEditor').classList.add('d-none');
    document.getElementById('btnReanalyze').style.display = 'none';
    modal.show();
    var fd = new FormData();
    var p = getFilterParams();
    Object.keys(p).forEach(function(k) { fd.append(k, p[k]); });
    fd.append('locale', getAiLang());
    var promptTplId = document.getElementById('aiPromptTemplateSelect').value;
    if (promptTplId && promptTplId !== '0') fd.append('promptTemplateId', promptTplId);
    fetch('@Url.Action("AnalyzeOffersReport","Reports")', { method:'POST', body:fd })
        .then(r=>r.json())
        .then(function(data) {
            document.getElementById('aiLoading').classList.add('d-none');
            if (!data.success) {
                document.getElementById('aiError').classList.remove('d-none');
                document.getElementById('aiErrorMsg').textContent = data.message;
                document.getElementById('btnReanalyze').style.display = 'inline-block';
                return;
            }
            renderAiAnalysis(data.analysis);
            initAiConversation(data.analysis, data.csvPreview);
            document.getElementById('aiResults').classList.remove('d-none');
            document.getElementById('btnReanalyze').style.display = 'inline-block';
        }).catch(function(err) {
            document.getElementById('aiLoading').classList.add('d-none');
            document.getElementById('aiError').classList.remove('d-none');
            document.getElementById('aiErrorMsg').textContent = 'Network error: '+err.message;
            document.getElementById('btnReanalyze').style.display = 'inline-block';
        });
}

function renderAiAnalysis(a) {
    if (a.healthScore != null) {
        var badge = document.getElementById('aiHealthBadge');
        var color = a.healthScore >= 80 ? '#22c55e' : a.healthScore >= 60 ? '#eab308' : '#ef4444';
        badge.style.background = color; badge.style.color = '#fff'; badge.textContent = a.healthScore;
        document.getElementById('aiHealthLabel').textContent = a.healthLabel || '';
        document.getElementById('aiTrendDesc').textContent = a.trendDescription || '';
        var tb = document.getElementById('aiTrendBadge');
        if (a.trend === 'up') { tb.className='badge fs-6 px-3 py-2 bg-success'; tb.textContent='\u2191 Improving'; }
        else if (a.trend === 'down') { tb.className='badge fs-6 px-3 py-2 bg-danger'; tb.textContent='\u2193 Declining'; }
        else { tb.className='badge fs-6 px-3 py-2 bg-secondary'; tb.textContent='\u2192 Stable'; }
        document.getElementById('aiHealthBanner').style.display = '';
    } else { document.getElementById('aiHealthBanner').style.display = 'none'; }
    document.getElementById('aiExecSummary').innerHTML = a.executiveSummary || '';
    var kpiHtml = '';
    if (a.kpis && a.kpis.length) { a.kpis.forEach(function(k){ kpiHtml += '<div class="col-6 col-md-3"><div class="stat-card text-center"><div class="stat-value">'+escapeHtml(k.value)+'</div><div class="stat-label">'+escapeHtml(k.label)+'</div></div></div>'; }); }
    document.getElementById('aiKpis').innerHTML = kpiHtml;
    document.getElementById('aiKeyFindings').innerHTML = renderList(a.keyFindings);
    document.getElementById('aiRecs').innerHTML = renderList(a.recommendations);
    document.getElementById('aiTopPerformers').innerHTML = renderList(a.topPerformers);
    document.getElementById('aiBottomPerformers').innerHTML = renderList(a.bottomPerformers);
    if (a.alerts && a.alerts.length) {
        var ah = '<div class="card border-0 shadow-sm"><div class="card-header bg-transparent border-0 pb-0"><h6 class="mb-0"><i class="bi bi-bell-fill text-danger me-2"></i>Alerts</h6></div><div class="card-body pt-2">'+renderList(a.alerts)+'</div></div>';
        document.getElementById('aiAlertsSection').innerHTML = ah;
    } else { document.getElementById('aiAlertsSection').innerHTML = ''; }
    document.getElementById('aiModel').textContent = a.model || '';
    document.getElementById('aiTokens').textContent = a.inputTokens ? ('In: '+a.inputTokens+' Out: '+a.outputTokens) : '';
    document.getElementById('aiTime').textContent = a.durationMs ? ((a.durationMs/1000).toFixed(1)+'s') : '';
}
function renderList(arr) {
    if (!arr || !arr.length) return '<p class="text-muted small">None</p>';
    return '<ul class="mb-0">'+arr.map(function(item){return '<li>'+escapeHtml(typeof item === 'string' ? item : item.text || JSON.stringify(item))+'</li>';}).join('')+'</ul>';
}
function estimateAiCost(inp,out) { return '$'+((inp*0.000003+out*0.000015).toFixed(4)); }

function initAiConversation(analysisJson, csvData) {
    _aiConversation = [{role:'system',content:'You are a sales analyst. The user received an AI analysis of their offers report. Raw CSV data is below. Be concise, cite specific values. Respond in the same language as the analysis.'}];
    if(csvData) _aiConversation.push({role:'user',content:'Here is the raw report data:\n'+csvData});
    _aiConversation.push({role:'assistant',content:JSON.stringify(analysisJson)});
}

function sendAiChat() {
    var input = document.getElementById('aiChatInput');
    var msg = input.value.trim();
    if (!msg) return;
    input.value = '';
    appendChatBubble('user', msg);
    var btn = document.getElementById('btnSendChat'); btn.disabled=true; input.disabled=true;
    var thinkingId = 'thinking_'+Date.now();
    appendChatBubble('thinking', 'Thinking...', thinkingId);
    fetch('/Reports/AiChatFollowup', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({history:_aiConversation,message:msg}) })
        .then(function(r){return r.json();})
        .then(function(data) {
            removeChatBubble(thinkingId); btn.disabled=false; input.disabled=false; input.focus();
            if(!data.success){appendChatBubble('error',data.message||'Failed.');return;}
            _aiConversation.push({role:'user',content:msg});
            _aiConversation.push({role:'assistant',content:data.content});
            appendChatBubble('assistant',data.content);
            _aiTotalChatTokens.input += (data.inputTokens||0);
            _aiTotalChatTokens.output += (data.outputTokens||0);
            var info = document.getElementById('aiChatTokenInfo');
            info.style.display=''; info.innerHTML='<i class="bi bi-currency-dollar me-1"></i>Chat: '+estimateAiCost(_aiTotalChatTokens.input,_aiTotalChatTokens.output);
        }).catch(function(err) {
            removeChatBubble(thinkingId); btn.disabled=false; input.disabled=false;
            appendChatBubble('error','Network error: '+err.message);
        });
}

function appendChatBubble(role, content, id) {
    var container = document.getElementById('aiChatMessages');
    var div = document.createElement('div');
    if(id) div.id = id;
    div.className = 'mb-2 p-2 rounded small';
    if(role==='user') { div.style.cssText='background:#ede9fe;margin-left:20%;'; div.innerHTML='<strong>You:</strong> '+escapeHtml(content); }
    else if(role==='assistant') { div.style.cssText='background:#f0fdf4;margin-right:20%;'; div.innerHTML='<strong>AI:</strong> '+escapeHtml(content); }
    else if(role==='thinking') { div.style.cssText='background:#fefce8;'; div.innerHTML='<span class="spinner-border spinner-border-sm me-2"></span>'+escapeHtml(content); }
    else { div.style.cssText='background:#fef2f2;'; div.innerHTML='<i class="bi bi-exclamation-triangle me-1"></i>'+escapeHtml(content); }
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
}
function removeChatBubble(id) { var el = document.getElementById(id); if(el) el.remove(); }

function togglePromptEditor() { document.getElementById('aiPromptEditor').classList.toggle('d-none'); if(!document.getElementById('aiPromptEditor').classList.contains('d-none')) loadAiPromptTemplates(); }
function clearPromptEditor() { document.getElementById('aiPromptName').value=''; document.getElementById('aiPromptText').value=''; document.getElementById('aiPromptIsDefault').checked=false; }
function loadAiPromptTemplates() {
    fetch('/Reports/GetAiPromptTemplates?reportType=OffersReport').then(r=>r.json()).then(function(data) {
        var sel = document.getElementById('aiPromptTemplateSelect');
        sel.innerHTML='<option value="0" style="color:#333;">Default Prompt</option>';
        var listHtml = '';
        (data||[]).forEach(function(t) {
            var opt = document.createElement('option'); opt.value=t.templateId; opt.textContent=t.templateName; opt.style.color='#333'; sel.appendChild(opt);
            listHtml += '<div class="d-flex justify-content-between align-items-center border-bottom py-1"><span>'+escapeHtml(t.templateName)+(t.isDefault?' <span class="badge bg-primary">default</span>':'')+'</span>'
                +'<div><button class="btn btn-sm btn-link p-0 me-2" onclick="editAiPrompt('+t.templateId+')">Edit</button><button class="btn btn-sm btn-link text-danger p-0" onclick="deleteAiPrompt('+t.templateId+')">Del</button></div></div>';
        });
        document.getElementById('aiPromptTemplatesList').innerHTML = listHtml || '<em>No templates yet.</em>';
    }).catch(function(){});
}
function saveAiPromptTemplate() {
    var fd = new FormData();
    fd.append('templateName',document.getElementById('aiPromptName').value);
    fd.append('systemPrompt',document.getElementById('aiPromptText').value);
    fd.append('reportType',document.getElementById('aiPromptReportType').value);
    fd.append('isDefault',document.getElementById('aiPromptIsDefault').checked);
    fetch('/Reports/SaveAiPromptTemplate',{method:'POST',body:fd}).then(r=>r.json()).then(function(d){
        document.getElementById('aiPromptAlert').innerHTML=d.success?'<span class="text-success">Saved!</span>':'<span class="text-danger">'+escapeHtml(d.message)+'</span>';
        if(d.success){clearPromptEditor();loadAiPromptTemplates();}
    }).catch(function(){});
}
function deleteAiPrompt(id){if(!confirm('Delete?'))return;fetch('/Reports/DeleteAiPromptTemplate?id='+id,{method:'DELETE'}).then(r=>r.json()).then(function(){loadAiPromptTemplates();});}
function editAiPrompt(id){fetch('/Reports/GetAiPromptTemplate?id='+id).then(r=>r.json()).then(function(t){if(!t)return;document.getElementById('aiPromptName').value=t.templateName||'';document.getElementById('aiPromptText').value=t.systemPrompt||'';document.getElementById('aiPromptIsDefault').checked=!!t.isDefault;}).catch(function(){});}

// ==================== Save / Reset Layout ====================

function collectCurrentLayout() {
    function v(id) { var el = document.getElementById(id); return el ? el.value : ''; }
    var p = {};
    p['DateField'] = v('dateField');
    p['StatusFilter'] = v('statusFilter');
    p['StoreFilter'] = v('storeFilter');
    p['AgentFilter'] = v('agentFilter');
    p['OfferType'] = v('offerTypeFilter');
    p['IncludeHistory'] = document.getElementById('includeHistory').checked ? 'true' : 'false';
    p['PrimaryGroup'] = v('primaryGroup');
    p['SecondaryGroup'] = v('secondaryGroup');
    p['MaxRecords'] = v('maxRecords');
    var hidden = [];
    document.querySelectorAll('.col-toggle').forEach(function(cb) { if (!cb.checked) hidden.push(cb.value); });
    p['HiddenColumns'] = hidden.join(',');
    var preset = document.querySelector('input[name="DatePreset"]:checked');
    if (preset) p['DatePreset'] = preset.value;
    return p;
}

function saveCurrentLayout() {
    var parms = collectCurrentLayout();
    fetch('@Url.Action("SaveOffersReportLayout", "Reports")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(parms)
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) showLayoutToast('Layout saved successfully', 'success');
        else showLayoutToast(data.message || 'Failed to save layout', 'danger');
    })
    .catch(function() { showLayoutToast('Network error saving layout', 'danger'); });
}

function resetSavedLayout() {
    if (!confirm('Reset your saved layout to factory defaults?')) return;
    fetch('@Url.Action("ResetOffersReportLayout", "Reports")', { method: 'POST' })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) {
            showLayoutToast('Layout reset \u2014 reloading...', 'success');
            setTimeout(function() { window.location.href = '@Url.Action("OffersReport")'; }, 800);
        } else {
            showLayoutToast(data.message || 'Failed to reset layout', 'danger');
        }
    })
    .catch(function() { showLayoutToast('Network error', 'danger'); });
}

var __layoutsCache = null;

function isAuthRedirect(response) {
    if (!response) return false;
    if (response.status === 401 || response.status === 403) return true;
    if (response.redirected && /\/Account\/Login/i.test(response.url || '')) return true;
    var ct = response.headers && response.headers.get ? response.headers.get('content-type') : '';
    if (ct && ct.indexOf('text/html') !== -1) return true;
    return false;
}
function showSessionExpiredToast() { showLayoutToast('Session expired \u2014 please reload the page and sign in again.', 'warning'); }

function loadLayoutsList() {
    var menu = document.getElementById('layoutsDropdownMenu');
    if (menu) menu.innerHTML = '<li><h6 class="dropdown-header">Loading...</h6></li>';
    return fetch('@Url.Action("ListOffersReportLayouts", "Reports")', { method: 'GET', credentials: 'same-origin' })
        .then(function(r) {
            if (isAuthRedirect(r)) { if (menu) menu.innerHTML = '<li><h6 class="dropdown-header text-danger">Session expired</h6></li>'; showSessionExpiredToast(); return null; }
            return r.json();
        })
        .then(function(data) {
            if (data == null) return;
            __layoutsCache = data && data.layouts ? data.layouts : [];
            renderLayoutsDropdown(__layoutsCache);
        })
        .catch(function() { if (menu) menu.innerHTML = '<li><h6 class="dropdown-header text-danger">Failed to load</h6></li>'; });
}

function renderLayoutsDropdown(layouts) {
    var menu = document.getElementById('layoutsDropdownMenu');
    if (!menu) return;
    if (!layouts || layouts.length === 0) {
        menu.innerHTML = '<li><h6 class="dropdown-header">No saved layouts</h6></li><li><span class="dropdown-item-text small text-muted">Use "Save as..." to create one.</span></li>';
        return;
    }
    var own = layouts.filter(function(l) { return !l.isPublic; });
    var pub = layouts.filter(function(l) { return  l.isPublic; });
    var html = '';
    function renderGroup(label, items) {
        if (!items.length) return;
        html += '<li><h6 class="dropdown-header">' + label + '</h6></li>';
        items.forEach(function(l) {
            var safeName = String(l.name || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            var publicBadge = l.isPublic ? '<span class="badge bg-secondary ms-2" title="Visible to all users">Public</span>' : '';
            var editorBadge = l.isPublic && l.createdBy ? '<span class="text-muted small ms-2">by ' + String(l.createdBy).replace(/</g,'&lt;') + '</span>' : '';
            html += '<li class="d-flex align-items-center px-2 py-1"><a href="#" class="flex-grow-1 text-decoration-none text-body" onclick="loadNamedLayout(\''+String(l.headerCode).replace(/'/g,"\\'")+'\'); return false;"><i class="bi bi-bookmark me-1"></i>'+safeName+publicBadge+editorBadge+'</a>';
            if (l.canEdit) html += '<button type="button" class="btn btn-sm btn-link text-danger p-0 ms-2" title="Delete" onclick="deleteNamedLayout(\''+String(l.headerCode).replace(/'/g,"\\'")+'\', \''+safeName.replace(/'/g,"\\'")+'\'); return false;"><i class="bi bi-trash"></i></button>';
            html += '</li>';
        });
    }
    renderGroup('Your layouts', own);
    renderGroup('Public layouts', pub);
    menu.innerHTML = html;
}

function loadNamedLayout(headerCode) {
    if (!headerCode) return;
    fetch('@Url.Action("LoadOffersReportLayout", "Reports")?headerCode=' + encodeURIComponent(headerCode), { method: 'POST', credentials: 'same-origin' })
        .then(function(r) { if (isAuthRedirect(r)) { showSessionExpiredToast(); return null; } return r.json(); })
        .then(function(data) {
            if (data == null) return;
            if (!data.success) { showLayoutToast(data.message || 'Failed to load layout', 'danger'); return; }
            applyLayoutParameters(data.parameters || {});
            var label = document.getElementById('layoutsCurrentName');
            if (label && __layoutsCache) {
                var match = __layoutsCache.find(function(l) { return l.headerCode === headerCode; });
                if (match) label.textContent = match.name;
            }
            showLayoutToast('Layout loaded \u2014 click Generate to run.', 'success');
        })
        .catch(function() { showLayoutToast('Network error loading layout', 'danger'); });
}

function applyLayoutParameters(parms) {
    function setVal(id, v) { var el = document.getElementById(id); if (el && v != null && v !== '') el.value = v; }
    setVal('dateField',       parms.DateField);
    setVal('statusFilter',    parms.StatusFilter);
    setVal('storeFilter',     parms.StoreFilter);
    setVal('agentFilter',     parms.AgentFilter);
    setVal('offerTypeFilter', parms.OfferType);
    setVal('primaryGroup',    parms.PrimaryGroup);
    setVal('secondaryGroup',  parms.SecondaryGroup);
    setVal('maxRecords',      parms.MaxRecords);
    if (parms.IncludeHistory != null) document.getElementById('includeHistory').checked = parms.IncludeHistory === 'true' || parms.IncludeHistory === true;
    if (parms.HiddenColumns != null) {
        var cols = parms.HiddenColumns ? parms.HiddenColumns.split(',') : [];
        document.querySelectorAll('.col-toggle').forEach(function(cb) { cb.checked = cols.indexOf(cb.value) === -1; });
        applyColumnVisibility();
    }
    if (parms.DatePreset) {
        var r = document.querySelector('input[name="DatePreset"][value="'+parms.DatePreset+'"]');
        if (r) { r.checked = true; applyPresetDates(parms.DatePreset); }
    }
}

function saveLayoutAsConfirm() {
    var nameEl = document.getElementById('saveLayoutAsName');
    var pubEl = document.getElementById('saveLayoutAsPublic');
    var alertEl = document.getElementById('saveLayoutAsAlert');
    var btn = document.getElementById('saveLayoutAsConfirmBtn');
    var spinner = document.getElementById('saveLayoutAsSpinner');
    if (alertEl) { alertEl.classList.add('d-none'); alertEl.textContent = ''; }
    var name = (nameEl.value || '').trim();
    if (!name) { alertEl.textContent = 'Layout name is required.'; alertEl.className = 'alert alert-warning'; return; }
    btn.disabled = true; spinner.classList.remove('d-none');
    var parms = collectCurrentLayout();
    fetch('@Url.Action("SaveOffersReportLayoutAs", "Reports")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name, isPublic: !!(pubEl && pubEl.checked), parameters: parms })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        btn.disabled = false; spinner.classList.add('d-none');
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('saveLayoutAsModal')).hide();
            showLayoutToast('Layout saved', 'success');
            loadLayoutsList();
            var label = document.getElementById('layoutsCurrentName');
            if (label) label.textContent = name;
        } else { alertEl.textContent = data.message || 'Failed to save'; alertEl.className = 'alert alert-danger'; }
    })
    .catch(function() { btn.disabled = false; spinner.classList.add('d-none'); alertEl.textContent = 'Network error.'; alertEl.className = 'alert alert-danger'; });
}

function deleteNamedLayout(headerCode, displayName) {
    if (!confirm('Delete layout "' + displayName + '"?')) return;
    fetch('@Url.Action("DeleteOffersReportLayout", "Reports")?headerCode=' + encodeURIComponent(headerCode), { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) { showLayoutToast('Layout deleted', 'success'); loadLayoutsList(); }
            else showLayoutToast(data.message || 'Failed to delete', 'danger');
        })
        .catch(function() { showLayoutToast('Network error', 'danger'); });
}

document.addEventListener('DOMContentLoaded', function() {
    var btn = document.getElementById('layoutsDropdownBtn');
    if (!btn) return;
    var loadedOnce = false;
    btn.addEventListener('show.bs.dropdown', function() {
        if (!loadedOnce) { loadedOnce = true; loadLayoutsList(); }
    });
    var modalEl = document.getElementById('saveLayoutAsModal');
    if (modalEl) {
        modalEl.addEventListener('show.bs.modal', function() {
            document.getElementById('saveLayoutAsName').value = '';
            document.getElementById('saveLayoutAsPublic').checked = false;
            var alertEl = document.getElementById('saveLayoutAsAlert');
            if (alertEl) { alertEl.classList.add('d-none'); alertEl.textContent = ''; }
        });
    }
});

function showLayoutToast(message, type) {
    var existing = document.getElementById('layoutToast');
    if (existing) existing.remove();
    var div = document.createElement('div');
    div.id = 'layoutToast';
    div.className = 'alert alert-' + type + ' alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow';
    div.style.zIndex = '9999';
    div.innerHTML = '<i class="bi bi-' + (type === 'success' ? 'check-circle' : 'exclamation-triangle') + ' me-1"></i>' + message +
        '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    document.body.appendChild(div);
    setTimeout(function() { if (div.parentNode) div.remove(); }, 4000);
}

// ==================== Column Visibility ====================

function applyColumnVisibility() {
    var styleEl = document.getElementById('colVisibilityStyle');
    if (!styleEl) { styleEl = document.createElement('style'); styleEl.id = 'colVisibilityStyle'; document.head.appendChild(styleEl); }
    var table = document.getElementById('reportTable');
    if (!table) return;
    var rules = [];
    document.querySelectorAll('.col-toggle').forEach(function(cb) {
        if (!cb.checked) {
            var headers = table.querySelectorAll('thead tr:first-child th');
            for (var i = 0; i < headers.length; i++) {
                if (headers[i].getAttribute('data-col') === cb.value) {
                    var colIdx = i + 1;
                    rules.push('#reportTable th:nth-child(' + colIdx + '), #reportTable td:nth-child(' + colIdx + ') { display: none; }');
                    break;
                }
            }
        }
    });
    styleEl.textContent = rules.join('\n');
    updateColVisibleCount();
}

function filterColumnList() {
    var el = document.getElementById('colSearchInput');
    if (!el) return;
    var search = el.value.toLowerCase().trim();
    document.querySelectorAll('#colToggleList label').forEach(function(label) {
        if (!search) { label.classList.remove('d-none'); return; }
        var name = (label.getAttribute('data-col-name') || '').toLowerCase();
        var spanText = label.querySelector('span');
        var text = spanText ? spanText.textContent.toLowerCase() : '';
        label.classList.toggle('d-none', name.indexOf(search) === -1 && text.indexOf(search) === -1);
    });
}

function updateColVisibleCount() {
    var total = document.querySelectorAll('.col-toggle').length;
    var visible = document.querySelectorAll('.col-toggle:checked').length;
    var el = document.getElementById('colVisibleCount'); if (el) el.textContent = visible;
    var totalEl = document.getElementById('colTotalCount'); if (totalEl) totalEl.textContent = total;
}

function toggleAllColumns(checked) {
    document.querySelectorAll('.col-toggle').forEach(function(cb) { cb.checked = checked; });
    applyColumnVisibility();
}

function resetColumnVisibility() {
    document.querySelectorAll('.col-toggle').forEach(function(cb) { cb.checked = true; });
    applyColumnVisibility();
}

function initColumnVisibilityFromLayout() {
    @if(savedLayout != null && savedLayout.ContainsKey("HiddenColumns"))
    {
        <text>
        var hiddenCols = '@savedLayout["HiddenColumns"]';
        if (hiddenCols) {
            var hidden = hiddenCols.split(',').filter(function(s) { return s.trim(); });
            hidden.forEach(function(col) {
                var cb = document.querySelector('.col-toggle[value="' + col.trim() + '"]');
                if (cb) cb.checked = false;
            });
            applyColumnVisibility();
        }
        </text>
    }
}

document.addEventListener('DOMContentLoaded', function() {
    initColumnVisibilityFromLayout();
    updateColVisibleCount();
    var colSearch = document.getElementById('colSearchInput');
    if (colSearch) colSearch.addEventListener('input', filterColumnList);
});

</script>
