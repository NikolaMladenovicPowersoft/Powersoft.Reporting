function onEmailTemplateChange() {
    var sel = document.getElementById('sendEmailTemplate');
    var id = parseInt(sel.value, 10);
    var preview = document.getElementById('sendEmailBodyPreview');

    if (isNaN(id) || !id) {
        preview.innerHTML = '<em class="text-muted">Default email body will be used.</em>';
        return;
    }

    var tmpl = _emailTemplatesCache.find(function(t) { return t.templateId === id; });
    if (!tmpl) return;

    if (tmpl.emailSubject) {
        document.getElementById('sendEmailSubject').value = replaceMergeFieldsPreview(tmpl.emailSubject);
    }

    if (tmpl.emailBodyHtml) {
        preview.innerHTML = replaceMergeFieldsPreview(tmpl.emailBodyHtml);
    }
}

function replaceMergeFieldsPreview(text) {
    return text
        .replace(/\u00ABReportName\u00BB/g, 'Average Basket')
        .replace(/\u00ABDatabaseName\u00BB/g, '@(Model.ConnectedDatabase ?? "Unknown")')
        .replace(/\u00ABPeriod\u00BB/g, '@Model.DateFrom.ToString("yyyy-MM-dd") to @Model.DateTo.ToString("yyyy-MM-dd")')
        .replace(/\u00ABRowCount\u00BB/g, '@(Model.Results?.Count ?? 0)')
        .replace(/\u00ABExportFormat\u00BB/g, document.getElementById('sendEmailFormat').value)
        .replace(/\u00ABGeneratedDate\u00BB/g, new Date().toLocaleString())
        .replace(/\u00ABUserName\u00BB/g, '@(User.Identity?.Name ?? "Unknown")')
        .replace(/\u00ABCompanyName\u00BB/g, '@(Model.ConnectedDatabase ?? "")')
        .replace(/\u00AB/g, '').replace(/\u00BB/g, '');
}

function validateEmailList(input) {
    if (!input || !input.trim()) return { valid: false, emails: [], errors: ['Please enter at least one email address.'] };
    var emails = input.split(/[,;]/).map(function(e) { return e.trim(); }).filter(function(e) { return e.length > 0; });
    var re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
    var invalid = emails.filter(function(e) { return !re.test(e); });
    if (invalid.length > 0) return { valid: false, emails: emails, errors: invalid.map(function(e) { return 'Invalid: ' + e; }) };
    return { valid: true, emails: emails, errors: [] };
}

