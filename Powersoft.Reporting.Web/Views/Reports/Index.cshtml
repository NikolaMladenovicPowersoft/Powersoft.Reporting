@{
    ViewData["Title"] = "Reports";
    var connectedDb = Context.Session.GetString("ConnectedDatabase");
    // Permission flags set by ReportsController.Index (async, resolved per-role)
    bool canViewAB        = ViewBag.CanViewAB        ?? true;
    bool canViewPS        = ViewBag.CanViewPS        ?? true;
    bool canViewPareto    = ViewBag.CanViewPareto    ?? true;
    bool canViewCharts    = ViewBag.CanViewCharts    ?? true;
    bool canViewCatalogue = ViewBag.CanViewCatalogue ?? true;
    bool canViewBMS       = ViewBag.CanViewBMS       ?? true;
    bool canViewCancelLog = ViewBag.CanViewCancelLog ?? true;
    bool canViewCNP       = ViewBag.CanViewCNP       ?? true;
    bool canViewPC        = ViewBag.CanViewPC        ?? true;
    bool canViewOffers    = ViewBag.CanViewOffers    ?? true;
    bool canViewTrialBalance = ViewBag.CanViewTrialBalance ?? true;
    bool canViewProfitLoss = ViewBag.CanViewProfitLoss ?? true;
    bool canViewCashFlow  = ViewBag.CanViewCashFlow  ?? true;
}

<div class="row">
    <div class="col-lg-3 mb-4">
        <div class="sidebar-nav p-3">
            <h6 class="text-muted text-uppercase small fw-bold px-3 mb-3">
                <i class="bi bi-folder me-2"></i>Stock Control
            </h6>
            <nav class="nav flex-column">
                <h6 class="text-muted small px-3 mt-2 mb-2">Power Reports</h6>
                @if (canViewAB) {
                <a class="nav-link active" asp-action="AverageBasket">
                    <i class="bi bi-basket me-2"></i>Average Basket
                </a>
                }
                @if (canViewPS) {
                <a class="nav-link" asp-action="PurchasesSales">
                    <i class="bi bi-arrow-left-right me-2"></i>Purchases vs Sales
                </a>
                }
                @if (canViewCharts) {
                <a class="nav-link" asp-action="Charts">
                    <i class="bi bi-pie-chart me-2"></i>Charts & Dashboards
                </a>
                }
                @if (canViewPareto) {
                <a class="nav-link" asp-action="Pareto">
                    <i class="bi bi-funnel me-2"></i>Pareto 80/20
                </a>
                }
                @if (canViewCatalogue) {
                <a class="nav-link" asp-action="Catalogue">
                    <i class="bi bi-journal-text me-2"></i>Power Reports Catalogue
                </a>
                }
                @if (canViewBMS) {
                <a class="nav-link" asp-action="BelowMinStock">
                    <i class="bi bi-exclamation-triangle me-2"></i>Below Minimum Stock
                </a>
                }
                @if (canViewCancelLog) {
                <a class="nav-link" asp-action="CancelLog">
                    <i class="bi bi-x-circle me-2"></i>Cancellation Logging
                </a>
                }
                @if (canViewCNP) {
                <a class="nav-link" asp-action="CustomerNotPurchased">
                    <i class="bi bi-cart-x me-2"></i>Items Not Purchased
                </a>
                }
            </nav>
            
            <hr class="my-3">

            <h6 class="text-muted text-uppercase small fw-bold px-3 mb-3">
                <i class="bi bi-folder me-2"></i>CRM
            </h6>
            <nav class="nav flex-column">
                @if (canViewPC) {
                <a class="nav-link" asp-action="ProspectClients">
                    <i class="bi bi-people me-2"></i>Prospect Clients
                </a>
                }
                @if (canViewOffers) {
                <a class="nav-link" asp-action="OffersReport">
                    <i class="bi bi-file-earmark-text me-2"></i>Offers Report
                </a>
                }
            </nav>

            <hr class="my-3">
            
            <h6 class="text-muted text-uppercase small fw-bold px-3 mb-3">
                <i class="bi bi-folder me-2"></i>Accounting
            </h6>
            <nav class="nav flex-column">
                @if (canViewTrialBalance) {
                <a class="nav-link" asp-action="TrialBalance">
                    <i class="bi bi-shuffle me-2"></i>Trial Balance
                </a>
                }
                @if (canViewProfitLoss) {
                <a class="nav-link" asp-action="ProfitLoss">
                    <i class="bi bi-graph-up-arrow me-2"></i>Profit &amp; Loss
                </a>
                }
                @if (canViewCashFlow) {
                <a class="nav-link" asp-action="CashFlow">
                    <i class="bi bi-cash-stack me-2"></i>Cash Flow
                </a>
                }
            </nav>
        </div>
    </div>
    
    <div class="col-lg-9">
        <div class="card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span><i class="bi bi-speedometer2 me-2"></i>Reports Dashboard</span>
                <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#templatePackModal">
                    <i class="bi bi-collection me-1"></i>Apply Template Pack
                </button>
            </div>
            <div class="card-body">
                <h6 class="text-muted text-uppercase small fw-bold mb-3">
                    <i class="bi bi-box-seam me-1"></i>Stock Control &mdash; Power Reports
                </h6>
                <div class="row g-4">
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border-primary">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-primary bg-opacity-10 rounded-circle p-3 me-3">
                                        <i class="bi bi-basket text-primary" style="font-size: 1.5rem;"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title mb-1">Average Basket</h5>
                                        <p class="text-muted small mb-0">Sales performance analysis</p>
                                    </div>
                                </div>
                                <p class="card-text text-muted small flex-grow-1">
                                    Analyze average transaction value, quantity per sale, and compare
                                    year-over-year performance with customizable date ranges and groupings.
                                </p>
                                <a asp-action="AverageBasket" class="btn btn-primary mt-auto">
                                    <i class="bi bi-arrow-right me-1"></i>Open Report
                                </a>
                            </div>
                        </div>
                    </div>

                    @if (canViewPS)
                    {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border-success">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-success bg-opacity-10 rounded-circle p-3 me-3">
                                        <i class="bi bi-arrow-left-right text-success" style="font-size: 1.5rem;"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title mb-1">Purchases vs Sales</h5>
                                        <p class="text-muted small mb-0">Procurement &amp; sales comparison</p>
                                    </div>
                                </div>
                                <p class="card-text text-muted small flex-grow-1">
                                    Compare purchased and sold quantities and values per item, with
                                    profit analysis, stock levels, and multi-level grouping.
                                </p>
                                <a asp-action="PurchasesSales" class="btn btn-success mt-auto">
                                    <i class="bi bi-arrow-right me-1"></i>Open Report
                                </a>
                            </div>
                        </div>
                    </div>
                    }

                    @if (canViewCharts) {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border-info">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-info bg-opacity-10 rounded-circle p-3 me-3">
                                        <i class="bi bi-pie-chart text-info" style="font-size: 1.5rem;"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title mb-1">Charts &amp; Dashboards</h5>
                                        <p class="text-muted small mb-0">Visual data exploration</p>
                                    </div>
                                </div>
                                <p class="card-text text-muted small flex-grow-1">
                                    Interactive pie charts, top 10 bar charts, and comparative dashboards
                                    by category, brand, store, customer, and more.
                                </p>
                                <a asp-action="Charts" class="btn btn-info text-white mt-auto">
                                    <i class="bi bi-arrow-right me-1"></i>Open Charts
                                </a>
                            </div>
                        </div>
                    </div>
                    }

                    @if (canViewPareto) {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100" style="border-color:#6366f1;">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rounded-circle p-3 me-3" style="background:rgba(99,102,241,0.10);">
                                        <i class="bi bi-funnel" style="font-size: 1.5rem; color:#6366f1;"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title mb-1">Pareto 80/20</h5>
                                        <p class="text-muted small mb-0">Top contributors analysis</p>
                                    </div>
                                </div>
                                <p class="card-text text-muted small flex-grow-1">
                                    Identify the top items, customers, or categories driving 80% of sales
                                    or profit using the 80/20 Pareto principle with cumulative breakdown.
                                </p>
                                <a asp-action="Pareto" class="btn mt-auto text-white" style="background:#6366f1;">
                                    <i class="bi bi-arrow-right me-1"></i>Open Report
                                </a>
                            </div>
                        </div>
                    </div>
                    }

                    @if (canViewCatalogue) {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border-warning">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-warning bg-opacity-10 rounded-circle p-3 me-3">
                                        <i class="bi bi-journal-text text-warning" style="font-size: 1.5rem;"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title mb-1">Power Reports Catalogue</h5>
                                        <p class="text-muted small mb-0">Item-level transactional report</p>
                                    </div>
                                </div>
                                <p class="card-text text-muted small flex-grow-1">
                                    Detailed item-level transactional report with profit, margin, cost, stock
                                    and multi-dimensional filtering (customer, supplier, agent, store).
                                </p>
                                <a asp-action="Catalogue" class="btn btn-warning text-dark mt-auto">
                                    <i class="bi bi-arrow-right me-1"></i>Open Report
                                </a>
                            </div>
                        </div>
                    </div>
                    }

                    @if (canViewBMS) {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border-danger">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-danger bg-opacity-10 rounded-circle p-3 me-3">
                                        <i class="bi bi-exclamation-triangle text-danger" style="font-size: 1.5rem;"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title mb-1">Below Minimum Stock</h5>
                                        <p class="text-muted small mb-0">Stock replenishment alert</p>
                                    </div>
                                </div>
                                <p class="card-text text-muted small flex-grow-1">
                                    List items whose on-hand stock is below the defined minimum level,
                                    ready for replenishment orders with supplier and store breakdown.
                                </p>
                                <a asp-action="BelowMinStock" class="btn btn-danger mt-auto">
                                    <i class="bi bi-arrow-right me-1"></i>Open Report
                                </a>
                            </div>
                        </div>
                    </div>
                    }

                    @if (canViewCancelLog) {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100" style="border-color:#dc2626;">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rounded-circle p-3 me-3" style="background:rgba(220,38,38,0.10);">
                                        <i class="bi bi-x-circle" style="font-size: 1.5rem; color:#dc2626;"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title mb-1">Cancellation Logging</h5>
                                        <p class="text-muted small mb-0">POS void &amp; cancel tracking</p>
                                    </div>
                                </div>
                                <p class="card-text text-muted small flex-grow-1">
                                    Track deleted lines, cancelled invoices, and complimentary items
                                    from POS transactions with detailed or summary grouping.
                                </p>
                                <a asp-action="CancelLog" class="btn mt-auto text-white" style="background:#dc2626;">
                                    <i class="bi bi-arrow-right me-1"></i>Open Report
                                </a>
                            </div>
                        </div>
                    </div>
                    }

                    @if (canViewCNP) {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border-primary">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-primary bg-opacity-10 rounded-circle p-3 me-3">
                                        <i class="bi bi-cart-x text-primary" style="font-size: 1.5rem;"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title mb-1">Items Not Purchased</h5>
                                        <p class="text-muted small mb-0">Customer purchase-gap analysis</p>
                                    </div>
                                </div>
                                <p class="card-text text-muted small flex-grow-1">
                                    Pick a customer (or all) and a day threshold to list items not bought recently,
                                    including when each was last purchased. Filter by category, brand, supplier and store.
                                </p>
                                <a asp-action="CustomerNotPurchased" class="btn btn-primary mt-auto">
                                    <i class="bi bi-arrow-right me-1"></i>Open Report
                                </a>
                            </div>
                        </div>
                    </div>
                    }
                </div>

                <h6 class="text-muted text-uppercase small fw-bold mb-3 mt-4">
                    <i class="bi bi-people me-1"></i>CRM
                </h6>
                <div class="row g-4 mb-4">
                    @if (canViewPC) {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100" style="border-color:#0ea5e9;">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rounded-circle p-3 me-3" style="background:rgba(14,165,233,0.10);">
                                        <i class="bi bi-people" style="font-size: 1.5rem; color:#0ea5e9;"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title mb-1">Prospect Clients</h5>
                                        <p class="text-muted small mb-0">CRM pipeline &amp; conversion tracking</p>
                                    </div>
                                </div>
                                <p class="card-text text-muted small flex-grow-1">
                                    Track leads and prospects by status, priority, and agent. View offers issued,
                                    emails/SMS sent, categories, and notes with full history support.
                                </p>
                                <a asp-action="ProspectClients" class="btn mt-auto text-white" style="background:#0ea5e9;">
                                    <i class="bi bi-arrow-right me-1"></i>Open Report
                                </a>
                            </div>
                        </div>
                    </div>
                    }

                    @if (canViewOffers) {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100" style="border-color:#7c3aed;">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rounded-circle p-3 me-3" style="background:rgba(124,58,237,0.10);">
                                        <i class="bi bi-file-earmark-text" style="font-size: 1.5rem; color:#7c3aed;"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title mb-1">Offers Report</h5>
                                        <p class="text-muted small mb-0">Sales offers by status &amp; analysis</p>
                                    </div>
                                </div>
                                <p class="card-text text-muted small flex-grow-1">
                                    Track sales offers by status, customer, store, and agent. View totals,
                                    discounts, VAT, cost analysis, and conversion rates with grouping.
                                </p>
                                <a asp-action="OffersReport" class="btn mt-auto text-white" style="background:#7c3aed;">
                                    <i class="bi bi-arrow-right me-1"></i>Open Report
                                </a>
                            </div>
                        </div>
                    </div>
                    }
                </div>

                <h6 class="text-muted text-uppercase small fw-bold mb-3 mt-4">
                    <i class="bi bi-calculator me-1"></i>Accounting
                </h6>
                <div class="row g-4">
                    @if (canViewTrialBalance) {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100" style="border-color:#16a34a;">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rounded-circle p-3 me-3" style="background:rgba(22,163,74,0.10);">
                                        <i class="bi bi-shuffle" style="font-size: 1.5rem; color:#16a34a;"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title mb-1">Trial Balance</h5>
                                        <p class="text-muted small mb-0">Opening, movements &amp; closing balances</p>
                                    </div>
                                </div>
                                <p class="card-text text-muted small flex-grow-1">
                                    Per-account opening balance, period debits/credits and closing balance as at a date,
                                    grouped by chart-of-accounts header. Detailed or summary, with header selection &amp; suppression.
                                </p>
                                <a asp-action="TrialBalance" class="btn mt-auto text-white" style="background:#16a34a;">
                                    <i class="bi bi-arrow-right me-1"></i>Open Report
                                </a>
                            </div>
                        </div>
                    </div>
                    }
                    @if (canViewProfitLoss) {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100" style="border-color:#16a34a;">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rounded-circle p-3 me-3" style="background:rgba(22,163,74,0.10);">
                                        <i class="bi bi-graph-up-arrow" style="font-size: 1.5rem; color:#16a34a;"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title mb-1">Profit &amp; Loss</h5>
                                        <p class="text-muted small mb-0">Sales, cost of sales, income &amp; expenses</p>
                                    </div>
                                </div>
                                <p class="card-text text-muted small flex-grow-1">
                                    Period-based Profit &amp; Loss statement grouped into Sales, Cost of Sales, Income
                                    and Expenses, with Gross &amp; Net Profit and an optional prior-year comparison column.
                                </p>
                                <a asp-action="ProfitLoss" class="btn mt-auto text-white" style="background:#16a34a;">
                                    <i class="bi bi-arrow-right me-1"></i>Open Report
                                </a>
                            </div>
                        </div>
                    </div>
                    }
                    @if (canViewCashFlow) {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100" style="border-color:#0891b2;">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rounded-circle p-3 me-3" style="background:rgba(8,145,178,0.10);">
                                        <i class="bi bi-cash-stack" style="font-size: 1.5rem; color:#0891b2;"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title mb-1">Cash Flow</h5>
                                        <p class="text-muted small mb-0">Direct cash flow statement</p>
                                    </div>
                                </div>
                                <p class="card-text text-muted small flex-grow-1">
                                    Cash movements from bank-touching transactions grouped by chart-of-accounts section,
                                    with net cash movement and optional prior-year and budget comparison columns.
                                </p>
                                <a asp-action="CashFlow" class="btn mt-auto text-white" style="background:#0891b2;">
                                    <i class="bi bi-arrow-right me-1"></i>Open Report
                                </a>
                            </div>
                        </div>
                    </div>
                    }
                </div>

                <hr class="my-4">

                <div class="row">
                    <div class="col-12">
                        <div class="alert alert-info d-flex align-items-center mb-0">
                            <i class="bi bi-info-circle me-3" style="font-size: 1.5rem;"></i>
                            <div>
                                <strong>Connected to:</strong> @connectedDb
                                <br>
                                <small class="text-muted">Select a report from the sidebar or cards above to begin.</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Apply Template Pack modal -->
<div class="modal fade" id="templatePackModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-collection me-2"></i>Apply Template Pack</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @Html.AntiForgeryToken()
                <p class="text-muted small">
                    Pick an industry pack for <strong>@connectedDb</strong>, then choose which reports to schedule
                    (all are selected by default — untick any you don't want). Already-applied reports are locked;
                    you can come back later to add more. You can edit each schedule afterwards.
                </p>
                <div id="tpAlert"></div>
                <div id="tpPackList" class="mb-3">
                    <div class="text-muted small"><span class="spinner-border spinner-border-sm me-2"></span>Loading packs&hellip;</div>
                </div>
                <div class="mb-2">
                    <label for="tpRecipients" class="form-label small fw-bold">Recipient email(s)</label>
                    <input type="text" class="form-control form-control-sm" id="tpRecipients"
                           placeholder="name@company.com, another@company.com">
                    <div class="form-text">Comma-separated. Scheduled reports are emailed here.</div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="tpApplyBtn" disabled>
                    <i class="bi bi-check2-circle me-1"></i>Apply Pack
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var modalEl = document.getElementById('templatePackModal');
    if (!modalEl) return;

    var listUrl = '@Url.Action("List", "TemplatePacks")';
    var applyUrl = '@Url.Action("Apply", "TemplatePacks")';
    var packListEl = document.getElementById('tpPackList');
    var recipientsEl = document.getElementById('tpRecipients');
    var applyBtn = document.getElementById('tpApplyBtn');
    var alertEl = document.getElementById('tpAlert');
    var selectedPack = null;

    function esc(s) {
        return (s == null ? '' : String(s)).replace(/[&<>"']/g, function (c) {
            return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
        });
    }

    function showAlert(kind, msg) {
        alertEl.innerHTML = '<div class="alert alert-' + kind + ' py-2 small mb-3">' + esc(msg) + '</div>';
    }

    // Checked, enabled (i.e. not-yet-applied) item checkboxes for the currently selected pack.
    function selectableChecked() {
        if (!selectedPack) return [];
        return Array.prototype.slice.call(
            packListEl.querySelectorAll('.tp-item[data-pack="' + cssEsc(selectedPack) + '"]:checked:not(:disabled)'));
    }

    function cssEsc(s) { return String(s).replace(/[^a-zA-Z0-9_-]/g, '\\$&'); }

    function updateApplyState() {
        applyBtn.disabled = !selectedPack || selectableChecked().length === 0;
    }

    // Item checkboxes for a given pack that are NOT already applied (i.e. the admin can toggle them).
    function freshItems(packCode) {
        return Array.prototype.slice.call(
            packListEl.querySelectorAll('.tp-item[data-pack="' + cssEsc(packCode) + '"][data-applied="0"]'));
    }

    function setPackSelected(card, on) {
        var itemsEl = card.querySelector('.tp-items');
        if (on) {
            card.classList.add('border-primary', 'border-2', 'bg-light');
            if (itemsEl) itemsEl.style.display = '';
        } else {
            card.classList.remove('border-primary', 'border-2', 'bg-light');
            if (itemsEl) itemsEl.style.display = 'none';
        }
    }

    function selectPack(code) {
        packListEl.querySelectorAll('.tp-pack').forEach(function (card) {
            var mine = card.getAttribute('data-pack') === code;
            setPackSelected(card, mine);
            card.querySelectorAll('.tp-item').forEach(function (cb) {
                var applied = cb.getAttribute('data-applied') === '1';
                cb.disabled = !mine || applied;      // applied items stay locked
                if (mine && !applied) cb.checked = true; // default: all fresh items selected
            });
        });
        selectedPack = code;
        updateApplyState();
    }

    function deselectAllPacks() {
        selectedPack = null;
        packListEl.querySelectorAll('.tp-pack').forEach(function (card) {
            setPackSelected(card, false);
            card.querySelectorAll('.tp-item').forEach(function (cb) {
                if (cb.getAttribute('data-applied') !== '1') cb.disabled = true;
            });
        });
        updateApplyState();
    }

    function renderPacks(packs) {
        if (!packs || !packs.length) {
            packListEl.innerHTML = '<div class="text-muted small">No template packs available.</div>';
            return;
        }
        var html = '';
        packs.forEach(function (p) {
            var appliedBadge = p.applied
                ? '<span class="badge bg-success ms-2">Applied</span>' : '';
            var items = (p.reports || []).map(function (r) {
                var itemApplied = !!r.applied;
                var itemBadge = itemApplied ? ' <span class="badge bg-success">Applied</span>' : '';
                var cbId = 'tpItem_' + esc(p.packCode) + '_' + esc(r.itemKey);
                return '' +
                    '<div class="form-check">' +
                        '<input class="form-check-input tp-item" type="checkbox" ' +
                            'data-pack="' + esc(p.packCode) + '" data-applied="' + (itemApplied ? '1' : '0') + '" ' +
                            'value="' + esc(r.itemKey) + '" id="' + cbId + '" checked disabled>' +
                        '<label class="form-check-label small" for="' + cbId + '">' +
                            esc(r.templateName) + ' <span class="text-muted">(' + esc(r.recurrenceType) + ')</span>' + itemBadge +
                        '</label>' +
                    '</div>';
            }).join('');
            html +=
                '<div class="tp-pack border rounded p-2 mb-2" data-pack="' + esc(p.packCode) + '" role="button" style="cursor:pointer">' +
                    '<div class="fw-bold">' + esc(p.packName) + appliedBadge + '</div>' +
                    '<div class="text-muted small">' + esc(p.description || '') + '</div>' +
                    '<div class="tp-items mt-2" style="display:none">' +
                        '<div class="mb-1 d-flex align-items-center gap-2">' +
                            '<button type="button" class="btn btn-sm btn-link p-0 tp-select-all">Select all</button>' +
                            '<span class="text-muted">&middot;</span>' +
                            '<button type="button" class="btn btn-sm btn-link p-0 tp-clear-all">Clear</button>' +
                        '</div>' +
                        items +
                    '</div>' +
                '</div>';
        });
        packListEl.innerHTML = html;

        // Click anywhere on a pack card (except inside its items area) toggles selection.
        packListEl.querySelectorAll('.tp-pack').forEach(function (card) {
            card.addEventListener('click', function (e) {
                if (e.target.closest('.tp-items')) return; // item checkboxes / select-all handled below
                var code = card.getAttribute('data-pack');
                if (selectedPack === code) deselectAllPacks();
                else selectPack(code);
            });
        });

        packListEl.querySelectorAll('.tp-item').forEach(function (cb) {
            cb.addEventListener('change', updateApplyState);
        });

        packListEl.querySelectorAll('.tp-select-all').forEach(function (btn) {
            btn.addEventListener('click', function () {
                if (!selectedPack) return;
                freshItems(selectedPack).forEach(function (cb) { cb.checked = true; });
                updateApplyState();
            });
        });
        packListEl.querySelectorAll('.tp-clear-all').forEach(function (btn) {
            btn.addEventListener('click', function () {
                if (!selectedPack) return;
                freshItems(selectedPack).forEach(function (cb) { cb.checked = false; });
                updateApplyState();
            });
        });
    }

    function loadPacks() {
        selectedPack = null;
        updateApplyState();
        alertEl.innerHTML = '';
        packListEl.innerHTML = '<div class="text-muted small"><span class="spinner-border spinner-border-sm me-2"></span>Loading packs&hellip;</div>';
        fetch(listUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (!d.success) { showAlert('warning', d.message || 'Could not load packs.'); packListEl.innerHTML = ''; return; }
                renderPacks(d.packs);
            })
            .catch(function () { showAlert('danger', 'Failed to load template packs.'); packListEl.innerHTML = ''; });
    }

    function applyPack() {
        if (!selectedPack) return;
        var chosen = selectableChecked();
        if (!chosen.length) { showAlert('warning', 'Select at least one report to apply.'); return; }
        var token = document.querySelector('#templatePackModal input[name="__RequestVerificationToken"]');
        var body = new URLSearchParams();
        body.append('packCode', selectedPack);
        body.append('recipients', recipientsEl.value || '');
        chosen.forEach(function (cb) { body.append('selectedItems', cb.value); });
        if (token) body.append('__RequestVerificationToken', token.value);

        applyBtn.disabled = true;
        applyBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Applying&hellip;';
        fetch(applyUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
            body: body.toString()
        })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (d.success) {
                    showAlert(d.alreadyApplied ? 'info' : 'success', d.message || 'Done.');
                    loadPacks();
                } else {
                    showAlert('warning', d.message || 'Could not apply pack.');
                }
            })
            .catch(function () { showAlert('danger', 'Failed to apply template pack.'); })
            .finally(function () {
                applyBtn.innerHTML = '<i class="bi bi-check2-circle me-1"></i>Apply Pack';
                updateApplyState();
            });
    }

    modalEl.addEventListener('show.bs.modal', loadPacks);
    applyBtn.addEventListener('click', applyPack);
})();
</script>
}
