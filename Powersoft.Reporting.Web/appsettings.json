{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PSCentral": "Data Source=YOUR_SERVER;Initial Catalog=pscentral;User ID=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;Encrypt=False;Pooling=true"
  },
  "Scheduler": {
    "IntervalSeconds": 60
  },
  "Storage": {
    "ServiceUrl": "",
    "Region": "fra1",
    "BucketName": "reports-ai-cold",
    "AccessKey": "",
    "SecretKey": "",
    "KeyPrefix": "scheduled-reports/"
  },
  "AiAnalyzer": {
    "Provider": "OpenAI",
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "MaxOutputTokens": 2048,
    "Temperature": 0.3
  }
}
