function validateEmailList(input){if(!input||!input.trim())return{valid:false,errors:['Enter at least one email.']};var emails=input.split(/[,;]/).map(e=>e.trim()).filter(e=>e.length>0);var re=/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;var invalid=emails.filter(e=>!re.test(e));if(invalid.length>0)return{valid:false,errors:invalid.map(e=>'Invalid: '+e)};return{valid:true,emails:emails,errors:[]};}

