function autoSelectScheduleDateRange(){var preset=document.querySelector('input[name="DatePreset"]:checked');if(!preset)return;var map={'today':'Today','yesterday':'Yesterday','ytd':'YearToDate','lastYear':'LastYear','thisMonth':'ThisMonth','lastMonth':'LastMonth','last7':'LastNDays_7','last30':'LastNDays_30'};var mapped=map[preset.value];if(!mapped)return;var sel=document.getElementById('schedDateRangeType');for(var i=0;i<sel.options.length;i++){var opt=sel.options[i];if(mapped.startsWith('LastNDays_')){var days=mapped.split('_')[1];if(opt.value==='LastNDays'&&opt.getAttribute('data-value')===days){sel.selectedIndex=i;return;}}else if(opt.value===mapped){sel.selectedIndex=i;return;}}}
