@model Powersoft.Reporting.Web.ViewModels.CatalogueViewModel
@using Powersoft.Reporting.Core.Enums
@using Powersoft.Reporting.Core.Models
@{
    ViewData["Title"] = "Power Reports Catalogue";
    var filterCols = new[] { "ItemCode", "ItemDescription", "Level1Description", "Level2Description", "Level3Description",
        "Quantity", "NetValue", "GrossAmount", "ProfitValue", "TransactionCost", "TotalStockQty",
        "EntityName", "StoreCode", "BrandName", "ItemCategoryDescr" };
    bool hasResults = Model.Results.Any();
    bool hasL1 = Model.HasPrimaryGroup;
    bool hasL2 = Model.HasSecondaryGroup;
    bool hasL3 = Model.HasThirdGroup;
    bool showItem = !Model.IsSummary || (!hasL1 && !hasL2 && !hasL3);
    bool useGross = Model.HasDisplayColumn("GrossAmount");

    var displayCols = Model.GetDisplayColumns();
    bool dc(string c) => displayCols.Contains(c, StringComparer.OrdinalIgnoreCase);
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-start">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">Reports</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">Stock Control</a></li>
                    <li class="breadcrumb-item active">Power Reports Catalogue</li>
                </ol>
            </nav>
            <h2 class="mb-0">
                <i class="bi bi-journal-text me-2 text-primary"></i>Power Reports Catalogue
            </h2>
            <p class="text-muted mb-0">Comprehensive transaction catalogue with flexible grouping and filtering</p>
        </div>
        <div class="mt-3">
            @await Html.PartialAsync("_TutorialButton", ("Power Reports Catalogue", ""))
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="bi bi-funnel me-2"></i>Report Parameters</div>
    <div class="card-body">
        <form asp-action="Catalogue" method="post" id="reportForm">
            <input type="hidden" asp-for="SelectedStoreCodesString" id="selectedStoreCodesHidden" />
            <input type="hidden" asp-for="ItemsSelectionJson" id="itemsSelectionJsonHidden" />
            <input type="hidden" asp-for="PageNumber" id="pageNumberHidden" />
            <input type="hidden" asp-for="SortColumn" id="sortColumnHidden" />
            <input type="hidden" asp-for="SortDirection" id="sortDirectionHidden" />
            <input type="hidden" asp-for="DisplayColumnsString" id="displayColumnsHidden" />
            <input type="hidden" asp-for="ColumnOrder" id="columnOrderHidden" />
            @foreach (var col in filterCols)
            {
                <input type="hidden" name="FilterValues[@col]" id="fv_@col" value="@(Model.FilterValues.GetValueOrDefault(col, ""))" />
                <input type="hidden" name="FilterOperators[@col]" id="fo_@col" value="@(Model.FilterOperators.GetValueOrDefault(col, ""))" />
            }

            @* ===== ROW 1: Date Selection ===== *@
            <div class="row mb-3">
                <div class="col-12">
                    <label class="form-label fw-semibold mb-2">Quick Date Selection</label>
                    <div class="date-presets btn-group flex-wrap" role="group">
                        <input type="radio" class="btn-check" name="DatePreset" id="presetToday" value="today" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetToday">Today</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetYesterday" value="yesterday" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetYesterday">Yesterday</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLast7" value="last7" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLast7">Last 7 Days</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLast30" value="last30" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLast30">Last 30 Days</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetThisMonth" value="thisMonth" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetThisMonth">This Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastMonth" value="lastMonth" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLastMonth">Last Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetYTD" value="ytd" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetYTD">Year to Date</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastYear" value="lastYear" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLastYear">Last Year</label>
                    </div>
                </div>
            </div>

            <hr class="my-3">

            <div class="row g-3 mb-3 align-items-end">
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date Basis</label>
                    <select asp-for="DateBasis" class="form-select" asp-items="Html.GetEnumSelectList<CatalogueDateBasis>()"
                            title="Filter by Transaction Date (h.DateTrans) or Session Date (h.SessionDateTime)"></select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date From</label>
                    <input type="@(Model.UseDateTime ? "datetime-local" : "date")" asp-for="DateFrom" class="form-control" id="DateFrom"
                           value="@(Model.UseDateTime ? Model.DateFrom.ToString("yyyy-MM-ddTHH:mm") : Model.DateFrom.ToString("yyyy-MM-dd"))"
                           onchange="clearPreset()" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date To</label>
                    <input type="@(Model.UseDateTime ? "datetime-local" : "date")" asp-for="DateTo" class="form-control" id="DateTo"
                           value="@(Model.UseDateTime ? Model.DateTo.ToString("yyyy-MM-ddTHH:mm") : Model.DateTo.ToString("yyyy-MM-dd"))"
                           onchange="clearPreset()" />
                </div>
                <div class="col-6 col-md-1">
                    <label class="form-label fw-semibold small" title="Include time component in filter">Use Time</label>
                    <div class="form-check form-switch pt-1">
                        <input type="checkbox" asp-for="UseDateTime" class="form-check-input" id="UseDateTime"
                               onchange="onUseDateTimeToggle(this.checked)" />
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Report Mode</label>
                    <select asp-for="ReportMode" class="form-select" asp-items="Html.GetEnumSelectList<CatalogueReportMode>()"></select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Report On</label>
                    <select asp-for="ReportOn" class="form-select" asp-items="Html.GetEnumSelectList<CatalogueReportOn>()"></select>
                </div>
            </div>

            @* ===== ROW 3: Grouping + Report Title ===== *@
            <div class="row g-3 mb-3 align-items-end">
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Primary Group</label>
                    <select asp-for="PrimaryGroup" id="PrimaryGroup" class="form-select group-select" asp-items="Html.GetEnumSelectList<CatalogueGroupBy>()"></select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Secondary Group</label>
                    <select asp-for="SecondaryGroup" id="SecondaryGroup" class="form-select group-select" asp-items="Html.GetEnumSelectList<CatalogueGroupBy>()"></select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Third Group</label>
                    <select asp-for="ThirdGroup" id="ThirdGroup" class="form-select group-select" asp-items="Html.GetEnumSelectList<CatalogueGroupBy>()"></select>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label fw-semibold">Report Title</label>
                    <input type="text" asp-for="ReportTitle" class="form-control" id="ReportTitle"
                           placeholder="Power Report" />
                </div>
            </div>

            @* ===== ROW 4: Profit / Stock / Cost (dropdowns + Includes VAT) + Options (Show Gross/Profit/Stock) + Rows per page ===== *@
            <div class="row g-3 mb-4 align-items-start">
                <div class="col-6 col-md-2" data-perm="cost">
                    <label class="form-label fw-semibold small mb-1">Profit Based On</label>
                    <select asp-for="ProfitBasedOn" class="form-select form-select-sm" asp-items="Html.GetEnumSelectList<CatalogueCostBasis>()"></select>
                    <div class="form-check mt-1">
                        <input type="checkbox" asp-for="ProfitIncludesVat" class="form-check-input" />
                        <label asp-for="ProfitIncludesVat" class="form-check-label small">Includes VAT</label>
                    </div>
                </div>
                <div class="col-6 col-md-2" data-perm="cost">
                    <label class="form-label fw-semibold small mb-1">Stock Value Based On</label>
                    <select asp-for="StockValueBasedOn" class="form-select form-select-sm" asp-items="Html.GetEnumSelectList<CatalogueCostBasis>()"></select>
                    <div class="form-check mt-1">
                        <input type="checkbox" asp-for="StockValueIncludesVat" class="form-check-input" />
                        <label asp-for="StockValueIncludesVat" class="form-check-label small">Includes VAT</label>
                    </div>
                </div>
                <div class="col-6 col-md-2" data-perm="cost">
                    <label class="form-label fw-semibold small mb-1">Cost Type</label>
                    <select asp-for="CostType" class="form-select form-select-sm" asp-items="Html.GetEnumSelectList<CatalogueCostBasis>()"></select>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label fw-semibold small mb-1">Display Options</label>
                    <div class="d-flex flex-wrap gap-3 pt-1">
                        <div class="form-check" data-perm="profit" title="Quick-toggle for Profit / Markup / Margin columns. Synced with Display Columns selector.">
                            <input type="checkbox" asp-for="ShowProfit" class="form-check-input" id="showProfitToggle" />
                            <label asp-for="ShowProfit" class="form-check-label small">Show Profit</label>
                        </div>
                        <div class="form-check" title="Quick-toggle for Stock Qty / Stock Value columns. Synced with Display Columns selector.">
                            <input type="checkbox" asp-for="ShowStock" class="form-check-input" id="showStockToggle" />
                            <label asp-for="ShowStock" class="form-check-label small">Show Stock</label>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold small mb-1">Rows per page</label>
                    <select asp-for="PageSize" class="form-select form-select-sm">
                        <option value="50">50</option>
                        <option value="100">100</option>
                        <option value="250">250</option>
                        <option value="500">500</option>
                    </select>
                </div>
            </div>

            <div class="report-form-actions d-flex flex-wrap gap-2 pt-2 border-top">
                <button type="submit" class="btn btn-primary btn-lg btn-generate" id="generateBtn">
                    <span class="btn-text"><i class="bi bi-play-fill me-2"></i>Generate Report</span>
                    <span class="spinner-border spinner-border-sm d-none" role="status"></span>
                </button>
                @if (Model.CanSchedule)
                {
                    <button type="button" class="btn btn-warning btn-lg" data-bs-toggle="modal" data-bs-target="#scheduleModal" title="Schedule recurring report delivery">
                        <i class="bi bi-clock-history me-2"></i>Schedule
                    </button>
                }
                <div class="btn-group ms-auto">
                    <div class="btn-group">
                        <button type="button" class="btn btn-outline-info dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false"
                                title="Saved report layouts" id="layoutsDropdownBtn">
                            <i class="bi bi-bookmark me-1"></i><span id="layoutsCurrentName">Layouts</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" id="layoutsDropdownMenu" style="min-width: 320px;">
                            <li><h6 class="dropdown-header">Loading...</h6></li>
                        </ul>
                    </div>
                    <button type="button" class="btn btn-outline-info" onclick="saveCurrentLayout()" title="Overwrite your default layout with current parameters">
                        <i class="bi bi-save me-1"></i>Save
                    </button>
                    <button type="button" class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#saveLayoutAsModal"
                            title="Save current parameters as a new named layout (optionally shared with all users)">
                        <i class="bi bi-bookmark-plus me-1"></i>Save as...
                    </button>
                    @if (Model.HasSavedLayout)
                    {
                        <button type="button" class="btn btn-outline-secondary" onclick="resetSavedLayout()" title="Discard your saved default layout and restore factory defaults">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Default
                        </button>
                    }
                    <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#columnSettingsModal" title="Choose which columns to show/hide">
                        <i class="bi bi-layout-three-columns me-1"></i>Columns
                    </button>
                </div>
                <a asp-action="Catalogue" class="btn btn-outline-secondary btn-reset" title="Clear all filters">
                    <i class="bi bi-funnel me-1"></i>Clear Filters
                </a>
            </div>
            @if (Model.HasSavedLayout)
            {
                <div class="mt-2"><small class="text-info"><i class="bi bi-check-circle me-1"></i>Saved layout loaded</small></div>
            }
        </form>
    </div>
</div>

@{
    var storesJson = System.Text.Json.JsonSerializer.Serialize(Model.AvailableStores.Select(s => new { code = s.StoreCode, name = s.StoreName }));
}
@await Html.PartialAsync("_ItemsSelection", new ItemsSelectionConfig
{
    ShowCategories = true,
    ShowDepartments = true,
    ShowBrands = true,
    ShowSeasons = true,
    ShowSuppliers = true,
    ShowCustomers = true,
    ShowAgents = true,
    ShowPostalCodes = true,
    ShowStores = true,
    ShowItems = false,
    ShowPaymentTypes = true,
    ShowZReports = true,
    ShowTowns = true,
    ShowUsers = true,
    StoresJson = storesJson,
    SavedFilterJson = Model.ItemsSelectionJson ?? "",
    ReportType = "Catalogue"
})

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.ErrorMessage</div>
}

@if (hasResults && Model.Totals != null)
{
    <div class="row mb-4 g-3">
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <div class="stat-value">@Model.Totals.TotalQuantity.ToString("N2")</div>
                <div class="stat-label">Total Quantity</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <div class="stat-value">@((useGross ? Model.Totals.TotalGrossAmount : Model.Totals.TotalNetValue).ToString("N2"))</div>
                <div class="stat-label">@(useGross ? "Total Gross" : "Total Net Value")</div>
            </div>
        </div>
        <div class="col-6 col-md-3" data-perm="profit">
            <div class="stat-card text-center">
                @{ var catProfitColor = Model.Totals.TotalProfitValue >= 0 ? "text-success" : "text-danger"; }
                <div class="stat-value @catProfitColor">@Model.Totals.TotalProfitValue.ToString("N2")</div>
                <div class="stat-label">Total Profit</div>
            </div>
        </div>
        <div class="col-6 col-md-3" data-perm="margin">
            <div class="stat-card text-center">
                @{ var catMarginColor = Model.Totals.TotalMargin >= 0 ? "text-success" : "text-danger"; }
                <div class="stat-value @catMarginColor">@Model.Totals.TotalMargin.ToString("N2")%</div>
                <div class="stat-label">Avg Margin</div>
            </div>
        </div>
    </div>
}

@if (hasResults)
{
    <div class="card mb-4" id="results">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>
                <i class="bi bi-table me-2"></i>
                <span id="resultsTitle">@(string.IsNullOrWhiteSpace(Model.ReportTitle) ? "Results" : Model.ReportTitle)</span>
                <span class="badge bg-primary ms-2">@Model.TotalCount.ToString("N0") rows</span>
                @if (Model.Totals != null)
                {
                    <span class="badge bg-secondary ms-1">@Model.DateFrom.ToString("dd/MM/yyyy") - @Model.DateTo.ToString("dd/MM/yyyy")</span>
                }
                <button type="button" class="btn btn-sm btn-outline-secondary ms-2" id="toggleSelectionsBtn"
                        title="Show/Hide active filter selections">
                    <i class="bi bi-list-check me-1"></i>Selections
                </button>
            </span>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <div class="btn-group btn-group-sm">
                    <button type="button" class="btn btn-outline-success" onclick="exportCatalogue('csv')">
                        <i class="bi bi-filetype-csv me-1"></i>CSV
                    </button>
                    <button type="button" class="btn btn-outline-success" onclick="exportCatalogue('excel')">
                        <i class="bi bi-filetype-xlsx me-1"></i>Excel
                    </button>
                </div>
                <button class="btn btn-sm btn-outline-primary" onclick="togglePreview()" id="previewToggleBtn" title="Toggle document-style preview">
                    <i class="bi bi-eye me-1"></i>Preview
                </button>
                <button class="btn btn-sm btn-outline-primary" onclick="openSendEmailModal()" title="Send report via email">
                    <i class="bi bi-envelope me-1"></i>Send to Email
                </button>
                <button class="btn btn-sm btn-outline-info" onclick="openAiAnalysis()" title="AI-powered report analysis" id="btnAnalyze">
                    <i class="bi bi-stars me-1"></i>AI Analyze
                </button>
            </div>
        </div>

        <div id="selectionsPanel" class="border-bottom px-3 py-2 bg-light small" style="display:none;">
            <strong class="text-muted">Active Selections:</strong>
            <div id="selectionsContent" class="mt-1 d-flex flex-wrap gap-2"></div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover table-striped mb-0" id="resultsTable">
                    <thead class="table-light sticky-top">
                        <tr>
                            @* data-fixed-left="1" marks columns that stay anchored to the left and are NOT part of
                               drag&drop reordering (controlled by Primary/Secondary/Third Group + Item visibility). *@
                            @if (hasL1) { <th class="sortable" data-col="Level1Description" data-fixed-left="1">Group 1</th> }
                            @if (hasL2) { <th class="sortable" data-col="Level2Description" data-fixed-left="1">Group 2</th> }
                            @if (hasL3) { <th class="sortable" data-col="Level3Description" data-fixed-left="1">Group 3</th> }
                            @if (showItem && dc("ItemCode")) { <th class="sortable" data-col="ItemCode" data-fixed-left="1">Code</th> }
                            @if (showItem && dc("MainBarcode")) { <th class="sortable" data-col="MainBarcode" data-fixed-left="1">Barcode</th> }
                            @if (showItem && dc("ItemName")) { <th class="sortable" data-col="ItemDescription" data-fixed-left="1">Description</th> }
                            @if (showItem && dc("ItemInvoiceDescription")) { <th class="sortable" data-col="ItemInvoiceDescription" data-fixed-left="1">Invoice Descr</th> }
                            @if (dc("Quantity")) { <th class="sortable text-end col-trans" data-col="Quantity">Qty</th> }
                            @if (dc("Value")) { <th class="sortable text-end col-trans" data-col="ValueBeforeDiscount">Value</th> }
                            @if (dc("Discount")) { <th class="sortable text-end col-trans" data-col="Discount">Discount</th> }
                            @if (dc("NetValue")) { <th class="sortable text-end col-trans" data-col="NetValue">Net Value</th> }
                            @if (dc("VatAmount")) { <th class="sortable text-end col-trans" data-col="VatAmount">VAT</th> }
                            @if (dc("GrossAmount")) { <th class="sortable text-end col-trans" data-col="GrossAmount">Gross Amt</th> }
                            @if (dc("Profit")) { <th class="sortable text-end col-profit" data-col="ProfitValue" data-perm="profit">Profit</th> }
                            @if (dc("Markup")) { <th class="text-end col-profit" data-col="Markup" data-perm="profit">Markup %</th> }
                            @if (dc("Margin")) { <th class="text-end col-profit" data-col="Margin" data-perm="margin">Margin %</th> }
                            @if (dc("Cost")) { <th class="sortable text-end col-cost" data-col="Cost" data-perm="cost">Cost</th> }
                            @if (dc("TotalCost")) { <th class="sortable text-end col-cost" data-col="TotalCost" data-perm="cost">Total Cost</th> }
                            @if (dc("TotalStockQty")) { <th class="sortable text-end col-stock" data-col="TotalStockQty">Stock Qty</th> }
                            @if (dc("TotalStockValue")) { <th class="text-end col-stock" data-col="TotalStockValue">Stock Value</th> }
                            @if (dc("EntityCode")) { <th data-col="EntityCode">Entity Code</th> }
                            @if (dc("EntityName")) { <th data-col="EntityName">Entity Name</th> }
                            @if (dc("EntityShortName")) { <th data-col="EntityShortName">Short Name</th> }
                            @if (dc("EntityID")) { <th data-col="EntityID">Entity ID</th> }
                            @if (dc("Sundry")) { <th data-col="Sundry">Sundry</th> }
                            @if (dc("EntityTel1")) { <th data-col="EntityTel1">Phone</th> }
                            @if (dc("EntityTel2")) { <th data-col="EntityTel2">Phone 2</th> }
                            @if (dc("EntityMobile")) { <th data-col="EntityMobile">Mobile</th> }
                            @if (dc("EntityFax")) { <th data-col="EntityFax">Fax</th> }
                            @if (dc("EntityEmail")) { <th data-col="EntityEmail">Email</th> }
                            @if (dc("EntityContactName")) { <th data-col="EntityContactName">Contact</th> }
                            @if (dc("EntityVatRegNo")) { <th data-col="EntityVatRegNo">VAT Reg No</th> }
                            @if (dc("EntityDOB")) { <th data-col="EntityDOB">Date of Birth</th> }
                            @if (dc("InvoiceNumber")) { <th data-col="InvoiceNumber">Invoice No</th> }
                            @if (dc("InvoiceType")) { <th data-col="InvoiceType">Inv. Type</th> }
                            @if (dc("StoreCode")) { <th data-col="StoreCode">Store Code</th> }
                            @if (dc("StoreName")) { <th data-col="StoreName">Store</th> }
                            @if (dc("StationCode")) { <th data-col="StationCode">Station</th> }
                            @if (dc("DateTrans")) { <th class="sortable" data-col="DateTrans">Date</th> }
                            @if (dc("UserCode")) { <th data-col="UserCode">User</th> }
                            @if (dc("AgentName")) { <th data-col="AgentName">Agent</th> }
                            @if (dc("ZReportNumber")) { <th data-col="ZReportNumber">Z Report</th> }
                            @if (dc("PaymentType")) { <th data-col="PaymentType">Payment Type</th> }
                            @if (dc("ItemCategory")) { <th data-col="ItemCategory">Category</th> }
                            @if (dc("ItemDepartment")) { <th data-col="ItemDepartment">Department</th> }
                            @if (dc("Brand")) { <th data-col="Brand">Brand</th> }
                            @if (dc("Season")) { <th data-col="Season">Season</th> }
                            @if (dc("Model")) { <th data-col="Model">Model</th> }
                            @if (dc("Colour")) { <th data-col="Colour">Colour</th> }
                            @if (dc("Size")) { <th data-col="Size">Size</th> }
                            @if (dc("Franchise")) { <th data-col="Franchise">Franchise</th> }
                            @if (dc("CustomerCategory1")) { <th data-col="CustomerCategory1Descr">Cust Cat 1</th> }
                            @if (dc("CustomerCategory2")) { <th data-col="CustomerCategory2Descr">Cust Cat 2</th> }
                            @if (dc("CustomerCategory3")) { <th data-col="CustomerCategory3Descr">Cust Cat 3</th> }
                            @if (dc("ItemSupplier")) { <th data-col="ItemSupplier" data-perm="supplier">Supplier</th> }
                            @if (dc("Price1Excl")) { <th class="text-end" data-col="Price1Excl">Price 1 Ex</th> }
                            @if (dc("Price1Incl")) { <th class="text-end" data-col="Price1Incl">Price 1 In</th> }
                            @if (dc("Price2Excl")) { <th class="text-end" data-col="Price2Excl">Price 2 Ex</th> }
