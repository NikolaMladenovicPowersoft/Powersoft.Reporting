// -------------------- Named / public layouts (multi per user) --------------------

var __chartLayoutsCache = null;

function isAuthRedirect(response) {
    if (!response) return false;
    if (response.status === 401 || response.status === 403) return true;
    if (response.redirected && /\/Account\/Login/i.test(response.url || '')) return true;
    var ct = response.headers && response.headers.get ? response.headers.get('content-type') : '';
    if (ct && ct.indexOf('text/html') !== -1) return true;
    return false;
}

function showSessionExpiredToast() {
    showLayoutToast('Session expired — please reload the page and sign in again.', 'warning');
}

function loadChartLayoutsList() {
    var menu = document.getElementById('layoutsDropdownMenu');
    if (menu) menu.innerHTML = '<li><h6 class="dropdown-header">Loading...</h6></li>';
    return fetch('@Url.Action("ListChartLayouts", "Reports")', { method: 'GET', credentials: 'same-origin' })
        .then(function(r) {
            if (isAuthRedirect(r)) {
                if (menu) menu.innerHTML = '<li><h6 class="dropdown-header text-danger">Session expired</h6></li>';
                showSessionExpiredToast();
                return null;
            }
            return r.json();
        })
        .then(function(data) {
            if (data == null) return;
            __chartLayoutsCache = data && data.layouts ? data.layouts : [];
            renderChartLayoutsDropdown(__chartLayoutsCache);
        })
        .catch(function() {
            if (menu) menu.innerHTML = '<li><h6 class="dropdown-header text-danger">Failed to load</h6></li>';
        });
}

function renderChartLayoutsDropdown(layouts) {
    var menu = document.getElementById('layoutsDropdownMenu');
    if (!menu) return;
    if (!layouts || layouts.length === 0) {
        menu.innerHTML =
            '<li><h6 class="dropdown-header">No saved layouts</h6></li>' +
            '<li><span class="dropdown-item-text small text-muted">Use "Save as..." to create one.</span></li>';
        return;
    }

    var own = layouts.filter(function(l) { return !l.isPublic; });
    var pub = layouts.filter(function(l) { return  l.isPublic; });

    var html = '';
    function renderGroup(label, items) {
        if (items.length === 0) return;
        html += '<li><h6 class="dropdown-header">' + label + '</h6></li>';
        items.forEach(function(l) {
            var safeName = String(l.name).replace(/</g, '&lt;').replace(/>/g, '&gt;');
            var publicBadge = l.isPublic ? ' <span class="badge bg-info bg-opacity-25 text-info ms-1">public</span>' : '';
            var editorBadge = l.isPublic && l.createdBy
                ? '<span class="text-muted small ms-2">by ' + String(l.createdBy).replace(/</g,'&lt;') + '</span>'
                : '';
            html += '<li class="d-flex align-items-center px-2 py-1 layout-row">' +
                        '<a href="#" class="flex-grow-1 text-decoration-none text-body" onclick="loadNamedChartLayout(\'' +
                            String(l.headerCode).replace(/'/g, "\\'") + '\'); return false;">' +
                            '<i class="bi bi-bookmark me-1"></i>' + safeName + publicBadge + editorBadge +
                        '</a>';
            if (l.canEdit) {
                html += '<button type="button" class="btn btn-sm btn-link text-danger p-0 ms-2" ' +
                            'title="Delete this layout" onclick="deleteNamedChartLayout(\'' +
                            String(l.headerCode).replace(/'/g, "\\'") + '\', \'' +
                            safeName.replace(/'/g, "\\'") + '\'); return false;">' +
                            '<i class="bi bi-trash"></i>' +
                        '</button>';
            }
            html += '</li>';
        });
    }
    renderGroup('Your layouts', own);
    renderGroup('Public layouts', pub);
    menu.innerHTML = html;
}

function loadNamedChartLayout(headerCode) {
    if (!headerCode) return;
    fetch('@Url.Action("LoadChartLayout", "Reports")?headerCode=' + encodeURIComponent(headerCode),
          { method: 'POST', credentials: 'same-origin' })
        .then(function(r) {
            if (isAuthRedirect(r)) { showSessionExpiredToast(); return null; }
            return r.json();
        })
        .then(function(data) {
            if (data == null) return;
            if (!data.success) {
                showLayoutToast(data.message || 'Failed to load layout', 'danger');
                return;
            }
            applyChartLayoutParameters(data.parameters || {});
            var label = document.getElementById('layoutsCurrentName');
            if (label && __chartLayoutsCache) {
                var match = __chartLayoutsCache.find(function(l) { return l.headerCode === headerCode; });
                if (match) label.textContent = match.name;
            }
            showLayoutToast('Layout loaded — click Generate to run.', 'success');
        })
        .catch(function() { showLayoutToast('Network error loading layout', 'danger'); });
}

function applyChartLayoutParameters(parms) {
    function setVal(id, v) { var el = document.getElementById(id); if (el && v != null && v !== '') el.value = v; }
    function setChk(id, v) { var el = document.getElementById(id); if (el && v != null) el.checked = (v === '1' || v === 1 || v === true); }

    setVal('chartMode',       parms.mode);
    setVal('dimension',       parms.dimension);
    setVal('metric',          parms.metric);
    setVal('topN',            parms.topN);
    setVal('chartType',       parms.chartType);
    setChk('showOthers',      parms.showOthers);
    setChk('compareLastYear', parms.compareLastYear);
    setChk('includeVat',      parms.includeVat);
    if (typeof onChartModeChange === 'function') onChartModeChange();
}

function saveChartLayoutAsConfirm() {
    var nameEl = document.getElementById('saveChartLayoutAsName');
    var pubEl  = document.getElementById('saveChartLayoutAsPublic');
    var alertEl = document.getElementById('saveChartLayoutAsAlert');
    var btn = document.getElementById('saveChartLayoutAsConfirmBtn');
    var spinner = document.getElementById('saveChartLayoutAsSpinner');
    if (alertEl) { alertEl.classList.add('d-none'); alertEl.textContent = ''; }

    var name = (nameEl.value || '').trim();
    if (!name) {
        alertEl.textContent = 'Layout name is required.';
        alertEl.className = 'alert alert-warning';
        return;
    }

    btn.disabled = true; spinner.classList.remove('d-none');

    var parms = collectChartParams();
    fetch('@Url.Action("SaveChartLayoutAs", "Reports")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name, isPublic: !!(pubEl && pubEl.checked), parameters: parms })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        btn.disabled = false; spinner.classList.add('d-none');
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('saveChartLayoutAsModal')).hide();
            showLayoutToast('Layout saved', 'success');
            loadChartLayoutsList();
            var label = document.getElementById('layoutsCurrentName');
            if (label) label.textContent = name;
        } else {
            alertEl.textContent = data.message || 'Failed to save';
            alertEl.className = 'alert alert-danger';
        }
    })
    .catch(function() {
        btn.disabled = false; spinner.classList.add('d-none');
        alertEl.textContent = 'Network error.';
        alertEl.className = 'alert alert-danger';
    });
}

function deleteNamedChartLayout(headerCode, displayName) {
    if (!confirm('Delete layout "' + displayName + '"?')) return;
    fetch('@Url.Action("DeleteChartLayout", "Reports")?headerCode=' + encodeURIComponent(headerCode), { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                showLayoutToast('Layout deleted', 'success');
                loadChartLayoutsList();
            } else {
                showLayoutToast(data.message || 'Failed to delete', 'danger');
            }
        })
        .catch(function() { showLayoutToast('Network error', 'danger'); });
}

// Lazy load the layouts list the first time the dropdown opens + reset Save As modal
document.addEventListener('DOMContentLoaded', function() {
    var btn = document.getElementById('layoutsDropdownBtn');
    if (btn) {
        var loadedOnce = false;
        btn.addEventListener('show.bs.dropdown', function() {
            if (!loadedOnce) { loadedOnce = true; loadChartLayoutsList(); }
        });
    }
    var modalEl = document.getElementById('saveChartLayoutAsModal');
    if (modalEl) {
        modalEl.addEventListener('show.bs.modal', function() {
            document.getElementById('saveChartLayoutAsName').value = '';
            document.getElementById('saveChartLayoutAsPublic').checked = false;
            var alertEl = document.getElementById('saveChartLayoutAsAlert');
            if (alertEl) { alertEl.classList.add('d-none'); alertEl.textContent = ''; }
        });
    }
});

function showLayoutToast(msg, type) {
    var existing = document.getElementById('layoutToast');
    if (existing) existing.remove();
    var div = document.createElement('div');
    div.id = 'layoutToast';
    div.className = 'alert alert-' + type + ' alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow';
    div.style.zIndex = '11000';
    div.innerHTML = '<i class="bi bi-' + (type === 'success' ? 'check-circle' : 'exclamation-triangle') + ' me-1"></i>' + msg + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    document.body.appendChild(div);
    setTimeout(function() { if (div.parentNode) div.remove(); }, 4000);
}

// Apply saved layout on page load
@if (savedLayout != null && savedLayout.Count > 0)
{
    <text>
(function() {
    var saved = @Html.Raw(JsonSerializer.Serialize(savedLayout));
    if (saved.mode) document.getElementById('chartMode').value = saved.mode;
    if (saved.dimension) document.getElementById('dimension').value = saved.dimension;
    if (saved.metric) document.getElementById('metric').value = saved.metric;
    if (saved.topN) document.getElementById('topN').value = saved.topN;
    if (saved.chartType) document.getElementById('chartType').value = saved.chartType;
    if (saved.showOthers !== undefined) document.getElementById('showOthers').checked = saved.showOthers === '1';
    if (saved.compareLastYear !== undefined) document.getElementById('compareLastYear').checked = saved.compareLastYear === '1';
    if (saved.includeVat !== undefined) document.getElementById('includeVat').checked = saved.includeVat === '1';
    onChartModeChange();
})();
    </text>
}
</script>
}
