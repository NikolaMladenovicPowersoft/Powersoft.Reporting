@model Powersoft.Reporting.Web.ViewModels.SystemSettingsViewModel
@{
    ViewData["Title"] = "System Settings";
}

<div class="container py-4" style="max-width: 720px;">
    <h4 class="mb-1"><i class="bi bi-sliders me-2"></i>System Settings</h4>
    <p class="text-muted mb-4">Global Report Engine configuration stored in psCentral. Changes affect all databases.</p>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-1"></i>@Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-1"></i>@Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="System" method="post">

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white">
                <i class="bi bi-cpu me-1"></i> Scheduler
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-check form-switch mt-2">
                            <input asp-for="SchedulerMasterEnabled" class="form-check-input" type="checkbox" />
                            <label asp-for="SchedulerMasterEnabled" class="form-check-label"></label>
                        </div>
                        <div class="form-text">Global kill switch. Disabling stops ALL scheduled report processing.</div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MaxDatabasesPerRun" class="form-label"></label>
                        <input asp-for="MaxDatabasesPerRun" class="form-control" type="number" min="1" max="500" />
                        <span asp-validation-for="MaxDatabasesPerRun" class="text-danger"></span>
                        <div class="form-text">Limit how many databases are processed in a single scheduler run.</div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="GlobalMaxSchedulesPerReport" class="form-label"></label>
                        <input asp-for="GlobalMaxSchedulesPerReport" class="form-control" type="number" min="1" max="100" />
                        <span asp-validation-for="GlobalMaxSchedulesPerReport" class="text-danger"></span>
                        <div class="form-text">Hard cap on active schedules per report type (overrides per-DB setting if lower).</div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DefaultRetentionDays" class="form-label"></label>
                        <input asp-for="DefaultRetentionDays" class="form-control" type="number" min="1" max="365" />
                        <span asp-validation-for="DefaultRetentionDays" class="text-danger"></span>
                        <div class="form-text">Default retention period for generated report files.</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white">
                <i class="bi bi-envelope me-1"></i> Email Defaults
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="DefaultSmtpFromEmail" class="form-label"></label>
                        <input asp-for="DefaultSmtpFromEmail" class="form-control" type="text" placeholder="reports@powersoft.com.cy" />
                        <div class="form-text">Sender address for scheduled report emails.</div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DefaultSmtpFromName" class="form-label"></label>
                        <input asp-for="DefaultSmtpFromName" class="form-control" type="text" placeholder="Powersoft Reports" />
                        <div class="form-text">Display name shown in recipient's inbox.</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Database" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Database Settings
            </a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Save System Settings
            </button>
        </div>
    </form>
</div>
