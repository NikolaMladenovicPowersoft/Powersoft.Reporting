    // ==================== Column Selection (drives DisplayColumnsString on server) ====================

    function filterColumnList() {
        var el = document.getElementById('colSearchInput');
        if (!el) return;
        var s = el.value.toLowerCase().trim();
        document.querySelectorAll('#colToggleList label').forEach(function(label) {
            if (!s) { label.classList.remove('d-none'); return; }
            var name = (label.getAttribute('data-col-name') || '').toLowerCase();
            var sp = label.querySelector('span'); var text = sp ? sp.textContent.toLowerCase() : '';
            var cv = label.querySelector('input') ? label.querySelector('input').value.toLowerCase() : '';
            label.classList.toggle('d-none', !(name.indexOf(s) !== -1 || text.indexOf(s) !== -1 || cv.indexOf(s) !== -1));
        });
    }

    function toggleAllColumns(checked) {
        document.querySelectorAll('.col-toggle:not([disabled])').forEach(function(cb) {
            if (cb.checked !== checked) { cb.checked = checked; onColToggleChange(cb); }
        });
    }

    function resetDefaultColumns() {
        var defaults = ['ItemCode','ItemName','Quantity','Value','Discount','NetValue','VatAmount','GrossAmount'];
        document.querySelectorAll('.col-toggle:not([disabled])').forEach(function(cb) {
            var key = cb.getAttribute('data-disp-key') || '';
            var shouldCheck = defaults.indexOf(key) >= 0;
            if (cb.checked !== shouldCheck) { cb.checked = shouldCheck; onColToggleChange(cb); }
        });
    }

    function updateColVisibleCount() {
        var visible = document.querySelectorAll('.col-toggle[data-is-grouping="0"]:not([disabled]):checked').length;
        var el = document.getElementById('colVisibleCount');
        if (el) el.textContent = visible;
    }

    // Returns true if the given SQL column name is currently rendered in the grid (<th data-col="X"> exists).
    function _isColumnInGrid(sqlCol) {
        return !!document.querySelector('#resultsTable thead th[data-col="' + sqlCol + '"]');
    }

    // Returns the list of SQL columns that the user has checked in the modal but that are NOT yet in the grid.
    // These require a server round-trip (Apply & Refresh) because we don't have their data client-side.
    function _getColumnsNeedingRefresh() {
        var out = [];
        document.querySelectorAll('.col-toggle[data-is-grouping="0"]:checked:not([disabled])').forEach(function(cb) {
            if (!_isColumnInGrid(cb.value)) out.push(cb.value);
        });
        return out;
    }

    // Updates the "add column needs refresh" UI: label highlight, banner, and Apply button pulse.
    function _updateNeedsRefreshUi() {
        // Mark individual labels
        document.querySelectorAll('#colToggleList label').forEach(function(lbl) {
            var cb = lbl.querySelector('input.col-toggle');
            if (!cb || cb.disabled) { lbl.classList.remove('col-needs-refresh'); return; }
            var needs = cb.checked && !_isColumnInGrid(cb.value);
            lbl.classList.toggle('col-needs-refresh', needs);
        });
        // Banner + Apply button pulse
        var missing = _getColumnsNeedingRefresh();
        var banner = document.getElementById('colAddBanner');
        var bannerText = document.getElementById('colAddBannerText');
        var btn = document.getElementById('applyColumnsBtn');
        if (missing.length > 0) {
            if (banner) banner.classList.remove('d-none');
            if (bannerText) {
                var labels = missing.slice(0, 3).map(function(sql) {
                    var cb = document.querySelector('.col-toggle[value="' + sql + '"]');
                    var lbl = cb && cb.closest('label'); var sp = lbl && lbl.querySelector('span.flex-grow-1');
                    return sp ? sp.textContent.trim() : sql;
                });
                var more = missing.length > 3 ? ' (+' + (missing.length - 3) + ' more)' : '';
                bannerText.innerHTML = '<strong>' + missing.length + '</strong> new column' + (missing.length > 1 ? 's' : '')
                    + ' selected: <em>' + labels.join(', ') + more + '</em>. '
                    + 'Click <strong>Apply &amp; Refresh</strong> to load their data.';
            }
            if (btn) btn.classList.add('needs-refresh');
        } else {
            if (banner) banner.classList.add('d-none');
            if (btn) btn.classList.remove('needs-refresh');
        }
    }

    // Rebuild DisplayColumnsString hidden input from modal checkboxes.
    function rebuildDisplayColumnsFromModal() {
        var keys = [];
        document.querySelectorAll('.col-toggle[data-is-grouping="0"]:checked').forEach(function(cb) {
            var k = cb.getAttribute('data-disp-key') || '';
            if (k && keys.indexOf(k) < 0) keys.push(k);
        });
        var hidden = document.getElementById('displayColumnsHidden');
        if (hidden) hidden.value = keys.join(',');
    }

    // Track whether the user changed the selection since the report was generated.
    var _colsInitialSig = '';
    function currentColsSignature() {
        var keys = [];
        document.querySelectorAll('.col-toggle[data-is-grouping="0"]').forEach(function(cb) {
            keys.push(cb.getAttribute('data-disp-key') + ':' + (cb.checked ? '1' : '0'));
        });
        return keys.join('|');
    }
    function updateDirtyIndicator() {
        var el = document.getElementById('colDirtyIndicator');
        if (!el) return;
        el.style.display = (currentColsSignature() !== _colsInitialSig) ? '' : 'none';
    }

    function onColToggleChange(cb) {
        // Immediate visual feedback: hide the corresponding <th>/<td> if it is currently rendered.
        try {
            var table = document.getElementById('resultsTable');
            if (table) {
                var headers = table.querySelectorAll('thead tr:first-child th');
                for (var i = 0; i < headers.length; i++) {
                    if (headers[i].getAttribute('data-col') === cb.value) {
                        var colIdx = i + 1;
                        var styleId = 'colHide_' + cb.value;
                        var existing = document.getElementById(styleId);
                        if (!cb.checked) {
                            if (!existing) {
                                var s = document.createElement('style');
                                s.id = styleId;
                                s.textContent = '#resultsTable th:nth-child(' + colIdx + '), #resultsTable td:nth-child(' + colIdx + '){display:none;}';
                                document.head.appendChild(s);
                            }
                        } else if (existing) {
                            existing.remove();
                        }
                        break;
                    }
                }
            }
        } catch (e) {}

        rebuildDisplayColumnsFromModal();
        syncQuickTogglesFromColToggles();
        updateColVisibleCount();
        updateDirtyIndicator();
        _updateNeedsRefreshUi();
    }

    function applyAndRefreshColumns() {
        rebuildDisplayColumnsFromModal();
        try { sessionStorage.setItem('catalogue_scroll_to_results', '1'); } catch (e) {}
        document.getElementById('pageNumberHidden').value = '1';
        document.getElementById('reportForm').submit();
    }

    // ==================== COLUMN REORDER (Phase 1 - client-side, session-scoped) ====================
    // Scope:
    //   - Grouping columns (L1/L2/L3) and Item columns (Code/Description) stay anchored LEFT
    //     (data-fixed-left="1"). Everything to the right of them is user-reorderable.
    //   - Order is persisted in sessionStorage under COL_ORDER_KEY per-tenant/per-session.
    //   - Order is applied to: thead <th>, tbody .data-row <td>, .group-subtotal-row metric <td>,
    //     tfoot .grand-total-row metric <td>. group-header-row is a single colspan cell and is skipped.
    //   - Does NOT affect CSV/Excel/PDF export yet (server-side, fixed order). Phase 2.
    var COL_ORDER_KEY = 'catalogue_col_order_v1';

    function _getReorderableThs() {
        var table = document.getElementById('resultsTable');
        if (!table) return [];
        var all = Array.from(table.querySelectorAll('thead tr:first-child th'));
        return all.filter(function(th) { return th.getAttribute('data-fixed-left') !== '1'; });
    }

    function _getFixedLeftCount() {
        var table = document.getElementById('resultsTable');
        if (!table) return 0;
        return table.querySelectorAll('thead tr:first-child th[data-fixed-left="1"]').length;
    }

    // Read the current order from the modal list (source of truth while user edits).
    function getColumnOrderFromModal() {
        var out = [];
        document.querySelectorAll('#colToggleList label.col-reorderable').forEach(function(lbl) {
            var sql = lbl.getAttribute('data-col-sql');
            if (sql) out.push(sql);
        });
        return out;
    }

    // Compute the index permutation that maps original reorderable <th> order -> requested order.
    function _computeReorderIndices(sqlOrder) {
        var reorderableTh = _getReorderableThs();
        var origIdxBySql = {};
        reorderableTh.forEach(function(th, i) { origIdxBySql[th.getAttribute('data-col')] = i; });

        var result = [];
        var added = new Set();
        for (var i = 0; i < sqlOrder.length; i++) {
            var sql = sqlOrder[i];
            if (origIdxBySql[sql] !== undefined && !added.has(sql)) {
                result.push(origIdxBySql[sql]);
                added.add(sql);
            }
        }
        // Append any reorderable columns not mentioned (new cols, forward compat) in their original order.
        reorderableTh.forEach(function(th, i) {
            var sql = th.getAttribute('data-col');
            if (!added.has(sql)) { result.push(i); added.add(sql); }
        });
        return result;
    }

    function _reorderCells(parent, startIdx, permutation) {
        var children = Array.from(parent.children);
        var reorderable = children.slice(startIdx);
        if (reorderable.length !== permutation.length) return false; // row shape mismatch, skip
        var frag = document.createDocumentFragment();
        for (var i = 0; i < permutation.length; i++) frag.appendChild(reorderable[permutation[i]]);
        parent.appendChild(frag);
        return true;
    }

    // Count leading "fixed" cells in a subtotal row: the leading empty <td>s (indent) + 1 colspan label cell.
    function _subtotalFixedCount(tr) {
        var cells = tr.children;
        var fixed = 0;
        for (var i = 0; i < cells.length; i++) {
            var c = cells[i];
            if (c.hasAttribute('colspan')) { fixed = i + 1; break; }
            fixed = i + 1;
        }
        return fixed;
    }

    // Apply the requested SQL-column order to the grid (header + all row types).
    function applyColumnOrderToGrid(sqlOrder) {
        var table = document.getElementById('resultsTable');
        if (!table || !sqlOrder || !sqlOrder.length) return;

        var perm = _computeReorderIndices(sqlOrder);
        var fixedLeft = _getFixedLeftCount();

        // 1. Header
        var theadRow = table.querySelector('thead tr:first-child');
        if (theadRow) _reorderCells(theadRow, fixedLeft, perm);

        // 2. Data rows (exactly one <td> per <th>)
        table.querySelectorAll('tbody tr.data-row').forEach(function(tr) {
            _reorderCells(tr, fixedLeft, perm);
        });

        // 3. Subtotal rows (leading indent <td>s + colspan label + metric <td>s matching reorderable <th>s)
        table.querySelectorAll('tbody tr.group-subtotal-row').forEach(function(tr) {
            _reorderCells(tr, _subtotalFixedCount(tr), perm);
        });

        // 4. Grand total (1 colspan label + metric <td>s). Skip if spanCols == 0 (no group/item cols).
        table.querySelectorAll('tfoot tr.grand-total-row').forEach(function(tr) {
            var first = tr.firstElementChild;
            var leading = (first && first.hasAttribute('colspan')) ? 1 : 0;
            _reorderCells(tr, leading, perm);
        });

        // 5. Rebuild any hide-column <style> tags: they reference <th>/<td>:nth-child(N) which
        //    must now point to the new DOM position of each hidden column.
        _rebuildHideStyles();
    }

    // After any reorder (drag or up/down), update <style id="colHide_X"> tags to use the new nth-child.
    function _rebuildHideStyles() {
        var table = document.getElementById('resultsTable');
        if (!table) return;
        var headers = Array.from(table.querySelectorAll('thead tr:first-child th'));
        document.querySelectorAll('style[id^="colHide_"]').forEach(function(s) {
            var sql = s.id.substring('colHide_'.length);
            var idx = -1;
            for (var i = 0; i < headers.length; i++) {
                if (headers[i].getAttribute('data-col') === sql) { idx = i + 1; break; }
            }
            if (idx > 0) {
                s.textContent = '#resultsTable th:nth-child(' + idx + '), #resultsTable td:nth-child(' + idx + '){display:none;}';
            }
        });
    }

    function _saveColumnOrder() {
        try {
            var order = getColumnOrderFromModal();
            sessionStorage.setItem(COL_ORDER_KEY, JSON.stringify(order));
            // Keep the hidden input in sync so subsequent form submits (report generate,
            // save layout, save-as) pick up the current order without extra round-trips.
            var hidden = document.getElementById('columnOrderHidden');
            if (hidden) hidden.value = order.join(',');
        } catch (e) { /* sessionStorage blocked */ }
    }

    // Load order with priority: sessionStorage (current working) > Model.ColumnOrder (from saved layout)
    function _loadColumnOrder() {
        try {
            var raw = sessionStorage.getItem(COL_ORDER_KEY);
            if (raw) {
                var arr = JSON.parse(raw);
                if (Array.isArray(arr) && arr.length) return arr;
            }
        } catch (e) {}
        // Fall back to server-provided layout order (Model.ColumnOrder → hidden input)
        var hidden = document.getElementById('columnOrderHidden');
        var val = hidden ? (hidden.value || '') : '';
        if (val) {
            var fromModel = val.split(',').map(function(s) { return s.trim(); }).filter(function(s) { return s.length > 0; });
            if (fromModel.length) return fromModel;
        }
        return null;
    }

    // Re-sort modal items to match a given SQL order. Non-reorderable items (grouping) keep their spots at the top.
    function _applyOrderToModal(sqlOrder) {
        var list = document.getElementById('colToggleList');
        if (!list) return;
        var items = Array.from(list.children);
        var bySql = {};
        var fixedItems = [];
        items.forEach(function(el) {
            var sql = el.getAttribute('data-col-sql');
            if (!sql) return;
            if (el.classList.contains('col-reorderable')) bySql[sql] = el;
            else fixedItems.push(el);
        });

        var frag = document.createDocumentFragment();
        fixedItems.forEach(function(el) { frag.appendChild(el); });

        var added = new Set();
        sqlOrder.forEach(function(sql) {
            if (bySql[sql] && !added.has(sql)) { frag.appendChild(bySql[sql]); added.add(sql); }
        });
        // Append any leftover reorderable (new cols) in original order.
        Object.keys(bySql).forEach(function(sql) {
            if (!added.has(sql)) frag.appendChild(bySql[sql]);
        });
        list.appendChild(frag);
    }

    // ---- ↑/↓ buttons ----
    function moveColumnOrder(btn, delta) {
        var lbl = btn.closest('label.col-reorderable');
        if (!lbl) return;
        var sibling = delta < 0 ? lbl.previousElementSibling : lbl.nextElementSibling;
        // Only swap with another reorderable item — do not cross the grouping/fixed boundary.
        while (sibling && !sibling.classList.contains('col-reorderable')) {
            sibling = delta < 0 ? sibling.previousElementSibling : sibling.nextElementSibling;
        }
        if (!sibling) return;
        if (delta < 0) lbl.parentNode.insertBefore(lbl, sibling);
        else lbl.parentNode.insertBefore(lbl, sibling.nextElementSibling);

        _onColumnOrderChanged();
    }

    // ---- HTML5 drag&drop ----
    var _dragSrc = null;
    function _onDragStart(e) {
        var lbl = e.target.closest('label.col-reorderable');
        if (!lbl) return;
        _dragSrc = lbl;
        lbl.classList.add('dragging');
        try { e.dataTransfer.effectAllowed = 'move'; e.dataTransfer.setData('text/plain', lbl.getAttribute('data-col-sql') || ''); } catch (_) {}
    }
    function _onDragEnd(e) {
        if (_dragSrc) _dragSrc.classList.remove('dragging');
        document.querySelectorAll('#colToggleList .drop-before, #colToggleList .drop-after')
            .forEach(function(el) { el.classList.remove('drop-before', 'drop-after'); });
        _dragSrc = null;
    }
    function _onDragOver(e) {
        if (!_dragSrc) return;
        var lbl = e.target.closest('label.col-reorderable');
        if (!lbl || lbl === _dragSrc) return;
        e.preventDefault();
        try { e.dataTransfer.dropEffect = 'move'; } catch (_) {}
        var rect = lbl.getBoundingClientRect();
        var before = (e.clientY - rect.top) < rect.height / 2;
        document.querySelectorAll('#colToggleList .drop-before, #colToggleList .drop-after')
            .forEach(function(el) { el.classList.remove('drop-before', 'drop-after'); });
        lbl.classList.add(before ? 'drop-before' : 'drop-after');
    }
    function _onDrop(e) {
        if (!_dragSrc) return;
        var lbl = e.target.closest('label.col-reorderable');
        if (!lbl || lbl === _dragSrc) { _onDragEnd(e); return; }
        e.preventDefault();
        var rect = lbl.getBoundingClientRect();
        var before = (e.clientY - rect.top) < rect.height / 2;
        if (before) lbl.parentNode.insertBefore(_dragSrc, lbl);
        else lbl.parentNode.insertBefore(_dragSrc, lbl.nextElementSibling);
        _onDragEnd(e);
        _onColumnOrderChanged();
    }

    function _onColumnOrderChanged() {
        _saveColumnOrder();
        applyColumnOrderToGrid(getColumnOrderFromModal());
    }

    function _initColumnReorder() {
        var list = document.getElementById('colToggleList');
        if (!list) return;
        list.addEventListener('dragstart', _onDragStart);
        list.addEventListener('dragend', _onDragEnd);
        list.addEventListener('dragover', _onDragOver);
        list.addEventListener('drop', _onDrop);
        list.addEventListener('dragleave', function(e) {
            var lbl = e.target.closest && e.target.closest('label.col-reorderable');
            if (lbl) lbl.classList.remove('drop-before', 'drop-after');
        });

        // Apply any previously saved order to BOTH the modal list and the grid.
        var saved = _loadColumnOrder();
        if (saved && saved.length) {
            _applyOrderToModal(saved);
            applyColumnOrderToGrid(saved);
        }
    }

    // Hook Reset to Default: wipe session-scoped order AND the hidden input, so defaults are genuine
    // on the next "Apply & Refresh" (the form post will carry ColumnOrder = empty => Model.ColumnOrder null).
    (function _extendResetDefaults() {
        var orig = window.resetDefaultColumns;
        window.resetDefaultColumns = function() {
            if (typeof orig === 'function') orig();
            try { sessionStorage.removeItem(COL_ORDER_KEY); } catch (_) {}
            var hidden = document.getElementById('columnOrderHidden');
            if (hidden) hidden.value = '';
        };
    })();

    // Also clear column order when the user resets their SAVED layout (server-side). The page
    // reloads immediately after so we don't need to touch the hidden input here.
    (function _extendResetSavedLayout() {
        var orig = window.resetSavedLayout;
        if (typeof orig !== 'function') return;
        window.resetSavedLayout = function() {
            try { sessionStorage.removeItem(COL_ORDER_KEY); } catch (_) {}
            return orig.apply(this, arguments);
        };
    })();
    // ==================== END COLUMN REORDER ====================

    // ==================== Show Profit / Show Stock <-> Display Columns sync ====================
    // Mapping of "quick toggle" -> Display Columns names (server) and col-toggle values (client visibility modal).
    // Display Columns names ("Profit") differ slightly from col-toggle values ("ProfitValue").
    var SYNC_GROUPS = {
        showProfitToggle: { display: ['Profit','Markup','Margin'], colToggle: ['ProfitValue','Markup','Margin'] },
        showStockToggle:  { display: ['TotalStockQty','TotalStockValue'], colToggle: ['TotalStockQty','TotalStockValue'] }
    };

    function _getDisplayColsArr() {
        var hidden = document.getElementById('displayColumnsHidden');
        if (!hidden) return [];
        return (hidden.value || '').split(',').map(function(s){ return s.trim(); }).filter(function(s){ return s.length > 0; });
    }
    function _setDisplayColsArr(cols) {
        var hidden = document.getElementById('displayColumnsHidden');
        if (hidden) hidden.value = cols.join(',');
    }
    function _hasAnyCi(arr, names) {
        var lower = arr.map(function(s){ return s.toLowerCase(); });
        for (var i = 0; i < names.length; i++) {
            if (lower.indexOf(names[i].toLowerCase()) >= 0) return true;
        }
        return false;
    }
    function _addUniqueCi(arr, name) {
        var exists = arr.some(function(s){ return s.toLowerCase() === name.toLowerCase(); });
        if (!exists) arr.push(name);
        return arr;
    }
    function _removeCi(arr, name) {
        return arr.filter(function(s){ return s.toLowerCase() !== name.toLowerCase(); });
    }

    // When Show Profit / Show Stock toggle is changed by the user.
    function onQuickToggleChange(toggleId) {
        var toggle = document.getElementById(toggleId);
        var grp = SYNC_GROUPS[toggleId];
        if (!toggle || !grp) return;
        var checked = toggle.checked;

        // 1) Update server-side DisplayColumns hidden input
        var cols = _getDisplayColsArr();
        if (checked) {
            grp.display.forEach(function(n){ cols = _addUniqueCi(cols, n); });
        } else {
            grp.display.forEach(function(n){ cols = _removeCi(cols, n); });
        }
        _setDisplayColsArr(cols);

        // 2) Sync modal col-toggle checkboxes so the two UIs stay consistent.
        grp.colToggle.forEach(function(v){
            var cb = document.querySelector('.col-toggle[value="' + v + '"]');
            if (cb && cb.checked !== checked) {
                cb.checked = checked;
                if (typeof onColToggleChange === 'function') onColToggleChange(cb);
            }
        });
        if (typeof updateDirtyIndicator === 'function') updateDirtyIndicator();
    }

    // When user toggles a col-toggle checkbox in the visibility modal: refresh quick-toggle states.
    function syncQuickTogglesFromColToggles() {
        Object.keys(SYNC_GROUPS).forEach(function(id) {
            var toggle = document.getElementById(id);
            if (!toggle) return;
            var grp = SYNC_GROUPS[id];
            var anyChecked = grp.colToggle.some(function(v) {
                var cb = document.querySelector('.col-toggle[value="' + v + '"]');
                return cb && cb.checked;
            });
            // Only flip if a corresponding column actually exists in DOM (i.e. server returned it),
            // otherwise rely on DisplayColumns-based init below.
            var anyExists = grp.colToggle.some(function(v) {
                return !!document.querySelector('.col-toggle[value="' + v + '"]');
            });
            if (anyExists) toggle.checked = anyChecked;
        });
    }

    // Initial sync on page load: derive quick-toggle state from current DisplayColumns.
    function initQuickTogglesFromDisplayCols() {
        var cols = _getDisplayColsArr();
        Object.keys(SYNC_GROUPS).forEach(function(id) {
            var toggle = document.getElementById(id);
            if (!toggle) return;
            toggle.checked = _hasAnyCi(cols, SYNC_GROUPS[id].display);
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        updateColVisibleCount();
        _colsInitialSig = currentColsSignature();

        // Column reorder (drag + up/down) — restores saved order from sessionStorage and wires listeners.
        _initColumnReorder();
        _updateNeedsRefreshUi();

        // Wire bidirectional sync between quick-toggles and Display Columns / col-toggle modal
        initQuickTogglesFromDisplayCols();
        ['showProfitToggle','showStockToggle'].forEach(function(id) {
            var t = document.getElementById(id);
            if (t) t.addEventListener('change', function() { onQuickToggleChange(id); });
        });

        var colSearch = document.getElementById('colSearchInput');
        if (colSearch) {
            colSearch.addEventListener('input', filterColumnList);
            colSearch.addEventListener('keyup', filterColumnList);
        }
    });

