@model Powersoft.Reporting.Web.ViewModels.SchedulePartialModel
@*
    Shared scheduling modal. Modelled 1:1 on the Purchases vs Sales schedule modal (the gold
    standard). Host view must define window.collectScheduleParameters() returning the report's
    parameters object; the partial adds reportDateRange and posts to Model.SaveAction.
*@
<div class="modal fade" id="scheduleModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-clock-history me-2"></i>Schedule Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-light border mb-3 py-2">
                    <small class="text-muted"><i class="bi bi-info-circle me-1"></i>The report will run automatically and recipients will receive an email with a link to download the exported file. The current on-screen selection is used.</small>
                </div>

                <h6 class="text-muted mb-2"><i class="bi bi-calendar-range me-1"></i>Report date range</h6>
                <p class="small text-muted mb-2">Computed when the schedule runs.</p>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Period type</label>
                        <select class="form-select" id="schedDateRangeType" onchange="onSchedDateRangeTypeChange()">
                            <option value="Today">Today</option>
                            <option value="Yesterday">Yesterday</option>
                            <option value="LastNDays" data-value="7">Last 7 days</option>
                            <option value="LastNDays" data-value="30">Last 30 days</option>
                            <option value="ThisMonth">This month (to today)</option>
                            <option value="LastMonth">Last month</option>
                            <option value="YearToDate">Year to date</option>
                            <option value="LastYear">Last year</option>
                            <option value="Custom">Custom (fixed dates)</option>
                        </select>
                    </div>
                    <div class="col-md-3" id="schedCustomDateFromWrap" style="display:none;">
                        <label class="form-label fw-semibold">From</label>
                        <input type="date" class="form-control" id="schedDateFrom" value="@Model.DefaultDateFrom">
                    </div>
                    <div class="col-md-3" id="schedCustomDateToWrap" style="display:none;">
                        <label class="form-label fw-semibold">To</label>
                        <input type="date" class="form-control" id="schedDateTo" value="@Model.DefaultDateTo">
                    </div>
                </div>

                <h6 class="text-muted mb-2"><i class="bi bi-gear me-1"></i>Schedule settings</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Schedule Name</label>
                        <input type="text" class="form-control" id="schedName" placeholder="@Model.NamePlaceholder" required>
                        <input type="hidden" id="schedId" value="">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Export Format</label>
                        <select class="form-select" id="schedFormat">
                            <option value="Excel">Excel (.xlsx)</option>
                            <option value="PDF">PDF</option>
                            <option value="CSV">CSV</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Recurrence</label>
                        <select class="form-select" id="schedRecurrence" onchange="onRecurrenceChange()">
                            <option value="Once">Run Once</option>
                            <option value="Daily" selected>Daily</option>
                            <option value="Weekly">Weekly</option>
                            <option value="Monthly">Monthly</option>
                        </select>
                    </div>
                    <div class="col-md-4" id="schedWeeklyDaysContainer" style="display:none;">
                        <label class="form-label fw-semibold">Days of week</label>
                        <div class="d-flex flex-wrap gap-2">
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="1"> Mon</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="2"> Tue</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="3"> Wed</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="4"> Thu</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="5"> Fri</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="6"> Sat</label>
                            <label class="btn btn-outline-secondary btn-sm"><input type="checkbox" class="sched-dow" value="0"> Sun</label>
                        </div>
                    </div>
                    <div class="col-md-4" id="schedMonthDayContainer" style="display:none;">
                        <label class="form-label fw-semibold">Day of month</label>
                        <select class="form-select" id="schedMonthDay">
                            @for (var i = 1; i <= 28; i++) { <option value="@i">@i</option> }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Time</label>
                        <input type="time" class="form-control" id="schedTime" value="08:00">
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Start date</label>
                        <input type="date" class="form-control" id="schedStartDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" min="@DateTime.Today.ToString("yyyy-MM-dd")" style="max-width:12rem;">
                    </div>
                    <div class="col-12 mt-2">
                        <h6 class="text-muted mb-2"><i class="bi bi-envelope me-1"></i>Recipients</h6>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Email addresses</label>
                        <div class="input-group mb-1">
                            <input type="text" class="form-control" id="schedRecipients" placeholder="user@@company.com, manager@@company.com">
                            <button class="btn btn-outline-secondary" type="button" id="schedAddrBookBtn"
                                    onclick="toggleAddressBook()" title="Address Book">
                                <i class="bi bi-book me-1"></i>Book
                            </button>
                        </div>
                        <small class="text-muted">Separate multiple addresses with commas</small>
                        <div id="schedAddrBookPanel" style="display:none;" class="border rounded p-2 mt-2 bg-light">
                            <div class="d-flex gap-2 mb-2">
                                <input type="text" class="form-control form-control-sm" id="schedAddrSearch"
                                       placeholder="Search address book..." oninput="searchAddressBook(this.value)">
                                <button class="btn btn-sm btn-outline-primary" type="button" onclick="showAddRecipientForm()">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>
                            <div id="schedAddrBookList" style="max-height:200px;overflow-y:auto;"></div>
                            <div id="schedAddRecipientForm" style="display:none;" class="mt-2 border-top pt-2">
                                <div class="row g-1">
                                    <div class="col-6">
                                        <input type="text" class="form-control form-control-sm" id="newRecipientEmail" placeholder="email@@example.com">
                                    </div>
                                    <div class="col-4">
                                        <input type="text" class="form-control form-control-sm" id="newRecipientName" placeholder="Display Name">
                                    </div>
                                    <div class="col-2">
                                        <button class="btn btn-sm btn-success w-100" type="button" onclick="saveNewRecipient()">
                                            <i class="bi bi-check"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Email Subject <span class="text-muted fw-normal">(optional)</span></label>
                        <input type="text" class="form-control" id="schedSubject" placeholder="@Model.SubjectPlaceholder">
                    </div>

                    <div class="col-12 mt-3">
                        <h6 class="text-muted mb-2"><i class="bi bi-stars me-1"></i>AI Analysis</h6>
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="schedSkipIfEmpty">
                            <label class="form-check-label fw-semibold" for="schedSkipIfEmpty">Don't send if empty</label>
                        </div>
                        <small class="text-muted d-block mb-3">When enabled, the email will not be sent if the report returns 0 records.</small>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="schedIncludeAi" onchange="onSchedAiToggle()">
                            <label class="form-check-label fw-semibold" for="schedIncludeAi">Include AI Analysis in email</label>
                        </div>
                        <small class="text-muted d-block mt-1">When enabled, an AI-generated business intelligence summary will be included in the scheduled email body.</small>
                        <div id="schedAiDetails" class="mt-2 ps-4" style="display:none;">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto">
                                    <label class="form-label small mb-0 fw-semibold" for="schedAiLocale">Language</label>
                                </div>
                                <div class="col-auto">
                                    <select class="form-select form-select-sm" id="schedAiLocale" style="width:auto;min-width:140px;">
                                        <option value="el">Ελληνικά</option>
                                        <option value="en">English</option>
                                        <option value="sr">Srpski</option>
                                        <option value="de">Deutsch</option>
                                        <option value="fr">Français</option>
                                        <option value="bg">Български</option>
                                        <option value="ru">Русский</option>
                                        <option value="uk">Українська</option>
                                        <option value="et">Eesti</option>
                                        <option value="nl">Nederlands</option>
                                    </select>
                                </div>
                            </div>
                            <div class="alert alert-light border py-2 mt-2 mb-0 small">
                                <i class="bi bi-info-circle me-1 text-primary"></i>
                                <strong>Estimated cost:</strong> ~$0.002–0.01 per analysis (depends on report size).
                                Token usage is logged for each execution.
                            </div>
                        </div>
                    </div>
                </div>
                <div id="scheduleAlert" class="mt-3" style="display:none;"></div>

                <hr class="my-3">
                <h6 class="text-muted"><i class="bi bi-list-check me-1"></i>Existing Schedules</h6>
                <div id="existingSchedules" class="small text-muted">Loading...</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary me-auto" onclick="resetScheduleForm()" title="Clear the form to create a new schedule"><i class="bi bi-arrow-counterclockwise me-1"></i>Reset</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="schedSaveBtn" onclick="saveSchedule()"><i class="bi bi-check-lg me-1"></i>Save Schedule</button>
            </div>
        </div>
    </div>
</div>

<script>
// ===== Shared schedule modal logic (mirrors Purchases vs Sales) =====
var SCHED_SAVE_URL = '@Url.Action(Model.SaveAction, "Reports")';
var SCHED_LIST_URL = '@Url.Action(Model.ListAction, "Reports")';
var SCHED_BADGE = '@Html.Raw(Model.ReportBadge.Replace("'", "\\'"))';
var SCHED_DEFAULT_RECIPIENTS = '@Html.Raw(Model.DefaultRecipients.Replace("'", "\\'"))';

if (typeof escapeHtml !== 'function') {
    window.escapeHtml = function (s) {
        return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    };
}
if (typeof validateEmailList !== 'function') {
    window.validateEmailList = function (list) {
        var parts = String(list || '').split(',').map(function (s) { return s.trim(); }).filter(Boolean);
        var re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
        var errors = parts.filter(function (p) { return !re.test(p); });
        return { valid: errors.length === 0, errors: errors };
    };
}

function showScheduleToast(message, type) {
    var existing = document.getElementById('schedToast');
    if (existing) existing.remove();
    var div = document.createElement('div');
    div.id = 'schedToast';
    div.className = 'alert alert-' + type + ' alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow';
    div.style.zIndex = '11000';
    div.innerHTML = '<i class="bi bi-' + (type === 'success' ? 'check-circle' : 'exclamation-triangle') + ' me-1"></i>' +
        message + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    document.body.appendChild(div);
    setTimeout(function () { if (div.parentNode) div.remove(); }, 4000);
}

function onSchedDateRangeTypeChange() {
    var sel = document.getElementById('schedDateRangeType');
    var opt = sel.options[sel.selectedIndex];
    var isCustom = (opt.value === 'Custom');
    document.getElementById('schedCustomDateFromWrap').style.display = isCustom ? '' : 'none';
    document.getElementById('schedCustomDateToWrap').style.display = isCustom ? '' : 'none';
}

function onRecurrenceChange() {
    var t = document.getElementById('schedRecurrence').value;
    document.getElementById('schedWeeklyDaysContainer').style.display = t === 'Weekly' ? '' : 'none';
    document.getElementById('schedMonthDayContainer').style.display = t === 'Monthly' ? '' : 'none';
}

function onSchedAiToggle() {
    var ai = document.getElementById('schedIncludeAi');
    var details = document.getElementById('schedAiDetails');
    if (ai && details) details.style.display = ai.checked ? '' : 'none';
}

function saveSchedule() {
    var name = document.getElementById('schedName').value.trim();
    var recipients = document.getElementById('schedRecipients').value.trim();
    var alertDiv = document.getElementById('scheduleAlert');
    if (!name || !recipients) {
        alertDiv.innerHTML = '<div class="alert alert-warning mb-0">Please fill in schedule name and recipients.</div>';
        alertDiv.style.display = ''; return;
    }
    var ev = validateEmailList(recipients);
    if (!ev.valid) {
        alertDiv.innerHTML = '<div class="alert alert-warning mb-0">Invalid email(s): ' + ev.errors.join('; ') + '</div>';
        alertDiv.style.display = ''; return;
    }
    var recurrence = document.getElementById('schedRecurrence').value;
    if (recurrence === 'Once') {
        var sd0 = document.getElementById('schedStartDate').value;
        var today = new Date().toISOString().slice(0, 10);
        if (!sd0 || sd0 < today) {
            alertDiv.innerHTML = '<div class="alert alert-warning mb-0">Start date must be today or later.</div>';
            alertDiv.style.display = ''; return;
        }
    }
    var day = (recurrence === 'Monthly') ? parseInt(document.getElementById('schedMonthDay').value, 10) : null;

    var fd = new FormData();
    fd.append('scheduleName', name);
    fd.append('recurrenceType', recurrence);
    if (day !== null && !isNaN(day)) fd.append('recurrenceDay', day);
    fd.append('scheduleTime', document.getElementById('schedTime').value);
    fd.append('exportFormat', document.getElementById('schedFormat').value);
    fd.append('recipients', recipients);
    fd.append('emailSubject', document.getElementById('schedSubject').value);
    fd.append('includeAiAnalysis', document.getElementById('schedIncludeAi').checked);
    fd.append('aiLocale', document.getElementById('schedAiLocale').value);
    fd.append('skipIfEmpty', document.getElementById('schedSkipIfEmpty').checked);

    var dateRangeSel = document.getElementById('schedDateRangeType');
    var dateRangeOpt = dateRangeSel.options[dateRangeSel.selectedIndex];
    var reportDateRange = { type: dateRangeOpt.value };
    if (reportDateRange.type === 'LastNDays') {
        reportDateRange.value = parseInt(dateRangeOpt.getAttribute('data-value') || '7', 10);
    } else if (reportDateRange.type === 'Custom') {
        reportDateRange.dateFrom = document.getElementById('schedDateFrom').value;
        reportDateRange.dateTo = document.getElementById('schedDateTo').value;
    }

    var params = (typeof collectScheduleParameters === 'function') ? (collectScheduleParameters() || {}) : {};
    params.reportDateRange = reportDateRange;
    fd.append('parametersJson', JSON.stringify(params));

    var startDate = document.getElementById('schedStartDate').value || new Date().toISOString().slice(0, 10);
    var recurrenceJson = { type: recurrence, time: document.getElementById('schedTime').value, range: { startDate: startDate, noEndDate: true } };
    if (recurrence === 'Weekly') {
        var days = [];
        document.querySelectorAll('.sched-dow:checked').forEach(function (cb) { days.push(parseInt(cb.value, 10)); });
        recurrenceJson.pattern = { interval: 1, daysOfWeek: days.length ? days : [1] };
    } else if (recurrence === 'Monthly') {
        recurrenceJson.pattern = { dayOfMonth: day !== null ? day : 1 };
    }
    fd.append('recurrenceJson', JSON.stringify(recurrenceJson));

    var sid = document.getElementById('schedId').value;
    if (sid) fd.append('scheduleId', sid);

    var saveBtn = document.getElementById('schedSaveBtn');
    if (saveBtn) saveBtn.disabled = true;
    fetch(SCHED_SAVE_URL, { method: 'POST', body: fd, credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (d) {
            if (saveBtn) saveBtn.disabled = false;
            if (d.success) {
                alertDiv.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle me-1"></i>' + d.message + '</div>';
                alertDiv.style.display = '';
                loadExistingSchedules();
                if (d.updated) { showScheduleToast('Schedule updated', 'success'); }
                else { setTimeout(function () { resetScheduleForm(); showScheduleToast('Schedule saved successfully', 'success'); }, 700); }
            } else {
                alertDiv.innerHTML = '<div class="alert alert-danger mb-0">' + d.message + '</div>';
                alertDiv.style.display = '';
            }
        })
        .catch(function () {
            if (saveBtn) saveBtn.disabled = false;
            alertDiv.innerHTML = '<div class="alert alert-danger mb-0">Network error.</div>';
            alertDiv.style.display = '';
        });
}

function deleteScheduleRow(scheduleId, scheduleName) {
    if (!confirm('Delete schedule "' + scheduleName + '"?\nThis cannot be undone.')) return;
    var fd = new FormData();
    fd.append('scheduleId', scheduleId);
    fetch('@Url.Action("DeleteSchedule", "Reports")', { method: 'POST', body: fd })
        .then(function (r) { return r.json(); })
        .then(function (d) {
            if (d.success) { showScheduleToast('Schedule deleted', 'success'); loadExistingSchedules(); resetScheduleForm(); }
            else { showScheduleToast(d.message || 'Failed to delete schedule', 'danger'); }
        })
        .catch(function () { showScheduleToast('Network error', 'danger'); });
}

function loadExistingSchedules() {
    fetch(SCHED_LIST_URL).then(function (r) { return r.json(); }).then(function (data) {
        var c = document.getElementById('existingSchedules');
        if (!data || data.length === 0) { c.innerHTML = '<em>No schedules configured yet.</em>'; return; }
        var h = '<table class="table table-sm mb-0 align-middle"><thead><tr><th>Name</th><th>Report</th><th>Recurrence</th><th>Format</th><th>Time</th><th>Next Run</th><th class="text-end">Actions</th></tr></thead><tbody>';
        data.forEach(function (s) {
            var safeName = (s.scheduleName || '').replace(/'/g, "\\'").replace(/"/g, '&quot;');
            h += '<tr data-schedule-id="' + s.scheduleId + '" style="cursor:pointer;" title="Click to load this schedule">' +
                '<td>' + escapeHtml(s.scheduleName || '') + '</td>' +
                '<td><span class="badge bg-primary">' + escapeHtml(SCHED_BADGE) + '</span></td>' +
                '<td>' + s.recurrenceType + '</td><td>' + s.exportFormat + '</td><td>' + s.scheduleTime + '</td>' +
                '<td>' + (s.nextRun || '-') + '</td>' +
                '<td class="text-end"><button type="button" class="btn btn-sm btn-outline-primary me-1" title="Load into form" onclick="event.stopPropagation(); loadScheduleIntoForm(' + s.scheduleId + ')"><i class="bi bi-pencil"></i></button>' +
                '<button type="button" class="btn btn-sm btn-outline-danger" title="Delete schedule" onclick="event.stopPropagation(); deleteScheduleRow(' + s.scheduleId + ', \'' + safeName + '\')"><i class="bi bi-trash"></i></button></td></tr>';
        });
        h += '</tbody></table>';
        c.innerHTML = h;
        c.querySelectorAll('tr[data-schedule-id]').forEach(function (tr) {
            tr.addEventListener('click', function () { loadScheduleIntoForm(parseInt(tr.getAttribute('data-schedule-id'), 10)); });
        });
    }).catch(function () { document.getElementById('existingSchedules').innerHTML = '<em>Could not load schedules.</em>'; });
}

function resetScheduleForm() {
    document.getElementById('schedId').value = '';
    document.getElementById('schedName').value = '';
    document.getElementById('schedRecipients').value = SCHED_DEFAULT_RECIPIENTS;
    document.getElementById('schedSubject').value = '';
    document.getElementById('schedFormat').value = 'Excel';
    document.getElementById('schedRecurrence').value = 'Daily';
    document.getElementById('schedTime').value = '08:00';
    var sd = document.getElementById('schedStartDate');
    if (sd) sd.value = new Date().toISOString().slice(0, 10);
    document.querySelectorAll('.sched-dow').forEach(function (cb) { cb.checked = false; });
    var skip = document.getElementById('schedSkipIfEmpty'); if (skip) skip.checked = false;
    var ai = document.getElementById('schedIncludeAi'); if (ai) ai.checked = false;
    onRecurrenceChange(); onSchedAiToggle();
    var a = document.getElementById('scheduleAlert'); if (a) { a.style.display = 'none'; a.innerHTML = ''; }
}

function loadScheduleIntoForm(scheduleId) {
    fetch('@Url.Action("GetScheduleById", "Reports")?scheduleId=' + scheduleId)
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (!data || !data.success || !data.schedule) { showScheduleToast((data && data.message) || 'Could not load schedule', 'danger'); return; }
            var s = data.schedule;
            document.getElementById('schedId').value = scheduleId;
            document.getElementById('schedName').value = s.scheduleName || '';
            document.getElementById('schedRecipients').value = s.recipients || '';
            document.getElementById('schedSubject').value = s.emailSubject || '';
            document.getElementById('schedFormat').value = s.exportFormat || 'Excel';
            document.getElementById('schedRecurrence').value = s.recurrenceType || 'Daily';
            document.getElementById('schedTime').value = s.scheduleTime || '08:00';
            onRecurrenceChange();
            if (s.recurrenceJson) {
                try {
                    var rec = typeof s.recurrenceJson === 'string' ? JSON.parse(s.recurrenceJson) : s.recurrenceJson;
                    if (rec && rec.range && rec.range.startDate) { var sd = document.getElementById('schedStartDate'); if (sd) sd.value = rec.range.startDate; }
                    if (rec && rec.pattern) {
                        if (rec.type === 'Weekly' && Array.isArray(rec.pattern.daysOfWeek)) {
                            document.querySelectorAll('.sched-dow').forEach(function (cb) { cb.checked = rec.pattern.daysOfWeek.indexOf(parseInt(cb.value, 10)) !== -1; });
                        } else if (rec.type === 'Monthly' && rec.pattern.dayOfMonth) {
                            var md = document.getElementById('schedMonthDay'); if (md) md.value = String(rec.pattern.dayOfMonth);
                        }
                    }
                } catch (e) { }
            }
            var skip = document.getElementById('schedSkipIfEmpty'); if (skip) skip.checked = !!s.skipIfEmpty;
            var ai = document.getElementById('schedIncludeAi'); if (ai) ai.checked = !!s.includeAiAnalysis;
            var al = document.getElementById('schedAiLocale'); if (al && s.aiLocale) al.value = s.aiLocale;
            onSchedAiToggle();
            if (s.parametersJson) {
                try {
                    var p = typeof s.parametersJson === 'string' ? JSON.parse(s.parametersJson) : s.parametersJson;
                    var rdrType = document.getElementById('schedDateRangeType');
                    if (rdrType && p.reportDateRange && p.reportDateRange.type) {
                        var v = p.reportDateRange.value; var targetVal = p.reportDateRange.type;
                        for (var i = 0; i < rdrType.options.length; i++) {
                            var opt = rdrType.options[i];
                            if (opt.value === targetVal && (targetVal !== 'LastNDays' || String(opt.getAttribute('data-value')) === String(v))) { rdrType.selectedIndex = i; break; }
                        }
                        if (p.reportDateRange.type === 'Custom') {
                            if (p.reportDateRange.dateFrom) document.getElementById('schedDateFrom').value = p.reportDateRange.dateFrom;
                            if (p.reportDateRange.dateTo) document.getElementById('schedDateTo').value = p.reportDateRange.dateTo;
                        }
                    }
                    onSchedDateRangeTypeChange();
                    if (typeof onScheduleParametersLoaded === 'function') onScheduleParametersLoaded(p);
                } catch (e) { }
            }
            var a = document.getElementById('scheduleAlert');
            if (a) {
                a.innerHTML = '<div class="alert alert-info mb-0 py-2"><i class="bi bi-pencil-square me-1"></i>Editing <strong>' + escapeHtml(s.scheduleName || '') + '</strong>. Saving will update this schedule in place &mdash; click <em>Reset</em> to start a new one instead.</div>';
                a.style.display = '';
            }
        })
        .catch(function () { showScheduleToast('Network error loading schedule', 'danger'); });
}

document.addEventListener('DOMContentLoaded', function () {
    var schedModal = document.getElementById('scheduleModal');
    if (schedModal) {
        schedModal.addEventListener('show.bs.modal', function () {
            resetScheduleForm();
            loadExistingSchedules();
            if (typeof autoSelectScheduleDateRange === 'function') autoSelectScheduleDateRange();
            onSchedDateRangeTypeChange();
        });
    }
    fetch('@Url.Action("GetAiStatus", "Reports")').then(function (r) { return r.json(); }).then(function (d) {
        if (!d.configured) {
            var schedAi = document.getElementById('schedIncludeAi');
            if (schedAi) { schedAi.disabled = true; if (schedAi.parentElement) schedAi.parentElement.title = 'AI not configured — set API key in Settings'; }
        }
    }).catch(function () { });

    var urlSchedId = new URLSearchParams(window.location.search).get('scheduleId');
    if (urlSchedId) {
        history.replaceState(null, '', window.location.pathname);
        fetch('@Url.Action("GetScheduleById", "Reports")?scheduleId=' + urlSchedId)
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (!data || !data.success || !data.schedule) return;
                var s = data.schedule;
                var p = {};
                try { p = typeof s.parametersJson === 'string' ? JSON.parse(s.parametersJson) : (s.parametersJson || {}); } catch (e) { }
                var rdr = p.reportDateRange || {};
                var resolved = _resolveSchedDates(rdr);
                var dfEl = document.getElementById('dateFrom') || document.getElementById('DateFrom');
                var dtEl = document.getElementById('dateTo') || document.getElementById('DateTo');
                var asAtEl = document.getElementById('asAt');
                if (dfEl) dfEl.value = resolved.from;
                if (dtEl) dtEl.value = resolved.to;
                if (asAtEl) asAtEl.value = resolved.to;
                if (typeof onScheduleParametersLoaded === 'function') onScheduleParametersLoaded(p);
                setTimeout(function () {
                    var btn = document.getElementById('generateBtn');
                    if (btn) btn.click();
                }, 300);
            }).catch(function () { });
    }

    function _resolveSchedDates(rdr) {
        var today = new Date(); today.setHours(0, 0, 0, 0);
        function addD(d, n) { var r = new Date(d); r.setDate(r.getDate() + n); return r; }
        function fmt(d) { return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0'); }
        var f, t;
        switch (rdr.type) {
            case 'Today': f = t = today; break;
            case 'Yesterday': f = t = addD(today, -1); break;
            case 'LastNDays': f = addD(today, -(Math.max(rdr.value || 7, 1) - 1)); t = today; break;
            case 'ThisMonth': f = new Date(today.getFullYear(), today.getMonth(), 1); t = today; break;
            case 'LastMonth': f = new Date(today.getFullYear(), today.getMonth() - 1, 1); t = new Date(today.getFullYear(), today.getMonth(), 0); break;
            case 'YearToDate': f = new Date(today.getFullYear(), 0, 1); t = today; break;
            case 'LastYear': f = new Date(today.getFullYear() - 1, 0, 1); t = new Date(today.getFullYear() - 1, 11, 31); break;
            case 'Custom': return { from: rdr.dateFrom || fmt(addD(today, -29)), to: rdr.dateTo || fmt(today) };
            default: f = addD(today, -29); t = today;
        }
        return { from: fmt(f), to: fmt(t) };
    }
});

// ── Address Book ─────────────────────────────────────────────────────────────
var _addrBookCache = null;
var _addrBookSearchTimer = null;

function toggleAddressBook() {
    var panel = document.getElementById('schedAddrBookPanel');
    if (!panel) return;
    var visible = panel.style.display !== 'none';
    panel.style.display = visible ? 'none' : '';
    if (!visible && _addrBookCache === null) loadAddressBook();
}

function loadAddressBook(query) {
    var url = '@Url.Action("GetEmailRecipients", "Reports")';
    if (query) url += '?q=' + encodeURIComponent(query);
    fetch(url, { credentials: 'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (!d.success) return;
            if (!query) _addrBookCache = d.recipients;
            renderAddressBookList(d.recipients || []);
        }).catch(function() {});
}

function renderAddressBookList(recipients) {
    var container = document.getElementById('schedAddrBookList');
    if (!container) return;
    if (!recipients.length) {
        container.innerHTML = '<div class="text-muted small p-2">No contacts found. Use <i class="bi bi-plus"></i> to add.</div>';
        return;
    }
    var html = '';
    recipients.forEach(function(r) {
        var safeName = escapeHtml(r.label || r.email);
        html += '<div class="d-flex align-items-center gap-1 py-1 border-bottom">'
            + '<span class="flex-grow-1 small" style="cursor:pointer;" onclick="addRecipientToInput(\'' + escapeHtml(r.email) + '\')">'
            + '<i class="bi bi-person-fill me-1 text-muted"></i>' + safeName + '</span>'
            + '<button type="button" class="btn btn-sm btn-link text-primary p-0" title="Add to recipients" onclick="addRecipientToInput(\'' + escapeHtml(r.email) + '\')">'
            + '<i class="bi bi-plus-circle"></i></button>'
            + '<button type="button" class="btn btn-sm btn-link text-danger p-0" title="Remove from book" onclick="removeRecipient(' + r.id + ', this)">'
            + '<i class="bi bi-trash"></i></button>'
            + '</div>';
    });
    container.innerHTML = html;
}

function addRecipientToInput(email) {
    var input = document.getElementById('schedRecipients');
    if (!input) return;
    var current = input.value.trim();
    var emails = current ? current.split(',').map(function(e) { return e.trim(); }) : [];
    if (emails.indexOf(email) === -1) {
        emails.push(email);
        input.value = emails.join(', ');
    }
}

function searchAddressBook(q) {
    clearTimeout(_addrBookSearchTimer);
    _addrBookSearchTimer = setTimeout(function() {
        if (!q) {
            if (_addrBookCache) renderAddressBookList(_addrBookCache);
            else loadAddressBook();
        } else {
            loadAddressBook(q);
        }
    }, 300);
}

function showAddRecipientForm() {
    var form = document.getElementById('schedAddRecipientForm');
    if (form) form.style.display = form.style.display === 'none' ? '' : 'none';
}

function saveNewRecipient() {
    var emailEl = document.getElementById('newRecipientEmail');
    var nameEl  = document.getElementById('newRecipientName');
    if (!emailEl) return;
    var email = (emailEl.value || '').trim();
    if (!email) { emailEl.focus(); return; }

    var fd = new FormData();
    fd.append('emailAddress', email);
    fd.append('displayName', nameEl ? nameEl.value.trim() : '');

    fetch('@Url.Action("AddEmailRecipient", "Reports")', { method: 'POST', body: fd, credentials: 'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.success) {
                emailEl.value = ''; if (nameEl) nameEl.value = '';
                showAddRecipientForm();
                _addrBookCache = null;
                loadAddressBook();
            } else {
                alert(d.message || 'Failed to add recipient.');
            }
        }).catch(function() { alert('Network error.'); });
}

function removeRecipient(id, btn) {
    if (!confirm('Remove this contact from the address book?')) return;
    fetch('@Url.Action("DeleteEmailRecipient", "Reports")?id=' + id, { method: 'DELETE', credentials: 'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.success) {
                _addrBookCache = null;
                loadAddressBook();
            } else {
                alert(d.message || 'Failed to remove.');
            }
        }).catch(function() {});
}
</script>
