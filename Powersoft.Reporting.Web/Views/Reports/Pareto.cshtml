@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
var _paretoChart = null;

document.querySelectorAll('input[name="DatePreset"]').forEach(function(el) {
    el.addEventListener('change', function() {
        var now = new Date();
        var y = now.getFullYear(), m = now.getMonth(), d = now.getDate();
        var from, to;
        switch (this.value) {
            case 'today': from = to = new Date(y, m, d); break;
            case 'last30': from = new Date(y, m, d - 30); to = new Date(y, m, d); break;
            case 'thisMonth': from = new Date(y, m, 1); to = new Date(y, m, d); break;
            case 'lastMonth': from = new Date(y, m - 1, 1); to = new Date(y, m, 0); break;
            case 'ytd': from = new Date(y, 0, 1); to = new Date(y, m, d); break;
            case 'lastYear': from = new Date(y - 1, 0, 1); to = new Date(y - 1, 11, 31); break;
        }
        if (from) document.getElementById('dateFrom').value = from.toISOString().split('T')[0];
        if (to) document.getElementById('dateTo').value = to.toISOString().split('T')[0];
    });
});
function clearPreset() { document.querySelectorAll('input[name="DatePreset"]').forEach(function(r) { r.checked = false; }); }

function onMetricChanged() {
    var m = document.getElementById('metric').value;
    document.getElementById('profitBasisGroup').style.display = m === 'Profit' ? '' : 'none';
    var pb = document.getElementById('profitBasis').value;
    var isCost = pb === '99' || pb === '88' || pb === '87';
    document.getElementById('includeVat').disabled = (m === 'Profit' && isCost);
}

function onDimensionChanged() {
    var d = document.getElementById('dimension').value;
    var show = d === 'ByPrice';
    document.getElementById('priceIntervalGroup').style.display = show ? '' : 'none';
    document.getElementById('priceOnGroup').style.display = show ? '' : 'none';
}

function syncParetoPerc(src) {
    if (src === 'items') {
        document.getElementById('paretoPercValue').value = 100 - parseInt(document.getElementById('paretoPercItems').value || '20');
    } else {
        document.getElementById('paretoPercItems').value = 100 - parseInt(document.getElementById('paretoPercValue').value || '80');
    }
}

function getItemsSelectionJson() {
    if (typeof getItemsSelectionFilter === 'function') {
        var f = getItemsSelectionFilter();
        return Object.keys(f).length > 0 ? JSON.stringify(f) : '';
    }
    return '';
}
function getSelectedStoreCodes() {
    return typeof getItemsSelectionStoreCodes === 'function'
        ? getItemsSelectionStoreCodes() : '';
}

function exportPareto(format) {
    var dateFrom = document.getElementById('dateFrom').value;
    var dateTo = document.getElementById('dateTo').value;
    if (!dateFrom || !dateTo) { alert('Please select dates first.'); return; }

    var dim = document.getElementById('dimension').value;
    var params = new URLSearchParams({
        dateFrom: dateFrom,
        dateTo: dateTo,
        dimension: dim,
        metric: document.getElementById('metric').value,
        includeVat: document.getElementById('includeVat').checked,
        storeCodes: getSelectedStoreCodes(),
        classAThreshold: document.getElementById('paretoPercValue').value,
        classBThreshold: '95',
        excludeNegativeAmounts: document.getElementById('excludeNegative').checked,
        profitBasis: document.getElementById('profitBasis').value,
        timezoneOffsetMinutes: -new Date().getTimezoneOffset()
    });
    if (dim === 'ByPrice') {
        params.set('priceInterval', document.getElementById('priceInterval').value);
        params.set('priceOnIndex', document.getElementById('priceOnIndex').value);
        params.set('priceOnIncludesVat', document.getElementById('includeVat').checked);
    }
    var isJson = getItemsSelectionJson();
    if (isJson) params.set('itemsSelection', isJson);

    var action = format === 'excel' ? 'ExportParetoExcel' : format === 'pdf' ? 'ExportParetoPdf' : 'ExportParetoCsv';
    window.location.href = '/Reports/' + action + '?' + params.toString();
}

function loadPareto() {
    var dateFrom = document.getElementById('dateFrom').value;
    var dateTo = document.getElementById('dateTo').value;
    if (!dateFrom || !dateTo) { alert('Please select dates.'); return; }

    document.getElementById('paretoLoading').classList.remove('d-none');
    document.getElementById('paretoError').classList.add('d-none');
    document.getElementById('paretoResults').classList.add('d-none');
    document.getElementById('emptyState').classList.add('d-none');
    var ra = document.getElementById('resultsActions');
    if (ra) { ra.style.display = 'none !important'; ra.style.cssText = 'display:none !important'; }

    var fd = new FormData();
    fd.append('dateFrom', dateFrom);
    fd.append('dateTo', dateTo);
    fd.append('dimension', document.getElementById('dimension').value);
    fd.append('metric', document.getElementById('metric').value);
    fd.append('includeVat', document.getElementById('includeVat').checked);
    fd.append('storeCodes', getSelectedStoreCodes());
    fd.append('classAThreshold', document.getElementById('paretoPercValue').value);
    fd.append('classBThreshold', '95');
    fd.append('excludeNegativeAmounts', document.getElementById('excludeNegative').checked);
    fd.append('showOthers', document.getElementById('showOthers').checked);
    fd.append('profitBasis', document.getElementById('profitBasis').value);
    fd.append('timezoneOffsetMinutes', -new Date().getTimezoneOffset());
    if (document.getElementById('dimension').value === 'ByPrice') {
        fd.append('priceInterval', document.getElementById('priceInterval').value);
        fd.append('priceOnIndex', document.getElementById('priceOnIndex').value);
        fd.append('priceOnIncludesVat', document.getElementById('includeVat').checked);
    }
    var isJson = getItemsSelectionJson();
    if (isJson) fd.append('itemsSelection', isJson);

    fetch('/Reports/GetParetoData', { method: 'POST', body: fd })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            document.getElementById('paretoLoading').classList.add('d-none');
            if (!data.success) {
                document.getElementById('paretoError').textContent = data.message;
                document.getElementById('paretoError').classList.remove('d-none');
                return;
            }
            renderPareto(data);
        })
        .catch(function(err) {
            document.getElementById('paretoLoading').classList.add('d-none');
            document.getElementById('paretoError').textContent = 'Network error: ' + err.message;
            document.getElementById('paretoError').classList.remove('d-none');
        });
}

var _paretoPreviewOpen = false;
function toggleParetoPreview() {
    var panel = document.getElementById('paretoPreviewPanel');
    var gridCard = document.getElementById('paretoGridCard');
    var btn = document.getElementById('previewToggleBtn');
    _paretoPreviewOpen = !_paretoPreviewOpen;

    if (_paretoPreviewOpen) {
        gridCard.style.display = 'none';
        panel.style.display = 'block';
        btn.innerHTML = '<i class="bi bi-table me-1"></i>Grid';
        btn.classList.remove('btn-outline-primary');
        btn.classList.add('btn-outline-warning');

        var frame = document.getElementById('paretoPreviewFrame');
        var dateFrom = document.getElementById('dateFrom').value;
        var dateTo = document.getElementById('dateTo').value;
        var dim = document.getElementById('dimension').value;
        var met = document.getElementById('metric').value;

        var tableHtml = document.querySelector('#paretoGridCard .card-body').innerHTML;

        var html = '<!DOCTYPE html><html><head><meta charset="utf-8">'
            + '<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">'
            + '<style>body{padding:30px;font-family:Arial,sans-serif;background:#fff}'
            + '.class-a{background:#dcfce7!important}.class-b{background:#fef9c3!important}'
            + '.class-c{background:#fee2e2!important}'
            + '.badge-a{background:#16a34a;color:#fff}.badge-b{background:#ca8a04;color:#fff}.badge-c{background:#dc2626;color:#fff}'
            + '@@media print{.no-print{display:none!important}body{padding:10px}}</style></head><body>'
            + '<div class="d-flex justify-content-between align-items-start mb-3">'
            + '<div><h4>Pareto 80/20 Analysis</h4>'
            + '<p class="text-muted mb-0">' + dateFrom + ' to ' + dateTo + ' \u2014 @(dbName.Replace("'", "\\'"))</p>'
            + '<p class="text-muted small">Dimension: ' + dim + ' \u2022 Metric: ' + met + '</p></div>'
            + '<button class="btn btn-sm btn-primary no-print" onclick="window.print()"><i class="bi bi-printer me-1"></i>Print</button>'
            + '</div>'
            + '<div style="max-height:none;overflow:visible;">' + tableHtml + '</div>'
            + '</body></html>';

        frame.srcdoc = html;
        frame.onload = function() {
            try {
                var h = frame.contentDocument.body.scrollHeight + 80;
                frame.style.height = Math.max(h, 700) + 'px';
            } catch (e) { frame.style.height = '900px'; }
        };
    } else {
        panel.style.display = 'none';
        gridCard.style.display = '';
        btn.innerHTML = '<i class="bi bi-eye me-1"></i>Preview';
        btn.classList.remove('btn-outline-warning');
        btn.classList.add('btn-outline-primary');
    }
}

function renderPareto(data) {
    document.getElementById('paretoResults').classList.remove('d-none');
    document.getElementById('resultsActions').style.display = '';
    document.getElementById('resultsActions').style.cssText = '';
    var metricType = document.getElementById('metric').value;
    var isQty = metricType === 'Quantity';
    var isProfit = metricType === 'Profit';
    var showOthers = document.getElementById('showOthers').checked;
    var metricLabel = isQty ? 'Quantity' : isProfit ? 'Profit' : 'Value';
    var fmt = function(v) { return isQty ? v.toLocaleString() : v.toLocaleString(undefined, {minimumFractionDigits:2}); };

    var cards = document.getElementById('summaryCards');
    var gt = data.grandTotal;
    var aPct = gt > 0 ? (data.classAValue / gt * 100).toFixed(1) : 0;
    var bPct = gt > 0 ? (data.classBValue / gt * 100).toFixed(1) : 0;
    var cPct = gt > 0 ? (data.classCValue / gt * 100).toFixed(1) : 0;
    var aItemPct = data.totalItems > 0 ? (data.classACount / data.totalItems * 100).toFixed(1) : 0;
    var bItemPct = data.totalItems > 0 ? (data.classBCount / data.totalItems * 100).toFixed(1) : 0;
    var cItemPct = data.totalItems > 0 ? (data.classCCount / data.totalItems * 100).toFixed(1) : 0;

    cards.innerHTML =
        '<div class="col-md-3"><div class="stat-card border" style="border-left:4px solid #2563eb !important;"><h3>' + fmt(gt) + '</h3><div class="label">Grand Total (' + data.totalItems + ' items)</div></div></div>' +
        '<div class="col-md-3"><div class="stat-card class-a border" style="border-left:4px solid #16a34a !important;"><h3>' + data.classACount + ' <small class="text-muted" style="font-size:0.7rem;">(' + aItemPct + '%)</small></h3><div class="label">Class A — ' + aPct + '% of ' + metricLabel.toLowerCase() + '</div></div></div>' +
        '<div class="col-md-3"><div class="stat-card class-b border" style="border-left:4px solid #ca8a04 !important;"><h3>' + data.classBCount + ' <small class="text-muted" style="font-size:0.7rem;">(' + bItemPct + '%)</small></h3><div class="label">Class B — ' + bPct + '% of ' + metricLabel.toLowerCase() + '</div></div></div>' +
        '<div class="col-md-3"><div class="stat-card class-c border" style="border-left:4px solid #dc2626 !important;"><h3>' + data.classCCount + ' <small class="text-muted" style="font-size:0.7rem;">(' + cItemPct + '%)</small></h3><div class="label">Class C — ' + cPct + '% of ' + metricLabel.toLowerCase() + '</div></div></div>';

    var allRows = data.rows;
    var rows = showOthers ? allRows : allRows.filter(function(r) { return r.isDisplay; });

    var maxRows = Math.min(rows.length, 50);
    var labels = rows.slice(0, maxRows).map(function(r) { return r.name.length > 25 ? r.name.substring(0, 22) + '...' : r.name; });
    var values = rows.slice(0, maxRows).map(function(r) { return r.value; });
    var cumPcts = rows.slice(0, maxRows).map(function(r) { return r.cumulativePercentage; });
    var barColors = rows.slice(0, maxRows).map(function(r) { return r.classification === 'A' ? '#16a34a' : r.classification === 'B' ? '#ca8a04' : '#dc2626'; });

    if (_paretoChart) _paretoChart.destroy();
    var ctx = document.getElementById('paretoChart').getContext('2d');
    _paretoChart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [
                { type: 'bar', label: metricLabel, data: values, backgroundColor: barColors.map(function(c) { return c + 'CC'; }), borderColor: barColors, borderWidth: 1, yAxisID: 'y', order: 2 },
                { type: 'line', label: 'Cumulative %', data: cumPcts, borderColor: '#2563eb', backgroundColor: '#2563eb22', borderWidth: 2, pointRadius: 2, fill: false, yAxisID: 'y1', order: 1 }
            ]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: { legend: { position: 'top', labels: { font: { size: 11 } } }, tooltip: { callbacks: { label: function(ctx) { if (ctx.dataset.yAxisID === 'y1') return 'Cumul: ' + ctx.parsed.y.toFixed(1) + '%'; return ctx.dataset.label + ': ' + fmt(ctx.parsed.y); } } } },
            scales: {
                x: { ticks: { font: { size: 9 }, maxRotation: 60 } },
                y: { beginAtZero: true, position: 'left', title: { display: true, text: metricLabel + (isQty ? '' : ' (\u20ac)') } },
                y1: { beginAtZero: true, max: 100, position: 'right', grid: { drawOnChartArea: false }, title: { display: true, text: 'Cumul. %' } }
            }
        }
    });

    var displayCount = allRows.filter(function(r) { return r.isDisplay; }).length;
    document.getElementById('rowCountBadge').textContent = rows.length + ' rows' + (!showOthers && allRows.length > rows.length ? ' (of ' + allRows.length + ' total, ' + (allRows.length - displayCount) + ' hidden)' : '');
    var tbody = document.getElementById('paretoTable');
    var html = '';
    var fmtNum = function(v) { return v.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2}); };
    var fmtQty = function(v) { return v.toLocaleString(undefined, {minimumFractionDigits:0, maximumFractionDigits:4}); };
    var isItemDim = document.getElementById('dimension').value === 'Item';
    rows.forEach(function(r) {
        var cls = r.classification === 'A' ? 'class-a' : r.classification === 'B' ? 'class-b' : 'class-c';
        var badge = r.classification === 'A' ? 'badge-a' : r.classification === 'B' ? 'badge-b' : 'badge-c';
        var codeCell = isItemDim
            ? '<td class="text-nowrap"><a href="#" class="text-decoration-none" onclick="showParetoItemDetail(\'' + r.code.replace(/'/g, "\\'") + '\');return false;">' + r.code + '</a></td>'
            : '<td class="text-nowrap">' + r.code + '</td>';
        html += '<tr class="' + cls + '">' +
            '<td>' + r.rank + '</td>' +
            codeCell +
            '<td>' + r.name + '</td>' +
            '<td class="text-end">' + fmtQty(r.quantity) + '</td>' +
            '<td class="text-end">' + fmtNum(r.subtotal) + '</td>' +
            '<td class="text-end">' + fmtNum(r.profit) + '</td>' +
            '<td class="text-end">' + r.percentage.toFixed(2) + '%</td>' +
            '<td class="text-end fw-semibold">' + r.cumulativePercentage.toFixed(1) + '%</td>' +
            '<td class="text-center"><span class="badge ' + badge + '">' + r.classification + '</span></td></tr>';
    });

    // Legacy parity (Report8020.vb fOther*): when "Show Others" is off we still surface the
    // hidden rows as a single aggregated "Others" line instead of dropping them — otherwise a
    // filter that leaves one dominant row (>= Class A threshold) looks like data vanished.
    if (!showOthers) {
        var hidden = allRows.filter(function(r) { return !r.isDisplay; });
        if (hidden.length > 0) {
            var sum = function(sel) { return hidden.reduce(function(a, r) { return a + sel(r); }, 0); };
            var oQty = sum(function(r) { return r.quantity; });
            var oSub = sum(function(r) { return r.subtotal; });
            var oProf = sum(function(r) { return r.profit; });
            var oPct = sum(function(r) { return r.percentage; });
            html += '<tr class="table-secondary fw-semibold">' +
                '<td></td><td></td>' +
                '<td><i class="bi bi-three-dots me-1"></i>Others (' + hidden.length + ')</td>' +
                '<td class="text-end">' + fmtQty(oQty) + '</td>' +
                '<td class="text-end">' + fmtNum(oSub) + '</td>' +
                '<td class="text-end">' + fmtNum(oProf) + '</td>' +
                '<td class="text-end">' + oPct.toFixed(2) + '%</td>' +
                '<td class="text-end">100.0%</td>' +
                '<td class="text-center">&mdash;</td></tr>';
        }
    }
    tbody.innerHTML = html;
}

// ==================== Collect Pareto Params ====================
function collectParetoParams() {
    var dim = document.getElementById('dimension').value;
    var p = {
        dateFrom: document.getElementById('dateFrom').value,
        dateTo: document.getElementById('dateTo').value,
        dimension: dim,
        metric: document.getElementById('metric').value,
        includeVat: document.getElementById('includeVat').checked,
        excludeNegativeAmounts: document.getElementById('excludeNegative').checked,
        classAThreshold: document.getElementById('paretoPercValue').value,
        classBThreshold: '95',
        profitBasis: document.getElementById('profitBasis').value,
        timezoneOffsetMinutes: -new Date().getTimezoneOffset(),
        storeCodes: getSelectedStoreCodes(),
        itemsSelectionJson: getItemsSelectionJson()
    };
    if (dim === 'ByPrice') {
        p.priceInterval = document.getElementById('priceInterval').value;
        p.priceOnIndex = document.getElementById('priceOnIndex').value;
        p.priceOnIncludesVat = document.getElementById('includeVat').checked;
    }
    return p;
}

function collectParetoFormData() {
    var p = collectParetoParams();
    var fd = new FormData();
    for (var k in p) fd.append(k, p[k]);
    var isJson = getItemsSelectionJson();
    if (isJson) fd.append('itemsSelection', isJson);
    return fd;
}

// ==================== Schedule ====================
function onSchedAiToggle() {
    document.getElementById('schedAiDetails').style.display =
        document.getElementById('schedIncludeAi').checked ? '' : 'none';
}

function onSchedDateRangeTypeChange() {
    var sel = document.getElementById('schedDateRangeType');
    var opt = sel.options[sel.selectedIndex];
    var isCustom = (opt.value === 'Custom');
    document.getElementById('schedCustomDateFromWrap').style.display = isCustom ? '' : 'none';
    document.getElementById('schedCustomDateToWrap').style.display = isCustom ? '' : 'none';
}

function onRecurrenceChange() {
    var type = document.getElementById('schedRecurrence').value;
    document.getElementById('schedWeeklyDaysContainer').style.display = type === 'Weekly' ? '' : 'none';
    document.getElementById('schedMonthDayContainer').style.display = type === 'Monthly' ? '' : 'none';
}

function autoSelectScheduleDateRange() {
    var preset = document.querySelector('input[name="DatePreset"]:checked');
    if (!preset) return;
    var map = { 'ytd': 'YearToDate', 'lastYear': 'LastYear', 'thisMonth': 'ThisMonth', 'lastMonth': 'LastMonth', 'last7': 'LastNDays_7', 'last30': 'LastNDays_30' };
    var mapped = map[preset.value];
    if (!mapped) return;
    var sel = document.getElementById('schedDateRangeType');
    for (var i = 0; i < sel.options.length; i++) {
        var opt = sel.options[i];
        if (mapped.startsWith('LastNDays_')) {
            var days = mapped.split('_')[1];
            if (opt.value === 'LastNDays' && opt.getAttribute('data-value') === days) { sel.selectedIndex = i; return; }
        } else if (opt.value === mapped) { sel.selectedIndex = i; return; }
    }
}

function resetScheduleForm() {
    document.getElementById('schedId').value = '';
    document.getElementById('schedName').value = '';
    document.getElementById('schedRecipients').value = '';
    document.getElementById('schedSubject').value = '';
    document.getElementById('schedRecurrence').value = 'Daily';
    document.getElementById('schedTime').value = '08:00';
    document.getElementById('schedFormat').value = 'Excel';
    document.getElementById('schedSkipIfEmpty').checked = false;
    document.getElementById('schedIncludeAi').checked = false;
    document.getElementById('schedAiDetails').style.display = 'none';
    document.getElementById('scheduleAlert').style.display = 'none';
    onRecurrenceChange();
}

function loadExistingSchedules() {
    fetch('@Url.Action("GetParetoSchedules", "Reports")')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var container = document.getElementById('existingSchedules');
            if (!data || data.length === 0) { container.innerHTML = '<em>No schedules configured yet.</em>'; return; }
            var html = '<table class="table table-sm mb-0 align-middle"><thead><tr><th>Name</th><th>Recurrence</th><th>Format</th><th>Time</th><th>Next Run</th><th class="text-end">Actions</th></tr></thead><tbody>';
            data.forEach(function(s) {
                var safeName = (s.scheduleName || '').replace(/'/g, "\\'").replace(/"/g, '&quot;');
                html += '<tr data-schedule-id="' + s.scheduleId + '" style="cursor:pointer;" title="Click to load">'
                    + '<td>' + escapeHtml(s.scheduleName || '') + '</td>'
                    + '<td>' + s.recurrenceType + '</td>'
                    + '<td>' + s.exportFormat + '</td>'
                    + '<td>' + s.scheduleTime + '</td>'
                    + '<td>' + (s.nextRun || '-') + '</td>'
                    + '<td class="text-end">'
                    + '<button type="button" class="btn btn-sm btn-outline-primary me-1" title="Load" onclick="event.stopPropagation(); loadScheduleIntoForm(' + s.scheduleId + ')"><i class="bi bi-pencil"></i></button>'
                    + '<button type="button" class="btn btn-sm btn-outline-danger" title="Delete" onclick="event.stopPropagation(); deleteScheduleRow(' + s.scheduleId + ', \'' + safeName + '\')"><i class="bi bi-trash"></i></button>'
                    + '</td></tr>';
            });
            html += '</tbody></table>';
            container.innerHTML = html;
            container.querySelectorAll('tr[data-schedule-id]').forEach(function(tr) {
                tr.addEventListener('click', function() { loadScheduleIntoForm(parseInt(tr.getAttribute('data-schedule-id'), 10)); });
            });
        })
        .catch(function() { document.getElementById('existingSchedules').innerHTML = '<em>Could not load schedules.</em>'; });
}

function escapeHtml(str) {
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
}

function loadScheduleIntoForm(scheduleId) {
    fetch('@Url.Action("GetScheduleById", "Reports")?scheduleId=' + scheduleId)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.success) return;
            var s = data.schedule;
            document.getElementById('schedId').value = s.scheduleId;
            document.getElementById('schedName').value = s.scheduleName || '';
            document.getElementById('schedRecipients').value = s.recipients || '';
            document.getElementById('schedSubject').value = s.emailSubject || '';
            document.getElementById('schedRecurrence').value = s.recurrenceType || 'Daily';
            document.getElementById('schedTime').value = s.scheduleTime || '08:00';
            document.getElementById('schedFormat').value = s.exportFormat || 'Excel';
            document.getElementById('schedSkipIfEmpty').checked = !!s.skipIfEmpty;
            document.getElementById('schedIncludeAi').checked = !!s.includeAiAnalysis;
            if (s.includeAiAnalysis) {
                document.getElementById('schedAiDetails').style.display = '';
                document.getElementById('schedAiLocale').value = s.aiLocale || 'el';
            }
            onRecurrenceChange();
            if (s.recurrenceType === 'Monthly' && s.recurrenceDay)
                document.getElementById('schedMonthDay').value = s.recurrenceDay;
        });
}

function deleteScheduleRow(scheduleId, name) {
    if (!confirm('Delete schedule "' + name + '"?')) return;
    var fd = new FormData();
    fd.append('scheduleId', scheduleId);
    fetch('@Url.Action("DeleteSchedule", "Reports")', { method: 'POST', body: fd })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) loadExistingSchedules();
            else alert(data.message);
        });
}

function showScheduleToast(msg, type) {
    var alertDiv = document.getElementById('scheduleAlert');
    alertDiv.innerHTML = '<div class="alert alert-' + (type || 'info') + ' mb-0">' + msg + '</div>';
    alertDiv.style.display = '';
    setTimeout(function() { alertDiv.style.display = 'none'; }, 3000);
}

function saveParetoSchedule() {
    var name = document.getElementById('schedName').value.trim();
    var recipients = document.getElementById('schedRecipients').value.trim();
    var alertDiv = document.getElementById('scheduleAlert');

    if (!name || !recipients) {
        alertDiv.innerHTML = '<div class="alert alert-warning mb-0">Please fill in schedule name and recipients.</div>';
        alertDiv.style.display = '';
        return;
    }

    var recurrence = document.getElementById('schedRecurrence').value;
    if (recurrence === 'Once') {
        var startDate = document.getElementById('schedStartDate').value;
        var today = new Date().toISOString().slice(0, 10);
        if (!startDate || startDate < today) {
            alertDiv.innerHTML = '<div class="alert alert-warning mb-0">For "Run once", start date must be today or in the future.</div>';
            alertDiv.style.display = '';
            return;
        }
    }

    var day = (recurrence === 'Monthly') ? parseInt(document.getElementById('schedMonthDay').value, 10) : null;

    var formData = new FormData();
    formData.append('scheduleName', name);
    formData.append('recurrenceType', recurrence);
    if (day !== null && !isNaN(day)) formData.append('recurrenceDay', day);
    formData.append('scheduleTime', document.getElementById('schedTime').value);
    formData.append('exportFormat', document.getElementById('schedFormat').value);
    formData.append('recipients', recipients);
    formData.append('emailSubject', document.getElementById('schedSubject').value);
    formData.append('includeAiAnalysis', document.getElementById('schedIncludeAi').checked);
    formData.append('aiLocale', document.getElementById('schedAiLocale').value);
    formData.append('skipIfEmpty', document.getElementById('schedSkipIfEmpty').checked);

    var dateRangeSel = document.getElementById('schedDateRangeType');
    var dateRangeOpt = dateRangeSel.options[dateRangeSel.selectedIndex];
    var reportDateRange = { type: dateRangeOpt.value };
    if (reportDateRange.type === 'LastNDays') {
        reportDateRange.value = parseInt(dateRangeOpt.getAttribute('data-value') || '7', 10);
    } else if (reportDateRange.type === 'Custom') {
        reportDateRange.dateFrom = document.getElementById('schedDateFrom').value;
        reportDateRange.dateTo = document.getElementById('schedDateTo').value;
    }

    var params = collectParetoParams();
    params.reportDateRange = reportDateRange;
    formData.append('parametersJson', JSON.stringify(params));

    var startDate = document.getElementById('schedStartDate').value || new Date().toISOString().slice(0, 10);
    var recurrenceJson = { type: recurrence, time: document.getElementById('schedTime').value, range: { startDate: startDate, noEndDate: true } };
    if (recurrence === 'Weekly') {
        var days = [];
        document.querySelectorAll('.sched-dow:checked').forEach(function(cb) { days.push(parseInt(cb.value, 10)); });
        recurrenceJson.pattern = { interval: 1, daysOfWeek: days.length ? days : [1] };
    } else if (recurrence === 'Monthly') {
        recurrenceJson.pattern = { dayOfMonth: day !== null ? day : 1 };
    }
    formData.append('recurrenceJson', JSON.stringify(recurrenceJson));

    var sid = document.getElementById('schedId').value;
    if (sid) formData.append('scheduleId', sid);

    var saveBtn = document.querySelector('#scheduleModal .btn-primary[onclick="saveParetoSchedule()"]');
    if (saveBtn) saveBtn.disabled = true;

    fetch('@Url.Action("SaveParetoSchedule", "Reports")', { method: 'POST', body: formData })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (saveBtn) saveBtn.disabled = false;
            if (data.success) {
                alertDiv.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle me-1"></i>' + data.message + '</div>';
                alertDiv.style.display = '';
                loadExistingSchedules();
                if (!data.updated) {
                    setTimeout(function() { resetScheduleForm(); showScheduleToast('Schedule saved successfully', 'success'); }, 700);
                } else {
                    showScheduleToast('Schedule updated', 'success');
                }
            } else {
                alertDiv.innerHTML = '<div class="alert alert-danger mb-0">' + data.message + '</div>';
                alertDiv.style.display = '';
            }
        })
        .catch(function() {
            if (saveBtn) saveBtn.disabled = false;
            alertDiv.innerHTML = '<div class="alert alert-danger mb-0">Network error. Please try again.</div>';
            alertDiv.style.display = '';
        });
}

document.addEventListener('DOMContentLoaded', function() {
    var modal = document.getElementById('scheduleModal');
    if (modal) {
        modal.addEventListener('show.bs.modal', function() {
            resetScheduleForm();
            loadExistingSchedules();
            autoSelectScheduleDateRange();
            var summary = document.getElementById('schedParamsSummary');
            if (summary) {
                var dim = (document.getElementById('dimension') || {}).value || 'Item';
                var met = (document.getElementById('metric') || {}).value || 'Value';
                var stores = getSelectedStoreCodes();
                var html = '<span class="me-3"><strong>Dimension:</strong> ' + dim + '</span>';
                html += '<span class="me-3"><strong>Metric:</strong> ' + met + '</span>';
                if (stores) html += '<span class="me-3"><strong>Stores:</strong> ' + stores.split(',').length + ' selected</span>';
                summary.innerHTML = html;
            }
            onSchedDateRangeTypeChange();
        });
    }
});

// ==================== Send Email ====================
var _emailTemplatesCache = [];

function openSendEmailModal() {
    document.getElementById('sendEmailRecipients').value = '';
    document.getElementById('sendEmailAlert').style.display = 'none';
    document.getElementById('sendEmailRecipients').classList.remove('is-invalid');
    var df = document.getElementById('dateFrom').value;
    var dt = document.getElementById('dateTo').value;
    if (df && dt) {
        document.getElementById('sendEmailSubject').value = 'Pareto 80/20 Report \u2014 ' + df + ' to ' + dt;
    }
    loadEmailTemplates();
    var modal = new bootstrap.Modal(document.getElementById('sendEmailModal'));
    modal.show();
}

function loadEmailTemplates() {
    fetch('@Url.Action("GetEmailTemplates", "Reports")?reportType=Pareto')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            _emailTemplatesCache = data || [];
            var sel = document.getElementById('sendEmailTemplate');
            sel.innerHTML = '<option value="">-- No template (default) --</option>';
            data.forEach(function(t) {
                var opt = document.createElement('option');
                opt.value = t.templateId;
                opt.textContent = t.templateName + (t.isDefault ? ' (default)' : '');
                opt.dataset.subject = t.emailSubject || '';
                sel.appendChild(opt);
                if (t.isDefault) opt.selected = true;
            });
            onEmailTemplateChange();
        })
        .catch(function() { /* templates may not exist yet */ });
}

function onEmailTemplateChange() {
    var sel = document.getElementById('sendEmailTemplate');
    var id = parseInt(sel.value, 10);
    var preview = document.getElementById('sendEmailBodyPreview');
    if (isNaN(id) || !id) { preview.innerHTML = '<em class="text-muted">Default email body will be used.</em>'; return; }
    var tmpl = _emailTemplatesCache.find(function(t) { return t.templateId === id; });
    if (!tmpl) return;
    if (tmpl.emailSubject) document.getElementById('sendEmailSubject').value = replaceMergeFieldsPreview(tmpl.emailSubject);
    if (tmpl.emailBodyHtml) preview.innerHTML = replaceMergeFieldsPreview(tmpl.emailBodyHtml);
}

function replaceMergeFieldsPreview(text) {
    return text
        .replace(/\u00ABReportName\u00BB/g, 'Pareto 80/20')
        .replace(/\u00ABDatabaseName\u00BB/g, '@(dbName)')
        .replace(/\u00ABPeriod\u00BB/g, document.getElementById('dateFrom').value + ' to ' + document.getElementById('dateTo').value)
        .replace(/\u00ABRowCount\u00BB/g, (document.querySelectorAll('#paretoTable tr').length || 0).toString())
        .replace(/\u00ABExportFormat\u00BB/g, document.getElementById('sendEmailFormat').value)
        .replace(/\u00ABGeneratedDate\u00BB/g, new Date().toLocaleString())
        .replace(/\u00ABUserName\u00BB/g, '@(User.Identity?.Name ?? "Unknown")')
        .replace(/\u00ABCompanyName\u00BB/g, '@(dbName)')
        .replace(/\u00AB/g, '').replace(/\u00BB/g, '');
}

function validateEmailList(input) {
    if (!input || !input.trim()) return { valid: false, emails: [], errors: ['Please enter at least one email address.'] };
    var emails = input.split(/[,;]/).map(function(e) { return e.trim(); }).filter(function(e) { return e.length > 0; });
    var re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
    var invalid = emails.filter(function(e) { return !re.test(e); });
    if (invalid.length > 0) return { valid: false, emails: emails, errors: invalid.map(function(e) { return 'Invalid: ' + e; }) };
    return { valid: true, emails: emails, errors: [] };
}

function sendParetoEmail() {
    var recipientsInput = document.getElementById('sendEmailRecipients');
    var alertDiv = document.getElementById('sendEmailAlert');
    var validation = validateEmailList(recipientsInput.value);

    if (!validation.valid) {
        recipientsInput.classList.add('is-invalid');
        document.getElementById('sendEmailRecipientsError').textContent = validation.errors.join('; ');
        return;
    }
    recipientsInput.classList.remove('is-invalid');

    var btn = document.getElementById('sendEmailBtn');
    var spinner = document.getElementById('sendEmailSpinner');
    var icon = document.getElementById('sendEmailIcon');
    btn.disabled = true;
    spinner.classList.remove('d-none');
    icon.classList.add('d-none');

    var formData = collectParetoFormData();
    formData.append('recipients', recipientsInput.value.trim());
    formData.append('cc', (document.getElementById('sendEmailCC').value || '').trim());
    formData.append('bcc', (document.getElementById('sendEmailBCC').value || '').trim());
    formData.append('emailSubject', document.getElementById('sendEmailSubject').value);
    formData.append('exportFormat', document.getElementById('sendEmailFormat').value);
    formData.append('templateId', document.getElementById('sendEmailTemplate').value || '');

    fetch('@Url.Action("SendParetoEmail", "Reports")', { method: 'POST', body: formData })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            btn.disabled = false;
            spinner.classList.add('d-none');
            icon.classList.remove('d-none');
            if (data.success) {
                alertDiv.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle me-1"></i>' + data.message + '</div>';
            } else {
                alertDiv.innerHTML = '<div class="alert alert-danger mb-0"><i class="bi bi-exclamation-triangle me-1"></i>' + data.message + '</div>';
            }
            alertDiv.style.display = '';
        })
        .catch(function() {
            btn.disabled = false;
            spinner.classList.add('d-none');
            icon.classList.remove('d-none');
            alertDiv.innerHTML = '<div class="alert alert-danger mb-0">Network error. Please try again.</div>';
            alertDiv.style.display = '';
        });
}

// ==================== AI Analysis ====================
var _currentReportType = 'Pareto';
var _aiConversationHistory = [];
var _csvPreviewForChat = '';

function getAiLang() {
    return (document.getElementById('aiLangSelect') || {}).value || 'en';
}

function saveAiLang(lang) {
    try { localStorage.setItem('ai_lang', lang); } catch(e) {}
}

function analyzeParetoReport() {
    var modalEl = document.getElementById('aiAnalysisModal');
    var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
    document.getElementById('aiLoading').classList.remove('d-none');
    document.getElementById('aiError').classList.add('d-none');
    document.getElementById('aiResults').classList.add('d-none');
    document.getElementById('aiPromptEditor').classList.add('d-none');
    document.getElementById('btnReanalyze').style.display = 'none';
    modal.show();

    var formData = collectParetoFormData();
    formData.append('locale', getAiLang());
    var promptTplId = document.getElementById('aiPromptTemplateSelect').value;
    if (promptTplId && promptTplId !== '0') formData.append('promptTemplateId', promptTplId);

    fetch('@Url.Action("AnalyzeParetoReport", "Reports")', { method: 'POST', body: formData })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            document.getElementById('aiLoading').classList.add('d-none');
            if (!data.success) {
                document.getElementById('aiError').classList.remove('d-none');
                document.getElementById('aiErrorMsg').textContent = data.message;
                document.getElementById('btnReanalyze').style.display = 'inline-block';
                return;
            }
            var a = data.analysis;
            renderAiAnalysis(a);
            initAiConversation(a, data.csvPreview);
            document.getElementById('aiResults').classList.remove('d-none');
            document.getElementById('btnReanalyze').style.display = 'inline-block';
        })
        .catch(function(err) {
            document.getElementById('aiLoading').classList.add('d-none');
            document.getElementById('aiError').classList.remove('d-none');
            document.getElementById('aiErrorMsg').textContent = 'Network error: ' + err.message;
            document.getElementById('btnReanalyze').style.display = 'inline-block';
        });
}

function renderAiAnalysis(a) {
    var summary = a.summary || '';
    document.getElementById('aiExecSummary').innerHTML = summary;
    document.getElementById('aiModel').textContent = a.modelUsed || '';
    document.getElementById('aiTokens').textContent = (a.inputTokens || 0) + ' in / ' + (a.outputTokens || 0) + ' out';
    document.getElementById('aiTime').textContent = ((a.durationMs || 0) / 1000).toFixed(1) + 's';

    var kf = document.getElementById('aiKeyFindings');
    kf.innerHTML = (a.keyFindings || []).map(function(f) { return '<div class="mb-2"><i class="bi bi-dot text-warning"></i>' + f + '</div>'; }).join('');

    var rec = document.getElementById('aiRecs');
    rec.innerHTML = (a.recommendations || []).map(function(r) { return '<div class="mb-2"><i class="bi bi-dot text-success"></i>' + r + '</div>'; }).join('');

    var alertsSection = document.getElementById('aiAlertsSection');
    if (a.alerts && a.alerts.length > 0) {
        alertsSection.innerHTML = '<div class="card border-0 shadow-sm"><div class="card-header bg-transparent border-0 pb-0"><h6 class="mb-0"><i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>Alerts</h6></div><div class="card-body pt-2">' +
            a.alerts.map(function(al) { return '<div class="mb-2 text-danger"><i class="bi bi-dot"></i>' + al + '</div>'; }).join('') + '</div></div>';
    } else {
        alertsSection.innerHTML = '';
    }

    document.getElementById('aiHealthBanner').style.display = 'none';
    document.getElementById('aiKpis').innerHTML = '';
}

function initAiConversation(analysisJson, csvData) {
    _csvPreviewForChat = csvData || '';
    _aiConversationHistory = [
        { role: 'system', content: 'You are a senior financial data analyst. The user has already received an AI analysis of their Pareto 80/20 report. The raw CSV data is included below so you can reference specific numbers when answering follow-up questions. Be concise, specific, and cite actual values from the data. Respond in the same language as the analysis.' }
    ];
    if (csvData) _aiConversationHistory.push({ role: 'user', content: 'Here is the raw report data for reference:\n' + csvData });
    _aiConversationHistory.push({ role: 'assistant', content: JSON.stringify(analysisJson) });
    document.getElementById('aiChatMessages').innerHTML = '';
}

function sendAiChat() {
    var input = document.getElementById('aiChatInput');
    var msg = input.value.trim();
    if (!msg) return;
    input.value = '';

    var chatDiv = document.getElementById('aiChatMessages');
    chatDiv.innerHTML += '<div class="mb-2 text-end"><span class="badge bg-primary px-3 py-2">' + escapeHtml(msg) + '</span></div>';
    chatDiv.innerHTML += '<div class="mb-2" id="aiChatPending"><span class="spinner-border spinner-border-sm text-muted"></span></div>';
    chatDiv.scrollTop = chatDiv.scrollHeight;

    _aiConversationHistory.push({ role: 'user', content: msg });

    fetch('@Url.Action("AiChatFollowup", "Reports")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ history: _aiConversationHistory, message: msg })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        var pending = document.getElementById('aiChatPending');
        if (pending) pending.remove();
        if (data.success) {
            _aiConversationHistory.push({ role: 'assistant', content: data.content });
            chatDiv.innerHTML += '<div class="mb-2"><div class="border rounded p-2 bg-light small">' + data.content + '</div></div>';
            var tokenInfo = document.getElementById('aiChatTokenInfo');
            tokenInfo.textContent = 'Tokens: ' + data.inputTokens + ' in / ' + data.outputTokens + ' out \u2022 ' + (data.durationMs / 1000).toFixed(1) + 's';
            tokenInfo.style.display = '';
        } else {
            chatDiv.innerHTML += '<div class="mb-2"><div class="alert alert-danger py-1 small mb-0">' + data.message + '</div></div>';
        }
        chatDiv.scrollTop = chatDiv.scrollHeight;
    })
    .catch(function(err) {
        var pending = document.getElementById('aiChatPending');
        if (pending) pending.remove();
        chatDiv.innerHTML += '<div class="mb-2"><div class="alert alert-danger py-1 small mb-0">Network error</div></div>';
    });
}

// ==================== AI Prompt Templates ====================
function togglePromptEditor() {
    var editor = document.getElementById('aiPromptEditor');
    editor.classList.toggle('d-none');
    if (!editor.classList.contains('d-none')) loadAiPromptTemplates();
}

function clearPromptEditor() {
    document.getElementById('aiPromptName').value = '';
    document.getElementById('aiPromptText').value = '';
    document.getElementById('aiPromptIsDefault').checked = false;
    document.getElementById('aiPromptAlert').textContent = '';
}

function loadAiPromptTemplates() {
    fetch('@Url.Action("GetAiPromptTemplates", "Reports")' + '?reportType=' + encodeURIComponent(_currentReportType))
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var list = document.getElementById('aiPromptTemplatesList');
            var sel = document.getElementById('aiPromptTemplateSelect');
            sel.innerHTML = '<option value="0" style="color:#333;">Default Prompt</option>';
            if (!data || data.length === 0) { list.innerHTML = '<em>No custom templates.</em>'; return; }
            var html = '<table class="table table-sm mb-0"><thead><tr><th>Name</th><th>Default</th><th></th></tr></thead><tbody>';
            data.forEach(function(t) {
                html += '<tr><td>' + escapeHtml(t.templateName) + '</td><td>' + (t.isDefault ? '<i class="bi bi-check-circle text-success"></i>' : '') + '</td>'
                    + '<td class="text-end"><button class="btn btn-sm btn-outline-danger" onclick="deleteAiPromptTemplate(' + t.templateId + ')"><i class="bi bi-trash"></i></button></td></tr>';
                var opt = document.createElement('option');
                opt.value = t.templateId;
                opt.textContent = t.templateName;
                opt.style.color = '#333';
                sel.appendChild(opt);
                if (t.isDefault) opt.selected = true;
            });
            html += '</tbody></table>';
            list.innerHTML = html;
        })
        .catch(function() { document.getElementById('aiPromptTemplatesList').innerHTML = '<em>Could not load templates.</em>'; });
}

function saveAiPromptTemplate() {
    var name = document.getElementById('aiPromptName').value.trim();
    var prompt = document.getElementById('aiPromptText').value.trim();
    if (!name || !prompt) { document.getElementById('aiPromptAlert').textContent = 'Name and prompt required.'; return; }
    fetch('@Url.Action("SaveAiPromptTemplate", "Reports")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            templateName: name,
            systemPrompt: prompt,
            reportType: document.getElementById('aiPromptReportType').value,
            isDefault: document.getElementById('aiPromptIsDefault').checked
        })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        document.getElementById('aiPromptAlert').innerHTML = data.success
            ? '<span class="text-success">Saved!</span>'
            : '<span class="text-danger">' + data.message + '</span>';
        if (data.success) { clearPromptEditor(); loadAiPromptTemplates(); }
    });
}

function deleteAiPromptTemplate(id) {
    if (!confirm('Delete this template?')) return;
    fetch('@Url.Action("DeleteAiPromptTemplate", "Reports")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ templateId: id })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) { if (data.success) loadAiPromptTemplates(); });
}

// ==================== Layout ====================
function collectCurrentLayout() {
    var parms = {};
    parms['Dimension'] = document.getElementById('dimension').value;
    parms['Metric'] = document.getElementById('metric').value;
    parms['IncludeVat'] = document.getElementById('includeVat').checked ? '1' : '0';
    parms['ExcludeNegative'] = document.getElementById('excludeNegative').checked ? '1' : '0';
    parms['ShowOthers'] = document.getElementById('showOthers').checked ? '1' : '0';
    parms['ProfitBasis'] = document.getElementById('profitBasis').value;
    parms['ClassAThreshold'] = document.getElementById('paretoPercValue').value;
    parms['PriceInterval'] = document.getElementById('priceInterval').value;
    parms['PriceOnIndex'] = document.getElementById('priceOnIndex').value;
    if (typeof getItemsSelectionFilter === 'function') {
        parms['ItemsSelectionJson'] = JSON.stringify(getItemsSelectionFilter());
    }
    return parms;
}

function saveParetoLayout() {
    var parms = collectCurrentLayout();
    fetch('@Url.Action("SaveParetoLayout", "Reports")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(parms)
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) alert('Layout saved successfully.');
        else alert('Failed: ' + data.message);
    })
    .catch(function() { alert('Network error saving layout.'); });
}

function resetParetoLayout() {
    if (!confirm('Reset layout to defaults?')) return;
    fetch('@Url.Action("ResetParetoLayout", "Reports")', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) { alert('Layout reset to defaults. Reload the page to apply.'); location.reload(); }
            else alert(data.message);
        })
        .catch(function() { alert('Network error.'); });
}

function loadSavedLayout() {
    fetch('@Url.Action("GetParetoLayout", "Reports")')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.success || !data.hasSaved) return;
            var p = data.parameters;
            if (p.Dimension) document.getElementById('dimension').value = p.Dimension;
            if (p.Metric) document.getElementById('metric').value = p.Metric;
            if (p.IncludeVat) document.getElementById('includeVat').checked = p.IncludeVat === '1';
            if (p.ExcludeNegative) document.getElementById('excludeNegative').checked = p.ExcludeNegative === '1';
            if (p.ShowOthers) document.getElementById('showOthers').checked = p.ShowOthers === '1';
            if (p.ProfitBasis) document.getElementById('profitBasis').value = p.ProfitBasis;
            if (p.ClassAThreshold) {
                document.getElementById('paretoPercValue').value = p.ClassAThreshold;
                document.getElementById('paretoPercItems').value = 100 - parseInt(p.ClassAThreshold);
            }
            if (p.PriceInterval) document.getElementById('priceInterval').value = p.PriceInterval;
            if (p.PriceOnIndex) document.getElementById('priceOnIndex').value = p.PriceOnIndex;
            if (p.ItemsSelectionJson && typeof reloadItemsSelectionFromJson === 'function') {
                try { reloadItemsSelectionFromJson(JSON.parse(p.ItemsSelectionJson)); } catch (e) {}
            }
            onDimensionChanged();
            onMetricChanged();
        })
        .catch(function() {});
}

document.addEventListener('DOMContentLoaded', function() {
    loadSavedLayout();
    try {
        var savedLang = localStorage.getItem('ai_lang');
        if (savedLang) {
            var sel = document.getElementById('aiLangSelect');
            if (sel) sel.value = savedLang;
        }
    } catch(e) {}
});

// ==================== Item Detail ====================
function showParetoItemDetail(itemCode) {
    document.getElementById('paretoModalCode').textContent = itemCode;
    document.getElementById('paretoModalLoading').style.display = '';
    document.getElementById('paretoModalError').classList.add('d-none');
    document.getElementById('paretoModalTable').style.display = 'none';

    var modal = new bootstrap.Modal(document.getElementById('paretoItemModal'));
    modal.show();

    var dateFrom = document.getElementById('dateFrom').value;
    var dateTo = document.getElementById('dateTo').value;
    var storeCodes = getSelectedStoreCodes();
    var url = '/Reports/GetTransactionDetails?itemCode=' + encodeURIComponent(itemCode)
        + '&type=all&dateFrom=' + dateFrom + '&dateTo=' + dateTo
        + '&storeCodes=' + encodeURIComponent(storeCodes);

    fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            document.getElementById('paretoModalLoading').style.display = 'none';
            if (!data.success) {
                document.getElementById('paretoModalError').textContent = data.message || 'Error loading transactions';
                document.getElementById('paretoModalError').classList.remove('d-none');
                return;
            }
            var tbody = document.getElementById('paretoModalTbody');
            var kindLabels = { 'P': 'Purchase', 'E': 'Purch Return', 'I': 'Sale', 'C': 'Credit' };
            var kindColors = { 'P': 'text-bg-info', 'E': 'text-bg-warning', 'I': 'text-bg-success', 'C': 'text-bg-danger' };
            var fmtN = function(v) { return v != null ? v.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2}) : ''; };
            tbody.innerHTML = data.rows.map(function(r) {
                return '<tr>' +
                    '<td class="text-nowrap">' + (r.date || '') + '</td>' +
                    '<td><span class="badge ' + (kindColors[r.kind] || 'text-bg-secondary') + '">' + (kindLabels[r.kind] || r.kind || '') + '</span></td>' +
                    '<td>' + (r.invoiceNo || '') + '</td>' +
                    '<td>' + (r.customerName || '') + '</td>' +
                    '<td class="text-end">' + (r.quantity != null ? r.quantity : '') + '</td>' +
                    '<td class="text-end">' + fmtN(r.amount) + '</td>' +
                    '<td>' + (r.storeCode || '') + '</td></tr>';
            }).join('');
            document.getElementById('paretoModalTable').style.display = '';
        })
        .catch(function(err) {
            document.getElementById('paretoModalLoading').style.display = 'none';
            document.getElementById('paretoModalError').textContent = 'Network error: ' + err.message;
            document.getElementById('paretoModalError').classList.remove('d-none');
        });
}
</script>
