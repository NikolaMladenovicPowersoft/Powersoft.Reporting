@* Reusable Tutorial button — renders a button + modal with embedded YouTube video.
   Usage: @await Html.PartialAsync("_TutorialButton", ("Average Basket", "YOUR_YOUTUBE_VIDEO_ID"))
   Pass a tuple of (reportName, youtubeVideoId). If videoId is empty, the button still shows but displays a placeholder. *@

@{
    var info = ((string ReportName, string VideoId))Model;
    var modalId = "tutorialModal_" + info.ReportName.Replace(" ", "");
    var hasVideo = !string.IsNullOrWhiteSpace(info.VideoId);
}

<button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#@modalId" title="Watch tutorial video">
    <i class="bi bi-play-circle me-1"></i>Tutorial
</button>

<div class="modal fade" id="@modalId" tabindex="-1" aria-labelledby="@(modalId)Label" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title" id="@(modalId)Label">
                    <i class="bi bi-play-circle me-2 text-primary"></i>@info.ReportName — Tutorial
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                @if (hasVideo)
                {
                    <div class="ratio ratio-16x9">
                        <iframe src="https://www.youtube.com/embed/@info.VideoId?rel=0" 
                                title="@info.ReportName Tutorial" 
                                frameborder="0" 
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                                allowfullscreen></iframe>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-camera-video" style="font-size:3rem;opacity:0.3;"></i>
                        <p class="mt-3">Tutorial video coming soon.</p>
                        <p class="small">A video walkthrough for <strong>@info.ReportName</strong> will be available here.</p>
                    </div>
                }
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    var modal = document.getElementById('@modalId');
    if (modal) {
        modal.addEventListener('hidden.bs.modal', function () {
            var iframe = modal.querySelector('iframe');
            if (iframe) {
                var src = iframe.src;
                iframe.src = '';
                iframe.src = src;
            }
        });
    }
})();
</script>
