@model Powersoft.Reporting.Web.ViewModels.ProfitLossViewModel
@using Powersoft.Reporting.Core.Models
@{
    Layout = null;
    var db = Model.ConnectedDatabase ?? "Unknown";
    var now = DateTime.Now;
    var compare = Model.CompareToLastYear;
    var embedded = Context.Request.Query.ContainsKey("embedded");
    var visible = Model.Rows.Where(r => !r.Suppressed).ToList();
    var groups = new[] { ProfitLossGroup.Sales, ProfitLossGroup.CostOfSales, ProfitLossGroup.Income, ProfitLossGroup.Expenses };

    string D(decimal v) => v == 0 ? "" : v.ToString("#,##0.00");
    string P(decimal? v) => v.HasValue ? v.Value.ToString("#,##0.00") + "%" : "";
    int cols = compare ? 5 : 2;
}
<!DOCTYPE html>
<html lang="en-GB">
<head>
    <meta charset="utf-8" />
    <title>Profit & Loss - Print Preview</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'Segoe UI', system-ui, -apple-system, sans-serif; background:#525659; color:#1e293b; }

        .toolbar {
            position:fixed; top:0; left:0; right:0; z-index:100;
            background:#2c3e50; color:#fff; padding:6px 16px;
            display:flex; align-items:center; gap:12px;
            box-shadow:0 2px 8px rgba(0,0,0,.3); font-size:13px;
        }
        .toolbar .title { font-weight:600; margin-right:auto; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        .toolbar button {
            background:none; border:1px solid rgba(255,255,255,.25); color:#fff;
            padding:5px 12px; border-radius:4px; cursor:pointer; font-size:13px;
            display:flex; align-items:center; gap:5px; white-space:nowrap;
        }
        .toolbar button:hover { background:rgba(255,255,255,.1); border-color:rgba(255,255,255,.4); }
        .zoom-controls { display:flex; align-items:center; gap:4px; }
        .zoom-controls button { padding:5px 8px; }
        .zoom-level { min-width:42px; text-align:center; font-size:12px; color:rgba(255,255,255,.8); }
        .toolbar .sep { width:1px; height:24px; background:rgba(255,255,255,.2); }

        .paper-container { margin:56px auto 40px; padding:20px; }
        .paper {
            background:#fff; margin:0 auto; padding:40px 48px;
            box-shadow:0 2px 12px rgba(0,0,0,.3);
            transform-origin:top center; transition:transform .15s ease;
            max-width:1000px;
        }

        .rpt-header { text-align:center; margin-bottom:20px; padding-bottom:12px; border-bottom:2px solid #1e293b; }
        .rpt-company { font-size:18px; font-weight:700; }
        .rpt-title { font-size:14px; font-weight:600; color:#475569; margin-top:2px; }
        .rpt-meta { display:flex; justify-content:space-between; font-size:10px; color:#64748b; margin-bottom:14px; }
        .rpt-meta .meta-r { text-align:right; }

        .report-table { width:100%; border-collapse:collapse; font-size:11px; }
        .report-table thead th {
            background:#e2e8f0; padding:5px 8px; text-align:right; font-weight:700; font-size:10px;
            text-transform:uppercase; letter-spacing:.3px; color:#334155;
            border-bottom:2px solid #94a3b8; white-space:nowrap;
        }
        .report-table thead th.l { text-align:left; }
        .report-table tbody td { padding:3px 8px; text-align:right; border-bottom:1px solid #f1f5f9; color:#334155; }
        .report-table tbody td.l { text-align:left; }
        .report-table .grp td { background:#f1f5f9; padding:5px 8px 3px; font-weight:700; font-size:11px; color:#1e293b; border-top:1px solid #94a3b8; text-align:left; }
        .report-table .sub td { font-weight:600; border-top:1px solid #cbd5e1; border-bottom:1px solid #94a3b8; padding:3px 8px; background:#f8fafc; font-style:italic; color:#475569; }
        .report-table .profit td { font-weight:700; background:#eef2ff; border-top:2px solid #6366f1; border-bottom:2px solid #6366f1; padding:5px 8px; }
        .report-table .net td { font-weight:700; background:#dbeafe; border-top:3px double #1e293b; padding:6px 8px; font-size:12px; }
        .var-pos{color:#059669;} .var-neg{color:#dc2626;}

        .rpt-footer { text-align:center; margin-top:20px; padding-top:10px; border-top:1px solid #e2e8f0; font-size:9px; color:#94a3b8; }

        body.embedded .toolbar { display:none; }
        body.embedded .paper-container { margin-top:12px; }

        @@media print {
            body { background:#fff; }
            .toolbar { display:none !important; }
            .paper-container { margin:0; padding:0; }
            .paper { box-shadow:none; padding:20px; transform:none !important; }
            .report-table tr { page-break-inside:avoid; }
            .rpt-footer { page-break-before:avoid; }
        }
    </style>
</head>
<body class="@(embedded ? "embedded" : "")">

    <div class="toolbar">
        <span class="title"><i class="bi bi-graph-up-arrow me-1"></i>Profit &amp; Loss &mdash; @db</span>
        <div class="zoom-controls">
            <button onclick="zoomOut()" title="Zoom out"><i class="bi bi-zoom-out"></i></button>
            <span class="zoom-level" id="zoomLabel">100%</span>
            <button onclick="zoomIn()" title="Zoom in"><i class="bi bi-zoom-in"></i></button>
            <button onclick="zoomReset()" title="Fit to width" style="font-size:11px;">Fit</button>
        </div>
        <div class="sep"></div>
        <button onclick="window.print()"><i class="bi bi-printer"></i> Print</button>
    </div>

    <div class="paper-container">
        <div class="paper" id="paper">
            <div class="rpt-header">
                <div class="rpt-company">@db</div>
                <div class="rpt-title">Profit &amp; Loss Statement</div>
            </div>
            <div class="rpt-meta">
                <div>
                    <strong>Period:</strong> @Model.DateFrom.ToString("dd/MM/yyyy") &mdash; @Model.DateTo.ToString("dd/MM/yyyy")<br />
                    <strong>Printed:</strong> @now.ToString("dd/MM/yyyy HH:mm")
                    @if (Model.HeaderLevel) { <text><br /><strong>Header level</strong></text> }
                </div>
                <div class="meta-r">
                    <strong>Accounts:</strong> @visible.Count.ToString("N0")
                    @if (compare)
                    {
                        <text><br /><strong>vs:</strong> @Model.DateFrom.AddYears(-1).ToString("dd/MM/yyyy") &mdash; @Model.DateTo.AddYears(-1).ToString("dd/MM/yyyy")</text>
                    }
                </div>
            </div>

            <table class="report-table">
                <thead>
                    <tr>
                        <th class="l">Account</th>
                        <th>Amount</th>
                        @if (compare)
                        {
                            <th>Prior Year</th><th>Variance</th><th>Variance %</th>
                        }
                    </tr>
                </thead>
                <tbody>
                @foreach (var g in groups)
                {
                    var items = visible.Where(r => r.Group == g).ToList();
                    var name = items.Count > 0 ? items[0].GroupName : g.ToString();
                    decimal cur = items.Sum(r => r.Balance);
                    decimal pri = items.Sum(r => r.PriorBalance);

                    <tr class="grp"><td colspan="@cols">@name</td></tr>
                    foreach (var r in items)
                    {
                        var acc = string.IsNullOrEmpty(r.AccountCode) ? r.AccountName : r.AccountCode + " - " + r.AccountName;
                        <tr>
                            <td class="l">@acc</td>
                            <td>@D(r.Balance)</td>
                            @if (compare)
                            {
                                var vc = r.Variance >= 0 ? "var-pos" : "var-neg";
                                <td>@D(r.PriorBalance)</td>
                                <td class="@vc">@D(r.Variance)</td>
                                <td class="@vc">@P(r.VariancePercent)</td>
                            }
                        </tr>
                    }
                    <tr class="sub">
                        <td class="l">@name subtotal</td>
                        <td>@D(cur)</td>
                        @if (compare)
                        {
                            var vc = (cur - pri) >= 0 ? "var-pos" : "var-neg";
                            <td>@D(pri)</td><td class="@vc">@D(cur - pri)</td><td></td>
                        }
                    </tr>

                    @if (g == ProfitLossGroup.CostOfSales)
                    {
                        var vc = (Model.GrossProfit - Model.PriorGrossProfit) >= 0 ? "var-pos" : "var-neg";
                        <tr class="profit">
                            <td class="l">GROSS PROFIT</td>
                            <td>@D(Model.GrossProfit)</td>
                            @if (compare)
                            {
                                <td>@D(Model.PriorGrossProfit)</td>
                                <td class="@vc">@D(Model.GrossProfit - Model.PriorGrossProfit)</td><td></td>
                            }
                        </tr>
                    }
                }
                <tr class="profit net">
                    <td class="l">NET PROFIT</td>
                    <td>@D(Model.NetProfit)</td>
                    @if (compare)
                    {
                        var vc = (Model.NetProfit - Model.PriorNetProfit) >= 0 ? "var-pos" : "var-neg";
                        <td>@D(Model.PriorNetProfit)</td>
                        <td class="@vc">@D(Model.NetProfit - Model.PriorNetProfit)</td><td></td>
                    }
                </tr>
                </tbody>
            </table>

            <div class="rpt-footer">
                End of Report &mdash; Profit &amp; Loss &mdash; @db<br />
                &copy; @now.Year Power Soft Ltd.
            </div>
        </div>
    </div>

    <script>
        var currentZoom = 100;
        var paper = document.getElementById('paper');
        function setZoom(val) {
            currentZoom = Math.max(40, Math.min(200, val));
            paper.style.transform = 'scale(' + (currentZoom / 100) + ')';
            paper.style.transformOrigin = 'top center';
            document.getElementById('zoomLabel').textContent = currentZoom + '%';
        }
        function zoomIn()    { setZoom(currentZoom + 10); }
        function zoomOut()   { setZoom(currentZoom - 10); }
        function zoomReset() { setZoom(100); }
        (function autoFit() {
            var containerW = document.querySelector('.paper-container').clientWidth - 40;
            var paperW = paper.scrollWidth;
            if (paperW > containerW) setZoom(Math.floor((containerW / paperW) * 100));
        })();
        document.addEventListener('keydown', function(e) {
            if (e.ctrlKey && e.key === 'p') { e.preventDefault(); window.print(); }
            if (e.ctrlKey && e.key === '+') { e.preventDefault(); zoomIn(); }
            if (e.ctrlKey && e.key === '-') { e.preventDefault(); zoomOut(); }
            if (e.ctrlKey && e.key === '0') { e.preventDefault(); zoomReset(); }
        });
    </script>
</body>
</html>
