    // ==================== Column Visibility ====================

    function filterColumnList() {
        var el = document.getElementById('colSearchInput');
        if (!el) return;
        var s = el.value.toLowerCase().trim();
        document.querySelectorAll('#colToggleList label').forEach(function(label) {
            if (!s) { label.classList.remove('d-none'); return; }
            var name = (label.getAttribute('data-col-name') || '').toLowerCase();
            var sp = label.querySelector('span'); var text = sp ? sp.textContent.toLowerCase() : '';
            var cv = label.querySelector('input') ? label.querySelector('input').value.toLowerCase() : '';
            label.classList.toggle('d-none', !(name.indexOf(s) !== -1 || text.indexOf(s) !== -1 || cv.indexOf(s) !== -1));
        });
    }

    function toggleAllColumns(checked) {
        document.querySelectorAll('.col-toggle').forEach(function(cb) { cb.checked = checked; });
        applyColumnVisibility();
        updateColVisibleCount();
    }

    function updateColVisibleCount() {
        var visible = document.querySelectorAll('.col-toggle:checked').length;
        var el = document.getElementById('colVisibleCount');
        if (el) el.textContent = visible;
    }

    function applyColumnVisibility() {
        var hidden = [];
        document.querySelectorAll('.col-toggle').forEach(function(cb) { if (!cb.checked) hidden.push(cb.value); });
        var hiddenInput = document.getElementById('hiddenColumnsInput');
        if (hiddenInput) hiddenInput.value = hidden.join(',');

        var styleEl = document.getElementById('colVisibilityStyle');
        if (!styleEl) {
            styleEl = document.createElement('style');
            styleEl.id = 'colVisibilityStyle';
            document.head.appendChild(styleEl);
        }
        var table = document.getElementById('resultsTable');
        if (!table) return;
        var rules = [];
        document.querySelectorAll('.col-toggle').forEach(function(cb) {
            var colKey = cb.value;
            if (!cb.checked) {
                var headers = table.querySelectorAll('thead tr:first-child th');
                for (var i = 0; i < headers.length; i++) {
                    if (headers[i].getAttribute('data-col') === colKey) {
                        var colIdx = i + 1;
                        rules.push('#resultsTable th:nth-child(' + colIdx + '), #resultsTable td:nth-child(' + colIdx + ') { display: none; }');
                        break;
                    }
                }
            }
        });
        styleEl.textContent = rules.join('\n');
        updateColVisibleCount();
    }

    function resetColumnVisibility() {
        document.querySelectorAll('.col-toggle').forEach(function(cb) { cb.checked = true; });
        applyColumnVisibility();
    }

    function initColumnVisibilityFromServer() {
        var h = '@(Model.HiddenColumns ?? "")';
        if (!h) { updateColVisibleCount(); return; }
        h.split(',').filter(function(s) { return s.trim(); }).forEach(function(col) {
            var cb = document.querySelector('.col-toggle[value="' + col.trim() + '"]');
            if (cb) cb.checked = false;
        });
        applyColumnVisibility();
    }

    // ==================== Show Profit / Show Stock <-> Display Columns sync ====================
    // Mapping of "quick toggle" -> Display Columns names (server) and col-toggle values (client visibility modal).
    // Display Columns names ("Profit") differ slightly from col-toggle values ("ProfitValue").
    var SYNC_GROUPS = {
        showProfitToggle: { display: ['Profit','Markup','Margin'], colToggle: ['ProfitValue','Markup','Margin'] },
        showStockToggle:  { display: ['TotalStockQty','TotalStockValue'], colToggle: ['TotalStockQty','TotalStockValue'] }
    };

    function _getDisplayColsArr() {
        var hidden = document.getElementById('displayColumnsHidden');
        if (!hidden) return [];
        return (hidden.value || '').split(',').map(function(s){ return s.trim(); }).filter(function(s){ return s.length > 0; });
    }
    function _setDisplayColsArr(cols) {
        var hidden = document.getElementById('displayColumnsHidden');
        if (hidden) hidden.value = cols.join(',');
    }
    function _hasAnyCi(arr, names) {
        var lower = arr.map(function(s){ return s.toLowerCase(); });
        for (var i = 0; i < names.length; i++) {
            if (lower.indexOf(names[i].toLowerCase()) >= 0) return true;
        }
        return false;
    }
    function _addUniqueCi(arr, name) {
        var exists = arr.some(function(s){ return s.toLowerCase() === name.toLowerCase(); });
        if (!exists) arr.push(name);
        return arr;
    }
    function _removeCi(arr, name) {
        return arr.filter(function(s){ return s.toLowerCase() !== name.toLowerCase(); });
    }

    // When Show Profit / Show Stock toggle is changed by the user.
    function onQuickToggleChange(toggleId) {
        var toggle = document.getElementById(toggleId);
        var grp = SYNC_GROUPS[toggleId];
        if (!toggle || !grp) return;
        var checked = toggle.checked;

        // 1) Update server-side DisplayColumns hidden input
        var cols = _getDisplayColsArr();
        if (checked) {
            grp.display.forEach(function(n){ cols = _addUniqueCi(cols, n); });
        } else {
            grp.display.forEach(function(n){ cols = _removeCi(cols, n); });
        }
        _setDisplayColsArr(cols);

        // 2) Sync client-side col-toggle checkboxes (visibility modal). Only meaningful for already-rendered columns;
        //    after Generate Report newly-added DisplayColumns will appear with col-toggle checked by default.
        grp.colToggle.forEach(function(v){
            var cb = document.querySelector('.col-toggle[value="' + v + '"]');
            if (cb) cb.checked = checked;
        });
        if (typeof applyColumnVisibility === 'function') applyColumnVisibility();
    }

    // When user toggles a col-toggle checkbox in the visibility modal: refresh quick-toggle states.
    function syncQuickTogglesFromColToggles() {
        Object.keys(SYNC_GROUPS).forEach(function(id) {
            var toggle = document.getElementById(id);
            if (!toggle) return;
            var grp = SYNC_GROUPS[id];
            var anyChecked = grp.colToggle.some(function(v) {
                var cb = document.querySelector('.col-toggle[value="' + v + '"]');
                return cb && cb.checked;
            });
            // Only flip if a corresponding column actually exists in DOM (i.e. server returned it),
            // otherwise rely on DisplayColumns-based init below.
            var anyExists = grp.colToggle.some(function(v) {
                return !!document.querySelector('.col-toggle[value="' + v + '"]');
            });
            if (anyExists) toggle.checked = anyChecked;
        });
    }

    // Initial sync on page load: derive quick-toggle state from current DisplayColumns.
    function initQuickTogglesFromDisplayCols() {
        var cols = _getDisplayColsArr();
        Object.keys(SYNC_GROUPS).forEach(function(id) {
            var toggle = document.getElementById(id);
            if (!toggle) return;
            toggle.checked = _hasAnyCi(cols, SYNC_GROUPS[id].display);
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        initColumnVisibilityFromServer();
        updateColVisibleCount();

        // Wire bidirectional sync between quick-toggles and Display Columns / col-toggle modal
        initQuickTogglesFromDisplayCols();
        ['showProfitToggle','showStockToggle'].forEach(function(id) {
            var t = document.getElementById(id);
            if (t) t.addEventListener('change', function() { onQuickToggleChange(id); });
        });
        document.querySelectorAll('.col-toggle').forEach(function(cb) {
            cb.addEventListener('change', syncQuickTogglesFromColToggles);
        });

        var colSearch = document.getElementById('colSearchInput');
        if (colSearch) {
            colSearch.addEventListener('input', filterColumnList);
            colSearch.addEventListener('keyup', filterColumnList);
        }
        // Check AI status
        fetch('/Reports/GetAiStatus')
            .then(r => r.json())
            .then(d => {
                if (!d.configured) {
                    var btn = document.getElementById('btnAnalyze');
                    if (btn) { btn.title = 'AI not configured — set API key in Settings'; btn.classList.add('disabled'); }
                    var sa = document.getElementById('schedIncludeAi');
                    if (sa) { sa.disabled = true; sa.parentElement.title = 'AI not configured'; }
                }
            }).catch(() => {});
    });

