// ==================== Save / Reset Layout ====================

function collectCurrentLayout() {
    function v(id) { var el = document.getElementById(id); return el ? el.value : ''; }
    var p = {};
    p['DateField'] = v('dateField');
    p['OfferType'] = v('offerTypeFilter');
    p['IncludeHistory'] = document.getElementById('includeHistory').checked ? 'true' : 'false';
    p['PrimaryGroup'] = v('primaryGroup');
    p['SecondaryGroup'] = v('secondaryGroup');
    p['ThirdGroup'] = v('thirdGroup');
    p['MaxRecords'] = v('maxRecords');
    p['StatusCodesJson'] = JSON.stringify(getCheckedValues('offerStatusCb'));
    p['StoreCodesJson']  = JSON.stringify(getCheckedValues('offerStoreCb'));
    p['AgentCodesJson']  = JSON.stringify(getCheckedValues('offerAgentCb'));
    var hidden = [];
    document.querySelectorAll('.col-toggle').forEach(function(cb) { if (!cb.checked) hidden.push(cb.value); });
    p['HiddenColumns'] = hidden.join(',');
    var preset = document.querySelector('input[name="DatePreset"]:checked');
    if (preset) p['DatePreset'] = preset.value;
    if (typeof getCustomerSelectionFilter === 'function') {
        var csf = getCustomerSelectionFilter();
        p['CustomerCodesJson'] = JSON.stringify(csf.codes || []);
        p['CustomerExcludeMode'] = csf.excludeMode ? 'true' : 'false';
    }
    if (typeof getItemsSelectionJson === 'function') {
        p['ItemsSelectionJson'] = getItemsSelectionJson() || '';
    }
    return p;
}

function saveCurrentLayout() {
    var parms = collectCurrentLayout();
    fetch('@Url.Action("SaveOffersReportLayout", "Reports")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(parms)
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) showLayoutToast('Layout saved successfully', 'success');
        else showLayoutToast(data.message || 'Failed to save layout', 'danger');
    })
    .catch(function() { showLayoutToast('Network error saving layout', 'danger'); });
}

function resetSavedLayout() {
    if (!confirm('Reset your saved layout to factory defaults?')) return;
    fetch('@Url.Action("ResetOffersReportLayout", "Reports")', { method: 'POST' })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) {
            showLayoutToast('Layout reset \u2014 reloading...', 'success');
            setTimeout(function() { window.location.href = '@Url.Action("OffersReport")'; }, 800);
        } else {
            showLayoutToast(data.message || 'Failed to reset layout', 'danger');
        }
    })
    .catch(function() { showLayoutToast('Network error', 'danger'); });
}

var __layoutsCache = null;

function isAuthRedirect(response) {
    if (!response) return false;
    if (response.status === 401 || response.status === 403) return true;
    if (response.redirected && /\/Account\/Login/i.test(response.url || '')) return true;
    var ct = response.headers && response.headers.get ? response.headers.get('content-type') : '';
    if (ct && ct.indexOf('text/html') !== -1) return true;
    return false;
}
function showSessionExpiredToast() { showLayoutToast('Session expired \u2014 please reload the page and sign in again.', 'warning'); }

function loadLayoutsList() {
    var menu = document.getElementById('layoutsDropdownMenu');
    if (menu) menu.innerHTML = '<li><h6 class="dropdown-header">Loading...</h6></li>';
    return fetch('@Url.Action("ListOffersReportLayouts", "Reports")', { method: 'GET', credentials: 'same-origin' })
        .then(function(r) {
            if (isAuthRedirect(r)) { if (menu) menu.innerHTML = '<li><h6 class="dropdown-header text-danger">Session expired</h6></li>'; showSessionExpiredToast(); return null; }
            return r.json();
        })
        .then(function(data) {
            if (data == null) return;
            __layoutsCache = data && data.layouts ? data.layouts : [];
            renderLayoutsDropdown(__layoutsCache);
        })
        .catch(function() { if (menu) menu.innerHTML = '<li><h6 class="dropdown-header text-danger">Failed to load</h6></li>'; });
}

function renderLayoutsDropdown(layouts) {
    var menu = document.getElementById('layoutsDropdownMenu');
    if (!menu) return;
    if (!layouts || layouts.length === 0) {
        menu.innerHTML = '<li><h6 class="dropdown-header">No saved layouts</h6></li><li><span class="dropdown-item-text small text-muted">Use "Save as..." to create one.</span></li>';
        return;
    }
    var own = layouts.filter(function(l) { return !l.isPublic; });
    var pub = layouts.filter(function(l) { return  l.isPublic; });
    var html = '';
    function renderGroup(label, items) {
        if (!items.length) return;
        html += '<li><h6 class="dropdown-header">' + label + '</h6></li>';
        items.forEach(function(l) {
            var safeName = String(l.name || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            var publicBadge = l.isPublic ? '<span class="badge bg-secondary ms-2" title="Visible to all users">Public</span>' : '';
            var editorBadge = l.isPublic && l.createdBy ? '<span class="text-muted small ms-2">by ' + String(l.createdBy).replace(/</g,'&lt;') + '</span>' : '';
            html += '<li class="d-flex align-items-center px-2 py-1"><a href="#" class="flex-grow-1 text-decoration-none text-body" onclick="loadNamedLayout(\''+String(l.headerCode).replace(/'/g,"\\'")+'\'); return false;"><i class="bi bi-bookmark me-1"></i>'+safeName+publicBadge+editorBadge+'</a>';
            if (l.canEdit) html += '<button type="button" class="btn btn-sm btn-link text-danger p-0 ms-2" title="Delete" onclick="deleteNamedLayout(\''+String(l.headerCode).replace(/'/g,"\\'")+'\', \''+safeName.replace(/'/g,"\\'")+'\'); return false;"><i class="bi bi-trash"></i></button>';
            html += '</li>';
        });
    }
    renderGroup('Your layouts', own);
    renderGroup('Public layouts', pub);
    menu.innerHTML = html;
}

function loadNamedLayout(headerCode) {
    if (!headerCode) return;
    fetch('@Url.Action("LoadOffersReportLayout", "Reports")?headerCode=' + encodeURIComponent(headerCode), { method: 'POST', credentials: 'same-origin' })
        .then(function(r) { if (isAuthRedirect(r)) { showSessionExpiredToast(); return null; } return r.json(); })
        .then(function(data) {
            if (data == null) return;
            if (!data.success) { showLayoutToast(data.message || 'Failed to load layout', 'danger'); return; }
            applyLayoutParameters(data.parameters || {});
            var label = document.getElementById('layoutsCurrentName');
            if (label && __layoutsCache) {
                var match = __layoutsCache.find(function(l) { return l.headerCode === headerCode; });
                if (match) label.textContent = match.name;
            }
            showLayoutToast('Layout loaded \u2014 click Generate to run.', 'success');
        })
        .catch(function() { showLayoutToast('Network error loading layout', 'danger'); });
}

function applyLayoutParameters(parms) {
    function setVal(id, v) { var el = document.getElementById(id); if (el && v != null && v !== '') el.value = v; }
    setVal('dateField',       parms.DateField);
    setVal('offerTypeFilter', parms.OfferType);
    setVal('primaryGroup',    parms.PrimaryGroup);
    setVal('secondaryGroup',  parms.SecondaryGroup);
    setVal('thirdGroup',      parms.ThirdGroup);
    setVal('maxRecords',      parms.MaxRecords);
    if (parms.IncludeHistory != null) document.getElementById('includeHistory').checked = parms.IncludeHistory === 'true' || parms.IncludeHistory === true;
    if (parms.HiddenColumns != null) {
        var cols = parms.HiddenColumns ? parms.HiddenColumns.split(',') : [];
        document.querySelectorAll('.col-toggle').forEach(function(cb) { cb.checked = cols.indexOf(cb.value) === -1; });
        applyColumnVisibility();
    }
    if (parms.DatePreset) {
        var r = document.querySelector('input[name="DatePreset"][value="'+parms.DatePreset+'"]');
        if (r) { r.checked = true; applyPresetDates(parms.DatePreset); }
    }
    try { if (parms.StatusCodesJson) setCheckedValues('offerStatusCb','statusFilterLabel','Statuses', JSON.parse(parms.StatusCodesJson)); } catch(e) {}
    try { if (parms.StoreCodesJson)  setCheckedValues('offerStoreCb', 'storeFilterLabel', 'Stores',   JSON.parse(parms.StoreCodesJson));  } catch(e) {}
    try { if (parms.AgentCodesJson)  setCheckedValues('offerAgentCb', 'agentFilterLabel', 'Agents',   JSON.parse(parms.AgentCodesJson));  } catch(e) {}
    if (parms.CustomerCodesJson && typeof reloadCustomerSelectionFromJson === 'function') {
        try {
            reloadCustomerSelectionFromJson({
                codes: JSON.parse(parms.CustomerCodesJson),
                excludeMode: parms.CustomerExcludeMode === 'true'
            });
        } catch(e) {}
    }
    if (parms.ItemsSelectionJson && typeof applyItemsSelectionJson === 'function') {
        try { applyItemsSelectionJson(parms.ItemsSelectionJson); } catch(e) {}
    }
}

function saveLayoutAsConfirm() {
    var nameEl = document.getElementById('saveLayoutAsName');
    var pubEl = document.getElementById('saveLayoutAsPublic');
    var alertEl = document.getElementById('saveLayoutAsAlert');
    var btn = document.getElementById('saveLayoutAsConfirmBtn');
    var spinner = document.getElementById('saveLayoutAsSpinner');
    if (alertEl) { alertEl.classList.add('d-none'); alertEl.textContent = ''; }
    var name = (nameEl.value || '').trim();
    if (!name) { alertEl.textContent = 'Layout name is required.'; alertEl.className = 'alert alert-warning'; return; }
    btn.disabled = true; spinner.classList.remove('d-none');
    var parms = collectCurrentLayout();
    fetch('@Url.Action("SaveOffersReportLayoutAs", "Reports")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name, isPublic: !!(pubEl && pubEl.checked), parameters: parms })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        btn.disabled = false; spinner.classList.add('d-none');
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('saveLayoutAsModal')).hide();
            showLayoutToast('Layout saved', 'success');
            loadLayoutsList();
            var label = document.getElementById('layoutsCurrentName');
            if (label) label.textContent = name;
        } else { alertEl.textContent = data.message || 'Failed to save'; alertEl.className = 'alert alert-danger'; }
    })
    .catch(function() { btn.disabled = false; spinner.classList.add('d-none'); alertEl.textContent = 'Network error.'; alertEl.className = 'alert alert-danger'; });
}

function deleteNamedLayout(headerCode, displayName) {
    if (!confirm('Delete layout "' + displayName + '"?')) return;
    fetch('@Url.Action("DeleteOffersReportLayout", "Reports")?headerCode=' + encodeURIComponent(headerCode), { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) { showLayoutToast('Layout deleted', 'success'); loadLayoutsList(); }
            else showLayoutToast(data.message || 'Failed to delete', 'danger');
        })
        .catch(function() { showLayoutToast('Network error', 'danger'); });
}

document.addEventListener('DOMContentLoaded', function() {
    var btn = document.getElementById('layoutsDropdownBtn');
    if (!btn) return;
    var loadedOnce = false;
    btn.addEventListener('show.bs.dropdown', function() {
        if (!loadedOnce) { loadedOnce = true; loadLayoutsList(); }
    });
    var modalEl = document.getElementById('saveLayoutAsModal');
    if (modalEl) {
        modalEl.addEventListener('show.bs.modal', function() {
            document.getElementById('saveLayoutAsName').value = '';
            document.getElementById('saveLayoutAsPublic').checked = false;
            var alertEl = document.getElementById('saveLayoutAsAlert');
            if (alertEl) { alertEl.classList.add('d-none'); alertEl.textContent = ''; }
        });
    }
});

function showLayoutToast(message, type) {
    var existing = document.getElementById('layoutToast');
    if (existing) existing.remove();
    var div = document.createElement('div');
    div.id = 'layoutToast';
    div.className = 'alert alert-' + type + ' alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow';
    div.style.zIndex = '9999';
    div.innerHTML = '<i class="bi bi-' + (type === 'success' ? 'check-circle' : 'exclamation-triangle') + ' me-1"></i>' + message +
        '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    document.body.appendChild(div);
    setTimeout(function() { if (div.parentNode) div.remove(); }, 4000);
}

// ==================== Column Visibility ====================

function applyColumnVisibility() {
    var styleEl = document.getElementById('colVisibilityStyle');
    if (!styleEl) { styleEl = document.createElement('style'); styleEl.id = 'colVisibilityStyle'; document.head.appendChild(styleEl); }
    var table = document.getElementById('reportTable');
    if (!table) return;
    var rules = [];
    document.querySelectorAll('.col-toggle').forEach(function(cb) {
        if (!cb.checked) {
            var headers = table.querySelectorAll('thead tr:first-child th');
            for (var i = 0; i < headers.length; i++) {
                if (headers[i].getAttribute('data-col') === cb.value) {
                    var colIdx = i + 1;
                    rules.push('#reportTable th:nth-child(' + colIdx + '), #reportTable td:nth-child(' + colIdx + ') { display: none; }');
                    break;
                }
            }
        }
    });
    styleEl.textContent = rules.join('\n');
    updateColVisibleCount();
}

function filterColumnList() {
    var el = document.getElementById('colSearchInput');
    if (!el) return;
    var search = el.value.toLowerCase().trim();
    document.querySelectorAll('#colToggleList label').forEach(function(label) {
        if (!search) { label.classList.remove('d-none'); return; }
        var name = (label.getAttribute('data-col-name') || '').toLowerCase();
        var spanText = label.querySelector('span');
        var text = spanText ? spanText.textContent.toLowerCase() : '';
        label.classList.toggle('d-none', name.indexOf(search) === -1 && text.indexOf(search) === -1);
    });
}

function updateColVisibleCount() {
    var total = document.querySelectorAll('.col-toggle').length;
    var visible = document.querySelectorAll('.col-toggle:checked').length;
    var el = document.getElementById('colVisibleCount'); if (el) el.textContent = visible;
    var totalEl = document.getElementById('colTotalCount'); if (totalEl) totalEl.textContent = total;
}

function toggleAllColumns(checked) {
    document.querySelectorAll('.col-toggle').forEach(function(cb) { cb.checked = checked; });
    applyColumnVisibility();
}

function resetColumnVisibility() {
    document.querySelectorAll('.col-toggle').forEach(function(cb) { cb.checked = true; });
    applyColumnVisibility();
}

function initColumnVisibilityFromLayout() {
    @if(savedLayout != null && savedLayout.ContainsKey("HiddenColumns"))
    {
        <text>
        var hiddenCols = '@savedLayout["HiddenColumns"]';
        if (hiddenCols) {
            var hidden = hiddenCols.split(',').filter(function(s) { return s.trim(); });
            hidden.forEach(function(col) {
                var cb = document.querySelector('.col-toggle[value="' + col.trim() + '"]');
                if (cb) cb.checked = false;
            });
            applyColumnVisibility();
        }
        </text>
    }
}

document.addEventListener('DOMContentLoaded', function() {
    initColumnVisibilityFromLayout();
    updateColVisibleCount();
    var colSearch = document.getElementById('colSearchInput');
    if (colSearch) colSearch.addEventListener('input', filterColumnList);
});

</script>
