// ==================== Searchable Column Chooser ====================

function filterColumnList() {
    var el = document.getElementById('colSearchInput');
    if (!el) return;
    var search = el.value.toLowerCase().trim();
    var items = document.querySelectorAll('#colToggleList label');
    items.forEach(function(label) {
        if (!search) { label.classList.remove('d-none'); return; }
        var name = (label.getAttribute('data-col-name') || '').toLowerCase();
        var spanText = label.querySelector('span');
        var text = spanText ? spanText.textContent.toLowerCase() : '';
        var colValue = label.querySelector('input') ? label.querySelector('input').value.toLowerCase() : '';
        var match = name.indexOf(search) !== -1 || text.indexOf(search) !== -1 || colValue.indexOf(search) !== -1;
        if (match) { label.classList.remove('d-none'); } else { label.classList.add('d-none'); }
    });
}

