@using Powersoft.Reporting.Core.Models
@{
    ViewData["Title"] = "Profit & Loss";
    var connectedDb = ViewBag.ConnectedDatabase as string ?? "";
    var headersJson = ViewBag.HeadersJson as string ?? "[]";
    var canSchedule = true;
    var hasSavedLayout = (bool)(ViewBag.HasSavedLayout ?? false);
    var savedLayout = ViewBag.SavedLayout as Dictionary<string, string>;
}

<style>
    .stat-card{background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:16px;box-shadow:0 1px 3px rgba(0,0,0,.06);overflow:hidden;}
    .stat-value{font-size:clamp(1rem,1.6vw,1.5rem);font-weight:700;color:#1e293b;line-height:1.15;overflow-wrap:anywhere;}
    .stat-label{font-size:.8rem;color:#64748b;text-transform:uppercase;letter-spacing:.5px;margin-top:4px;}
    .group-header-row td{background:#f1f5f9!important;font-weight:600;border-top:2px solid #cbd5e1;}
    .group-subtotal-row td{background:#f8fafc!important;border-top:1px solid #cbd5e1;border-bottom:1px solid #94a3b8;font-style:italic;color:#475569;}
    .profit-row td{background:#eef2ff!important;font-weight:700;border-top:2px solid #6366f1;border-bottom:2px solid #6366f1;}
    .grand-total-row td{background:#dbeafe!important;font-weight:700;border-top:3px double #2563eb;}
    .picker-scroll { max-height:200px; overflow-y:auto; }
    .var-pos{color:#059669;} .var-neg{color:#dc2626;}
</style>

<div class="rpt-modern">

<div class="rpt-hero rpt-rise">
    <div class="rpt-hero-left">
        <div class="rpt-hero-icon"><i class="bi bi-graph-up-arrow"></i></div>
        <div>
            <div class="rpt-crumbs">
                <a asp-controller="Reports" asp-action="Index">Reports</a>
                <span>Financial</span>
                <span>Profit &amp; Loss</span>
            </div>
            <h2>Profit &amp; Loss</h2>
            <p class="rpt-hero-sub">Sales, cost of sales, income and expenses for a period, with optional prior-year comparison</p>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="bi bi-funnel me-2"></i>Report Parameters</div>
    <div class="card-body">
        <div class="row g-3 mb-3 align-items-end">
            <div class="col-6 col-md-3">
                <label class="form-label fw-semibold">From Date <span class="text-danger">*</span></label>
                <input type="date" class="form-control" id="dateFrom">
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label fw-semibold">To Date <span class="text-danger">*</span></label>
                <input type="date" class="form-control" id="dateTo">
            </div>
            <div class="col-6 col-md-3">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" id="headerLevel">
                    <label class="form-check-label" for="headerLevel">Header level (aggregate)</label>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" id="compareLastYear">
                    <label class="form-check-label" for="compareLastYear">Compare to last year</label>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-3 align-items-start">
            <div class="col-6 col-md-3">
                <label class="form-label fw-semibold">Opening stock value <small class="text-muted fw-normal">(DR)</small></label>
                <input type="number" step="0.01" class="form-control" id="openingStock" value="0">
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label fw-semibold">Closing stock value <small class="text-muted fw-normal">(CR)</small></label>
                <input type="number" step="0.01" class="form-control" id="closingStock" value="0">
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label fw-semibold">Suppress headers <small class="text-muted fw-normal">(hidden, excluded from totals)</small></label>
                <div class="dropdown">
                    <button class="btn btn-outline-secondary w-100 d-flex justify-content-between align-items-center text-start" type="button"
                            data-bs-toggle="dropdown" data-bs-auto-close="outside" style="min-height:38px;">
                        <span id="supLabel" class="text-truncate small">None suppressed</span>
                        <i class="bi bi-chevron-down flex-shrink-0 ms-1"></i>
                    </button>
                    <div class="dropdown-menu p-2" style="min-width:320px;">
                        <input type="text" class="form-control form-control-sm mb-2" placeholder="Search headers..." oninput="filterPickerItems('sup-chk',this.value)">
                        <div id="supItems" class="picker-scroll"></div>
                        <hr class="my-1">
                        <button type="button" class="btn btn-link btn-sm p-0 text-muted" onclick="clearMultiSelect('sup-chk','supLabel','Header')">Clear</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="report-form-actions d-flex flex-wrap gap-2 pt-2 border-top">
            <button type="button" class="btn btn-primary btn-lg btn-generate" id="generateBtn" onclick="generateReport()">
                <span class="btn-text"><i class="bi bi-play-fill me-2"></i>Generate Report</span>
                <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
            </button>
            @if (canSchedule)
            {
                <button type="button" class="btn btn-warning btn-lg" data-bs-toggle="modal" data-bs-target="#scheduleModal" title="Schedule recurring report delivery">
                    <i class="bi bi-clock-history me-2"></i>Schedule
                </button>
            }
            <div class="btn-group ms-auto">
                <div class="btn-group">
                    <button type="button" class="btn btn-outline-info dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false"
                            title="Saved report layouts" id="layoutsDropdownBtn">
                        <i class="bi bi-bookmark me-1"></i><span id="layoutsCurrentName">Layouts</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" id="layoutsDropdownMenu" style="min-width: 320px;">
                        <li><h6 class="dropdown-header">Loading...</h6></li>
                    </ul>
                </div>
                <button type="button" class="btn btn-outline-info" onclick="saveCurrentLayout()" title="Overwrite your default layout with current parameters">
                    <i class="bi bi-save me-1"></i>Save
                </button>
                <button type="button" class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#saveLayoutAsModal"
                        title="Save current parameters as a new named layout">
                    <i class="bi bi-bookmark-plus me-1"></i>Save as...
                </button>
                <button type="button" class="btn btn-outline-secondary" onclick="resetSavedLayout()" title="Discard your saved default layout and restore defaults">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Default
                </button>
            </div>
            <button type="button" class="btn btn-outline-secondary" onclick="clearFilters()" title="Clear suppressed header selections and stock values">
                <i class="bi bi-funnel me-1"></i>Clear Filters
            </button>
        </div>
        @if (hasSavedLayout)
        {
            <div class="mt-2"><small class="text-info"><i class="bi bi-check-circle me-1"></i>Saved layout loaded</small></div>
        }
    </div>
</div>

<div id="reportAlert" style="display:none;"></div>

<div id="reportLoading" style="display:none;" class="text-center py-5">
    <div class="spinner-border text-primary" role="status"></div>
    <p class="mt-2 text-muted">Loading report data...</p>
</div>

<div id="kpiCards" class="row mb-4 g-3" style="display:none;"></div>

<div id="reportResults" style="display:none;">
    <div class="card" id="results">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span><i class="bi bi-table me-2"></i>Results: <span id="rowCountInfo">0</span></span>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <button class="btn btn-sm btn-outline-primary" onclick="togglePreview()" id="previewToggleBtn" title="Toggle document preview">
                    <i class="bi bi-eye me-1"></i>Preview
                </button>
                <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-success" onclick="exportServerCsv()" title="Export CSV"><i class="bi bi-filetype-csv me-1"></i>CSV</button>
                    <button class="btn btn-outline-success" onclick="exportServerExcel()" title="Export Excel"><i class="bi bi-filetype-xlsx me-1"></i>Excel</button>
                    <button class="btn btn-outline-danger" onclick="exportServerPdf()" title="Export PDF"><i class="bi bi-filetype-pdf me-1"></i>PDF</button>
                </div>
                <button class="btn btn-sm btn-outline-primary" onclick="openSendEmailModal()" title="Send report via email"><i class="bi bi-envelope me-1"></i>Send to Email</button>
                <button class="btn btn-sm btn-outline-info" onclick="if(!_lastData.length){alert('Generate a report first.');return;}openAiAnalysis()" title="AI-powered report analysis" id="btnAnalyze"><i class="bi bi-stars me-1"></i>AI Analyze</button>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-striped table-hover mb-0" id="reportTable">
                    <thead class="table-light" id="reportHead"></thead>
                    <tbody id="reportBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="previewPanel" style="display:none;" class="mt-3">
    <div class="card border-primary">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-2">
            <span><i class="bi bi-file-earmark-text me-2"></i>Document Preview</span>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-light" onclick="printPreview()" title="Print"><i class="bi bi-printer me-1"></i>Print</button>
                <button class="btn btn-sm btn-outline-light" onclick="togglePreview()" title="Close preview"><i class="bi bi-x-lg me-1"></i>Back to Grid</button>
            </div>
        </div>
        <div class="card-body p-0">
            <iframe id="previewFrame" style="width:100%; border:none; min-height:700px; background:#525659;"></iframe>
        </div>
    </div>
</div>

@await Html.PartialAsync("_Schedule", new Powersoft.Reporting.Web.ViewModels.SchedulePartialModel
{
    SaveAction = "SaveProfitLossSchedule",
    ListAction = "GetProfitLossSchedules",
    ReportBadge = "Profit & Loss",
    NamePlaceholder = "e.g. Monthly Profit & Loss",
    SubjectPlaceholder = "Profit & Loss Report - {date}"
})

@await Html.PartialAsync("_SendEmail", new Powersoft.Reporting.Web.ViewModels.SendEmailPartialModel {
    SendAction = "SendProfitLossReportEmail",
    ReportType = "ProfitLoss",
    SubjectDefault = "Profit & Loss Report"
})

@await Html.PartialAsync("_AiAnalyze", new Powersoft.Reporting.Web.ViewModels.AiAnalyzePartialModel {
    AnalyzeActionUrl = Url.Action("AnalyzeProfitLossReport", "Reports"),
    ReportType = "ProfitLoss"
})

@await Html.PartialAsync("_SaveLayout", new Powersoft.Reporting.Web.ViewModels.SaveLayoutPartialModel
{
    ReportType     = Powersoft.Reporting.Core.Constants.ReportTypeConstants.ProfitLoss,
    HasSavedLayout = (bool)(ViewBag.HasSavedLayout ?? false),
    ReportViewUrl  = Url.Action("ProfitLoss", "Reports") ?? ""
})

<script>
var _headers = @Html.Raw(headersJson);
var _lastData = [];
var _lastTotals = null;
var _lastCompare = false;

// ===== multi-select helpers (suppress headers) =====
function updateMultiLabel(cbClass, labelId, noun) {
    var checked = Array.from(document.querySelectorAll('.' + cbClass + ':checked'));
    var el = document.getElementById(labelId);
    if (!el) return;
    if (checked.length === 0) { el.textContent = 'None suppressed'; return; }
    if (checked.length === 1) { var lbl = checked[0].closest('.form-check').querySelector('label'); el.textContent = lbl ? lbl.textContent.trim() : checked[0].value; return; }
    el.textContent = checked.length + ' selected';
}
function clearMultiSelect(cbClass, labelId, noun) {
    document.querySelectorAll('.' + cbClass).forEach(function(cb) { cb.checked = false; });
    updateMultiLabel(cbClass, labelId, noun);
}
function getCheckedValues(cbClass) {
    return Array.from(document.querySelectorAll('.' + cbClass + ':checked')).map(function(cb) { return cb.value; });
}
function setCheckedValues(cbClass, labelId, noun, values) {
    document.querySelectorAll('.' + cbClass).forEach(function(cb) { cb.checked = values.indexOf(cb.value) !== -1; });
    updateMultiLabel(cbClass, labelId, noun);
}
function filterPickerItems(cbClass, q) {
    q = (q || '').toLowerCase();
    document.querySelectorAll('.' + cbClass).forEach(function(cb) {
        var row = cb.closest('.form-check');
        if (!row) return;
        var lbl = row.querySelector('label');
        var text = lbl ? lbl.textContent.toLowerCase() : '';
        row.style.display = (!q || text.indexOf(q) >= 0) ? '' : 'none';
    });
}
function populatePicker(containerId, cbClass, labelId, noun, items) {
    var container = document.getElementById(containerId);
    if (!container) return;
    var prevSelected = getCheckedValues(cbClass);
    container.innerHTML = '';
    items.forEach(function(item, i) {
        var id = cbClass + '_' + i;
        var div = document.createElement('div');
        div.className = 'form-check';
        var cb = document.createElement('input');
        cb.className = 'form-check-input ' + cbClass;
        cb.type = 'checkbox'; cb.id = id; cb.value = item.value;
        cb.checked = prevSelected.indexOf(String(item.value)) >= 0;
        cb.addEventListener('change', function() { updateMultiLabel(cbClass, labelId, noun); });
        var lbl = document.createElement('label');
        lbl.className = 'form-check-label small';
        lbl.setAttribute('for', id);
        lbl.textContent = item.label;
        div.appendChild(cb); div.appendChild(lbl);
        container.appendChild(div);
    });
    updateMultiLabel(cbClass, labelId, noun);
}

// ===== Init ==========
(function init() {
    var t = new Date();
    var y = t.getFullYear();
    document.getElementById('dateFrom').value = y + '-01-01';
    document.getElementById('dateTo').value = y+'-'+String(t.getMonth()+1).padStart(2,'0')+'-'+String(t.getDate()).padStart(2,'0');

    var hdrItems = _headers.map(function(h) { return { value: h.key, label: (h.code ? h.code + ' - ' : '') + h.name }; });
    populatePicker('supItems', 'sup-chk', 'supLabel', 'Header', hdrItems);
})();

function escapeHtml(s) { if (s==null) return ''; var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
function fmtDec(v) { if (v==null || v==0) return ''; return Number(v).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}); }
function fmtPct(v) { if (v==null) return ''; return Number(v).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '%'; }

function showAlert(id, type, msg) {
    var el = document.getElementById(id);
    el.innerHTML = '<div class="alert alert-'+type+' alert-dismissible fade show"><i class="bi bi-info-circle me-2"></i>'+escapeHtml(msg)+'<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
    el.style.display = '';
}

function clearFilters() {
    clearMultiSelect('sup-chk', 'supLabel', 'Header');
    document.getElementById('openingStock').value = '0';
    document.getElementById('closingStock').value = '0';
}

function getFilterParams() {
    return {
        dateFrom: document.getElementById('dateFrom').value,
        dateTo: document.getElementById('dateTo').value,
        headerLevel: document.getElementById('headerLevel').checked,
        compareToLastYear: document.getElementById('compareLastYear').checked,
        openingStockValue: document.getElementById('openingStock').value || '0',
        closingStockValue: document.getElementById('closingStock').value || '0',
        suppressedHeaders: getCheckedValues('sup-chk').join(',')
    };
}

function buildExportUrl(action) {
    var p = getFilterParams();
    return '/Reports/' + action
        + '?dateFrom=' + p.dateFrom + '&dateTo=' + p.dateTo
        + '&headerLevel=' + p.headerLevel
        + '&compareToLastYear=' + p.compareToLastYear
        + '&openingStockValue=' + encodeURIComponent(p.openingStockValue)
        + '&closingStockValue=' + encodeURIComponent(p.closingStockValue)
        + '&suppressedHeaders=' + encodeURIComponent(p.suppressedHeaders);
}

function exportServerCsv() { if (!_lastData.length) { alert('Generate a report first.'); return; } window.location.href = buildExportUrl('ExportProfitLossCsv'); }
function exportServerExcel() { if (!_lastData.length) { alert('Generate a report first.'); return; } window.location.href = buildExportUrl('ExportProfitLossExcel'); }
function exportServerPdf() { if (!_lastData.length) { alert('Generate a report first.'); return; } window.location.href = buildExportUrl('ExportProfitLossPdf'); }

var previewOpen = false;
function togglePreview() {
    if (!_lastData.length) { alert('Generate a report first.'); return; }
    var panel = document.getElementById('previewPanel');
    var gridCard = document.getElementById('results');
    var kpis = document.getElementById('kpiCards');
    var btn = document.getElementById('previewToggleBtn');
    previewOpen = !previewOpen;
    if (previewOpen) {
        gridCard.style.display = 'none';
        kpis.style.display = 'none';
        panel.style.display = 'block';
        btn.innerHTML = '<i class="bi bi-table me-1"></i>Grid';
        btn.classList.remove('btn-outline-primary'); btn.classList.add('btn-outline-warning');
        var frame = document.getElementById('previewFrame');
        frame.src = buildExportUrl('ProfitLossPrintPreview') + '&embedded=true';
        frame.onload = function() {
            try { var h = frame.contentDocument.body.scrollHeight + 40; frame.style.height = Math.max(h, 700) + 'px'; }
            catch (e) { frame.style.height = '900px'; }
        };
    } else {
        panel.style.display = 'none';
        gridCard.style.display = '';
        kpis.style.display = '';
        btn.innerHTML = '<i class="bi bi-eye me-1"></i>Preview';
        btn.classList.remove('btn-outline-warning'); btn.classList.add('btn-outline-primary');
    }
}
function printPreview() {
    var frame = document.getElementById('previewFrame');
    if (frame && frame.contentWindow) frame.contentWindow.print();
}

function generateReport() {
    var from = document.getElementById('dateFrom').value;
    var to = document.getElementById('dateTo').value;
    if (!from || !to) { showAlert('reportAlert','danger','Please select From and To dates.'); return; }
    if (from > to) { showAlert('reportAlert','danger','From date must be on or before To date.'); return; }

    document.getElementById('reportAlert').style.display = 'none';
    document.getElementById('reportResults').style.display = 'none';
    document.getElementById('kpiCards').style.display = 'none';
    document.getElementById('reportLoading').style.display = '';

    var btn = document.getElementById('generateBtn');
    btn.querySelector('.btn-text').classList.add('d-none');
    btn.querySelector('.spinner-border').classList.remove('d-none');
    btn.disabled = true;

    var fd = new FormData();
    var p = getFilterParams();
    Object.keys(p).forEach(function(k) { fd.append(k, p[k]); });

    fetch('@Url.Action("GetProfitLossData","Reports")', { method:'POST', body:fd, credentials:'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            document.getElementById('reportLoading').style.display = 'none';
            btn.querySelector('.btn-text').classList.remove('d-none');
            btn.querySelector('.spinner-border').classList.add('d-none');
            btn.disabled = false;
            if (!d.success) { showAlert('reportAlert','danger',d.message); return; }
            _lastData = d.data || [];
            _lastTotals = d.totals;
            _lastCompare = !!d.compareToLastYear;
            renderKpis(d.totals, _lastCompare);
            renderTable(_lastData, d.totals, _lastCompare);
            document.getElementById('rowCountInfo').textContent = (d.totalRows || 0) + ' account(s)';
            document.getElementById('reportResults').style.display = '';
            if (_lastData.length === 0) showAlert('reportAlert','info','No accounts found for the selected criteria.');
        })
        .catch(function(e) {
            document.getElementById('reportLoading').style.display = 'none';
            btn.querySelector('.btn-text').classList.remove('d-none');
            btn.querySelector('.spinner-border').classList.add('d-none');
            btn.disabled = false;
            showAlert('reportAlert','danger','Request failed: '+e.message);
        });
}

function renderKpis(t, compare) {
    var cards = document.getElementById('kpiCards');
    if (!t) { cards.style.display = 'none'; return; }
    function card(label, val, cls) {
        return '<div class="col-6 col-md-3"><div class="stat-card text-center"><div class="stat-value '+(cls||'')+'">'+fmtDec(val)+'</div><div class="stat-label">'+label+'</div></div></div>';
    }
    cards.innerHTML =
        card('Sales', t.sales, 'text-primary') +
        card('Gross Profit', t.grossProfit, t.grossProfit>=0?'text-success':'text-danger') +
        card('Net Profit', t.netProfit, t.netProfit>=0?'text-success':'text-danger') +
        (compare ? card('Net Profit (LY)', t.priorNetProfit, 'text-muted')
                 : card('Expenses', t.expenses, ''));
    cards.style.display = '';
}

function colCount(compare) { return compare ? 5 : 2; }

function headRow(compare) {
    var h = '<tr><th>Account</th><th class="text-end">Amount</th>';
    if (compare) h += '<th class="text-end">Prior Year</th><th class="text-end">Variance</th><th class="text-end">Variance %</th>';
    return h + '</tr>';
}

function numCells(row, compare) {
    var s = '<td class="text-end">'+fmtDec(row.balance)+'</td>';
    if (compare) {
        var vcls = (row.variance||0) >= 0 ? 'var-pos' : 'var-neg';
        s += '<td class="text-end">'+fmtDec(row.priorBalance)+'</td>'
           + '<td class="text-end '+vcls+'">'+fmtDec(row.variance)+'</td>'
           + '<td class="text-end '+vcls+'">'+fmtPct(row.variancePercent)+'</td>';
    }
    return s;
}

function sumCells(cur, prior, compare) {
    var s = '<td class="text-end">'+fmtDec(cur)+'</td>';
    if (compare) {
        var v = cur - prior; var vcls = v >= 0 ? 'var-pos' : 'var-neg';
        s += '<td class="text-end">'+fmtDec(prior)+'</td>'
           + '<td class="text-end '+vcls+'">'+fmtDec(v)+'</td><td></td>';
    }
    return s;
}

var GROUP_NAMES = { 1:'Sales', 2:'Cost of Sales', 3:'Income', 4:'Expenses' };

function renderTable(data, t, compare) {
    var thead = document.getElementById('reportHead');
    var tbody = document.getElementById('reportBody');
    thead.innerHTML = headRow(compare);

    var visible = data.filter(function(r){ return !r.suppressed; });
    var byGroup = {1:[],2:[],3:[],4:[]};
    visible.forEach(function(r){ if (byGroup[r.group]) byGroup[r.group].push(r); });

    var html = '';
    [1,2,3,4].forEach(function(g) {
        var items = byGroup[g];
        var name = (items[0] && items[0].groupName) || GROUP_NAMES[g];
        html += '<tr class="group-header-row"><td colspan="'+colCount(compare)+'"><i class="bi bi-diagram-3 me-2"></i><strong>'+escapeHtml(name)+'</strong></td></tr>';
        items.forEach(function(r) {
            var acc = r.accountCode ? (r.accountCode + ' - ' + r.accountName) : r.accountName;
            html += '<tr><td>'+escapeHtml(acc)+'</td>'+numCells(r, compare)+'</tr>';
        });
        var cur = items.reduce(function(a,r){return a+(+r.balance||0);},0);
        var prior = items.reduce(function(a,r){return a+(+r.priorBalance||0);},0);
        html += '<tr class="group-subtotal-row"><td class="fw-semibold text-uppercase text-muted">'+escapeHtml(name)+' subtotal</td>'+sumCells(cur, prior, compare)+'</tr>';

        if (g === 2) {
            html += '<tr class="profit-row"><td class="text-uppercase">Gross Profit</td>'+sumCells(t.grossProfit, t.priorGrossProfit, compare)+'</tr>';
        }
    });
    html += '<tr class="profit-row grand-total-row"><td class="text-uppercase">Net Profit</td>'+sumCells(t.netProfit, t.priorNetProfit, compare)+'</tr>';
    tbody.innerHTML = html;
}

// ========== SCHEDULE ==========
function autoSelectScheduleDateRange() {
    var from = document.getElementById('dateFrom').value;
    var to = document.getElementById('dateTo').value;
    if (!from || !to) return;
    var sel = document.getElementById('schedDateRangeType');
    if (!sel) return;
    for (var i = 0; i < sel.options.length; i++) {
        if (sel.options[i].value === 'Custom') { sel.selectedIndex = i; break; }
    }
    var schedFrom = document.getElementById('schedDateFrom');
    var schedTo = document.getElementById('schedDateTo');
    if (schedFrom) schedFrom.value = from;
    if (schedTo) schedTo.value = to;
    if (typeof onSchedDateRangeTypeChange === 'function') onSchedDateRangeTypeChange();
}

function collectScheduleParameters() {
    var p = getFilterParams();
    return {
        reportType: 'ProfitLoss',
        headerLevel: p.headerLevel,
        compareToLastYear: p.compareToLastYear,
        openingStockValue: p.openingStockValue,
        closingStockValue: p.closingStockValue,
        suppressedHeaders: p.suppressedHeaders
    };
}

function onScheduleParametersLoaded(p) {
    if (!p) return;
    if (typeof p.headerLevel !== 'undefined') document.getElementById('headerLevel').checked = (p.headerLevel === true || p.headerLevel === 'true');
    if (typeof p.compareToLastYear !== 'undefined') document.getElementById('compareLastYear').checked = (p.compareToLastYear === true || p.compareToLastYear === 'true');
    if (typeof p.openingStockValue !== 'undefined') document.getElementById('openingStock').value = p.openingStockValue;
    if (typeof p.closingStockValue !== 'undefined') document.getElementById('closingStock').value = p.closingStockValue;
}

// ========== SEND EMAIL ==========
window.collectEmailParameters = function() {
    if (!_lastData.length) { alert('Generate a report first.'); return null; }
    return getFilterParams();
};
window.getEmailDefaultSubject = function() {
    return 'Profit & Loss Report \u2014 ' + document.getElementById('dateFrom').value + ' to ' + document.getElementById('dateTo').value;
};

// ========== AI ANALYSIS ==========
function collectAiFormData() {
    if (!_lastData.length) { alert('Generate a report first.'); return null; }
    var fd = new FormData();
    var p = getFilterParams();
    Object.keys(p).forEach(function(k) { fd.append(k, p[k]); });
    return fd;
}

// ========== Save / Reset Layout ==========
function collectCurrentLayout() {
    var p = {};
    p['HeaderLevel'] = document.getElementById('headerLevel').checked ? 'Y' : 'N';
    p['CompareLastYear'] = document.getElementById('compareLastYear').checked ? 'Y' : 'N';
    p['OpeningStock'] = document.getElementById('openingStock').value || '0';
    p['ClosingStock'] = document.getElementById('closingStock').value || '0';
    p['SuppressedHeaders'] = getCheckedValues('sup-chk').join(',');
    return p;
}

function applyLayoutParameters(parms) {
    if (parms.HeaderLevel != null) document.getElementById('headerLevel').checked = (parms.HeaderLevel === 'Y');
    if (parms.CompareLastYear != null) document.getElementById('compareLastYear').checked = (parms.CompareLastYear === 'Y');
    if (parms.OpeningStock != null && parms.OpeningStock !== '') document.getElementById('openingStock').value = parms.OpeningStock;
    if (parms.ClosingStock != null && parms.ClosingStock !== '') document.getElementById('closingStock').value = parms.ClosingStock;
    if (parms.SuppressedHeaders) setCheckedValues('sup-chk', 'supLabel', 'Header', parms.SuppressedHeaders.split(',').map(function(s){return s.trim();}));
}

@if (hasSavedLayout && savedLayout != null)
{
    <text>
    (function() {
        var parms = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(savedLayout));
        applyLayoutParameters(parms);
    })();
    </text>
}
</script>
