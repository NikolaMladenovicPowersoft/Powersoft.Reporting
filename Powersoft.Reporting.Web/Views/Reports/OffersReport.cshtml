@using Powersoft.Reporting.Core.Models
@{
    ViewData["Title"] = "Offers Report";
    var connectedDb = ViewBag.ConnectedDatabase as string ?? "";
    var canSchedule = (bool)(ViewBag.CanSchedule ?? true);
    var hasSavedLayout = (bool)(ViewBag.HasSavedLayout ?? false);
    var savedLayout = ViewBag.SavedLayout as Dictionary<string, string>;
    var storesJson = ViewBag.StoresJson as string ?? "[]";
}

<style>
    .stat-card{background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:16px;box-shadow:0 1px 3px rgba(0,0,0,.06);overflow:hidden;}
    .stat-value{font-size:clamp(1rem,1.6vw,1.5rem);font-weight:700;color:#1e293b;line-height:1.15;overflow-wrap:anywhere;}
    .stat-label{font-size:.8rem;color:#64748b;text-transform:uppercase;letter-spacing:.5px;margin-top:4px;}
    .group-header-row td{background:#f1f5f9!important;font-weight:600;border-top:2px solid #cbd5e1;}
    .group-header-row.l2 td{background:#e8f0fe!important;font-weight:600;border-top:1px solid #93c5fd;}
    .status-badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:.75rem;font-weight:600;border:1px solid rgba(0,0,0,.15);}
    th.sortable{cursor:pointer;user-select:none;white-space:nowrap;}
    th.sortable:hover{background:#e2e8f0;}
    th.sortable .sort-icon{font-size:.65rem;opacity:.4;margin-left:4px;}
    th.sortable.sort-asc .sort-icon,th.sortable.sort-desc .sort-icon{opacity:1;color:#7c3aed;}
</style>

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-start">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">Reports</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">CRM</a></li>
                    <li class="breadcrumb-item active">Offers Report</li>
                </ol>
            </nav>
            <h2 class="mb-0">
                <i class="bi bi-file-earmark-text me-2" style="color:#7c3aed;"></i>Offers Report
            </h2>
            <p class="text-muted mb-0">Sales offers by status, customer, store and agent analysis</p>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="bi bi-funnel me-2"></i>Report Parameters</div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-12">
                <label class="form-label fw-semibold mb-2">Quick Date Selection</label>
                <div class="date-presets btn-group flex-wrap" role="group">
                    <input type="radio" class="btn-check" name="DatePreset" id="presetToday" value="today" autocomplete="off">
                    <label class="btn btn-outline-secondary btn-sm" for="presetToday">Today</label>
                    <input type="radio" class="btn-check" name="DatePreset" id="presetYesterday" value="yesterday" autocomplete="off">
                    <label class="btn btn-outline-secondary btn-sm" for="presetYesterday">Yesterday</label>
                    <input type="radio" class="btn-check" name="DatePreset" id="presetLast7" value="last7" autocomplete="off">
                    <label class="btn btn-outline-secondary btn-sm" for="presetLast7">Last 7 Days</label>
                    <input type="radio" class="btn-check" name="DatePreset" id="presetLast30" value="last30" autocomplete="off">
                    <label class="btn btn-outline-secondary btn-sm" for="presetLast30">Last 30 Days</label>
                    <input type="radio" class="btn-check" name="DatePreset" id="presetThisMonth" value="thisMonth" autocomplete="off">
                    <label class="btn btn-outline-secondary btn-sm" for="presetThisMonth">This Month</label>
                    <input type="radio" class="btn-check" name="DatePreset" id="presetLastMonth" value="lastMonth" autocomplete="off">
                    <label class="btn btn-outline-secondary btn-sm" for="presetLastMonth">Last Month</label>
                    <input type="radio" class="btn-check" name="DatePreset" id="presetYTD" value="ytd" autocomplete="off">
                    <label class="btn btn-outline-secondary btn-sm" for="presetYTD">Year to Date</label>
                    <input type="radio" class="btn-check" name="DatePreset" id="presetLastYear" value="lastYear" autocomplete="off">
                    <label class="btn btn-outline-secondary btn-sm" for="presetLastYear">Last Year</label>
                </div>
            </div>
        </div>
        <hr class="my-3">
        <div class="row g-3 mb-3 align-items-end">
            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold">Date From <span class="text-danger">*</span></label>
                <input type="date" class="form-control" id="dateFrom" onchange="clearPreset()">
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold">Date To <span class="text-danger">*</span></label>
                <input type="date" class="form-control" id="dateTo" onchange="clearPreset()">
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold">Date Field</label>
                <select class="form-select" id="dateField">
                    <option value="DateTrans" selected>Transaction Date</option>
                    <option value="ValidUntil">Valid Until</option>
                    <option value="SessionDateTime">Session Date</option>
                    <option value="DeliveryDate">Delivery Date</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold">Status</label>
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start" type="button"
                            id="statusDropdownBtn" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                        <span id="statusFilterLabel">All Statuses</span>
                    </button>
                    <div class="dropdown-menu p-2" style="min-width:220px;max-height:280px;overflow-y:auto;" aria-labelledby="statusDropdownBtn">
                        <div id="statusCheckboxList"></div>
                        <div class="border-top mt-2 pt-2 d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary flex-fill"
                                    onclick="clearMultiSelect('offerStatusCb','statusFilterLabel','Statuses')">Clear</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold">Store</label>
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start" type="button"
                            id="storeDropdownBtn" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                        <span id="storeFilterLabel">All Stores</span>
                    </button>
                    <div class="dropdown-menu p-2" style="min-width:220px;max-height:280px;overflow-y:auto;" aria-labelledby="storeDropdownBtn">
                        <div id="storeCheckboxList"></div>
                        <div class="border-top mt-2 pt-2 d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary flex-fill"
                                    onclick="clearMultiSelect('offerStoreCb','storeFilterLabel','Stores')">Clear</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold">Max Records</label>
                <input type="number" class="form-control" id="maxRecords" value="50000" min="100" max="200000">
            </div>
        </div>
        <div class="row g-3 mb-3 align-items-end">
            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold">Agent</label>
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start" type="button"
                            id="agentDropdownBtn" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                        <span id="agentFilterLabel">All Agents</span>
                    </button>
                    <div class="dropdown-menu p-2" style="min-width:220px;max-height:280px;overflow-y:auto;" aria-labelledby="agentDropdownBtn">
                        <div id="agentCheckboxList"></div>
                        <div class="border-top mt-2 pt-2 d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary flex-fill"
                                    onclick="clearMultiSelect('offerAgentCb','agentFilterLabel','Agents')">Clear</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold">Offer Type</label>
                <select class="form-select" id="offerTypeFilter">
                    <option value="All" selected>All Types</option>
                    <option value="Offers">Offers Only</option>
                    <option value="Standard">Standard Offers</option>
                </select>
            </div>
            <div class="col-6 col-md-2 d-flex align-items-end">
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="includeHistory">
                    <label class="form-check-label fw-semibold" for="includeHistory">Include History</label>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold">Primary Group</label>
                <select class="form-select" id="primaryGroup">
                    <option value="NONE" selected>None</option>
                    <option value="STATUS">Status</option>
                    <option value="STORE">Store</option>
                    <option value="CUSTOMER">Customer</option>
                    <option value="AGENT">Agent</option>
                    <option value="MONTH">Month</option>
                    <option value="YEAR">Year</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold">Secondary Group</label>
                <select class="form-select" id="secondaryGroup">
                    <option value="NONE" selected>None</option>
                    <option value="STATUS">Status</option>
                    <option value="STORE">Store</option>
                    <option value="CUSTOMER">Customer</option>
                    <option value="AGENT">Agent</option>
                    <option value="MONTH">Month</option>
                    <option value="YEAR">Year</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold">Third Group</label>
                <select class="form-select" id="thirdGroup">
                    <option value="NONE" selected>None</option>
                    <option value="STATUS">Status</option>
                    <option value="STORE">Store</option>
                    <option value="CUSTOMER">Customer</option>
                    <option value="AGENT">Agent</option>
                    <option value="MONTH">Month</option>
                    <option value="YEAR">Year</option>
                </select>
            </div>
        </div>

        @await Html.PartialAsync("_ItemsSelection", new ItemsSelectionConfig
        {
            ShowCategories = true,
            ShowDepartments = true,
            ShowBrands = true,
            ShowSeasons = true,
            ShowSuppliers = true,
            ShowStores = true,
            ShowCustomers = false,
            ShowItems = true,
            ShowUsers = false,
            ShowZReports = false,
            ShowModels = true,
            ShowColours = true,
            ShowSizes = true,
            ShowGroupSizes = true,
            ShowFabrics = true,
            ShowAttributes = true,
            ShowStockFilter = false,
            ShowECommerce = false,
            ShowModifiedDate = false,
            StoresJson = storesJson,
            ReportType = "OffersReport"
        })
        @await Html.PartialAsync("_CustomerSelection")
        <div class="report-form-actions d-flex flex-wrap gap-2 pt-2 border-top">
            <button type="button" class="btn btn-primary btn-lg btn-generate" id="generateBtn" onclick="generateReport()">
                <span class="btn-text"><i class="bi bi-play-fill me-2"></i>Generate Report</span>
                <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
            </button>
            @if (canSchedule)
            {
                <button type="button" class="btn btn-warning btn-lg" data-bs-toggle="modal" data-bs-target="#scheduleModal" title="Schedule recurring report delivery">
                    <i class="bi bi-clock-history me-2"></i>Schedule
                </button>
            }
            <div class="btn-group ms-auto">
                <div class="btn-group">
                    <button type="button" class="btn btn-outline-info dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false"
                            title="Saved report layouts" id="layoutsDropdownBtn">
                        <i class="bi bi-bookmark me-1"></i><span id="layoutsCurrentName">Layouts</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" id="layoutsDropdownMenu" style="min-width: 320px;">
                        <li><h6 class="dropdown-header">Loading...</h6></li>
                    </ul>
                </div>
                <button type="button" class="btn btn-outline-info" onclick="saveCurrentLayout()" title="Overwrite your default layout with current parameters">
                    <i class="bi bi-save me-1"></i>Save
                </button>
                <button type="button" class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#saveLayoutAsModal"
                        title="Save current parameters as a new named layout">
                    <i class="bi bi-bookmark-plus me-1"></i>Save as...
                </button>
                @if (hasSavedLayout)
                {
                    <button type="button" class="btn btn-outline-secondary" onclick="resetSavedLayout()" title="Discard your saved default layout and restore factory defaults">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Default
                    </button>
                }
            </div>
            <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#columnSettingsModal" title="Choose which columns to show/hide">
                <i class="bi bi-layout-three-columns me-1"></i>Columns
            </button>
            <button type="button" class="btn btn-outline-secondary" onclick="resetFilters()" title="Clear all filters and reset to defaults">
                <i class="bi bi-funnel me-1"></i>Clear Filters
            </button>
        </div>
        @if (hasSavedLayout)
        {
            <div class="mt-2"><small class="text-info"><i class="bi bi-check-circle me-1"></i>Saved layout loaded</small></div>
        }
    </div>
</div>

<div id="reportAlert" style="display:none;"></div>

<div id="reportLoading" style="display:none;" class="text-center py-5">
    <div class="spinner-border text-primary" role="status"></div>
    <p class="mt-2 text-muted">Loading offers data...</p>
</div>

<div id="kpiCards" class="row mb-4 g-3" style="display:none;"></div>

<div id="reportResults" style="display:none;">
    <div class="card" id="results">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>
                <i class="bi bi-table me-2"></i>Results: <span id="rowCountInfo">0</span> rows
                <span id="groupBadges"></span>
            </span>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <button class="btn btn-sm btn-outline-primary" onclick="togglePreview()" id="previewToggleBtn" title="Toggle document preview">
                    <i class="bi bi-eye me-1"></i>Preview
                </button>
                <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-success" onclick="exportServerCsv()" title="Export CSV">
                        <i class="bi bi-filetype-csv me-1"></i>CSV
                    </button>
                    <button class="btn btn-outline-success" onclick="exportServerExcel()" title="Export Excel">
                        <i class="bi bi-filetype-xlsx me-1"></i>Excel
                    </button>
                    <button class="btn btn-outline-danger" onclick="exportServerPdf()" title="Export PDF">
                        <i class="bi bi-filetype-pdf me-1"></i>PDF
                    </button>
                </div>
                <button class="btn btn-sm btn-outline-primary" onclick="openSendEmailModal()" title="Send report via email">
                    <i class="bi bi-envelope me-1"></i>Send to Email
                </button>
                <button class="btn btn-sm btn-outline-info" onclick="var fd=collectAiFormData();if(fd)openAiAnalysis(fd)" title="AI-powered report analysis" id="btnAnalyze">
                    <i class="bi bi-stars me-1"></i>AI Analyze
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-striped table-hover mb-0" id="reportTable">
                    <thead class="table-light" id="reportHead"></thead>
                    <tbody id="reportBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="previewPanel" style="display:none;" class="mt-3">
    <div class="card border-primary">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-2">
            <span><i class="bi bi-file-earmark-text me-2"></i>Document Preview</span>
            <button class="btn btn-sm btn-outline-light" onclick="togglePreview()" title="Close preview">
                <i class="bi bi-x-lg me-1"></i>Back to Grid
            </button>
        </div>
        <div class="card-body p-0">
            <iframe id="previewFrame" style="width:100%; border:none; min-height:700px; background:#525659;"></iframe>
        </div>
    </div>
</div>

<!-- Column Settings Modal -->
<div class="modal fade" id="columnSettingsModal" tabindex="-1" aria-labelledby="columnSettingsLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="columnSettingsLabel">
                    <i class="bi bi-layout-three-columns me-2"></i>Column Visibility
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-2">Search and toggle which columns are visible. Changes apply immediately.</p>
                <div class="input-group mb-3">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" id="colSearchInput" placeholder="Search columns..." oninput="filterColumnList()">
                </div>
                <div class="border rounded" style="max-height: 400px; overflow-y: auto;">
                    <div class="list-group list-group-flush" id="colToggleList">
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="offer no number"><input class="form-check-input col-toggle me-2" type="checkbox" value="OfferNo" checked onchange="applyColumnVisibility()"><span>Offer No</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="date transaction"><input class="form-check-input col-toggle me-2" type="checkbox" value="DateTrans" checked onchange="applyColumnVisibility()"><span>Date</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="valid until expiry"><input class="form-check-input col-toggle me-2" type="checkbox" value="ValidUntil" checked onchange="applyColumnVisibility()"><span>Valid Until</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="status"><input class="form-check-input col-toggle me-2" type="checkbox" value="StatusName" checked onchange="applyColumnVisibility()"><span>Status</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="customer name"><input class="form-check-input col-toggle me-2" type="checkbox" value="CustomerName" checked onchange="applyColumnVisibility()"><span>Customer</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="store shop"><input class="form-check-input col-toggle me-2" type="checkbox" value="StoreName" checked onchange="applyColumnVisibility()"><span>Store</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="agent salesperson"><input class="form-check-input col-toggle me-2" type="checkbox" value="AgentName" checked onchange="applyColumnVisibility()"><span>Agent</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="items count"><input class="form-check-input col-toggle me-2" type="checkbox" value="ItemCount" checked onchange="applyColumnVisibility()"><span>Items</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="quantity qty"><input class="form-check-input col-toggle me-2" type="checkbox" value="TotalQuantity" checked onchange="applyColumnVisibility()"><span>Qty</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="subtotal invoice total"><input class="form-check-input col-toggle me-2" type="checkbox" value="InvoiceTotal" checked onchange="applyColumnVisibility()"><span>Subtotal</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="discount"><input class="form-check-input col-toggle me-2" type="checkbox" value="InvoiceTotalDiscount" checked onchange="applyColumnVisibility()"><span>Discount</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="vat tax"><input class="form-check-input col-toggle me-2" type="checkbox" value="InvoiceVat" checked onchange="applyColumnVisibility()"><span>VAT</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="grand total"><input class="form-check-input col-toggle me-2" type="checkbox" value="InvoiceGrandTotal" checked onchange="applyColumnVisibility()"><span>Grand Total</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="cost" data-perm="cost"><input class="form-check-input col-toggle me-2" type="checkbox" value="TotalItemCost" checked onchange="applyColumnVisibility()"><span>Cost</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="order percentage"><input class="form-check-input col-toggle me-2" type="checkbox" value="OrderPercentage" checked onchange="applyColumnVisibility()"><span>Order %</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="lead linked"><input class="form-check-input col-toggle me-2" type="checkbox" value="LinkedLead" checked onchange="applyColumnVisibility()"><span>Lead</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="comments"><input class="form-check-input col-toggle me-2" type="checkbox" value="Comments" checked onchange="applyColumnVisibility()"><span>Comments</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="internal notes"><input class="form-check-input col-toggle me-2" type="checkbox" value="InternalNotes" checked onchange="applyColumnVisibility()"><span>Internal Notes</span></label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center" data-col-name="source"><input class="form-check-input col-toggle me-2" type="checkbox" value="Source" checked onchange="applyColumnVisibility()"><span>Source</span></label>
                    </div>
                </div>
                <div class="mt-2 d-flex justify-content-between small text-muted">
                    <span><span id="colVisibleCount">19</span> of <span id="colTotalCount">19</span> columns visible</span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleAllColumns(true)">Select All</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleAllColumns(false)">Deselect All</button>
                <button type="button" class="btn btn-outline-secondary" onclick="resetColumnVisibility()">Show All</button>
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Done</button>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_Schedule", new Powersoft.Reporting.Web.ViewModels.SchedulePartialModel {
    SaveAction      = "SaveOffersReportSchedule",
    ListAction      = "GetOffersReportSchedules",
    ReportBadge     = "Offers Report",
    NamePlaceholder = "e.g. Weekly Offers Summary",
    SubjectPlaceholder = "Offers Report - {date}"
})

<!-- Send Email Modal -->
@await Html.PartialAsync("_SendEmail", new Powersoft.Reporting.Web.ViewModels.SendEmailPartialModel {
    SendAction = "SendOffersReportEmail",
    ReportType = "OffersReport",
    SubjectDefault = "Offers Report"
})

@await Html.PartialAsync("_AiAnalyze", new Powersoft.Reporting.Web.ViewModels.AiAnalyzePartialModel {
    AnalyzeActionUrl = Url.Action("AnalyzeOffersReport", "Reports"),
    ReportType = "OffersReport"
})

<!-- Save Layout As Modal -->
<div class="modal fade" id="saveLayoutAsModal" tabindex="-1" aria-labelledby="saveLayoutAsLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="saveLayoutAsLabel"><i class="bi bi-bookmark-plus me-2"></i>Save Layout As</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="saveLayoutAsName" class="form-label">Layout name <span class="text-danger">*</span></label>
                    <input type="text" id="saveLayoutAsName" class="form-control" maxlength="100" placeholder="e.g. Approved Offers Only" autocomplete="off" />
                    <div class="form-text">Used to identify the layout. You can have multiple named layouts.</div>
                </div>
                <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox" id="saveLayoutAsPublic" />
                    <label class="form-check-label" for="saveLayoutAsPublic">Share with all users (public layout)</label>
                    <div class="form-text">Public layouts are visible to everyone but can only be edited or deleted by you.</div>
                </div>
                <div id="saveLayoutAsAlert" class="alert d-none" role="alert"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveLayoutAsConfirmBtn" onclick="saveLayoutAsConfirm()">
                    <span class="spinner-border spinner-border-sm d-none me-1" id="saveLayoutAsSpinner"></span>
                    <i class="bi bi-save me-1"></i>Save
                </button>
            </div>
        </div>
    </div>
</div>

<script>
var _sortCol = 'DateTrans';
var _sortDir = 'DESC';
var _lastData = [];
var _lastTotalRecords = 0;
var _statusLookup = {};

(function init() {
    var today = new Date();
    var y = today.getFullYear();
    document.getElementById('dateFrom').value = y+'-01-01';
    document.getElementById('dateTo').value = fmtDate(today);
    document.querySelectorAll('input[name="DatePreset"]').forEach(function(r) {
        r.addEventListener('change', function() { applyPresetDates(this.value); });
    });
    // schedule modal lifecycle managed by shared _Schedule.cshtml partial
    loadFilterDropdowns();
})();

function loadFilterDropdowns() {
    fetch('@Url.Action("GetOffersReportLookups","Reports")', { credentials:'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.statuses) {
                var list = document.getElementById('statusCheckboxList');
                d.statuses.forEach(function(s) {
                    _statusLookup[s.code] = s.color;
                    _statusLookup[s.name] = s.color;
                    var id = 'offerSt_' + s.code.replace(/[^a-z0-9]/gi,'_');
                    list.innerHTML += '<div class="form-check"><input class="form-check-input offerStatusCb" type="checkbox"'
                        + ' id="'+id+'" value="'+escapeHtml(s.code)+'" onchange="updateMultiLabel(\'offerStatusCb\',\'statusFilterLabel\',\'Statuses\')">'
                        + '<label class="form-check-label small" for="'+id+'">'+escapeHtml(s.name)+'</label></div>';
                });
            }
            if (d.stores) {
                var listSt = document.getElementById('storeCheckboxList');
                d.stores.forEach(function(s) {
                    var id = 'offerStore_' + String(s.id).replace(/[^a-z0-9]/gi,'_');
                    listSt.innerHTML += '<div class="form-check"><input class="form-check-input offerStoreCb" type="checkbox"'
                        + ' id="'+id+'" value="'+escapeHtml(String(s.id))+'" onchange="updateMultiLabel(\'offerStoreCb\',\'storeFilterLabel\',\'Stores\')">'
                        + '<label class="form-check-label small" for="'+id+'">'+escapeHtml(s.name)+'</label></div>';
                });
            }
            if (d.agents) {
                var listAg = document.getElementById('agentCheckboxList');
                d.agents.forEach(function(a) {
                    var id = 'offerAgent_' + String(a.id).replace(/[^a-z0-9]/gi,'_');
                    listAg.innerHTML += '<div class="form-check"><input class="form-check-input offerAgentCb" type="checkbox"'
                        + ' id="'+id+'" value="'+escapeHtml(String(a.id))+'" onchange="updateMultiLabel(\'offerAgentCb\',\'agentFilterLabel\',\'Agents\')">'
                        + '<label class="form-check-label small" for="'+id+'">'+escapeHtml(a.name)+'</label></div>';
                });
            }
            @if (hasSavedLayout && savedLayout != null) {
                <text>applyLayoutParameters(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(savedLayout)));</text>
            }
        }).catch(function(){});
}

function escapeHtml(s) { if (!s) return ''; var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
function statusBadgeStyle(hex) {
    hex = (hex||'#999').replace('#','');
    if (hex.length === 3) hex = hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
    var r = parseInt(hex.substr(0,2),16), g = parseInt(hex.substr(2,2),16), b = parseInt(hex.substr(4,2),16);
    var lum = (0.299*r + 0.587*g + 0.114*b) / 255;
    if (lum > 0.85) return 'background:'+('#'+hex)+';color:#1e293b;border-color:rgba(0,0,0,.25);';
    if (lum > 0.6) return 'background:'+('#'+hex)+';color:#1e293b;';
    return 'background:'+('#'+hex)+';color:#fff;';
}
function fmtDate(d) { return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }
function fmtInt(v) { if (v==null) return '0'; return Number(v).toLocaleString(undefined,{maximumFractionDigits:0}); }
function formatNumber(v) { if (v === 0) return '0.00'; return Number(v).toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2}); }

function clearPreset() { document.querySelectorAll('input[name="DatePreset"]').forEach(r=>r.checked=false); }

function resetFilters() {
    var today = new Date(), y = today.getFullYear();
    document.getElementById('dateFrom').value = y+'-01-01';
    document.getElementById('dateTo').value = fmtDate(today);
    document.getElementById('dateField').value = 'DateTrans';
    clearMultiSelect('offerStatusCb','statusFilterLabel','Statuses');
    clearMultiSelect('offerStoreCb','storeFilterLabel','Stores');
    clearMultiSelect('offerAgentCb','agentFilterLabel','Agents');
    document.getElementById('offerTypeFilter').value = 'All';
    document.getElementById('includeHistory').checked = false;
    document.getElementById('primaryGroup').value = 'NONE';
    document.getElementById('secondaryGroup').value = 'NONE';
    document.getElementById('thirdGroup').value = 'NONE';
    document.getElementById('maxRecords').value = '50000';
    clearPreset();
    _sortCol = 'DateTrans'; _sortDir = 'DESC';
    document.getElementById('reportResults').style.display = 'none';
    document.getElementById('kpiCards').style.display = 'none';
    document.getElementById('reportAlert').style.display = 'none';
    _lastData = [];
    document.getElementById('layoutsCurrentName').textContent = 'Layouts';
    resetColumnVisibility();
    if (typeof clearCustomerSelection === 'function') clearCustomerSelection();
    if (typeof clearItemsSelection === 'function') clearItemsSelection();
}

function applyPresetDates(preset) {
    var today = new Date(), y = today.getFullYear(), m = today.getMonth(), d = today.getDate();
    var from, to;
    switch(preset) {
        case 'today': from = to = today; break;
        case 'yesterday': from = to = new Date(y,m,d-1); break;
        case 'last7': from = new Date(y,m,d-7); to = today; break;
        case 'last30': from = new Date(y,m,d-30); to = today; break;
        case 'thisMonth': from = new Date(y,m,1); to = today; break;
        case 'lastMonth': from = new Date(y,m-1,1); to = new Date(y,m,0); break;
        case 'ytd': from = new Date(y,0,1); to = today; break;
        case 'lastYear': from = new Date(y-1,0,1); to = new Date(y-1,11,31); break;
        default: return;
    }
    document.getElementById('dateFrom').value = fmtDate(from);
    document.getElementById('dateTo').value = fmtDate(to);
}

function showAlert(id, type, msg) {
    var el = document.getElementById(id);
    el.innerHTML = '<div class="alert alert-'+type+' alert-dismissible fade show"><i class="bi bi-info-circle me-2"></i>'+escapeHtml(msg)+'<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
    el.style.display = '';
}

function updateMultiLabel(cbClass, labelId, noun) {
    var checked = getCheckedValues(cbClass);
    var lbl = document.getElementById(labelId);
    if (!lbl) return;
    if (checked.length === 0) lbl.textContent = 'All ' + noun;
    else if (checked.length === 1) lbl.textContent = checked[0];
    else lbl.textContent = checked.length + ' ' + noun + ' selected';
}
function clearMultiSelect(cbClass, labelId, noun) {
    document.querySelectorAll('.' + cbClass).forEach(function(cb) { cb.checked = false; });
    var lbl = document.getElementById(labelId);
    if (lbl) lbl.textContent = 'All ' + noun;
}
function getCheckedValues(cbClass) {
    return Array.from(document.querySelectorAll('.' + cbClass + ':checked')).map(function(cb) { return cb.value; });
}
function setCheckedValues(cbClass, labelId, noun, values) {
    if (!values || !values.length) { clearMultiSelect(cbClass, labelId, noun); return; }
    document.querySelectorAll('.' + cbClass).forEach(function(cb) {
        cb.checked = values.indexOf(cb.value) !== -1;
    });
    updateMultiLabel(cbClass, labelId, noun);
}

function getFilterParams() {
    var csf = typeof getCustomerSelectionFilter === 'function' ? getCustomerSelectionFilter() : {codes:[],excludeMode:false};
    var itmSel = typeof getItemsSelectionJson === 'function' ? getItemsSelectionJson() : null;
    var statusCodes = getCheckedValues('offerStatusCb');
    var storeCodes  = getCheckedValues('offerStoreCb');
    var agentCodes  = getCheckedValues('offerAgentCb');
    return {
        dateFrom: document.getElementById('dateFrom').value,
        dateTo: document.getElementById('dateTo').value,
        dateField: document.getElementById('dateField').value,
        statusFilter: 'All',
        storeFilter: 'All',
        agentFilter: 'All',
        primaryGroup: document.getElementById('primaryGroup').value,
        secondaryGroup: document.getElementById('secondaryGroup').value,
        thirdGroup: document.getElementById('thirdGroup').value,
        maxRecords: document.getElementById('maxRecords').value,
        sortColumn: _sortCol,
        sortDirection: _sortDir,
        offerType: document.getElementById('offerTypeFilter').value,
        includeHistory: document.getElementById('includeHistory').checked,
        customerCodesJson: JSON.stringify(csf.codes || []),
        customerExcludeMode: csf.excludeMode || false,
        statusCodesJson: JSON.stringify(statusCodes),
        storeCodesJson: JSON.stringify(storeCodes),
        agentCodesJson: JSON.stringify(agentCodes),
        itemsSelectionJson: itmSel || ''
    };
}

function buildExportUrl(action) {
    var p = getFilterParams();
    var qs = 'dateFrom='+p.dateFrom+'&dateTo='+p.dateTo+'&dateField='+p.dateField
        +'&statusFilter=All&storeFilter=All&agentFilter=All'
        +'&primaryGroup='+p.primaryGroup+'&secondaryGroup='+p.secondaryGroup
        +'&thirdGroup='+p.thirdGroup
        +'&maxRecords='+p.maxRecords+'&sortColumn='+p.sortColumn+'&sortDirection='+p.sortDirection
        +'&offerType='+encodeURIComponent(p.offerType)+'&includeHistory='+p.includeHistory
        +'&customerCodesJson='+encodeURIComponent(p.customerCodesJson)
        +'&customerExcludeMode='+p.customerExcludeMode
        +'&statusCodesJson='+encodeURIComponent(p.statusCodesJson)
        +'&storeCodesJson='+encodeURIComponent(p.storeCodesJson)
        +'&agentCodesJson='+encodeURIComponent(p.agentCodesJson)
        +'&itemsSelectionJson='+encodeURIComponent(p.itemsSelectionJson||'');
    return '/Reports/' + action + '?' + qs;
}

function exportServerCsv() { if(!_lastData.length){alert('Generate a report first.');return;} window.location.href=buildExportUrl('ExportOffersReportCsv'); }
function exportServerExcel() { if(!_lastData.length){alert('Generate a report first.');return;} window.location.href=buildExportUrl('ExportOffersReportExcel'); }
function exportServerPdf() { if(!_lastData.length){alert('Generate a report first.');return;} window.location.href=buildExportUrl('ExportOffersReportPdf'); }

var previewOpen = false;
function togglePreview() {
    if (!_lastData.length) { alert('Generate a report first.'); return; }
    var panel = document.getElementById('previewPanel');
    var gridCard = document.getElementById('results');
    var btn = document.getElementById('previewToggleBtn');
    previewOpen = !previewOpen;
    if (previewOpen) {
        gridCard.style.display = 'none';
        panel.style.display = 'block';
        btn.innerHTML = '<i class="bi bi-table me-1"></i>Grid';
        btn.classList.remove('btn-outline-primary'); btn.classList.add('btn-outline-warning');
        var frame = document.getElementById('previewFrame');
        frame.src = buildExportUrl('OffersReportPrintPreview');
        frame.onload = function() { try { var h = frame.contentDocument.body.scrollHeight+80; frame.style.height=Math.max(h,700)+'px'; } catch(e){frame.style.height='900px';} };
    } else {
        panel.style.display = 'none'; gridCard.style.display = '';
        btn.innerHTML = '<i class="bi bi-eye me-1"></i>Preview';
        btn.classList.remove('btn-outline-warning'); btn.classList.add('btn-outline-primary');
    }
}

function generateReport() {
    var dateFrom = document.getElementById('dateFrom').value;
    var dateTo = document.getElementById('dateTo').value;
    if (!dateFrom || !dateTo) { showAlert('reportAlert','danger','Please select both From and To dates.'); return; }
    if (dateFrom > dateTo) { showAlert('reportAlert','danger','Date From cannot be after Date To.'); return; }
    var pg = document.getElementById('primaryGroup').value;
    var sg = document.getElementById('secondaryGroup').value;
    var tg = document.getElementById('thirdGroup').value;
    if (pg !== 'NONE' && sg !== 'NONE' && pg === sg) { showAlert('reportAlert','danger','Primary and Secondary groups must be different.'); return; }
    if (tg !== 'NONE' && (tg === pg || tg === sg)) { showAlert('reportAlert','danger','Third group must be different from Primary and Secondary.'); return; }

    document.getElementById('reportAlert').style.display = 'none';
    document.getElementById('reportResults').style.display = 'none';
    document.getElementById('kpiCards').style.display = 'none';
    document.getElementById('reportLoading').style.display = '';

    var btn = document.getElementById('generateBtn');
    btn.querySelector('.btn-text').classList.add('d-none');
    btn.querySelector('.spinner-border').classList.remove('d-none');
    btn.disabled = true;

    var fd = new FormData();
    var p = getFilterParams();
    Object.keys(p).forEach(function(k) { fd.append(k, p[k]); });

    fetch('@Url.Action("GetOffersReportData","Reports")', { method:'POST', body:fd, credentials:'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            document.getElementById('reportLoading').style.display = 'none';
            btn.querySelector('.btn-text').classList.remove('d-none');
            btn.querySelector('.spinner-border').classList.add('d-none');
            btn.disabled = false;
            if (!d.success) { showAlert('reportAlert','danger',d.message); return; }
            _lastData = d.data || [];
            _lastTotalRecords = d.totalRecords || _lastData.length;
            renderKpis(_lastData);
            renderTable(_lastData);
            var info = _lastData.length + ' row(s)';
            if (_lastTotalRecords > _lastData.length) info += ' (limited from ' + fmtInt(_lastTotalRecords) + ')';
            document.getElementById('rowCountInfo').textContent = info;
            var badges = '';
            if (pg !== 'NONE') badges += '<span class="badge bg-secondary ms-2">Grouped by '+pg+'</span>';
            if (sg !== 'NONE') badges += '<span class="badge bg-secondary ms-1">then '+sg+'</span>';
            if (tg !== 'NONE') badges += '<span class="badge bg-secondary ms-1">then '+tg+'</span>';
            document.getElementById('groupBadges').innerHTML = badges;
            document.getElementById('reportResults').style.display = '';
            if (_lastData.length === 0) showAlert('reportAlert','info','No offers found for the selected criteria.');
        })
        .catch(function(e) {
            document.getElementById('reportLoading').style.display = 'none';
            btn.querySelector('.btn-text').classList.remove('d-none');
            btn.querySelector('.spinner-border').classList.add('d-none');
            btn.disabled = false;
            showAlert('reportAlert','danger','Request failed: '+e.message);
        });
}

function renderKpis(data) {
    var cards = document.getElementById('kpiCards');
    if (!data.length) { cards.style.display = 'none'; return; }

    var totalGrand = 0, totalDisc = 0, totalVat = 0, totalCost = 0, totalItems = 0;
    var statusCounts = {};
    data.forEach(function(r) {
        totalGrand += (r.invoiceGrandTotal||0);
        totalDisc += (r.invoiceTotalDiscount||0);
        totalVat += (r.invoiceVat||0);
        totalCost += (r.totalItemCost||0);
        totalItems += (r.itemCount||0);
        var s = r.statusName || 'Unknown';
        statusCounts[s] = (statusCounts[s]||0) + 1;
    });

    var html = '<div class="col-6 col-md-2"><div class="stat-card text-center"><div class="stat-value" style="color:#7c3aed;">'+fmtInt(data.length)+'</div><div class="stat-label">Total Offers</div></div></div>';
    html += '<div class="col-6 col-md-2"><div class="stat-card text-center"><div class="stat-value text-success">'+formatNumber(totalGrand)+'</div><div class="stat-label">Grand Total</div></div></div>';
    html += '<div class="col-6 col-md-2"><div class="stat-card text-center"><div class="stat-value text-warning">'+formatNumber(totalDisc)+'</div><div class="stat-label">Total Discount</div></div></div>';
    html += '<div class="col-6 col-md-2"><div class="stat-card text-center"><div class="stat-value text-info">'+formatNumber(totalVat)+'</div><div class="stat-label">Total VAT</div></div></div>';
    if (_viewCost) html += '<div class="col-6 col-md-2"><div class="stat-card text-center"><div class="stat-value text-danger">'+formatNumber(totalCost)+'</div><div class="stat-label">Total Cost</div></div></div>';
    html += '<div class="col-6 col-md-2"><div class="stat-card text-center"><div class="stat-value text-primary">'+fmtInt(totalItems)+'</div><div class="stat-label">Total Items</div></div></div>';

    Object.keys(statusCounts).forEach(function(s) {
        var color = _statusLookup[s] || '#64748b';
        html += '<div class="col-6 col-md-2"><div class="stat-card text-center"><div class="stat-value" style="color:'+color+'">'+fmtInt(statusCounts[s])+'</div><div class="stat-label">'+escapeHtml(s)+'</div></div></div>';
    });

    cards.innerHTML = html;
    cards.style.display = '';
}

function renderTable(data) {
    var thead = document.getElementById('reportHead');
    var tbody = document.getElementById('reportBody');
    var hasPrimary   = document.getElementById('primaryGroup').value !== 'NONE';
    var hasSecondary = document.getElementById('secondaryGroup').value !== 'NONE';
    var hasTertiary  = document.getElementById('thirdGroup').value !== 'NONE';
    var pgLabel = document.getElementById('primaryGroup').selectedOptions[0].textContent;
    var sgLabel = document.getElementById('secondaryGroup').selectedOptions[0].textContent;
    var tgLabel = document.getElementById('thirdGroup').selectedOptions[0].textContent;

    function sth(label, col, align, dataCol) {
        var dc = dataCol || col;
        var cls = 'sortable' + (align ? ' text-end' : '');
        if (_sortCol === col) cls += _sortDir === 'ASC' ? ' sort-asc' : ' sort-desc';
        var icon = _sortCol === col ? (_sortDir === 'ASC' ? 'bi-caret-up-fill' : 'bi-caret-down-fill') : 'bi-caret-up-fill';
        return '<th data-col="'+dc+'" class="'+cls+'" onclick="sortBy(\''+col+'\')">'+label+'<i class="bi '+icon+' sort-icon"></i></th>';
    }
    var hdr = '<tr>';
    if (hasPrimary)   hdr += sth(escapeHtml(pgLabel), 'level1Descr');
    if (hasSecondary) hdr += sth(escapeHtml(sgLabel), 'level2Descr');
    if (hasTertiary)  hdr += sth(escapeHtml(tgLabel), 'level3Descr');
    hdr += sth('Offer No','offerNo','','OfferNo') + sth('Date','dateTrans','','DateTrans') + sth('Valid Until','validUntil','','ValidUntil');
    hdr += sth('Status','statusName','','StatusName') + sth('Customer','customerName','','CustomerName') + sth('Store','storeName','','StoreName') + sth('Agent','agentName','','AgentName');
    hdr += sth('Items','itemCount',true,'ItemCount') + sth('Qty','totalQuantity',true,'TotalQuantity');
    hdr += sth('Subtotal','invoiceTotal',true,'InvoiceTotal') + sth('Discount','invoiceTotalDiscount',true,'InvoiceTotalDiscount');
    hdr += sth('VAT','invoiceVat',true,'InvoiceVat') + sth('Grand Total','invoiceGrandTotal',true,'InvoiceGrandTotal');
    hdr += (_viewCost ? sth('Cost','totalItemCost',true,'TotalItemCost') : '') + sth('Order %','orderPercentage',true,'OrderPercentage');
    hdr += '<th data-col="LinkedLead">Lead</th><th data-col="Comments">Comments</th><th data-col="InternalNotes">Internal Notes</th>';
    hdr += sth('Source','source','','Source');
    hdr += '</tr>';
    thead.innerHTML = hdr;
    applyColumnVisibility();

    if (hasPrimary) {
        tbody.innerHTML = renderGroupedRows(data, hasPrimary, hasSecondary, hasTertiary, pgLabel, sgLabel, tgLabel);
    } else {
        tbody.innerHTML = renderRows(data, hasPrimary, hasSecondary, hasTertiary);
    }
}

function renderGroupedRows(data, hasPrimary, hasSecondary, hasTertiary, pgLabel, sgLabel, tgLabel) {
    var colCount = 20 + (hasPrimary?1:0) + (hasSecondary?1:0) + (hasTertiary?1:0);
    var groups = groupBy(data, 'level1Descr');
    var html = '';
    groups.forEach(function(g) {
        html += '<tr class="group-header-row"><td colspan="'+colCount+'"><i class="bi bi-diagram-3 me-2"></i><strong>'+escapeHtml(pgLabel)+':</strong> '+escapeHtml(g.key)+' <span class="badge bg-secondary">'+g.items.length+'</span></td></tr>';
        if (hasSecondary) {
            var subGroups = groupBy(g.items, 'level2Descr');
            subGroups.forEach(function(sg2) {
                html += '<tr class="group-header-row l2"><td colspan="'+colCount+'" class="ps-4"><i class="bi bi-chevron-right me-1"></i><strong>'+escapeHtml(sgLabel)+':</strong> '+escapeHtml(sg2.key)+' <span class="badge bg-info">'+sg2.items.length+'</span></td></tr>';
                if (hasTertiary) {
                    var thirdGroups = groupBy(sg2.items, 'level3Descr');
                    thirdGroups.forEach(function(tg3) {
                        html += '<tr class="group-header-row l3"><td colspan="'+colCount+'" class="ps-5"><i class="bi bi-chevron-double-right me-1"></i><strong>'+escapeHtml(tgLabel)+':</strong> '+escapeHtml(tg3.key)+' <span class="badge bg-warning text-dark">'+tg3.items.length+'</span></td></tr>';
                        html += renderRows(tg3.items, hasPrimary, hasSecondary, hasTertiary);
                    });
                } else {
                    html += renderRows(sg2.items, hasPrimary, hasSecondary, hasTertiary);
                }
            });
        } else {
            html += renderRows(g.items, hasPrimary, hasSecondary, hasTertiary);
        }
    });
    return html;
}

function renderRows(items, hasPrimary, hasSecondary, hasTertiary) {
    var html = '';
    for (var i = 0; i < items.length; i++) {
        var r = items[i];
        var dateTr = r.dateTrans ? new Date(r.dateTrans).toLocaleDateString() : '';
        var validUntil = r.validUntil ? new Date(r.validUntil).toLocaleDateString() : '';
        html += '<tr>';
        if (hasPrimary)   html += '<td class="text-info fw-semibold">'+escapeHtml(r.level1Descr)+'</td>';
        if (hasSecondary) html += '<td class="text-info">'+escapeHtml(r.level2Descr)+'</td>';
        if (hasTertiary)  html += '<td class="text-info">'+escapeHtml(r.level3Descr)+'</td>';
        html += '<td class="text-nowrap">'+escapeHtml(r.offerNo)+'</td>';
        html += '<td class="text-nowrap">'+escapeHtml(dateTr)+'</td>';
        html += '<td class="text-nowrap">'+escapeHtml(validUntil)+'</td>';
        html += '<td><span class="status-badge" style="'+statusBadgeStyle(r.statusColor)+'">'+escapeHtml(r.statusName)+'</span></td>';
        html += '<td>'+escapeHtml(r.customerName)+'</td>';
        html += '<td>'+escapeHtml(r.storeName)+'</td>';
        html += '<td>'+escapeHtml(r.agentName)+'</td>';
        html += '<td class="text-end">'+(r.itemCount||0)+'</td>';
        html += '<td class="text-end">'+formatNumber(r.totalQuantity||0)+'</td>';
        html += '<td class="text-end">'+formatNumber(r.invoiceTotal||0)+'</td>';
        html += '<td class="text-end">'+formatNumber(r.invoiceTotalDiscount||0)+'</td>';
        html += '<td class="text-end">'+formatNumber(r.invoiceVat||0)+'</td>';
        html += '<td class="text-end fw-semibold">'+formatNumber(r.invoiceGrandTotal||0)+'</td>';
        if (_viewCost) html += '<td class="text-end">'+formatNumber(r.totalItemCost||0)+'</td>';
        html += '<td class="text-end">'+(r.orderPercentage||0).toFixed(1)+'%</td>';
        html += '<td>'+escapeHtml(r.linkedLead||'')+'</td>';
        html += '<td style="white-space:normal;word-break:break-word;">'+escapeHtml(r.comments||'')+'</td>';
        html += '<td style="white-space:normal;word-break:break-word;">'+escapeHtml(r.internalNotes||'')+'</td>';
        var srcCls = r.source === 'History' ? 'bg-secondary' : (r.source === 'Standard Offer' ? 'bg-info text-dark' : 'bg-primary');
        html += '<td><span class="badge '+srcCls+'">'+escapeHtml(r.source||'Offer')+'</span></td>';
        html += '</tr>';
    }
    return html;
}

function sortBy(col) {
    if (_sortCol === col) { _sortDir = _sortDir === 'ASC' ? 'DESC' : 'ASC'; }
    else { _sortCol = col; _sortDir = 'ASC'; }
    var dateFields = { dateTrans:1, validUntil:1, deliveryDate:1 };
    var numFields = { itemCount:1, totalQuantity:1, invoiceTotal:1, invoiceTotalDiscount:1, invoiceVat:1, invoiceGrandTotal:1, totalItemCost:1, orderPercentage:1, invoiceDiscountPerc:1 };
    _lastData.sort(function(a, b) {
        var va = a[col], vb = b[col];
        if (va == null) va = ''; if (vb == null) vb = '';
        var cmp;
        if (dateFields[col]) { cmp = new Date(va||0) - new Date(vb||0); }
        else if (numFields[col]) { cmp = Number(va) - Number(vb); }
        else { cmp = String(va).localeCompare(String(vb)); }
        return _sortDir === 'ASC' ? cmp : -cmp;
    });
    renderTable(_lastData);
}

function groupBy(arr, key) {
    var map = {}, order = [];
    arr.forEach(function(item) {
        var k = item[key] || '';
        if (!map[k]) { map[k] = []; order.push(k); }
        map[k].push(item);
    });
    return order.map(function(k) { return { key: k, items: map[k] }; });
}

