@using Powersoft.Reporting.Core.Models
@using System.Text.Json
@{
    ViewData["Title"] = "Pareto 80/20 Analysis";
    var stores = ViewBag.Stores as List<Store> ?? new List<Store>();
    var dbName = ViewBag.ConnectedDatabase as string ?? "Unknown";
    var storesJson = JsonSerializer.Serialize(stores.Select(s => new { s.StoreCode, s.StoreName }));
    var canSchedule = (bool)(ViewBag.CanSchedule ?? false);
    var dateFromDefault = ViewBag.DateFrom as string ?? DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd");
    var dateToDefault = ViewBag.DateTo as string ?? DateTime.Today.ToString("yyyy-MM-dd");
}

<style>
    .class-a { background: #dcfce7 !important; }
    .class-b { background: #fef9c3 !important; }
    .class-c { background: #fee2e2 !important; }
    .badge-a { background: #16a34a; }
    .badge-b { background: #ca8a04; }
    .badge-c { background: #dc2626; }
    .stat-card { border-radius: 8px; padding: 16px; text-align: center; }
    .stat-card h3 { margin: 0; font-size: 1.5rem; }
    .stat-card .label { font-size: 0.8rem; color: #6b7280; }
</style>

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-start">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">Reports</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Reports" asp-action="Index">Stock Control</a></li>
                    <li class="breadcrumb-item active">Pareto 80/20</li>
                </ol>
            </nav>
            <h2 class="mb-0">
                <i class="bi bi-funnel me-2 text-primary"></i>Pareto 80/20 Analysis
            </h2>
            <p class="text-muted mb-0">ABC classification of sales data — @dbName</p>
        </div>
        <div class="mt-3">
            @await Html.PartialAsync("_TutorialButton", ("Pareto Analysis", ""))
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-funnel me-2"></i>Report Parameters
    </div>
    <div class="card-body">
        <form id="paretoForm">
            <div class="row mb-3">
                <div class="col-12">
                    <label class="form-label fw-semibold mb-2">Quick Date Selection</label>
                    <div class="date-presets btn-group flex-wrap" role="group">
                        <input type="radio" class="btn-check" name="DatePreset" id="presetToday" value="today" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetToday">Today</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLast30" value="last30" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLast30">Last 30 Days</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetThisMonth" value="thisMonth" autocomplete="off" checked>
                        <label class="btn btn-outline-secondary btn-sm" for="presetThisMonth">This Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastMonth" value="lastMonth" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLastMonth">Last Month</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetYTD" value="ytd" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetYTD">Year to Date</label>
                        <input type="radio" class="btn-check" name="DatePreset" id="presetLastYear" value="lastYear" autocomplete="off">
                        <label class="btn btn-outline-secondary btn-sm" for="presetLastYear">Last Year</label>
                    </div>
                </div>
            </div>

            <hr class="my-3">

            <div class="row g-3 mb-3 align-items-end">
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date From</label>
                    <input type="date" class="form-control" id="dateFrom" onchange="clearPreset()"
                           value="@DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Date To</label>
                    <input type="date" class="form-control" id="dateTo" onchange="clearPreset()"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Dimension (By)</label>
                    <select class="form-select" id="dimension" onchange="onDimensionChanged()">
                        <option value="Item" selected>By Item</option>
                        <option value="Customer">By Customer</option>
                        <option value="CustomerCategory1">By Customer Category 1</option>
                        <option value="CustomerCategory2">By Customer Category 2</option>
                        <option value="Category">By Item Category</option>
                        <option value="Department">By Department</option>
                        <option value="Brand">By Brand</option>
                        <option value="Season">By Season</option>
                        <option value="Supplier">By Supplier</option>
                        <option value="Model">By Model</option>
                        <option value="Colour">By Colour</option>
                        <option value="Size">By Size</option>
                        <option value="GroupSize">By Group Size</option>
                        <option value="Fabric">By Fabric</option>
                        <option value="Store">By Store</option>
                        <option value="User">By User</option>
                        <option value="ByPrice">By Price Range</option>
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold">Report On</label>
                    <select class="form-select" id="metric" onchange="onMetricChanged()">
                        <option value="Value" selected>Value</option>
                        <option value="Quantity">Quantity</option>
                        <option value="Profit">Profit</option>
                    </select>
                </div>
                <div class="col-6 col-md-2" id="profitBasisGroup" style="display:none;">
                    <label class="form-label fw-semibold">Profit Based On</label>
                    <select class="form-select" id="profitBasis">
                        <option value="0">Default Price</option>
                        <option value="1">Price 1</option>
                        <option value="2">Price 2</option>
                        <option value="3">Price 3</option>
                        <option value="4">Price 4</option>
                        <option value="5">Price 5</option>
                        <option value="6">Price 6</option>
                        <option value="7">Price 7</option>
                        <option value="8">Price 8</option>
                        <option value="9">Price 9</option>
                        <option value="10">Price 10</option>
                        <option value="99" selected>Latest Cost</option>
                        <option value="88">Average Cost</option>
                        <option value="87">Weighted Average Cost</option>
                    </select>
                </div>
                <div class="col-6 col-md-2" id="priceIntervalGroup" style="display:none;">
                    <label class="form-label fw-semibold">Price Interval</label>
                    <input type="number" class="form-control" id="priceInterval" value="10" min="0.01" step="1">
                </div>
                <div class="col-6 col-md-2" id="priceOnGroup" style="display:none;">
                    <label class="form-label fw-semibold">Based On Price</label>
                    <select class="form-select" id="priceOnIndex">
                        <option value="0" selected>Transaction Price</option>
                        <option value="1">Price 1</option>
                        <option value="2">Price 2</option>
                        <option value="3">Price 3</option>
                        <option value="4">Price 4</option>
                        <option value="5">Price 5</option>
                        <option value="6">Price 6</option>
                        <option value="7">Price 7</option>
                        <option value="8">Price 8</option>
                        <option value="9">Price 9</option>
                        <option value="10">Price 10</option>
                    </select>
                </div>
            </div>

            <div class="row g-3 mb-4 align-items-center">
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="includeVat">
                        <label class="form-check-label" for="includeVat">Include VAT</label>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="excludeNegative" checked>
                        <label class="form-check-label" for="excludeNegative">Exclude Negative Amounts</label>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="showOthers">
                        <label class="form-check-label" for="showOthers">Show Others</label>
                    </div>
                </div>
            </div>

            <div class="row g-2 mb-4 align-items-center">
                <div class="col-auto">
                    <span class="fw-semibold small text-muted">Pareto Threshold:</span>
                </div>
                <div class="col-auto">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text">Top</span>
                        <input type="number" class="form-control text-end" id="paretoPercItems" value="20" min="1" max="99" style="width:56px;" onchange="syncParetoPerc('items')">
                        <span class="input-group-text">% of items gives</span>
                        <input type="number" class="form-control text-end" id="paretoPercValue" value="80" min="1" max="99" style="width:56px;" onchange="syncParetoPerc('value')">
                        <span class="input-group-text">% of value</span>
                    </div>
                </div>
            </div>

            <div class="report-form-actions d-flex flex-wrap gap-2 pt-2 border-top">
                <button type="button" class="btn btn-primary btn-lg" onclick="loadPareto()" id="generateBtn">
                    <i class="bi bi-play-fill me-2"></i>Generate Report
                </button>
                @if (canSchedule)
                {
                    <button type="button" class="btn btn-warning btn-lg" data-bs-toggle="modal" data-bs-target="#scheduleModal" title="Schedule recurring report delivery">
                        <i class="bi bi-clock-history me-2"></i>Schedule
                    </button>
                }
                <div class="btn-group ms-auto">
                    <button type="button" class="btn btn-outline-info" onclick="saveParetoLayout()" title="Save current parameters as your default layout">
                        <i class="bi bi-save me-1"></i>Save Layout
                    </button>
                    <button type="button" class="btn btn-outline-secondary" onclick="resetParetoLayout()" title="Discard your saved layout and restore factory defaults">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Layout
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@await Html.PartialAsync("_ItemsSelection", new ItemsSelectionConfig
{
    ShowCategories = true,
    ShowDepartments = true,
    ShowBrands = true,
    ShowSeasons = true,
    ShowSuppliers = true,
    ShowCustomers = true,
    ShowStores = true,
    StoresJson = storesJson,
    ReportType = "Pareto"
})

<div id="paretoLoading" class="text-center py-5 d-none">
    <div class="spinner-border text-primary"></div>
    <p class="text-muted mt-2">Calculating Pareto analysis...</p>
</div>
<div id="paretoError" class="alert alert-danger d-none"></div>

<div id="paretoResults" class="d-none">
    <div class="row g-3 mb-4" id="summaryCards"></div>

    <div class="card mb-4">
        <div class="card-header">
            <i class="bi bi-bar-chart me-2"></i>Pareto Chart
        </div>
        <div class="card-body" style="position:relative;height:400px;">
            <canvas id="paretoChart"></canvas>
        </div>
    </div>

    <div class="card mb-4" id="paretoGridCard">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>
                <i class="bi bi-table me-2"></i>Detailed Breakdown
                <span id="rowCountBadge" class="badge bg-secondary ms-2"></span>
            </span>
            <div class="d-flex gap-2 flex-wrap align-items-center" id="resultsActions" style="display:none !important;">
                <button class="btn btn-sm btn-outline-primary" onclick="toggleParetoPreview()" id="previewToggleBtn" title="Toggle document preview">
                    <i class="bi bi-eye me-1"></i>Preview
                </button>
                <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-success" onclick="exportPareto('csv')">
                        <i class="bi bi-filetype-csv me-1"></i>CSV
                    </button>
                    <button class="btn btn-outline-success" onclick="exportPareto('excel')">
                        <i class="bi bi-filetype-xlsx me-1"></i>Excel
                    </button>
                    <button class="btn btn-outline-danger" onclick="exportPareto('pdf')">
                        <i class="bi bi-filetype-pdf me-1"></i>PDF
                    </button>
                </div>
                <button class="btn btn-sm btn-outline-primary" onclick="openSendEmailModal()" title="Send report via email">
                    <i class="bi bi-envelope me-1"></i>Send to Email
                </button>
                <button class="btn btn-sm btn-outline-info" onclick="analyzeParetoReport()" title="AI-powered report analysis" id="btnAnalyze">
                    <i class="bi bi-stars me-1"></i>AI Analyze
                </button>
            </div>
        </div>
        <div class="card-body p-0" style="max-height:500px;overflow-y:auto;">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light sticky-top">
                    <tr class="small">
                        <th>#</th>
                        <th>Code</th>
                        <th>Name</th>
                        <th class="text-end">Quantity</th>
                        <th class="text-end">Subtotal</th>
                        <th class="text-end">Profit</th>
                        <th class="text-end">%</th>
                        <th class="text-end">Cumul. %</th>
                        <th class="text-center">Class</th>
                    </tr>
                </thead>
                <tbody id="paretoTable" class="small"></tbody>
            </table>
        </div>
    </div>

    <!-- Inline Preview Panel (hidden by default) -->
    <div id="paretoPreviewPanel" style="display:none;" class="mt-3">
        <div class="card border-primary">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-2">
                <span><i class="bi bi-file-earmark-text me-2"></i>Document Preview</span>
                <button class="btn btn-sm btn-outline-light" onclick="toggleParetoPreview()" title="Close preview">
                    <i class="bi bi-x-lg me-1"></i>Back to Grid
                </button>
            </div>
            <div class="card-body p-0">
                <iframe id="paretoPreviewFrame" style="width:100%; border:none; min-height:700px; background:#525659;"></iframe>
            </div>
        </div>
    </div>
</div>

<div id="emptyState" class="text-center py-5 text-muted">
    <i class="bi bi-funnel" style="font-size:3rem;opacity:0.3;"></i>
    <p class="mt-3">Select parameters and click <strong>Generate Report</strong> for Pareto 80/20 analysis.</p>
    <p class="small">The Pareto principle: ~20% of items generate ~80% of value.</p>
</div>

<div class="modal fade" id="paretoItemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title"><i class="bi bi-clock-history me-2"></i>Transaction History — <span id="paretoModalCode"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div id="paretoModalLoading" class="text-center py-4"><div class="spinner-border spinner-border-sm"></div> Loading...</div>
                <div id="paretoModalError" class="alert alert-danger m-3 d-none"></div>
                <table class="table table-sm table-hover mb-0" id="paretoModalTable" style="display:none;">
                    <thead class="table-light">
                        <tr class="small">
                            <th>Date</th><th>Type</th><th>Invoice</th><th>Customer</th>
                            <th class="text-end">Qty</th><th class="text-end">Amount</th><th>Store</th>
                        </tr>
                    </thead>
                    <tbody id="paretoModalTbody" class="small"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* Schedule Modal — shared partial *@
@await Html.PartialAsync("_Schedule", new Powersoft.Reporting.Web.ViewModels.SchedulePartialModel {
    SaveAction      = "SaveParetoSchedule",
    ListAction      = "GetParetoSchedules",
    ReportBadge     = "Pareto 80/20",
    NamePlaceholder = "e.g. Weekly Pareto Analysis",
    SubjectPlaceholder = "Pareto 80/20 Report - {date}"
})

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
var _viewCost     = @(ViewBag.ViewCost     != null ? (ViewBag.ViewCost     ? "true" : "false") : "true");
var _viewSupplier = @(ViewBag.ViewSupplier != null ? (ViewBag.ViewSupplier ? "true" : "false") : "true");
var _paretoChart = null;

document.querySelectorAll('input[name="DatePreset"]').forEach(function(el) {
    el.addEventListener('change', function() {
        var now = new Date();
        var y = now.getFullYear(), m = now.getMonth(), d = now.getDate();
        var from, to;
        switch (this.value) {
            case 'today': from = to = new Date(y, m, d); break;
            case 'last30': from = new Date(y, m, d - 30); to = new Date(y, m, d); break;
            case 'thisMonth': from = new Date(y, m, 1); to = new Date(y, m, d); break;
            case 'lastMonth': from = new Date(y, m - 1, 1); to = new Date(y, m, 0); break;
            case 'ytd': from = new Date(y, 0, 1); to = new Date(y, m, d); break;
            case 'lastYear': from = new Date(y - 1, 0, 1); to = new Date(y - 1, 11, 31); break;
        }
        if (from) document.getElementById('dateFrom').value = from.toISOString().split('T')[0];
        if (to) document.getElementById('dateTo').value = to.toISOString().split('T')[0];
    });
});
function clearPreset() { document.querySelectorAll('input[name="DatePreset"]').forEach(function(r) { r.checked = false; }); }

function onMetricChanged() {
    var m = document.getElementById('metric').value;
    document.getElementById('profitBasisGroup').style.display = m === 'Profit' ? '' : 'none';
    var pb = document.getElementById('profitBasis').value;
    var isCost = pb === '99' || pb === '88' || pb === '87';
    document.getElementById('includeVat').disabled = (m === 'Profit' && isCost);
}

function onDimensionChanged() {
    var d = document.getElementById('dimension').value;
    var show = d === 'ByPrice';
    document.getElementById('priceIntervalGroup').style.display = show ? '' : 'none';
    document.getElementById('priceOnGroup').style.display = show ? '' : 'none';
}

function syncParetoPerc(src) {
    if (src === 'items') {
        document.getElementById('paretoPercValue').value = 100 - parseInt(document.getElementById('paretoPercItems').value || '20');
    } else {
        document.getElementById('paretoPercItems').value = 100 - parseInt(document.getElementById('paretoPercValue').value || '80');
    }
}

function getItemsSelectionJson() {
    if (typeof getItemsSelectionFilter === 'function') {
        var f = getItemsSelectionFilter();
        return Object.keys(f).length > 0 ? JSON.stringify(f) : '';
    }
    return '';
}
function getSelectedStoreCodes() {
    return typeof getItemsSelectionStoreCodes === 'function'
        ? getItemsSelectionStoreCodes() : '';
}

function exportPareto(format) {
    var dateFrom = document.getElementById('dateFrom').value;
    var dateTo = document.getElementById('dateTo').value;
    if (!dateFrom || !dateTo) { alert('Please select dates first.'); return; }

    var dim = document.getElementById('dimension').value;
    var params = new URLSearchParams({
        dateFrom: dateFrom,
        dateTo: dateTo,
        dimension: dim,
        metric: document.getElementById('metric').value,
        includeVat: document.getElementById('includeVat').checked,
        storeCodes: getSelectedStoreCodes(),
        classAThreshold: document.getElementById('paretoPercValue').value,
        classBThreshold: '95',
        excludeNegativeAmounts: document.getElementById('excludeNegative').checked,
        profitBasis: document.getElementById('profitBasis').value,
        timezoneOffsetMinutes: -new Date().getTimezoneOffset()
    });
    if (dim === 'ByPrice') {
        params.set('priceInterval', document.getElementById('priceInterval').value);
        params.set('priceOnIndex', document.getElementById('priceOnIndex').value);
        params.set('priceOnIncludesVat', document.getElementById('includeVat').checked);
    }
    var isJson = getItemsSelectionJson();
    if (isJson) params.set('itemsSelection', isJson);

    var action = format === 'excel' ? 'ExportParetoExcel' : format === 'pdf' ? 'ExportParetoPdf' : 'ExportParetoCsv';
    window.location.href = '/Reports/' + action + '?' + params.toString();
}

function loadPareto() {
    var dateFrom = document.getElementById('dateFrom').value;
    var dateTo = document.getElementById('dateTo').value;
    if (!dateFrom || !dateTo) { alert('Please select dates.'); return; }

    document.getElementById('paretoLoading').classList.remove('d-none');
    document.getElementById('paretoError').classList.add('d-none');
    document.getElementById('paretoResults').classList.add('d-none');
    document.getElementById('emptyState').classList.add('d-none');
    var ra = document.getElementById('resultsActions');
    if (ra) { ra.style.display = 'none !important'; ra.style.cssText = 'display:none !important'; }

    var fd = new FormData();
    fd.append('dateFrom', dateFrom);
    fd.append('dateTo', dateTo);
    fd.append('dimension', document.getElementById('dimension').value);
    fd.append('metric', document.getElementById('metric').value);
    fd.append('includeVat', document.getElementById('includeVat').checked);
    fd.append('storeCodes', getSelectedStoreCodes());
    fd.append('classAThreshold', document.getElementById('paretoPercValue').value);
    fd.append('classBThreshold', '95');
    fd.append('excludeNegativeAmounts', document.getElementById('excludeNegative').checked);
    fd.append('showOthers', document.getElementById('showOthers').checked);
    fd.append('profitBasis', document.getElementById('profitBasis').value);
    fd.append('timezoneOffsetMinutes', -new Date().getTimezoneOffset());
    if (document.getElementById('dimension').value === 'ByPrice') {
        fd.append('priceInterval', document.getElementById('priceInterval').value);
        fd.append('priceOnIndex', document.getElementById('priceOnIndex').value);
        fd.append('priceOnIncludesVat', document.getElementById('includeVat').checked);
    }
    var isJson = getItemsSelectionJson();
    if (isJson) fd.append('itemsSelection', isJson);

    fetch('/Reports/GetParetoData', { method: 'POST', body: fd })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            document.getElementById('paretoLoading').classList.add('d-none');
            if (!data.success) {
                document.getElementById('paretoError').textContent = data.message;
                document.getElementById('paretoError').classList.remove('d-none');
                return;
            }
            renderPareto(data);
        })
        .catch(function(err) {
            document.getElementById('paretoLoading').classList.add('d-none');
            document.getElementById('paretoError').textContent = 'Network error: ' + err.message;
            document.getElementById('paretoError').classList.remove('d-none');
        });
}

var _paretoPreviewOpen = false;
function toggleParetoPreview() {
    var panel = document.getElementById('paretoPreviewPanel');
    var gridCard = document.getElementById('paretoGridCard');
    var btn = document.getElementById('previewToggleBtn');
    _paretoPreviewOpen = !_paretoPreviewOpen;

    if (_paretoPreviewOpen) {
        gridCard.style.display = 'none';
        panel.style.display = 'block';
        btn.innerHTML = '<i class="bi bi-table me-1"></i>Grid';
        btn.classList.remove('btn-outline-primary');
        btn.classList.add('btn-outline-warning');

        var frame = document.getElementById('paretoPreviewFrame');
        var dateFrom = document.getElementById('dateFrom').value;
        var dateTo = document.getElementById('dateTo').value;
        var dim = document.getElementById('dimension').value;
        var met = document.getElementById('metric').value;

        var tableHtml = document.querySelector('#paretoGridCard .card-body').innerHTML;

        var html = '<!DOCTYPE html><html><head><meta charset="utf-8">'
            + '<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">'
            + '<style>body{padding:30px;font-family:Arial,sans-serif;background:#fff}'
            + '.class-a{background:#dcfce7!important}.class-b{background:#fef9c3!important}'
            + '.class-c{background:#fee2e2!important}'
            + '.badge-a{background:#16a34a;color:#fff}.badge-b{background:#ca8a04;color:#fff}.badge-c{background:#dc2626;color:#fff}'
            + '@@media print{.no-print{display:none!important}body{padding:10px}}</style></head><body>'
            + '<div class="d-flex justify-content-between align-items-start mb-3">'
            + '<div><h4>Pareto 80/20 Analysis</h4>'
            + '<p class="text-muted mb-0">' + dateFrom + ' to ' + dateTo + ' \u2014 @(dbName.Replace("'", "\\'"))</p>'
            + '<p class="text-muted small">Dimension: ' + dim + ' \u2022 Metric: ' + met + '</p></div>'
            + '<button class="btn btn-sm btn-primary no-print" onclick="window.print()"><i class="bi bi-printer me-1"></i>Print</button>'
            + '</div>'
            + '<div style="max-height:none;overflow:visible;">' + tableHtml + '</div>'
            + '</body></html>';

        frame.srcdoc = html;
        frame.onload = function() {
            try {
                var h = frame.contentDocument.body.scrollHeight + 80;
                frame.style.height = Math.max(h, 700) + 'px';
            } catch (e) { frame.style.height = '900px'; }
        };
    } else {
        panel.style.display = 'none';
        gridCard.style.display = '';
        btn.innerHTML = '<i class="bi bi-eye me-1"></i>Preview';
        btn.classList.remove('btn-outline-warning');
        btn.classList.add('btn-outline-primary');
    }
}

function renderPareto(data) {
    document.getElementById('paretoResults').classList.remove('d-none');
    document.getElementById('resultsActions').style.display = '';
    document.getElementById('resultsActions').style.cssText = '';
    var metricType = document.getElementById('metric').value;
    var isQty = metricType === 'Quantity';
    var isProfit = metricType === 'Profit';
    var showOthers = document.getElementById('showOthers').checked;
    var metricLabel = isQty ? 'Quantity' : isProfit ? 'Profit' : 'Value';
    var fmt = function(v) { return isQty ? v.toLocaleString() : v.toLocaleString(undefined, {minimumFractionDigits:2}); };

    var cards = document.getElementById('summaryCards');
    var gt = data.grandTotal;
    var aPct = gt > 0 ? (data.classAValue / gt * 100).toFixed(1) : 0;
    var bPct = gt > 0 ? (data.classBValue / gt * 100).toFixed(1) : 0;
    var cPct = gt > 0 ? (data.classCValue / gt * 100).toFixed(1) : 0;
    var aItemPct = data.totalItems > 0 ? (data.classACount / data.totalItems * 100).toFixed(1) : 0;
    var bItemPct = data.totalItems > 0 ? (data.classBCount / data.totalItems * 100).toFixed(1) : 0;
    var cItemPct = data.totalItems > 0 ? (data.classCCount / data.totalItems * 100).toFixed(1) : 0;

    cards.innerHTML =
        '<div class="col-md-3"><div class="stat-card border" style="border-left:4px solid #2563eb !important;"><h3>' + fmt(gt) + '</h3><div class="label">Grand Total (' + data.totalItems + ' items)</div></div></div>' +
        '<div class="col-md-3"><div class="stat-card class-a border" style="border-left:4px solid #16a34a !important;"><h3>' + data.classACount + ' <small class="text-muted" style="font-size:0.7rem;">(' + aItemPct + '%)</small></h3><div class="label">Class A — ' + aPct + '% of ' + metricLabel.toLowerCase() + '</div></div></div>' +
        '<div class="col-md-3"><div class="stat-card class-b border" style="border-left:4px solid #ca8a04 !important;"><h3>' + data.classBCount + ' <small class="text-muted" style="font-size:0.7rem;">(' + bItemPct + '%)</small></h3><div class="label">Class B — ' + bPct + '% of ' + metricLabel.toLowerCase() + '</div></div></div>' +
        '<div class="col-md-3"><div class="stat-card class-c border" style="border-left:4px solid #dc2626 !important;"><h3>' + data.classCCount + ' <small class="text-muted" style="font-size:0.7rem;">(' + cItemPct + '%)</small></h3><div class="label">Class C — ' + cPct + '% of ' + metricLabel.toLowerCase() + '</div></div></div>';

    var allRows = data.rows;
    var rows = showOthers ? allRows : allRows.filter(function(r) { return r.isDisplay; });

    var maxRows = Math.min(rows.length, 50);
    var labels = rows.slice(0, maxRows).map(function(r) { return r.name.length > 25 ? r.name.substring(0, 22) + '...' : r.name; });
    var values = rows.slice(0, maxRows).map(function(r) { return r.value; });
    var cumPcts = rows.slice(0, maxRows).map(function(r) { return r.cumulativePercentage; });
    var barColors = rows.slice(0, maxRows).map(function(r) { return r.classification === 'A' ? '#16a34a' : r.classification === 'B' ? '#ca8a04' : '#dc2626'; });

    if (_paretoChart) _paretoChart.destroy();
    var ctx = document.getElementById('paretoChart').getContext('2d');
    _paretoChart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [
                { type: 'bar', label: metricLabel, data: values, backgroundColor: barColors.map(function(c) { return c + 'CC'; }), borderColor: barColors, borderWidth: 1, yAxisID: 'y', order: 2 },
                { type: 'line', label: 'Cumulative %', data: cumPcts, borderColor: '#2563eb', backgroundColor: '#2563eb22', borderWidth: 2, pointRadius: 2, fill: false, yAxisID: 'y1', order: 1 }
            ]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: { legend: { position: 'top', labels: { font: { size: 11 } } }, tooltip: { callbacks: { label: function(ctx) { if (ctx.dataset.yAxisID === 'y1') return 'Cumul: ' + ctx.parsed.y.toFixed(1) + '%'; return ctx.dataset.label + ': ' + fmt(ctx.parsed.y); } } } },
            scales: {
                x: { ticks: { font: { size: 9 }, maxRotation: 60 } },
                y: { beginAtZero: true, position: 'left', title: { display: true, text: metricLabel + (isQty ? '' : ' (\u20ac)') } },
                y1: { beginAtZero: true, max: 100, position: 'right', grid: { drawOnChartArea: false }, title: { display: true, text: 'Cumul. %' } }
            }
        }
    });

    var displayCount = allRows.filter(function(r) { return r.isDisplay; }).length;
    document.getElementById('rowCountBadge').textContent = rows.length + ' rows' + (!showOthers && allRows.length > rows.length ? ' (of ' + allRows.length + ' total, ' + (allRows.length - displayCount) + ' hidden)' : '');
    var tbody = document.getElementById('paretoTable');
    var html = '';
    var fmtNum = function(v) { return v.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2}); };
    var fmtQty = function(v) { return v.toLocaleString(undefined, {minimumFractionDigits:0, maximumFractionDigits:4}); };
    var isItemDim = document.getElementById('dimension').value === 'Item';
    rows.forEach(function(r) {
        var cls = r.classification === 'A' ? 'class-a' : r.classification === 'B' ? 'class-b' : 'class-c';
        var badge = r.classification === 'A' ? 'badge-a' : r.classification === 'B' ? 'badge-b' : 'badge-c';
        var codeCell = isItemDim
            ? '<td class="text-nowrap"><a href="#" class="text-decoration-none" onclick="showParetoItemDetail(\'' + r.code.replace(/'/g, "\\'") + '\');return false;">' + r.code + '</a></td>'
            : '<td class="text-nowrap">' + r.code + '</td>';
        html += '<tr class="' + cls + '">' +
            '<td>' + r.rank + '</td>' +
            codeCell +
            '<td>' + r.name + '</td>' +
            '<td class="text-end">' + fmtQty(r.quantity) + '</td>' +
            '<td class="text-end">' + fmtNum(r.subtotal) + '</td>' +
            '<td class="text-end">' + fmtNum(r.profit) + '</td>' +
            '<td class="text-end">' + r.percentage.toFixed(2) + '%</td>' +
            '<td class="text-end fw-semibold">' + r.cumulativePercentage.toFixed(1) + '%</td>' +
            '<td class="text-center"><span class="badge ' + badge + '">' + r.classification + '</span></td></tr>';
    });

    // Legacy parity (Report8020.vb fOther*): when "Show Others" is off we still surface the
    // hidden rows as a single aggregated "Others" line instead of dropping them — otherwise a
    // filter that leaves one dominant row (>= Class A threshold) looks like data vanished.
    if (!showOthers) {
        var hidden = allRows.filter(function(r) { return !r.isDisplay; });
        if (hidden.length > 0) {
            var sum = function(sel) { return hidden.reduce(function(a, r) { return a + sel(r); }, 0); };
            var oQty = sum(function(r) { return r.quantity; });
            var oSub = sum(function(r) { return r.subtotal; });
            var oProf = sum(function(r) { return r.profit; });
            var oPct = sum(function(r) { return r.percentage; });
            html += '<tr class="table-secondary fw-semibold">' +
                '<td></td><td></td>' +
                '<td><i class="bi bi-three-dots me-1"></i>Others (' + hidden.length + ')</td>' +
                '<td class="text-end">' + fmtQty(oQty) + '</td>' +
                '<td class="text-end">' + fmtNum(oSub) + '</td>' +
                '<td class="text-end">' + fmtNum(oProf) + '</td>' +
                '<td class="text-end">' + oPct.toFixed(2) + '%</td>' +
                '<td class="text-end">100.0%</td>' +
                '<td class="text-center">&mdash;</td></tr>';
        }
    }
    tbody.innerHTML = html;
}

// ==================== Collect Pareto Params ====================
function collectParetoParams() {
    var dim = document.getElementById('dimension').value;
    var p = {
        dateFrom: document.getElementById('dateFrom').value,
        dateTo: document.getElementById('dateTo').value,
        dimension: dim,
        metric: document.getElementById('metric').value,
        includeVat: document.getElementById('includeVat').checked,
        excludeNegativeAmounts: document.getElementById('excludeNegative').checked,
        classAThreshold: document.getElementById('paretoPercValue').value,
        classBThreshold: '95',
        profitBasis: document.getElementById('profitBasis').value,
        timezoneOffsetMinutes: -new Date().getTimezoneOffset(),
        storeCodes: getSelectedStoreCodes(),
        itemsSelectionJson: getItemsSelectionJson()
    };
    if (dim === 'ByPrice') {
        p.priceInterval = document.getElementById('priceInterval').value;
        p.priceOnIndex = document.getElementById('priceOnIndex').value;
        p.priceOnIncludesVat = document.getElementById('includeVat').checked;
    }
    return p;
}

function collectParetoFormData() {
    var p = collectParetoParams();
    var fd = new FormData();
    for (var k in p) fd.append(k, p[k]);
    var isJson = getItemsSelectionJson();
    if (isJson) fd.append('itemsSelection', isJson);
    return fd;
}

// ===== Shared schedule partial API =====

// Delegates to collectParetoParams() — the partial merges reportDateRange on top.
function collectScheduleParameters() {
    return collectParetoParams();
}

// Restore Pareto filter UI when an existing schedule is loaded for editing.
function onScheduleParametersLoaded(p) {
    if (!p) return;
    function sv(id, val) { var el = document.getElementById(id); if (el && val != null) el.value = val; }
    function sc(id, val) { var el = document.getElementById(id); if (el && val != null) el.checked = !!val; }
    sv('dimension',    p.dimension);
    sv('metric',       p.metric);
    sc('includeVat',   p.includeVat);
    sc('excludeNegative', p.excludeNegativeAmounts);
    sv('paretoPercValue', p.classAThreshold);
    sv('profitBasis',  p.profitBasis);
    if (p.priceInterval) sv('priceInterval', p.priceInterval);
    if (p.priceOnIndex)  sv('priceOnIndex',  p.priceOnIndex);
    if (p.itemsSelectionJson && typeof reloadItemsSelectionFromJson === 'function') {
        try { reloadItemsSelectionFromJson(typeof p.itemsSelectionJson === 'string' ? JSON.parse(p.itemsSelectionJson) : p.itemsSelectionJson); } catch (e) {}
    }
}

// Maps Pareto radio-button date presets to the shared modal date range type.
function autoSelectScheduleDateRange() {
    var preset = document.querySelector('input[name="DatePreset"]:checked');
    if (!preset) return;
    var map = { 'ytd': 'YearToDate', 'lastYear': 'LastYear', 'thisMonth': 'ThisMonth', 'lastMonth': 'LastMonth', 'last7': 'LastNDays_7', 'last30': 'LastNDays_30' };
    var mapped = map[preset.value];
    if (!mapped) return;
    var sel = document.getElementById('schedDateRangeType');
    if (!sel) return;
    for (var i = 0; i < sel.options.length; i++) {
        var opt = sel.options[i];
        if (mapped.startsWith('LastNDays_')) {
            var days = mapped.split('_')[1];
            if (opt.value === 'LastNDays' && opt.getAttribute('data-value') === days) { sel.selectedIndex = i; break; }
        } else if (opt.value === mapped) { sel.selectedIndex = i; break; }
    }
    if (typeof onSchedDateRangeTypeChange === 'function') onSchedDateRangeTypeChange();
}

